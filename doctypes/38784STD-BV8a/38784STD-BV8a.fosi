	<font inherit="0">
	<indent inherit="0" leftind="0pt" rightind="15pt" firstln="0pt">
	<quadding inherit="0" quad="left" lastquad="lleft">
	<keeps keep="1" scope="col">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="TOCNUMSEC" occur="all" scope="usetext" elemtype="gi">
