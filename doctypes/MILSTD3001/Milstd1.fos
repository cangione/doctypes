<!--Reference Material List-->
<e-i-c gi="reflist"><?Pub Dtl>
<charlist charsubsetref="listspace">
<hyphen inherit="0" hyph="0">
<span span="1">
<usetext source="\Reference Material\" placemnt="before">
<subchars charsubsetref="title"></subchars>
</usetext>
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="\Reference Material (Cont)\">
<subchars charsubsetref="title.cont">
<float scope="reflist"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="title" context="* refentry"><?Pub Dtl>
<charlist>
<hyphen inherit="0" hyph="0">
<indent inherit="0" leftind="@+2em" rightind="15pi" firstln="*-2em">
<quadding quad="left" lastquad="lleft">
<keeps keep="1">
<textbrk startln="1">
<algroup refpoint="last">
<usetext source="dotfill" placemnt="after"></usetext>
</charlist>
<att>
<specval attname="type" attloc="refentry" attval="internal-ref">
<charsubset><?Pub Dtl>
<hyphen inherit="0" hyph="0">
<indent inherit="0" leftind="@+2em" rightind="15pi" firstln="*-1em">
<quadding quad="left" lastquad="ljustify">
<keeps keep="1" next="1">
<textbrk startln="1">
<algroup refpoint="last">
<usetext source="dotfill" placemnt="after"></usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="reference" context="* refentry"><?Pub Dtl>
<charlist>
<hyphen inherit="0" hyph="0">
