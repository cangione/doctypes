<!DOCTYPE doctdt PUBLIC "-//USA-DOD//DTD TDT//EN"
[
<!ENTITY notuse "(Not Used; Under Review)" >
]>
<!--
"/jcals/wss_data/sgml_applications/services/library/TDT_source_files/TDT.dtd"
-->
<doctdt>
	<title>
		<dtd>MIL-STD-38784 V8a</dtd>
		<date>6 December 2007</date>
	</title>
	<ele>
		<tag>abbrsect</tag>
		<long>Abbreviation Section</long>
		<desc>Identifies the paragraph used to define abbreviations/acronyms and the associated list.</desc>
		<source>4.3.4 & 4.5.9</source>
		<contmdl>((title, warning*, caution?, note?, (para, note?)?, (step1, step1+)?, subpara1*)?, (abbrtitle?, acronymlist))</contmdl>
		<usedin>forward, preface, and intro</usedin>
		<ents>parazero and para0att</ents>
		<specatts>
			<attrtbl>
				<attr>emergency</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates that the primary paragraph will produce an emergency border on the page when set equal to 1.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>esds</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Electrostatic Discharge Sensitive. All paragraphs which address handling or maintenance which could damage *** ESDS *** parts shall be identified by the esds symbol by setting attribute equal to 1.</attrdesc>

				<attr>nsp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Nuclear Surety Procedures.  A **NSP** symbol will appear when set equal to 1.</attrdesc>

				<attr>fcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Fracture Critical Process. All paragraphs which address Fracture Critical Process shall be identified by the *** FCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Process. All paragraphs which address Hardness Critical Process shall be identified by the *** HCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Item. All paragraphs which address Hardness Critical Item shall be identified by the *** HCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>ocp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Process. All paragraphs which address observable critical processes shall be identified by the *** OCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>oci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Item. All paragraphs which address observable critical items shall be identified by the *** OCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>abbrtitle</tag>
		<long>Abbreviation Title</long>
		<desc>Identifies the title for the list of acronyms and abbreviations.</desc>
		<source>4.3.4 & 4.5.9</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrsect</usedin>
		<ents>text, exclus, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>acronym</tag>
		<long>Acronym</long>
		<desc>Identifies the first time an acronym or abbreviation is used in a chapter. The def part of the acronym is used to define the acronym/abbreviation, while the term part of the acronym contains the actual acronym/abbreviation. Within the text, the term portion will be surrounded with parenthesis.</desc>
		<source>4.3.4 & 4.5.9</source>
		<contmdl>(def, term)   -(acronym | figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>exclus and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>acronymlist</tag>
		<long>Acronym/Abbreviation List</long>
		<desc>Identifies the list of acronyms and abbreviations.</desc>
		<source>4.3.4 & 4.5.9</source>
		<contmdl>(acronymrow | (term, def))+   -(acronym | figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrsect</usedin>
		<ents>exclus and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>rtermwidth</attr>
				<type>NUTOKEN</type>
				<default>2.5in</default>
				<attrdesc>Allows you to define the right term width</attrdesc>

				<attr>ltermwidth</attr>
				<type>NUTOKEN</type>
				<default>1in</default>
				<attrdesc>Allows you to define the left term width</attrdesc>

				<attr>autobuild</attr>
				<type>CDATA</type>
				<default>#CONREF</default>
				<attrdesc>This attribute should be set equal to 1 when the list is autogenerated.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>acronymrow</tag>
		<long>Acronym/Abbreviation List Row</long>
		<desc>Identifies a set of term and definition for an acronym/abbreviation list.</desc>
		<source>4.3.4 & 4.5.9</source>
		<contmdl>(term, def)</contmdl>
		<usedin>acronymlist</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>activity</tag>
		<long>Reporting Activity</long>
		<desc>Identifies the activity submitting a technical publication deficiency report list.</desc>
		<source>4.5.9</source>
		<contmdl>(#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+</contmdl>
		<usedin>tpdrrow and tpdrtbl</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>address</tag>
		<long>Change Sheet Name/Address</long>
		<desc>Identifies the name and address of the activity responsible for preparation of the change instruction sheet.</desc>
		<source>4.7.3.10.2</source>
		<contmdl>(#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+</contmdl>
		<usedin>chginssht</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>appendix</tag>
		<long>Appendix</long>
		<desc>Identifies an appendix to the manual</desc>
		<source>4.2.9.6</source>
		<contmdl>(title, para0+)   +(ftnote | figure | table | foldout | objmedia)</contmdl>
		<usedin>rear</usedin>
		<ents>append, inclus, and chapatt</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>applic</tag>
		<long>Applicability/Effectivity Definition Entry</long>
		<desc>Defines applicability/effectivity markings.</desc>
		<source>4.3f & 4.5.9</source>
		<contmdl>(term, def)</contmdl>
		<usedin>applicdef</usedin>
		<ents>chgatt and yesorno</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>flagnote</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Identifies whether flagnotes (TV Screens) shall be used to display Effectivity.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>applicabil</tag>
		<long>Applicability/Effectivity</long>
		<desc>Identifies a portion of text as being applicable to a specific model, serial number, part number, etc. Use of this element will cause the applicabilty/effectivity markings defined in the applicability definition (applicdef) to appear at that point in running text.</desc>
		<source>4.3f</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(applicabil | figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>text, exclus, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>applicdef</tag>
		<long>Applicability/Effectivity Definition</long>
		<desc>Identifies the paragraph used to define applicability/effectivity markings, and the associated list.</desc>
		<source>4.3f</source>
		<contmdl>((title, warning*, caution?, note?, (para, note?)?, (step1, step1+)?, subpara1*)?, (appltitle?, applichd?, applic+))</contmdl>
		<usedin>foreword, preface, and intro</usedin>
		<ents>parazero and para0att</ents>
		<specatts>
			<attrtbl>
				<attr>rtermwidth</attr>
				<type>NUTOKEN</type>
				<default>2.5in</default>
				<attrdesc>Allows you to define the right term width. Their is currently no FOSI support for this attribute.</attrdesc>

				<attr>ltermwidth</attr>
				<type>NUTOKEN</type>
				<default>1in</default>
				<attrdesc>Allows you to define the left term width. Their is currently no FOSI support for this attribute.</attrdesc>

				<attr>emergency</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates that the primary paragraph will produce an emergency border on the page when set equal to 1.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>esds</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Electrostatic Discharge Sensitive. All paragraphs which address handling or maintenance which could damage *** ESDS *** parts shall be identified by the esds symbol by setting attribute equal to 1.</attrdesc>

				<attr>nsp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Nuclear Surety Procedures.  A **NSP** symbol will appear when set equal to 1.</attrdesc>

				<attr>fcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Fracture Critical Process. All paragraphs which address Fracture Critical Process shall be identified by the *** FCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Process. All paragraphs which address Hardness Critical Process shall be identified by the *** HCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Item. All paragraphs which address Hardness Critical Item shall be identified by the *** HCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>ocp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Process. All paragraphs which address observable critical processes shall be identified by the *** OCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>oci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Item. All paragraphs which address observable critical items shall be identified by the *** OCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>applichd</tag>
		<long>Applicabilty/Effectivity List Column Headings</long>
		<desc>Defines the column headings used for the applicabilty/effectivity list.</desc>
		<source>4.3f</source>
		<contmdl>(term, def)</contmdl>
		<usedin>applicdef</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
