<chngdesc>
<chnglevl formatlv="formatlevelnum" pagelevl="pagelevelnum" leaflevl="leaflevelnum" sprdlevl="sprdlevelnum" doclevl="doclevelnum" doctag="chgnum">
<levlgi levltype="number" gilist="change" levlattr="level" typeattr="change">
<levlchar which="doc" when="equal">
<charlist inherit="0"></charlist>

<att logic="or">
<specval attname="mark" attval="#EQ#0">
<specval attname="inbody.st" attloc="#FOSI" attval="no">
<charsubset>
	<chgmark barthick="0pt" join="1">	</chgmark>
</charsubset>
</att>

<att logic="and">
<specval attname="mark" attval="#EQ#1">
<specval attname="inbody.st" attloc="#FOSI" attval="yes">
<charsubset>
	<chgmark barthick="6pt" join="1">	</chgmark>
</charsubset>
</att>
</levlchar>

<levlchar which="doc" when="less">
<charlist inherit="0">
	<chgmark barthick="0pt" join="1">	</chgmark>
</charlist>
</levlchar>
</levlgi>

<levlatt attrlist="inschlvl" chngtype="insert" attrcont="level">
<levlchar which="doc" when="equal">
<charlist inherit="0"></charlist>

<att logic="and">
<specval attname="inbody.st" attloc="#FOSI" attval="yes">
<charsubset>
	<chgmark barthick="6pt" join="1">	</chgmark>
</charsubset>
</att>
</levlchar>

<levlchar which="doc" when="less">
<charlist inherit="0">
	<chgmark barthick="0pt" join="1">	</chgmark>
</charlist>
</levlchar>
</levlatt>

<levlatt attrlist="delchlvl" chngtype="delete" attrcont="level">
<levlchar which="doc" when="equal">
<charlist inherit="0">
	<suppress sup="1"></charlist>

<att logic="and">
<specval attname="inbody.st" attloc="#FOSI" attval="yes">
<charsubset>
	<chgmark barthick="6pt" join="1">	</chgmark>
</charsubset>
</att>
</levlchar>

<levlchar which="doc" when="less">
<charlist inherit="0">
	<chgmark barthick="0pt" join="1">	</chgmark>

	<suppress sup="1"></charlist>
</levlchar>
</levlatt>
</chnglevl>

