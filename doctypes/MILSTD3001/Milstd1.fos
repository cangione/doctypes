<savetext textid="wpct.txt" conrule="wpnotxt"></charsubset>
</att>
</e-i-c>
<e-i-c gi="fititleblk"><?Pub Dtl>
<charlist>
<postsp minimum="1.2em" nominal="1.2em" maximum="1.5em" condit="discard"
priority="high">
<span span="1">
<ruling thick="1pt" lentype="rel" rellen="col" placemnt="before"
type="dash">
<keeps next="1"></ruling>
<ruling thick="1pt" lentype="rel" rellen="col" voffset="6pt"
placemnt="after" type="dash">
<keeps next="1">
<textbrk startln="1" endln="1"></ruling>
<savetext textid="alphaindex.app"
conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixpgstr>,</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
placemnt="after" append="1">
<savetext textid="alphaindex.app"
conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixpgstr>,wpct.txt[BO],\/  \,</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
placemnt="after" append="1">
<savetext textid="alphaindex2.app"
conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixpgstr>,</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
placemnt="after" append="1">
