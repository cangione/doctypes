    ********************************************************************** -->
	<xs:include schemaLocation="ipd.xsd" />

<!--**********************************************************************
    * Include the Content Breakdown definitions.                         *
    ********************************************************************** -->
	<xs:include schemaLocation="content.xsd" />

<!--**********************************************************************
    * Include the Paracon definitions for static DMs.                    *
    ********************************************************************** -->
	<xs:include schemaLocation="paracon_static.xsd"/>

<!--**********************************************************************
    * Include the Lists definitions.                                     *
    ********************************************************************** -->
	<xs:include schemaLocation="lists.xsd" />
 
<!--**********************************************************************
    * Include the Figure definitions.                                    *
    ********************************************************************** -->
	<xs:include schemaLocation="figure.xsd" />

<!--**********************************************************************
    * Include the Para definitions.                                      *
    ********************************************************************** -->
	<xs:include schemaLocation="paragraphs.xsd"/>


