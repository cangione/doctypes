<charlist inherit="1" charsubsetref="para0.title.csub clearstrings">
<quadding quad="left" lastquad="relative">
<presp minimum="6pt" nominal="6pt" maximum="6pt" condit="discard">
<keeps scope="col" keep="1" next="1"></charlist>&security-mark;
<att>
