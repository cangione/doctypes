	<highlt scoring="1" scoreoff="2pt"></charlist>
</e-i-c>

<e-i-c gi="acronym" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1"></charlist>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>

<att logic="and">
