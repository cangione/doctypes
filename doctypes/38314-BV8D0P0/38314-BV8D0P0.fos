<e-i-c gi="figure" context="* front" occur="all"><?Pub Dtl>
<charlist inherit="1" charsubsetref="clearstrings">
<quadding quad="center" lastquad="lcenter">
<postsp minimum="12pt" nominal="12pt" maximum="12pt" condit="discard"
priority="high">
<textbrk startln="1" endln="1">
<reset resetlist="subfig.ctr">
<enumerat increm="1" enumid="fig.ctr">
<savetext textid="label.txt" conrule="fig.ctr">
<reset resetlist="totalsubfig.ctr subfig.flag">
<savetext textid="legend.txt" conrule="\\" placemnt="before">
<savetext textid="subfig.ist" conrule="">
<savetext textid="figtitle.txt" conrule="\\" placemnt="before">
<savetext textid="figtitle.tdv" conrule="\\" placemnt="before">
<savetext textid="object.str" conrule="\Figure\">
<savetext textid="inilluslist.st" conrule="\1\"></charlist>
&att-set-label;
<att>
<charsubset>
<savetext textid="fignum" conrule="label.txt"></charsubset>
</att>&att-content-cbar;&att-stringdecl-reset;
