<!--Indication Group-->
<e-i-c gi="indicationgrp" occur="notfirst"><?Pub Dtl>
<charlist charsubsetref="calist2">
<savetext textid="table.app"
conrule='!<row>!,!<entry colname="col1"></entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">
<reset
resetlist="row.app col1.app col2.app col3.app tabletxt reftxt condtxt">
<reset resetlist="step3ct"></charlist>
</e-i-c>
<e-i-c gi="indicationgrp" occur="first"><?Pub Dtl>
<charlist charsubsetref="calist2">
<savetext textid="table.app"
conrule='!<row>!,nobrk.txt,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">
<reset resetlist="row.app col2.app col3.app tabletxt reftxt condtxt">
<reset resetlist="step3ct"></charlist>
</e-i-c>
<e-i-c gi="step-with-indication"><?Pub Dtl>
<charlist charsubsetref="calist1">
<reset
resetlist="nobrk.txt row.app col1.app col2.app col3.app tabletxt reftxt condtxt">
