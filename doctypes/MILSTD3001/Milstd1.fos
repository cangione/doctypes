<!--Title page notices-->
<e-i-c gi="notices" context="* titlepg"><?Pub Dtl>
<charlist>
<presp minimum="8pt" nominal="360pt" maximum="360pt" condit="keep"
priority="high">
<keeps keep="4">
<textbrk startln="1"></charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<specval attname="cfa" attloc="#XPATH" attval="0">
<charsubset>
<usetext source="secretstatement">
<subchars charsubsetref="titlepg.notices.center.style">
<font style="serif" weight="medium">
<indent leftind="144pt" rightind="144pt" firstln="*"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="cfa * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.center.style"></charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="secretstatement" placemnt="after">
<subchars charsubsetref="titlepg.notices.center.style">
<font style="serif" weight="medium">
<indent leftind="144pt" rightind="144pt" firstln="*"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="super * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.center.style"></charlist>
</e-i-c>
<e-i-c gi="para" context="suppl * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.center.style"></charlist>
</e-i-c>
<e-i-c gi="para" context="continue * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.center.style"></charlist>
</e-i-c>
<e-i-c gi="para" context="irac * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.center.style"></charlist>
</e-i-c>
<e-i-c gi="distrib" context="notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.title.style">
<usetext source="\DISTRIBUTION STATEMENT \"></usetext>
</charlist>
<att>
<fillval attname="type" fillcat="usetext" fillchar="source">
<charsubset><?Pub Dtl>
<highlt allcap="1"></charsubset>
</att>
<att>
<charsubset><?Pub Dtl>
<usetext source="\.  \">
<subchars charsubsetref="no-scoring"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="distrib * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.para.style"></charlist>
</e-i-c>
<e-i-c gi="destr" context="notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.title.style">
<usetext source="\DESTRUCTION NOTICE\"></usetext>
</charlist>
<att>
<charsubset><?Pub Dtl>
<usetext source="\ - \">
<subchars charsubsetref="no-scoring"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="destr * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.para.style"></charlist>
</e-i-c>
<e-i-c gi="thirdparty" context="notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.title.style">
<usetext source="\THIRD PARTY AGREEMENT\"></usetext>
</charlist>
<att>
<charsubset><?Pub Dtl>
<usetext source="\ - \">
<subchars charsubsetref="no-scoring"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="thirdparty * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.para.style"></charlist>
</e-i-c>
<e-i-c gi="export" context="notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.title.style">
<usetext source="\EXPORT NOTICE\"></usetext>
</charlist>
<att>
<charsubset><?Pub Dtl>
<usetext source="\ - \">
<subchars charsubsetref="no-scoring"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="export * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.para.style"></charlist>
</e-i-c>
<e-i-c gi="para" context="secretstatement"><?Pub Dtl>
<charlist>
<suppress sup="1">
<savetext textid="secretstatement" conrule="#CONTENT"></charlist>
</e-i-c>
<e-i-c gi="para" context="authnote * notices"><?Pub Dtl>
<charlist charsubsetref="titlepg.notices.center.style">
<presp minimum="12pt" nominal="12pt" maximum="12pt" condit="keep"
priority="high">
<postsp minimum="12pt" nominal="16pt" maximum="20pt" condit="keep"
priority="high">
<keeps prev="3">
<ruling thick="1pt" lentype="rel" rellen="col" placemnt="after">
<leading lead="1pt">
<indent leftind="0" rightind="0" firstln="*">
<presp minimum="8pt" nominal="10pt" maximum="16pt" condit="keep"
priority="force">
<textbrk startln="1" endln="1"></ruling>
</charlist>
</e-i-c>
<e-i-c gi="para" context="downgradenot"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph">
<suppress sup="1">
<savetext textid="downgradenot.txt"
conrule="<ppara-ctr>,#CONTENT,</ppara-ctr>" append="1"></charlist>
</e-i-c>
<e-i-c gi="para"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph"></charlist>
<att>
<specval attname="label" attval="#NONE">
<charsubset><?Pub Dtl>
<enumerat increm="1" enumid="paract">
<savetext textid="taskparanum" conrule="taskct,\-\,paract">
<usetext source="taskparanum,\. \" placemnt="before">
<subchars></subchars>
</usetext>
</charsubset>
</att>
<att>
<fillval attname="label" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="taskparanum">
<usetext source="taskparanum,\. \" placemnt="before">
<subchars></subchars>
</usetext>
</charsubset>
</att>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="taskparanum"></charsubset>
</att>&security.before.att;&change.marks.att;</e-i-c>
<!--NUMERICAL INDEX OF EFFECTIVE WORK PACKAGES/PAGES-->
<e-i-c gi="niewp"><?Pub Dtl>
<charlist charsubsetref="font">
<font style="sanserif" size="10pt">
<span span="3">
<savetext textid="chgnumstr" conrule="\0\">
<savetext textid="chgstring" conrule="strPubDate"></charlist>
&change.number-date.att;
