<specval attname="cols" attloc="ipbrfdsindx" attval="#EQ#2">
<charsubset>
	<span span="2">
	<tabatts widthtype="colrelative" relwidth="50" frame="all">
	<stdcellatts colsep="1" rowsep="0" leftmar="5pt" rightmar="2pt" topmar="2pt">	</tabatts>

	<tgroupatts cols="2">	</tgroupatts>

	<colatts colname="col1" colwidth="1*">	</colatts>

	<colatts colname="col2" colwidth="1*">	</colatts>

	<usetext source="<header.ps>,<sssnhd>,\S/S/SN\,</sssnhd>,        <fighd>,\FIGURE &\,</fighd>, <sssnhd>,\\,</sssnhd>,        <fighd>,\INDEX NO.\,</fighd>, </header.ps>,<body.ps>">	</usetext>
