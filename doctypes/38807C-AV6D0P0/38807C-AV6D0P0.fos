conrule="<toclinec>,<toctitle.fmt>,label.txt,@3em,\DELETED\,tocfill,</toctitle.fmt>,<tocnumx>,folio.txt[BO],</tocnumx>,</toclinec>"
append="1">
<usetext source="!<table><title>!,\Deleted\,!</title></table>!">
</usetext>
</charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
