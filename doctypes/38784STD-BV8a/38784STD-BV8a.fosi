	<textbrk startln="1">
	<span span="1"></charlist>

<att logic="and">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="\List of Time Compliance Technical Orders\">
	<savetext textid="labelstr" conrule="\List of Time Compliance Technical Orders\"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<charsubset>
	<savetext textid="labelstr" conrule="\List of Time Compliance Technical Orders\">
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="\List of Time Compliance Technical Orders\">
	<savetext textid="label" conrule="labelstr" saverule="1"></charsubset>
</att>

<att logic="and">
<specval attname="numcols" attloc="front" attval="#ANY">
<charsubset>
	<usetext source="<tcto.table>" placemnt="before">	</usetext>

	<usetext source="\List of Time Compliance Technical Orders\">
	<subchars>
	<font weight="bold">
	<leading lead="12pt">
	<quadding inherit="0" quad="center" lastquad="lcenter">
	<postsp nominal="10pt" condit="keep" priority="force">
	<textbrk startln="1" endln="1">
	<subsetatts subsettype="title" titlepos="above" subsetusage="normal">	</subsetatts>
	</subchars>
	</usetext>

	<usetext source="\List of Time Compliance Technical  Orders&mdash;Continued\">
	<subchars>
	<font weight="bold">
	<leading lead="12pt">
	<quadding inherit="0" quad="center" lastquad="lcenter">
	<presp nominal="12pt" condit="keep" priority="force">
	<postsp nominal="6pt" condit="keep" priority="force">
	<textbrk startln="1" endln="1">
	<subsetatts subsettype="title" titlepos="above" subsetusage="continued">	</subsetatts>
	</subchars>
	</usetext>

	<usetext source="<tcto.tablehead>,  <numberhead>,<underline.ps>,\TCTO Number\,</underline.ps>,</numberhead>,  <titlehead>,<underline.ps>,\TCTO Title\,</underline.ps>,</titlehead>,  <datehead>,<underline.ps>,\TCTO Date\,</underline.ps>,</datehead>,  </tcto.tablehead>,<tcto.tablebody>">	</usetext>

	<usetext source="<tcto.tablebody>" placemnt="before">	</usetext>

	<usetext source="</tcto.tablebody>" placemnt="after">	</usetext>

	<usetext source="</tcto.table>" placemnt="after">	</usetext>
</charsubset>
