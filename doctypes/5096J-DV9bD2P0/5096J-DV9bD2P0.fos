&division-settings;&set-deltypstr;
<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\DELETED\">
<savetext textid="titleholdst" conrule="contentcbar.txt,\DELETED\">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\RESERVED\">
<savetext textid="titleholdst" conrule="contentcbar.txt,\RESERVED\">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="na">
<specval attname="status" attval="notapp">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\NOT APPLICABLE\">
<savetext textid="titleholdst" conrule="#CONTENT(titlehold)">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="real">
