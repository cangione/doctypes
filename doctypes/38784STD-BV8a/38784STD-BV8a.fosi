	<savetext textid="xrefstr" conrule="#CONTENT(label)">
	<savetext textid="labelstr" conrule="#CONTENT(label)"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<specval attname="inbody.st" attloc="#FOSI" attval="#EQ#\no\">
