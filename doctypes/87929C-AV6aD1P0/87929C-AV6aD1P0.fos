<charsubset>
<savetext textid="tabtitle" conrule="scontent.txt,#CONTENT,econtent.txt">
</charsubset>
</att>
<att><?Pub Lcl
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext
source="\Table \,label.txt,\.\,1em,applicrefidtxt.txt,symbol.st">
<subchars></subchars>
</usetext>
<usetext source="\.\" placemnt="after">
<subchars></subchars>
</usetext>
<savetext textid="lotmatter"
conrule="<toclinec>,label.txt,@3em,scontent.txt,applicrefidtxt.txt,symbol.st,#CONTENT,econtent.txt,tocfill,<tocnum>, folio.txt[BO],</tocnum>,</toclinec>"
append="1"></charsubset>
</att>
<att logic="and">
<specval attname="status" attloc="table" attval="#NE#\empty\">
<charsubset>
<savetext textid="dlctcont"
conrule="<tabconta>,\Table \,label.txt,\.\,1em,scontent.txt,#CONTENT,econtent.txt,\ &ndash; Continued.\,</tabconta>,<line>,\ \,</line>">
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext
source="\Table \,label.txt,\.\,1em,tabtitle,\ &ndash; Continued.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<textbrk startln="1" endln="1">
<float flidref="top-col.flt" width="col" scope="table"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>&mark.changed;</e-i-c>
<e-i-c gi="table" context="* ipbforeword"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="clearstrings">
<quadding quad="center">
<presp minimum="12pt" nominal="12pt" maximum="12pt" condit="discard"
priority="high">
<postsp minimum="6pt" nominal="12pt" maximum="12pt" condit="discard">
<keeps scope="page" prev="1">
<textbrk startln="1" endln="1">
<enumerat increm="1" enumid="tbl.ctr">
<savetext textid="label.txt" conrule="tbl.ctr">
<savetext textid="prefix.tdv" conrule="\Table \" placemnt="before">
<savetext textid="dlctcont" conrule="">
<savetext textid="prefix.tdv" conrule="\\" placemnt="after">
<savetext textid="symbol.tdv" conrule="\*\" placemnt="before" append="0">
<savetext textid="set-next-symbol.tdv"
conrule="<double-asterisk.psu>,</double-asterisk.psu>" placemnt="before"
append="0">
<savetext textid="object.str" conrule="\Table\">
<savetext textid="tfn.st" conrule="\\" placemnt="before"></charlist>
&security-mark;
<att logic="and">
<specval attname="tabstyle" attval="8pt">
<charsubset>
<font size="8pt"></charsubset>
</att>
<att logic="and">
<specval attname="tabstyle" attval="9pt">
<charsubset>
<font size="9pt"></charsubset>
</att>
