<!-- ENTITY DECLARATIONS -->

<!ENTITY % doc "docnnmunbas">

<!-- CCB#: 9977-C-04021-01 -->
<!ENTITY % bodyele "munitdesc, suspequipdesc, gunpodsdesc, sedesc,
suppinfo, suppeq?" >

<!ENTITY % titles "title" >

<!ENTITY % sedesc "%titles;, bombliftruck, munadapters, munitrailers,
ammoloadsys, testequip, testadapters" >

<!ENTITY % parazero "%titles;, warning*, caution*, note*, (para, note?)?,
(step1, step1+)?" >

<!ENTITY % sect "(para0+)" >

<!-- CCB#: 38784std-02030-22-->

<!ENTITY % idinf "tmidno+, (chgnum, chgdate)?, 
chghistory, pretmidno*, volnum?, revnum?, doctype, maintlvl?, prtitle, subtitle?, 
(mfr+, contractno+)?, seal?, supersed?, suppl*, effdatenot?, volnot?, discl?, distrib, expcont?,
 destr?, copyright*, cogact?, moveddata?, authnot, downgrd?, pubdate" >

<!ENTITY % frnt "idinfo, warnpage?, chginssht?, (lep | vollep), verstat?,
tpdr?, chgrec?, (contents | volcontents), (foreword | preface | intro), safesum?" >

<!ENTITY % distrib.att "type (A | B | C | D | E | F | X | other) #REQUIRED" > 

<!ENTITY % m38784       PUBLIC "-//USA-DOD//DTD 38784STD-BV7//EN" >
%m38784;

<!-- ELEMENT and ATTRIBUTE LIST DECLARATIONS -->

<!ELEMENT ammoloadsys - o (%sect;) >
