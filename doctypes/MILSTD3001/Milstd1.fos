<!--Materials Required List-->
<e-i-c gi="matlist"><?Pub Dtl>
<charlist envname="tableenv">
<font inherit="0">
<leading inherit="0">
<indent inherit="0">
<quadding inherit="0" quad="center">
<presp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<postsp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<textbrk startln="1" endln="1">
<span span="1">
<reset resetlist="table.app tableconttxt">
<reset resetlist="row.app col1.app col2.app col3.app">
<reset resetlist="tfnnumct tfnalphact">
<usetext source="\Materials Required\" placemnt="before">
<subchars charsubsetref="title"></subchars>
</usetext>
<usetext
source='!<table frame="none" rowsep="0" colsep="0"><tgroup cols="3"><colspec colname="col1" align="left" colwidth="17pi"/><colspec colname="col2"
align="left" colwidth="16pi"/><colspec colname="col3"
align="center" colwidth="9pi"/><spanspec spanname="span1to3" namest="col1" nameend="col3"/><thead><row><entry><bold>Nomenclature</bold></entry><entry><bold>Specification/Part Number</bold></entry><entry><bold>HMWS Index Number</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="\Materials Required (Cont)\">
<subchars charsubsetref="title.cont">
<float scope="matlist"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
