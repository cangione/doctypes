<e-i-c gi="heading" context="majaction" occur="all"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1">
<font size="8pt">
<leading lead="8pt">
<indent leftind="11.5pi" rightind="4pi" firstln="*">
<presp nominal="12pt">
<keeps keep="1">
<textbrk startln="1" endln="1"></charlist>&att-content-cbar;
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="headstr.1"
conrule="scontent.txt,#CONTENT,econtent.txt"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="headstr.1,\ &ndash; Continued\">
<subchars>
<font size="8pt">
<indent leftind="12pi" rightind="1pi" firstln="*">
<presp nominal="6pt" priority="force">
<postsp nominal="6pt">
<textbrk startln="1" endln="1">
<float flidref="top-page.flt" scope="majaction action task"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<savetext textid="headstr.1" conrule="scontent.txt,\ \,econtent.txt">
<usetext source="contentcbar.txt,\ \"></usetext>
</charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
