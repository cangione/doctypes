<subchars>
<indent leftind="0.5in" firstln="0.5in">
<quadding quad="left" lastquad="lleft">
<textbrk startln="0" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attloc="seqlist" attval="real">
<specval attname="status" attloc="seqlist" attval="empty">
<charsubset>
<suppress sup="1"></charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attloc="seqlist" attval="#ANY">
<specval attname="deltype" attloc="seqlist" attval="#NE#\real\">
<charsubset charsubsetref="delchlvl"></charsubset>
</att>
<att logic="and">
<specval attname="status" attloc="seqlist" attval="#ANY">
