<savetext conrule="tableftnotenum"></charsubset>
</att>
</e-i-c>
<e-i-c gi="notesentry" context="noteslist * bunroutepl" occur="notfirst"><?Pub Dtl>
<charlist>
<suppress sup="1">
<enumerat increm="1" enumid="outline.lev1.ct">
<savetext textid="tableftnotenum" conrule="outline.lev1.ct">
<savetext textid="notestxt"
conrule="<ppara>,outline.lev1.ct,\. \,#CONTENT,</ppara>">
<savetext textid="row.app"
conrule='!<entry spanname="span1to6" align="left">!,notestxt,!</entry>!'>
<savetext textid="table.app" conrule="!<row>!,row.app,!</row>!"
placemnt="after" append="1"></charlist>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tableftnotenum"></charsubset>
</att>
</e-i-c>
<e-i-c gi="bunrouteplentry"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph space">
<reset
resetlist="row.app col1.app col2.app col3.app col4.app col5.app col6.app">
</charlist>
</e-i-c>
<e-i-c gi="remarks" context="* consoleffectlistentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col3.app" conrule="#CONTENT" append="1"></charlist>
</e-i-c>
<e-i-c gi="config" context="* consoleffectlistentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col2.app" conrule="#CONTENT" append="1"></charlist>
</e-i-c>
<e-i-c gi="effectcode" context="* effectlegend" occur="notfirst"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<usetext source="\, \" placemnt="before"></usetext>
</charlist>
</e-i-c>
<e-i-c gi="effectcode" context="* effectlegend" occur="first"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1"></charlist>
</e-i-c>
<e-i-c gi="graphic" context="* effectgraphic"><?Pub Dtl>
<charlist inherit="1">
<keeps next="0" prev="0">
<textbrk startln="0" endln="0"></charlist>
</e-i-c>
<e-i-c gi="effectgraphic" context="* consoleffectlistentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col1.app" conrule="#CONTENT" append="1">
<savetext textid="effectlegend.txt" conrule="#CONTENT"></charlist>
</e-i-c>
<e-i-c gi="effectlegend" context="* consoleffectlistentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col1.app" conrule="<boxing>,#CONTENT,</boxing>"
append="1">
<savetext textid="effectlegend.txt"
conrule="<boxing_link>,#CONTENT,</boxing_link>"></charlist>
</e-i-c>
<e-i-c gi="boxing"><?Pub Dtl>
<charlist>
<boxing toffset="3pt" boffset="3pt" loffset="3pt" roffset="3pt"
thick="1pt" ttype="tsingle" btype="bsingle" ltype="lsingle"
rtype="rsingle"></charlist>
</e-i-c>
<e-i-c gi="boxing_link"><?Pub Dtl>
<charlist>
<boxing toffset="1pt" boffset="1pt" loffset="1pt" roffset="1pt"
thick="1pt" ttype="tsingle" btype="bsingle" ltype="lsingle"
rtype="rsingle"></charlist>
</e-i-c>
<e-i-c gi="consoleffectlist"><?Pub Dtl>
<charlist charsubsetref="paragraph space">
<usetext
source='!<table><tgroup cols="3"><colspec colname="col1" align="center"/><colspec colname="col2"
align="left"/><colspec colname="col3" align="left"/><spanspec spanname="span1to3" namest="col1"
nameend="col3"/><thead valign="top"><row><entry align="center"><bold>Effectivity Legend</bold></entry><entry align="center"><bold>Configuration Identification</bold></entry><entry align="center"><bold>Remarks</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
<reset resetlist="table.app col1.app col2.app col3.app row.app">
</charlist>
</e-i-c>
<e-i-c gi="consoleffectlistentry"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph space">
<savetext textid="table.app"
conrule='!<row>!,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">
<reset
resetlist="row.app col1.app col2.app col3.app effecttypetxt effectalltxt effectkidsct effectct">
<savetext textid="effectlegend.txt" conrule="\\"></charlist>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="effectlegend.txt" placemnt="after"></charsubset>
</att>
</e-i-c>
</styldesc>
</outspec>
