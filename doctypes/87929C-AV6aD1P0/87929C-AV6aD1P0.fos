</charlist>&security-mark;
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext source="\List of Related Publications.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="relative">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="10pt" nominal="10pt" maximum="10pt" condit="keep"
priority="force">
<keeps next="7">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
<usetext
source='!<tabmat frame="none"><tgroup cols="2"><?PubTbl tgroup ctmarg="2pt" cbmarg="1pt"><colspec colname="col1" colsep="0"><colspec colname="col2" colsep="0"><thead><row><entry align="center">Number</entry><entry align="center">Title</entry></row></thead><tbody>!,lrp-body.txt,!</tbody></tgroup></tabmat>!'
placemnt="after"></usetext>
</charsubset>
</att>
<att logic="or">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<span span="1">
<suppress sup="1">
<usetext source="\List of Related Publications - DELETED.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="10pt" nominal="10pt" maximum="10pt" condit="keep"
priority="force">
<keeps scope="col" next="1">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att logic="and">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<savetext textid="xrefstr" conrule="\List of Related Publications\">
</charsubset>
</att>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="\List of Related Publications &ndash; Continued.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<float flidref="top-page.flt" width="col" scope="lrptable"
pagetype="afterref"></subchars>
</usetext>
</charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
