	<ele>
		<tag>volume</tag>
		<long>Volume</long>
		<desc>Identifies a volume.</desc>
		<source>4.2.9.1</source>
		<contmdl>((front | auxfront), body, rear?)</contmdl>
		<usedin>doc</usedin>
		<ents>bodyatt, secur, docatt, service, and yesorno</ents>
		<specatts>
			<attrtbl>
				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>docid</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows for the author to define an identification number for the document.</attrdesc>

				<attr>docstat</attr>
				<type>(revision | change | prelim | draft | formal)</type>
				<default>prelim</default>
				<attrdesc>Author can stipulate what form the manual is in.</attrdesc>

				<attr>verstatpg</attr>
				<type>(ver | unver)</type>
				<default>unver</default>
				<attrdesc>Author can stipulate a verified or unverified manual. Use of this attribute will trigger the generation of the verification status page and the temporary file - vsmatter.dat. See the accompanying readme.txt file for verification status for more detail.</attrdesc>

				<attr>index</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicated whether an index is included in the manual. Attribute should be set to 1 when an index is present. Use of this attribute will affect the level of detail in the TOC</attrdesc>

				<attr>service</attr>
				<type>(AF | NAVAIR | NAVSEA | SPAWARS | ARMY | MC | DLA | CG | DOD | FRN)</type>
				<default>#REQUIRED</default>
				<attrdesc>Defines the branch of service.</attrdesc>

				<attr>volpages</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates whether the page numbers within the volume use the volume number prefix. "0" indicates standard page numbers. "1" indicates a volume prefix will be used.</attrdesc>

				<attr>resetnbars</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Allows you to reset chapter numbers when continuing to a second or subsequent volume. "1" will reset chapter numbers back to 1. "0" will continue with the chapter numbers.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>warning</tag>
		<long>Warning</long>
		<desc>Identifies a WARNING in the manual. Multiple warning tags may be used only when it is desired to change the warning icon (standard or hazardous warning graphic).</desc>
		<source>4.3.10</source>
		<contmdl>(icon?, para*) -(randlist | deflist | seqlist | figure | table | foldout | objmedia | warning | caution)</contmdl>
		<usedin>abbrsect, applicdef, dddesc, ddindex, entry, ipbesdsdesc, ipbfinding, ipbhcidesc, ipbmfrlist, ipbmodelcover, ipbpartstd, ipbquickchgexpl, ipbserialization, ipbshtnoexpl, ipbsimassem, ipbsmrexpl, ipbuseonexpl, lrp, para0, ratddesc, safesum, step1, step2, step3, step4, subpara1, subpara2, subpara3, subpara4, subpara5, subpara6, subpara7, subpara8, symsect, tctolist, and tmimprep</usedin>
		<ents>list, exclus, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>warnpage</tag>
		<long>Warning Page</long>
		<desc>Identifies the warning page(s) of the manual.</desc>
		<source>4.5.2</source>
		<contmdl>(wpgentry+)</contmdl>
		<usedin>front and auxfront</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>wpgentry</tag>
		<long>Warning Page Entry</long>
		<desc>Identifies an individual warning on the warning page(s). The FOSI does not currently fully support this element.</desc>
		<source>4.5.2</source>
		<contmdl>(title, para+)</contmdl>
		<usedin>warnpage</usedin>
		<ents>yesorno and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>warnbox</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to specify the appearance and size of the warning box.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>titlefont</attr>
				<type>(10pt | 14pt)</type>
				<default>14pt</default>
				<attrdesc>Specifies the font size choices available for a warning page entry.</attrdesc>

				<attr>line</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies whether a line should appear between warning page entries.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>xref</tag>
		<long>Cross-reference</long>
		<desc>Identifies a cross-reference to a paragraph, figure, table, etc.</desc>
		<source>4.3.1</source>
		<contmdl>EMPTY</contmdl>
		<usedin>bindByCoords, bindById, bindByName, abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>xrefid</attr>
				<type>IDREF</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the ID of the element that you are referencing. The value of this attribute should match the value of an ID attribute elsewhere in the manual.</attrdesc>

				<attr>displayvalue</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>If the author needs to add additional, unique information for purposes of referencing an external document, this attribute should be tagged. This attribute should be used for providing paragraph titles, system numbers, task numbers and for author-generated TO numbers where applicable.</attrdesc>

				<attr>HyTime</attr>
				<type>NAME #FIXED</type>
				<default>clink</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>HyNames</attr>
				<type>CDATA #FIXED</type>
				<default>linkend xrefid</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
