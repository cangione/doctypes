	  <xs:include schemaLocation="../basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="./approvalDate.xsd"/>
	  <!--=============================================-->
	<!--  common approval data provided in dmStatus and pmStatus-->
	<!--=============================================-->
	<xs:element name="approvalInfo" type="approvalInfoType">
		    <xs:annotation>
			      <xs:documentation>Set of data related to the approval status of the DM or PM</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="approvalInfoType">
		    <xs:sequence>
			      <xs:element name="authority" type="nameType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Agency responsible of the approval in case of approvalRequired set to "yes" or "partial"</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="approvalStatement" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Used if Approval Required is "yes" or "partial", it contains a statement like “EASA Approved” or “A/R Related"</xs:documentation>
				        </xs:annotation>
				        <xs:complexType mixed="true">
					          <xs:choice minOccurs="0" maxOccurs="unbounded">
						            <xs:element ref="abbreviation"/>
					          </xs:choice>
				        </xs:complexType>
			      </xs:element>
			      <xs:element ref="approvalDate" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Date of approval.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attribute name="approvalRequired" use="required">
			      <xs:annotation>
				        <xs:documentation>used to identify if a DM contains content that must be approved.</xs:documentation>
			      </xs:annotation>
			      <xs:simpleType>
				        <xs:restriction base="xs:string">
					          <xs:enumeration value="yes"/>
					          <xs:enumeration value="no"/>
					          <xs:enumeration value="partial"/>
				        </xs:restriction>
			      </xs:simpleType>
		    </xs:attribute>
	  </xs:complexType>
</xs:schema>