<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="ITEM" context="randlist" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<indent inherit="1" leftind="@2em" firstln="*-1em">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="prefix" attloc="randlist" attval="#ANY">
<charsubset>
	<usetext source="#CONTENT(label),@1em">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="prefix" attloc="randlist" attval="#NONE">
<charsubset>
	<usetext source="\&bull;\,@1em">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="SEQLIST" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<presp nominal="12pt">
	<textbrk startln="1" endln="1">
	<reset resetlist="seq1ct"></charlist>

<att logic="and">
<specval attname="prefix" attval="#ANY">
<charsubset>
	<savetext textid="seqlist.prefix.str" conrule="#CONTENT(prefix)"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Deleted)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Reserved)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="na">
<specval attname="status" attval="notapp">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Not Applicable)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<specval attname="deltype" attval="#NE#\real\">
<charsubset charsubsetref="delchlvl"></charsubset>
</att>

<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
<charsubset charsubsetref="delstatus"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#NE#0">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="ITEM" context="seqlist" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<suppress sup="1"></charlist>

<att logic="and">
<specval attname="label" attval="#ANY">
<charsubset>
	<savetext textid="labelstr" conrule="#CONTENT(label)">
	<usetext source="labelstr,\.\">
	<subchars>
	<indent inherit="1" leftind="@2em" firstln="*-1em">
	<textbrk startln="1" endln="0">
	<algroup refpoint="first">	</subchars>
	</usetext>

	<usetext source="#CONTENT">
	<subchars>
	<indent inherit="1" leftind="@2em" firstln="@2em">
	<textbrk startln="0" endln="1">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<specval attname="prefix" attloc="seqlist" attval="#ANY">
<charsubset>
	<savetext textid="labelstr" conrule="seqlist.prefix.str"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<specval attname="prefix" attloc="seqlist" attval="#NONE">
<specval attname="numstyle" attloc="seqlist" attval="#NONE">
<charsubset>
	<enumerat increm="1" enumid="seq1ct">
	<savetext textid="labelstr" conrule="seq1ct">
	<usetext source="labelstr,\.\">
	<subchars>
	<indent inherit="1" leftind="@2em" firstln="*-1em">
	<textbrk startln="1" endln="0">
	<algroup refpoint="first">	</subchars>
	</usetext>

	<usetext source="#CONTENT">
	<subchars>
	<indent inherit="1" leftind="@2em" firstln="@2em">
	<textbrk startln="0" endln="1">	</subchars>
	</usetext>

