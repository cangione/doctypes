<font weight="bold">
<hyphen hyph="0">
<quadding quad="center" lastquad="lcenter">
<textbrk startln="1" endln="1">
<float flidref="top-col.flt" width="col" scope="abbrsect"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>&mark.changed;</e-i-c>
