<?xml version="1.0" encoding="UTF-8"?>
<!--
  Root XML Catalog for the doctypes repository.

  Chains to all XML-based sub-catalogs for DITA and S1000D standards.
  SGML-based MILSPEC/ATA doctypes use the SGML catalog at doctypes/catalog.

  See: https://www.oasis-open.org/committees/entity/spec-2001-08-06.html
-->
<catalog xmlns="urn:oasis:names:tc:entity:xmlns:xml:catalog">

  <!-- ============================================================ -->
  <!-- MILSPEC / MIL-STD DTDs, FOSI & JCALS Entities                -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/milspec-catalog.xml"/>

  <!-- ============================================================ -->
  <!-- DITA 1.2 (DTD, XSD)                                          -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/dita-1.2/catalog.xml"/>

  <!-- ============================================================ -->
  <!-- DITA 1.3 (DTD, XSD, RNG)                                     -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/dita-1.3/catalog.xml"/>

  <!-- ============================================================ -->
  <!-- S1000D 2.3 (XML DTD, XSD)                                    -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/S1000D_2-3/cat/xml_schema/catalog.xml"/>

  <!-- ============================================================ -->
  <!-- S1000D 3.0 (XML DTD, XSD)                                    -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/S1000D_3-0/cat/xml_schema/catalog.xml"/>

  <!-- ============================================================ -->
  <!-- S1000D 4.1 (XSD)                                             -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/S1000D_4.1_Schemas/Catalog/catalog.xml"/>

  <!-- ============================================================ -->
  <!-- S1000D 4.2 (XSD)                                             -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/S1000D_4.2_Schemas/xml_schema_cat/catalog.xml"/>

  <!-- ============================================================ -->
  <!-- S1000D 5.0 (XSD)                                             -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/S1000D_5.0_Schemas/xml_schema_cat/catalog.xml"/>

  <!-- ============================================================ -->
  <!-- S1000D 6.0 (XSD)                                             -->
  <!-- ============================================================ -->
  <nextCatalog catalog="doctypes/S1000D_6.0_Schemas/xml_schema_cat/catalog.xml"/>

</catalog>
