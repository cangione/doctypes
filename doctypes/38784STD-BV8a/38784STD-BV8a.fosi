	<quadding quad="left" lastquad="lleft">
	<presp nominal="12pt">
	<textbrk startln="1"></charsubset>
</att>

<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
