<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>
</e-i-c>

<e-i-c gi="entbrk" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<indent leftind="5em" rightind="2em" firstln="0em">
	<presp nominal="8pt" priority="force">
	<textbrk startln="1" endln="1">
	<usetext source="4em">	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="tfndisplay" context="tgroup" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<subsetatts cols="1" frame="noframe" keep="none" subsettype="title" titlepos="below">	</subsetatts>

	<usetext source="tfn.st">	</usetext>

	<savetext textid="tfn.st" conrule="" placemnt="after"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="tfndisplay" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<reset resetlist="ntftnct.ctr atftnct.ctr symftnct.ctr">
	<usetext source="<blankrow.ps>,</blankrow.ps>">	</usetext>

	<usetext source="<footnote.ps>,</footnote.ps>">	</usetext>

	<savetext textid="tfn.st" conrule="" placemnt="after"></charlist>

