<!-- ============================================================== -->
<!--      MSG3 ANALYSIS HEADER                                      -->
<!-- ============================================================== -->
<!ELEMENT msg3     - - ((title?, intro?, prodid, legalntc, 
                        (syspower | structur | zonal)+) | increv)
                       +(revst | revend | hotlink)                    >

