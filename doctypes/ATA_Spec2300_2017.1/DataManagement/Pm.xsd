	  <xs:include schemaLocation="../common/dataManagement/pmIdent.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/pmIssue.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/links.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/pmRef.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/extensibleInterface.xsd"/>
	  <!--=============================================-->
	<!-- pm Element Declaration (DM Status List  root element) -->
	<!--=============================================-->
	<xs:element name="pm" type="pmElemType">
		    <xs:annotation>
			      <xs:documentation>Publication module</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="pmElemType">
		    <xs:sequence>
			      <xs:element ref="pmIdent"/>
			      <xs:element name="issueInfo" type="pmIssueInfoElemType">
				        <xs:annotation>
					          <xs:documentation>issue date of the publication module</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="content" type="contentElemType">
				        <xs:annotation>
					          <xs:documentation>publication module content</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- content Content model												 -->
	<!--=============================================-->
	<xs:complexType name="contentElemType">
		    <xs:sequence>
			      <xs:element ref="pmEntry"/>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- pmEntry Content model												 -->
	<!--=============================================-->
	<xs:element name="pmEntry" type="pmEntryElemType">
		    <xs:annotation>
			      <xs:documentation>a publication module entry.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="pmEntryElemType">
		    <xs:sequence>
			      <xs:element name="title" type="nameType">
				        <xs:annotation>
					          <xs:documentation>publication module entry title</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:choice>
				        <xs:choice maxOccurs="unbounded">
					          <xs:element ref="pmRef"/>
					          <xs:element ref="pmEntry"/>
				        </xs:choice>
				        <xs:choice maxOccurs="unbounded">
					          <xs:element name="dmRef" type="dmEntryRefType"/>
					          <xs:element ref="dmRefGroup"/>
				        </xs:choice>
			      </xs:choice>
		    </xs:sequence>
		    <xs:attribute name="pmEntryCode" type="xs:string" use="optional">
			      <xs:annotation>
				        <xs:documentation>code if the pm entry.</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="pmEntryType" type="xs:string" use="optional">
			      <xs:annotation>
				        <xs:documentation>type of the pm entry.</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- dmRefGroup Content model												 -->
	<!--=============================================-->
	<xs:complexType name="dmEntryRefType">
		    <xs:complexContent>
			      <xs:extension base="dmRefElemType">
				        <xs:attributeGroup ref="dmEntryCodeAttGrp"/>
			      </xs:extension>
		    </xs:complexContent>
	  </xs:complexType>
	  <!--/xs:element-->
	<!--=============================================-->
	<!-- dmRefGroup Content model												 -->
	<!--=============================================-->
	<xs:element name="dmRefGroup" type="dmRefGroupType">
		    <xs:annotation>
			      <xs:documentation>A group of DM that must be published grouped.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="dmRefGroupType">
		    <xs:sequence>
			      <xs:element name="title" type="nameType">
				        <xs:annotation>
					          <xs:documentation>title of a dmEntryGroup</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="dmRef" type="dmEntryRefType" maxOccurs="unbounded"/>
		    </xs:sequence>
		    <xs:attributeGroup ref="dmEntryCodeAttGrp"/>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <xs:attributeGroup name="dmEntryCodeAttGrp">
		    <xs:attribute name="dmEntryCode" type="xs:string" use="optional">
			      <xs:annotation>
				        <xs:documentation>code of a dmRef or dmRefGroup.</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:attributeGroup>
</xs:schema>