<ruling thick="1pt" lentype="rel" rellen="text" voffset="10pt">
<leading lead="0">
<indent leftind="@+12.60pi" rightind="*+13.2pi" firstln="*">
<textbrk startln="1" endln="1"></ruling>
<usetext source="\ \">
<subchars>
<leading lead="0pt">
<indent leftind="0" rightind="-6pi" firstln="*">
<textbrk startln="1" endln="1">
<boxing toffset="11pt" boffset="37pi" loffset="6pt" roffset="11pt"
