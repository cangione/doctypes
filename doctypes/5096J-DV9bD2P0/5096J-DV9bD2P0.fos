<e-i-c gi="subfig" context="foldout * foldsect" occur="first"><?Pub Lcl
_id="f1"><?Pub Dtl>
<charlist inherit="0">
<quadding quad="right" lastquad="lright">
<textbrk startln="1">
<enumerat increm="1" enumid="totalsubfig.ctr">
<savetext textid="subfig.flag" conrule="\yes\" placemnt="before">
<savetext textid="subfig-legend.txt" conrule="\\" placemnt="before">
</charlist>&att-set-label;
<att>
<charsubset>
<savetext textid="sheetno.txt" conrule="label.txt">
<savetext textid="subfigctr" conrule="label.txt"></charsubset>
</att>&att-content-cbar;&set-deltypstr;&security-mark;
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="subfigctr" conrule="label.txt">
<savetext textid="foldtitle.ftr"
conrule="\ (Sheet \,sheetno.txt,\ of \,foldsubfigno.ist,\)\" append="1">
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<savetext textid="subfigctr" conrule="label.txt">
<savetext textid="foldtitle.ftr" conrule="\\"></charsubset>
</att>
<att>
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr"
conrule="\Figure \,fignum,\ (Sheet \,sheetno.txt,\)\"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<textbrk startpg="recto" pageid="bodypg" newpgmdl="local">
<suppress sup="1">
<usetext
source="\Figure \,fignum,\. \,scontent.txt,\(Sheet \,sheetno.txt,\ of \,foldsubfigno.ist,\) \,econtent.txt,deltypestr">
<subchars>
<font inherit="0" weight="bold">
<quadding quad="left" lastquad="lleft">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<textbrk startln="1"></subchars>
</usetext>
<usetext source="\\" placemnt="after">
<subchars>
<textbrk startpg="recto" startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext
source="foldtitle-flt,\Sheet \,sheetno.txt,\ of \,foldsubfigno.ist,\ &ndash; Continued\">
<subchars>
<font inherit="0" size="1pt" width="ultcond" offset="1000pt">
<leading lead="1pt">
<quadding quad="right" lastquad="lright">
<highlt fontclr="white" forpct="0">
<presp minimum="0pt" nominal="0pt" maximum="0pt">
<postsp minimum="0" nominal="0" maximum="0" priority="high">
<keeps next="1">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<usetext
source="foldtitle-flt,\Sheet \,sheetno.txt,\ of \,foldsubfigno.ist,\ &ndash; Continued\">
<subchars>
<font inherit="0" size="1pt" width="ultcond" offset="1000pt">
<leading lead="1pt">
<quadding quad="right" lastquad="lright">
<highlt fontclr="white" forpct="0">
<presp minimum="0pt" nominal="0pt" maximum="0pt">
<postsp minimum="0" nominal="0" maximum="0" priority="high">
<float flidref="bot-invisible.flt" width="col" scope="subfig"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>
