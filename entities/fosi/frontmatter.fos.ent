<charsubset charsubsetref="own-line">
<presp minimum="5mm" nominal="5mm" maximum="5mm" condit="keep" priority="force">
<usetext source="\Page Number\,7pi,\*Change Number\,spcfill,\Page Number\,7pi,\*Change Number\">
<subchars charsubsetref="own-line"></subchars>
