<presp minimum="1pi" nominal="1pi" maximum="1pi"&gt;
<postsp minimum="2pi" nominal="2pi" maximum="2pi"&gt;
<textbrk startln="1" endln="1"&gt;</subchars&gt;
</usetext&gt;'>
<specval attname="delchlvl" attval="#NONE">
<specval attname="docstat" attloc="doc" attval="draft">
<specval attname="verstatus" attval="ver">
