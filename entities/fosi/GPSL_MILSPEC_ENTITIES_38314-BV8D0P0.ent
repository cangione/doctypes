<!ENTITY pagespec-flowtext-column-3col-lep '<!-- GPSL:RK Entity "pagespec-flowtext-column-3col-lep" -->
<column width="2.2in" topfloat="top-col.flt  topbot-invisible.flt" botfloat="bot-invisible.flt bot-col.flt topbot-invisible.flt">
<gutter width="0.2in">
'>
<!ENTITY LastSecurityPage '<!-- GPSL:RK Entity "LastSecurityPage" -->
<att>
<charsubset>
<usetext source="\ \" placemnt="after">
<subchars>
<textbrk startpg="recto" pageid="dummypg" newpgmdl="local" startln="1" endln="1">
</subchars>
</usetext>
</charsubset>
</att>
'>
<!ENTITY change-page-handler-header '<!-- GPSL:RK Entity "change-page-handler-header" -->
<usetext source="divinfo.txt[FB]">
</usetext>
<usetext source="<setfolio.psu>,</setfolio.psu>">
</usetext>
'>
<!ENTITY division-settings '<!-- GPSL:RK Entity "division-settings" -->'>
<!ENTITY division-settings-nofootprint '<!-- GPSL:RK Entity "division-settings-nofootprint" -->'>
<!ENTITY % page-test "IGNORE">
<!ENTITY security-mark '<!-- GPSL:RK Entity "security-mark" -->
<att logic="and">
<specval attname="security" attval="u">
<charsubset>
<savetext textid="secur.str" conrule="\(U) \,0.25em">
</charsubset>
</att>
<att logic="and">
<specval attname="security" attval="s">
<charsubset>
<savetext textid="secur.str" conrule="\(S) \,0.25em">
</charsubset>
</att>
<att logic="and">
<specval attname="security" attval="c">
<charsubset>
<savetext textid="secur.str" conrule="\(C) \,0.25em">
</charsubset>
</att>
<att logic="or">
<specval attname="security" attval="#NONE">
<specval attname="security" attval="n">
<charsubset>
<savetext textid="secur.str" conrule="\\">
</charsubset>
</att>
'>
<!ENTITY wcn-change '<!-- GPSL:RK Entity "wcn-change" -->
<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<usetext source="\ \">
<subchars>
<textbrk startln="1" endln="1">
</subchars>
</usetext>
</charsubset>
</att>
'>
<!ENTITY para0-sub3-change.front '<!-- GPSL:RK Entity "para0-sub3-change.front" -->
<!-- para0s/subparas in front are not saved to the toc -->
&set-deltypstr;
<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
<suppress sup="1">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<charsubset charsubsetref="delchlvl.front">
</charsubset>
</att>
<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
<charsubset charsubsetref="delstatus.front">
</charsubset>
</att>
'>
<!ENTITY label.yes-proc '<!-- GPSL:RK Entity "label.yes-proc" -->
<att logic="and">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<usetext source="label.txt,\.\,1em,secur.str">
<subchars>
<font style="sanserif">
<highlt scoring="0">
<textbrk startln="1">
</subchars>
</usetext>
</charsubset>
</att>
'>
<!ENTITY set-deltypstr '<!-- GPSL:RK Entity "set-deltypstr" -->
<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Deleted)\">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Reserved)\">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="na">
<specval attname="status" attval="notapp">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Not Applicable)\">
</charsubset>
</att>
'>
