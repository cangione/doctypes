<charlist inherit="0">
<quadding quad="right" lastquad="lright">
<span span="1">
<reset resetlist="subfig.ctr">
<enumerat increm="1" enumid="foldout.ctr">
<savetext textid="label.txt" conrule="\FO-\,foldout.ctr">
<reset resetlist="totalsubfig.ctr inilluslist.st">
<savetext textid="legend.txt" conrule="\\" placemnt="before">
<savetext textid="object.str" conrule="\FO\">
<savetext textid="figpages.tiv" conrule="oldsubfig.ctr" placemnt="after">
<savetext textid="subfig.total.tiv" conrule="subfig.ctr"
placemnt="after">
