<specval attname="resetpg" attloc="#FOSI" attval="#EQ#\no\">
<charsubset>
<enumerat increm="0" enumid="pageenum" setvalue="1">
<savetext textid="resetpg" conrule="\yes\"></charsubset>
</att>
<att>
<charsubset>
<savetext textid="tocmatter"
conrule="<toclinec>,<toctitle.fmt>,1.5em,code.txt,@6.5em,secur.str,scontent.txt,applicrefidtxt.txt,symbol.st,\INTRODUCTION\,econtent.txt,sssn.st,tocfill,</toctitle.fmt>,<tocnumx>,page.chap.txt,\-\,folio.txt[BO],</tocnumx>,</toclinec>"
append="1">
<savetext textid="tocmatter"
conrule="<toclinechappre>,</toclinechappre>" append="1"></charsubset>
</att>
<!--removed all deleted and inserted att tests. There are no attributes on fwdintro-->
