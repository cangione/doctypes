<e-i-c gi="LEPENTRY" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<postsp nominal="0">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="lepsingle" attloc="#FOSI" attval="FALSE">
<specval attname="lepchgnum" attloc="#FOSI" attval="#NONE">
<charsubset>
	<usetext source="lepfirst, \ - \, leplast, lepfill, \0\, 1pi">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="lepsingle" attloc="#FOSI" attval="FALSE">
<specval attname="lepstatus" attloc="#FOSI" attval="UNCHANGED">
<specval attname="lepchgnum" attloc="#FOSI" attval="#ANY">
<charsubset>
	<usetext source="lepfirst, \ - \, leplast, lepfill, lepchgnum, 1pi">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="lepsingle" attloc="#FOSI" attval="FALSE">
<specval attname="lepstatus" attloc="#FOSI" attval="CHANGED">
<specval attname="lepchgnum" attloc="#FOSI" attval="#ANY">
<charsubset>
	<usetext source="lepfirst, \ - \, leplast, lepfill, lepchgnum, 1pi">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="lepsingle" attloc="#FOSI" attval="FALSE">
<specval attname="lepstatus" attloc="#FOSI" attval="ADDED">
<specval attname="lepchgnum" attloc="#FOSI" attval="#ANY">
<charsubset>
	<usetext source="lepfirst, \ - \, leplast, \ Added\, lepfill, lepchgnum, 1pi">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="lepsingle" attloc="#FOSI" attval="FALSE">
<specval attname="lepstatus" attloc="#FOSI" attval="DELETED">
