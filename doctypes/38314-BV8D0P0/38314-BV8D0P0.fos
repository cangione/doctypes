<charsubset>
<savetext textid="tctotbl-body.txt"
conrule='!<row><entry colsep="0">!,tctotbl-tctono.txt,!</entry><entry colsep="0">!,tctotbl-title.txt,!</entry><entry colsep="0">!,tctotbl-date.txt,!</entry></row>!'
placemnt="after" append="1"></charsubset>
