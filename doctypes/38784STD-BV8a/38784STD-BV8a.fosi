<charsubset>
	<keeps keep="0" next="0" prev="0">
	<span span="1">
	<usetext source="<index.ps>,index-secur.str,\INDEX\,</index.ps>,<indp.ps>,\Paragraph and\,</indp.ps>,\Subject\,spfill,\Page Numbers  \" placemnt="before">
	<subchars>
	<keeps prev="1">
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>

