<?xml version="1.0"?>
<xs:schema 	xmlns:xs="http://www.w3.org/2001/XMLSchema" 		
		xmlns:xlink="http://www.w3.org/1999/xlink"
           	elementFormDefault="qualified"
           	attributeFormDefault="qualified">

<!--**********************************************************************
    *                                                                    *
    *                        S1000D Issue 2                              *
    *                   Document Type Definition                         *
    *                                                                    *
    *                     Release Version 2.0                            *
    *                       Date: 2003-05-31                             *
    *                                                                    *
    * Amendment:-                                                        *
    * 1. Update public identifier.                                       *
    * 2. CPF 2002-06F: Change content models of supequi, supply and      *
    *                  spare. Entity %NIC; redefined and renamed to %NI;.*
    * 3. XML Extension: Import XLINK Definitions (see XLINK.XSD).        * 
    *                                                                    *
    * Typical invocation:-                                               *
    * <!ENTITY % PRELREQ PUBLIC                                          *
    *   "-//S1000D//ELEMENTS Preliminary Requirements 20030531//EN" >    *
    * %PRELREQ;                                                          *
    ********************************************************************** -->


<!--**********************************************************************
    * Call the XLINK Definition Public Text. The formal public           *
    * identifier is stored in the entity %EXTXLINK;                      *
    ********************************************************************** -->
<!-- %EXTXLINK; -->
	<xs:import 	namespace="http://www.w3.org/1999/xlink" 
			schemaLocation="xlink.xsd"/>

<!--**********************************************************************
    * Call the Product Management Data Public Text.                      *
    * The formal public identifier is stored in entity %PMDATA;          *
    ********************************************************************** -->
<!-- %PMDATA; -->
	<xs:include schemaLocation="pmdata.xsd" />

<!--**********************************************************************
    * Call the NOMEN and IDENTNO Public Text.                            *
    * The formal public identifier is stored in entity %NI;              *
    ********************************************************************** -->
<!-- %NI; -->
	<xs:include schemaLocation="ni.xsd"/>


	<xs:element name="prelreqs">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element prelreqs (Preliminary Requirements) containing:-    *
    *  pmd      - Optional   Single      contains thi, zone, accpnl,     *
    *                                     avehcfg, opndurn.              *
    *  reqconds - Mandatory  Single      contains noconds, reqcond,      *
    *                                     reqcondm, reqcontp.            *
    *  reqpers  - Optional   Single      contains asrequir, person,      *
    *                                     perscat, perskill, trade,      *
    *                                     esttime.                       *
    *  supequip - Mandatory  Single      contains nosupeq, supeqli.      *
    *  supplies - Mandatory  Single      contains nosupply, supply.      *
    *  spares   - Mandatory  Single      contains nospares, sparesli.    *
    *  safety   - Mandatory  Single      contains nosafety, safecond.    *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="pmd" minOccurs="0"/>
				<xs:element ref="reqconds"/>
				<xs:element ref="reqpers" minOccurs="0"/>
				<xs:element ref="supequip"/>
				<xs:element ref="supplies"/>
				<xs:element ref="spares"/>
				<xs:element ref="safety"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="reqconds">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element reqconds (Required Conditions) containing:-         *
    *  noconds  - Mandatory  Single      contains No Other Tags.         *
    * or                                                                 *
    *====================================================================*
    * Mandatory Repeatable Group                                         *
    *====================================================================*
    *  reqcond  - Mandatory  Single      contains applic and Definition  *
    *                                     stored in entity %text;        *
    * or                                                                 *
    *  reqcondm - Mandatory  Single      contains applic, reqcond, reqdm.*
    * or                                                                 *
    *  reqcontp - Mandatory  Single      contains applic, reqcond, reqtp.*
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:choice>
				<xs:element ref="noconds"/>
				<xs:choice maxOccurs="unbounded">
					<xs:element ref="reqcond"/>
					<xs:element ref="reqcondm"/>
					<xs:element ref="reqcontp"/>
				</xs:choice>
			</xs:choice>
		</xs:complexType>
	</xs:element>

	<xs:element name="noconds">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element noconds (No Required Conditions) containing:-       *
    *   No Other Tags.                                                   *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType/>
	</xs:element>

	<xs:element name="reqcondm">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element reqcondm (Required Condition Data Modules)          *
    * containing:-                                                       *
    *  applic    - Optional  Single     contains type, model.            *
    *====================================================================*
    * Mandatory Repeatable Group                                         *
    *====================================================================*
    *  reqcond   - Mandatory Single     contains Definition stored in    *
    *                                   entity %text;                    *
    *  reqdm     - Mandatory Single     contains Definition stored in    *
    *                                   entity %ALLDMC;, issno, dmtitle  *
    *                                   or Definition stored in entity   *
    *                                   %XLINKEXT;                       *
    *====================================================================*
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="applic" minOccurs="0"/>
				<xs:sequence maxOccurs="unbounded">
					<xs:element ref="reqcond"/>
					<xs:element ref="reqdm"/>
				</xs:sequence>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="reqcond">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element reqcond (Required Condition) containing:-           *
    *  applic    - Optional  Single     contains type, model.            *
    *====================================================================*
    * Mandatory Repeatable Group.                                        *
    *====================================================================*
    *  Definition stored in entity %text;                                *
    *====================================================================*
    **********************************************************************
    * EXCLUSION: refdm, reftp.                                           *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType mixed="true">
			<xs:sequence minOccurs="0">
				<xs:element ref="applic" minOccurs="0"/>
				<xs:group ref="text"  minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="reqdm">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element reqdm (Required Data Module) containing:-           *
    *====================================================================*
    * Mandatory Single Group.                                            *
    *====================================================================*
    *  Definition stored in entity %ALLDMC;                              *
    *  issno    - Optional   Single      contains No Other Tags.         *
    *  dmtitle  - Optional   Single      contains techname, infoname.    *
    *====================================================================*
    * or                                                                 *
    *  Definition stored in entity %XLINKEXT;.                           *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  target  - CDATA   - IMPLIED - Cross reference ID within target DM *
    *  Attribute Definition list stored in entity %bodyatt;              *
    *  Attribute Definition List stored in entity %XLINKATT;             *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:choice>
				<xs:sequence>
					<xs:group ref="ALLDMC"/>
					<xs:element ref="issno" minOccurs="0"/>
					<xs:element ref="dmtitle" minOccurs="0"/>
				</xs:sequence>
				<xs:group ref="xlink:XLINKEXT" minOccurs="0" maxOccurs="unbounded"/>
			</xs:choice>
			<xs:attribute name="target" type="xs:string"/>
			<xs:attributeGroup ref="bodyatt"/>
			<xs:attributeGroup ref="xlink:XLINKATT"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="reqcontp">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element reqcontp (Required Condition Technical              *
    *                          Publications)                             *
    * containing:-                                                       *
    *  applic    - Optional  Single     contains type, model.            *
    *====================================================================*
    * Mandatory Repeatable Group.                                        *
    *====================================================================*
    *  reqcond   - Mandatory Single     contains Definition stored in    *
    *                                   entity %text;                    *
    *  reqtp     - Mandatory Single     contains Definition stored in    *
    *                                   entity %text;                    *
    *====================================================================*
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="applic" minOccurs="0"/>
				<xs:sequence maxOccurs="unbounded">
					<xs:element ref="reqcond"/>
					<xs:element ref="reqtp"/>
				</xs:sequence>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="reqtp">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element reqtp (Required Technical Publication)              *
    * containing:-                                                       *
    *====================================================================*
    * Mandatory Repeatable Group.                                        *
    *====================================================================*
    *  Definition stored in entity %text;                                *
    *====================================================================*
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
    * EXCLUSION: refdm, reftp.                                           *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType mixed="true">
			<xs:sequence minOccurs="0">
				<xs:group ref="text" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attributeGroup ref="bodyatt"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="reqpers">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element reqpers (Required Persons) containing:-             *
    *====================================================================*
    * Mandatory Repeatable Group.                                        *
    *====================================================================*
    *++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*
    *  asrequir  - Mandatory Single     contains No Other Tags.          *
    * or                                                                 *
    *  person    - Mandatory Single     contains No Other Tags.          *
    *++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++*
    *====================================================================*
    * Optional Single Group                                              *
    *====================================================================*
    *  perscat   - Mandatory Single     contains No Other Tags.          *
    *  perskill  - Optional  Single     contains No Other Tags.          *
    *  trade     - Optional  Single     contains Parsed Character Data.  *
    *  esttime   - Optional  Single     contains Parsed Character Data.  *
    *====================================================================*
    *====================================================================*
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence maxOccurs="unbounded">
				<xs:choice>
					<xs:element ref="asrequir"/>
					<xs:element ref="person"/>
				</xs:choice>
				<xs:sequence minOccurs="0">
					<xs:element ref="perscat"/>
					<xs:element ref="perskill" minOccurs="0"/>
					<xs:element ref="trade" minOccurs="0"/>
					<xs:element ref="esttime" minOccurs="0"/>
				</xs:sequence>
			</xs:sequence>
			<xs:attributeGroup ref="bodyatt"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="asrequir">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element asrequir (As Required) containing:-                 *
    *  No Other Tags.                                                    *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType/>
	</xs:element>

	<xs:element name="person">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element person (Personnel) containing:-                     *
    *  No Other Tags.                                                    *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  man      - NMTOKEN  - REQUIRED - Man identifier.                  *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:attribute name="man" type="xs:NMTOKEN" use="required"/>
			<xs:attributeGroup ref="bodyatt"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="perscat">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element perscat (Personnel Category) containing:-           *
    *  No Other Tags.                                                    *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  category - Declared - REQUIRED - Personnel category of required   *
    *                                   trade to complete the task.      *
    *             Definition stored in entity %CATEG;                    *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:attribute name="category" type="CATEG" use="required"/>
			<xs:attributeGroup ref="bodyatt"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="perskill">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element perskill (Personnel Skill Level) containing:-       *
    *  No Other Tags.                                                    *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  skill    - Declared - REQUIRED - Personnel skill level            *
    *             Definition stored in entity %SKILL;                    *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:attribute name="skill" type="SKILL" use="required"/>
			<xs:attributeGroup ref="bodyatt"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="trade">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element trade (Personnel Trade Code) containing:-           *
    *  Parsed Character Data.                                            *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attributeGroup ref="bodyatt"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>

	<xs:element name="esttime">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element esttime (Estimated Time Spent) containing:-         *
    *  Parsed Character Data.                                            *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attributeGroup ref="bodyatt"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>

	<xs:element name="supequip">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element supequip (Support Equipment) containing:-           *
    *  nosupeq  - Mandatory Single       contains No Other Tags.         *
    * or                                                                 *
    *  supeqli  - Mandatory Single       contains supequi.               *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:choice>
				<xs:element ref="nosupeq"/>
				<xs:element ref="supeqli"/>
			</xs:choice>
		</xs:complexType>
	</xs:element>

	<xs:element name="nosupeq">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element nosupeq (No Support Equipment) containing:-         *
    *  No Other Tags.                                                    *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType/>
	</xs:element>

	<xs:element name="supeqli">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element supeqli (Support Equipment List) containing:-       *
    *  supequi  - Mandatory Repeatable   contains applic, nomen, nsn,    *
    *                                    identno, csnref, qty.           *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="supequi" maxOccurs="unbounded"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="supequi">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element supequi (Support Equipment Item) containing:-       *
    *  applic   - Optional   Single      contains type, model.           *
    *  nomen    - Mandatory Single       contains Parsed Character Data. *
    *====================================================================*
    *  Mandatory Repeatable Group                                        *
    *====================================================================*
    *  csnref   - Mandatory Single       contains No Other Tags.         *
    * or                                                                 *
    *  nsn      - Mandatory Single       contains No Other Tags.         *
    * or                                                                 *
    *  identno  - Mandatory Single       contains mfc, pnr, serialno.    *
    *====================================================================*
    *  qty      - Mandatory Single       contains Parsed Character Data. *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="applic" minOccurs="0"/>
				<xs:element ref="nomen"/>
				<xs:choice maxOccurs="unbounded">
					<xs:element ref="csnref"/>
					<xs:element ref="nsn" minOccurs="0"/>
					<xs:element ref="identno"/>
				</xs:choice>
				<xs:element ref="qty"/>
			</xs:sequence>
			<xs:attributeGroup ref="bodyatt"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="qty">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element qty (Quantity) containing:-                         *
    *   Parsed Character Data.                                           *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  uom    - CDATA  - IMPLIED - Unit of measurement.                  *
    *  Attribute Definition list stored in entity %INSDEL;               *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="xs:string">
					<xs:attribute name="uom" type="xs:string"/>
					<xs:attributeGroup ref="INSDEL"/>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>

	<xs:element name="supplies">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element supplies (Supplies) containing:-                    *
    *  nosupply - Mandatory  Single      contains No Other Tags.         *
    * or                                                                 *
    *  supplyli - Mandatory  Single      contains supply.                *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:choice>
				<xs:element ref="nosupply"/>
				<xs:element ref="supplyli"/>
			</xs:choice>
		</xs:complexType>
	</xs:element>

	<xs:element name="nosupply">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element nosupply (No Supplies) containing:-                 *
    *  No Other Tags.                                                    *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType/>
	</xs:element>

	<xs:element name="supplyli">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element supplyli (Supply List) containing:-                 *
    *  supply   - Mandatory Repeatable   contains applic, nomen, nsn,    *
    *                                    identno, csnref, qty.           *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="supply" maxOccurs="unbounded"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="supply">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element supply (Supply Item) containing:-                   *
    *  applic   - Optional  Single       contains type, model.           *
    *  nomen    - Mandatory Single       contains Parsed Character Data. *
    *====================================================================*
    *  Mandatory Repeatable Group                                        *
    *====================================================================*
    *  csnref   - Mandatory Single       contains No Other Tags.         *
    * or                                                                 *
    *  nsn      - Mandatory Single       contains No Other Tags.         *
    * or                                                                 *
    *  identno  - Mandatory Single       contains mfc, pnr, serialno.    *
    *====================================================================*
    *  qty      - Mandatory  Single      contains Parsed Character Data. *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute Definition list stored in entity %bodyatt;              *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="applic" minOccurs="0"/>
				<xs:element ref="nomen"/>
				<xs:choice maxOccurs="unbounded">
					<xs:element ref="csnref"/>
					<xs:element ref="nsn" minOccurs="0"/>
					<xs:element ref="identno"/>
				</xs:choice>
				<xs:element ref="qty"/>
			</xs:sequence>
			<xs:attributeGroup ref="bodyatt"/>
		</xs:complexType>
	</xs:element>

	<xs:element name="spares">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element spares (Spares) containing:-                        *
    *  nospares - Mandatory  Single      contains No Other Tags.         *
    * or                                                                 *
    *  sparesli - Mandatory  Single      contains spare.                 *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:choice>
				<xs:element ref="nospares"/>
				<xs:element ref="sparesli"/>
			</xs:choice>
		</xs:complexType>
	</xs:element>

	<xs:element name="nospares">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element nospares (No Spares) containing:-                   *
    *  No Other Tags.                                                    *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType/>
	</xs:element>

	<xs:element name="sparesli">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element sparesli (Spare List) containing:-                  *
    *  spare    - Mandatory Repeatable   contains applic, nomen, nsn,    *
    *                                    identno, csnref, qty.           *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="spare" maxOccurs="unbounded"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>

	<xs:element name="spare">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element spare (Spare Item) containing:-                     *
    *  applic   - Optional   Single      contains type, model.           *
    *  nomen    - Mandatory Single       contains Parsed Character Data. *
    *====================================================================*
    *  Mandatory Repeatable Group                                        *
    *====================================================================*
    *  csnref   - Mandatory Single       contains No Other Tags.         *
    * or                                                                 *
    *  nsn      - Mandatory Single       contains No Other Tags.         *
    * or                                                                 *
    *  identno  - Mandatory Single       contains mfc, pnr, serialno.    *
    *====================================================================*
    *  qty      - Mandatory  Single      contains Parsed Character Data. *
