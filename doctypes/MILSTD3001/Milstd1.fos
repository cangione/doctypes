<!--Alert-->
<e-i-c gi="warning" context="* testproc">
<charlist inherit="0" charsubsetref="paragraph space">
<savetext textid="nobrk.txt" conrule="!!" placemnt="before" append="0">
<reset resetlist="warningtxt row.app pparatxt reftxt tabletxt">
</charlist>
<att>
<specval attname="warning-type" attloc="warning" attval="not-hazmat">
<charsubset>
<savetext textid="table.app"
conrule='!<row rowsep="0">!,row.app,!</row>!' placemnt="after"
append="1"></charsubset>
</att>
<att>
<specval attname="warning-type" attloc="warning" attval="hazmat">
<charsubset>
<savetext textid="tabletxt"
conrule="<ppara-noindent>,#CONTENT,</ppara-noindent>" append="1">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3">!,tabletxt,!</entry>!' append="1">
<savetext textid="table.app"
conrule='!<row rowsep="0">!,row.app,!</row>!' placemnt="after"
append="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="warning * testproc" occur="only">
<charlist inherit="1">
<suppress sup="1"></charlist>
<att>
<specval attname="warning-type" attloc="warning" attval="not-hazmat">
<charsubset>
<savetext textid="warningtxt" conrule="<dblline>,\WARNING\,</dblline>">
<savetext textid="tabletxt"
conrule="<pnote>,warningtxt,</pnote>,<ppara4b>,#CONTENT,</ppara4b>"
append="1">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3">!,tabletxt,!</entry>!' append="1">
<reset resetlist="pparatxt reftxt tabletxt"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="warning * testproc" occur="first">
<charlist inherit="1">
<suppress sup="1">
<savetext textid="warningtxt" conrule="<dblline>,\WARNING\,</dblline>">
<savetext textid="tabletxt"
conrule="<pnote>,warningtxt,</pnote>,<ppara4b>,#CONTENT,</ppara4b>"
append="1"></charlist>
</e-i-c>
<e-i-c gi="para" context="warning * testproc" occur="notfirst">
<charlist inherit="1">
<suppress sup="1">
<savetext textid="tabletxt" conrule="<ppara4b>,#CONTENT,</ppara4b>"
append="1"></charlist>
</e-i-c>
<e-i-c gi="para" context="warning * testproc" occur="last">
<charlist inherit="1">
<suppress sup="1">
<savetext textid="tabletxt" conrule="<ppara4b>,#CONTENT,</ppara4b>"
append="1">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3">!,tabletxt,!</entry>!' append="1">
<reset resetlist="pparatxt reftxt tabletxt"></charlist>
</e-i-c>
<e-i-c gi="caution" context="* testproc">
