<!--Notes List-->
<e-i-c gi="noteslist" context="chghist"><?Pub Dtl>
<charlist inherit="1">
<span span="1">
<reset resetlist="outline.lev1.ct">
<usetext source="\NOTES\">
<subchars charsubsetref="titlefont">
<quadding quad="center" lastquad="lcenter">
<presp minimum="4pt" nominal="6pt" maximum="12pt" priority="force">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charlist>
<att>
