	  <xs:include schemaLocation="../basicDataTypes/text.xsd"/>
	  <!--=============================================-->
	<!--  common approval data used in Approval and SubSetHeader -->
	<!--=============================================-->
	<xs:element name="approvedBy" type="approvedByType">
		    <xs:annotation>
			      <xs:documentation>gives the details of approval responsible</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="approvedByType">
		    <xs:sequence>
			      <xs:element name="name" type="nameType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Name of the approver</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="jobTitle" type="nameType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Job title of the approver</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="department" type="nameType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Department of the approver</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="approvalComment" type="nameType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Comment given by the approver if any.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="signature" type="signatureType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>graphic (scan) of the signature</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
	  </xs:complexType>
	  <xs:complexType name="signatureType">
		    <xs:choice>
			      <xs:element ref="figure"/>
			      <xs:element ref="multimedia"/>
		    </xs:choice>
	  </xs:complexType>
	  <xs:complexType name="approvalCommentType">
		    <xs:sequence>
			      <xs:element name="para" type="paraType" maxOccurs="unbounded">
				        <xs:annotation>
					          <xs:documentation>General purpose container for textual information and structured data.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
	  </xs:complexType>
</xs:schema>