<hyphen hyph="0">
<indent inherit="1" leftind="@+5.0em" rightind="@" firstln="*-2.75em">
<highlt allcap="1">
<postsp minimum="1.2em" nominal="1.2em" maximum="1.5em" condit="discard"
priority="med">
<keeps next="1" prev="1"></charlist>
</e-i-c>
<e-i-c gi="qeckentry" context="qecklist" occur="all"><?Pub Dtl>
