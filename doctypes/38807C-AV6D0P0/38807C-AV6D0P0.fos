conrule="<toclinecfig>,<toctitle.fmt>,label.txt,@3em,secur.str,deltypestr,</toctitle.fmt>,</toclinecfig>"
append="1"></charsubset>
</att>
<att>
<specval attname="name" attval="ftnote">
<fillval attname="label" fillcat="savetext" fillchar="conrule">
<charsubset>
<savetext textid="label.txt">
<usetext source="<ftnote.psu>,contentcbar.txt,\(Deleted)\,</ftnote.psu>">
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attloc="ipbplgrp" attval="#ANY">
<specval attname="name" attval="partno">
<charsubset>
