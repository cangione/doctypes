<!ENTITY TaskCard.KeepNext "<specval attname='print-only' attloc='system-var' attval='#ANY'>
<specval attname='card.change.status.att' attloc='#FOSI' attval='#NE#\delete\'>
  <charsubset>
    <suppress sup='1'>
