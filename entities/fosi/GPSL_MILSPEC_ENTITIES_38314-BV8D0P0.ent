<!ENTITY att-save-symbols '<!-- GPSL:RK Entity "att-save-symbols" -->
<!-- saves the symbols (esds, nsp, fcp, hcp, hci, ocp, oci) to symbol.st also replaces other text entities such as esds-proc and hcp-proc -->
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="nsp" attval="#GT#0">
<charsubset>
<savetext textid="symbol.st" conrule="<nsp.ps>,</nsp.ps>">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="hci" attval="#GT#0">
<charsubset>
<savetext textid="symbol.st" conrule="<hci.ps>,</hci.ps>" append="1">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="hcp" attval="#GT#0">
<charsubset>
<savetext textid="symbol.st" conrule="<hcp.ps>,</hcp.ps>" append="1">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="esds" attval="#GT#0">
<charsubset>
<savetext textid="symbol.st" conrule="<esds.ps>,</esds.ps>" append="1">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="fcp" attval="#GT#0">
<charsubset>
<savetext textid="symbol.st" conrule="<fcp.ps>,</fcp.ps>" append="1">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="oci" attval="#GT#0">
<charsubset>
<savetext textid="symbol.st" conrule="<oci.ps>,</oci.ps>" append="1">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="ocp" attval="#GT#0">
<charsubset>
<savetext textid="symbol.st" conrule="<ocp.ps>,</ocp.ps>" append="1">
</charsubset>
</att>
'>
