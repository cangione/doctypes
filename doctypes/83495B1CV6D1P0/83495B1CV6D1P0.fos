<savetext textid="resetpg" conrule="\no\" placemnt="after"></charsubset>
</att>
<att logic="and">
<specval attname="pagesize" attloc="docjg" attval="8.5x11">
<charsubset charsubsetref=" reset-folios foliostyle-rl">
<textbrk startpg="next" pageid="FRONTPG" newpgmdl="global">
<span span="2">
<savetext textid="dot.st" conrule="\.\">
<savetext textid="tocmatter"
conrule="<toclinea>,1.5em,\PREFACE\,tocfill,<tocnumchap>,folio.txt[BO],</tocnumchap>,</toclinea>"
append="1"></charsubset>
</att>
<att logic="and">
<specval attname="pagesize" attloc="docjg" attval="8.5x11">
<specval attname="resetpg" attloc="#FOSI" attval="#EQ#\no\">
<charsubset charsubsetref="foliostyle-rl">
<enumerat increm="0" enumid="pageenum" setvalue="1">
<savetext textid="resetpg" conrule="\yes\"></charsubset>
</att>
<att logic="and">
<specval attname="pagesize" attloc="docjg" attval="8.5x11">
<specval attname="numcols" attloc="front" attval="#NONE">
<charsubset charsubsetref=" reset-folios foliostyle-rl">
<textbrk startpg="recto" pageid="frontpg" newpgmdl="global" startln="1"
endln="1">
<span span="2"></charsubset>
</att>
<att logic="and">
<specval attname="pagesize" attloc="docjg" attval="8.5x11">
<specval attname="numcols" attloc="front" attval="#ANY">
<specval attname="numcols" attloc="front" attval="#EQ#\1\">
