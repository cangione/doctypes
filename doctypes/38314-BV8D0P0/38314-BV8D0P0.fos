placemnt="before" append="1">
<savetext textid="vsmatter-vol.tiv"
conrule="!<row>!,vsmatter1.tdv,vsmatter2.tdv,vsmatter3.tdv,vsmatter4.tdv,!</row>!"
placemnt="before" append="1"></charsubset>
