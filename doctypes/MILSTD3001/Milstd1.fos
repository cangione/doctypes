align="left" colwidth="9pi"/><spanspec spanname="span1to3" namest="col1" nameend="col3"/><thead><row><entry><bold>Nomenclature</bold></entry><entry><bold>Part Number</bold></entry><entry><bold>CAGE Code</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="\Facilities Required (Cont)\">
<subchars charsubsetref="title.cont">
<float scope="faclist"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="table" context="faclist"><?Pub Dtl>
<charlist envname="tableenv"></charlist>
</e-i-c>
<e-i-c gi="facentry"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph space">
<savetext textid="table.app"
conrule='!<row>!,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">
<reset resetlist="serestricttxt row.app col1.app col2.app col3.app">
</charlist>
</e-i-c>
<e-i-c gi="cage" context="* facentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col3.app" conrule="#CONTENT" append="1"></charlist>
</e-i-c>
<e-i-c gi="partno" context="* facentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1"></charlist>
<att>
<specval attname="alternate" attloc="partno" attval="alternate-app">
<charsubset><?Pub Dtl>
<savetext textid="col2.app" conrule="<ppara>,1em,#CONTENT,</ppara>"
append="1"></charsubset>
</att>
<att>
<specval attname="alternate" attloc="partno" attval="alternate-notapp">
<charsubset><?Pub Dtl>
<savetext textid="col2.app" conrule="<ppara>,#CONTENT,</ppara>"
append="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="nomen" context="* facentry" occur="all"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col1.app" conrule="<ppara1>,#CONTENT,</ppara1>"
append="1"></charlist>
</e-i-c>
<e-i-c gi="noteslist" context="faclist"><?Pub Dtl>
<charlist inherit="1">
<reset resetlist="row.app outline.lev1.ct notestxt"></charlist>
</e-i-c>
<e-i-c gi="notesentry" context="noteslist * faclist" occur="first"><?Pub Dtl>
<charlist>
<suppress sup="1">
<enumerat increm="1" enumid="outline.lev1.ct">
<savetext textid="tableftnotenum" conrule="outline.lev1.ct">
<savetext textid="notestxt"
conrule="<pnote>,\NOTES\,</pnote>,<ppara>,outline.lev1.ct,\. \,#CONTENT,</ppara>">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3" align="left">!,notestxt,!</entry>!'>
<savetext textid="table.app" conrule="!<row>!,row.app,!</row>!"
placemnt="after" append="1"></charlist>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tableftnotenum"></charsubset>
</att>
</e-i-c>
<e-i-c gi="notesentry" context="noteslist * faclist" occur="notfirst"><?Pub Dtl>
<charlist>
<suppress sup="1">
<enumerat increm="1" enumid="outline.lev1.ct">
<savetext textid="tableftnotenum" conrule="outline.lev1.ct">
<savetext textid="notestxt"
conrule="<ppara>,outline.lev1.ct,\. \,#CONTENT,</ppara>">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3" align="left">!,notestxt,!</entry>!'>
<savetext textid="table.app" conrule="!<row>!,row.app,!</row>!"
placemnt="after" append="1"></charlist>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tableftnotenum"></charsubset>
</att>
</e-i-c>
