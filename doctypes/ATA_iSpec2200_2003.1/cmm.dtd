<!-- DOCTYPE cmm [   -->
<!-- The following set of declarations may be referred to
     using the public entity as follows:
<!DOCTYPE cmm PUBLIC
  "-//ATA-TEXT//DTD CMM-VER17-LEVEL2//EN"[ ]>                  -->

<!-- ========================================================= -->
<!--          NOTATIONS                                        -->
<!-- ========================================================= -->

<!NOTATION cgm PUBLIC
"-//USA-DOD//NOTATION Computer Graphics Metafile//EN"            >

<!NOTATION ccitt4 PUBLIC
"-//USA-DOD//NOTATION CCITT Group4 Facsimile//EN"                >

<!NOTATION gcf PUBLIC
"-//ATA-TEXT//NOTATION Graphic Companion File//EN"               >

<!NOTATION pdf PUBLIC
"-//Adobe Inc.//NOTATION Portable Document Format//EN"           >

<!NOTATION png PUBLIC
"-//W3C//NOTATION Portable Network Graphics//EN"                 >

<!NOTATION jpeg PUBLIC
"+//ISBN 0-7923-9432-1::Graphic Notation//NOTATION Joint
Photographic Experts Group Raster//EN"                           >

<!NOTATION vrml PUBLIC
  "-//ATA-TEXT//NOTATION Virtual Reality Modeling Language//EN"  >

<!NOTATION mpeg PUBLIC
"-//ATA-TEXT//NOTATION Motion Pictures Expert Group//EN"         >

<!NOTATION mp3 PUBLIC
"-//ATA-TEXT//NOTATION Motion Pictures Expert Group, Audio
Layer 3//EN"                                                     >

<!-- ========================================================= -->
<!--                      ENTITIES                             -->
<!-- ========================================================= -->

<!ENTITY % g.r      "(refblock* | (grphcref*, refext*, refint*))">
<!ENTITY % w.c      "(warning*, caution*)"                       >
<!ENTITY % text     "(para | table | unlist | numlist | note
                     | deflist)+"                                >
<!ENTITY % deleted  "(deleted, chgdesc?)"                        >
<!ENTITY % revatt
           "chg      (N|R|U|D)                     #REQUIRED
            key      ID                            #REQUIRED
            revdate  NUMBER                        #REQUIRED"    >
<!ENTITY  % yesorno  "NUMBER"                                    >

<!ENTITY   % ISOtech      PUBLIC
     "ISO 8879-1986//ENTITIES   General Technical//EN"           >
<!ENTITY   % ISOpub      PUBLIC
     "ISO 8879-1986//ENTITIES Publishing//EN"                    >
<!ENTITY   % ISOnum      PUBLIC
   "ISO 8879-1986//ENTITIES   Numeric and Special Graphic//EN"   >
<!ENTITY   % ISOgrk1     PUBLIC
     "ISO 8879-1986//ENTITIES   Greek Letters//EN"               >
<!ENTITY   % ISOgrk2     PUBLIC
     "ISO 8879-1986//ENTITIES Monotoniko Greek//EN"              >
<!ENTITY   % ISOgrk3     PUBLIC
     "ISO 8879-1986//ENTITIES Greek Symbols//EN"                 >
<!ENTITY   % ISOgrk4     PUBLIC
     "ISO 8879-1986//ENTITIES Alternative Greek Symbols//EN"     >
<!ENTITY   % ISOlat1     PUBLIC
     "ISO 8879-1986//ENTITIES Added Latin 1//EN"                 >
<!ENTITY   % ISObox      PUBLIC
     "ISO 8879-1986//ENTITIES Box and Line Drawing//EN"          >
<!ENTITY   % ISOamso     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Ordinary//EN"  >
<!ENTITY   % ISOamsc     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Delimiters//EN">

%ISOtech; %ISOpub; %ISOnum; %ISOgrk1; %ISOgrk2; %ISOgrk3;
%ISOgrk4; %ISOlat1; %ISObox; %ISOamso; %ISOamsc;

<!-- ========================================================= -->
<!--       CMM TOP LEVEL STRUCTURE                             -->
<!-- ========================================================= -->

<!ELEMENT cmm       - - ((title, partinfo+, legalntc?, mfmatr,
                        pgblk+, ipl) | increv | tr+)
                        +(revst, revend, hotlink)                >
<!ATTLIST cmm
          spl       CDATA                            #REQUIRED
          oidate    NUMBER                           #REQUIRED
          tsn       CDATA                            #REQUIRED
          docnbr    CDATA                            #IMPLIED
          lang      CDATA                            #REQUIRED
          chapnbr   NUMBER                           #REQUIRED
          sectnbr   NUMBER                           #REQUIRED
          subjnbr   NUMBER                           #REQUIRED
          type      (cmm, acmm)                      "cmm"
          prelim    NUMBER                           "0"
          chg       (N | R | S | U)                  "N"
          revdate   NUMBER                           #REQUIRED
          efflen    NUMBER                           #IMPLIED
          efftype   CDATA                            #IMPLIED    >

<!ELEMENT increv    - - (legalntc?, (pgblk | ipl | task | subtask
                        | transltr | sblist | sheet | graphic
                        | figure | prtlist | hazmtlst)+)         >

<!ELEMENT tr        - - (legalntc?, trfmatr, trlist?, (legalntc 
                        | pgblk+ | task+ | sheet+ | graphic+
                        | sblist | figure | prtlist | hazmtlst)) >

<!ELEMENT trfmatr   - - (title, (%text;))                        >
<!ATTLIST trfmatr
          trnbr     CDATA                            #REQUIRED
          issdate   NUMBER                           #REQUIRED
          trdel     CDATA                            #IMPLIED
          trrepl    CDATA                            #IMPLIED    >

<!-- ========================================================= -->
<!--       Legal Notice Information                            -->
<!-- ========================================================= -->

<!ELEMENT legalntc  - - (exprtcl | cpyrght | proptary | geninfo)+>
<!ATTLIST legalntc
          %revatt;                                               >

<!ELEMENT proptary  - - (fullstmt, partstmt?)                    >
<!ELEMENT fullstmt  - - (title?, cpyrght?, para+)                >
<!ELEMENT partstmt  - - (title?, para+)                          >
<!ELEMENT exprtcl   - - (para | unlist | numlist | note)+        >
<!ELEMENT cpyrght   - - (year*, holder*, geninfo)                >
<!ELEMENT year      - - (#PCDATA)                                >
<!ELEMENT holder    - - (#PCDATA)                                >
<!ELEMENT geninfo   - - (para | unlist | numlist | note)+        >

<!-- ========================================================= -->
<!--         Part Information                                  -->
<!-- ========================================================= -->
<!ELEMENT partinfo  - - (title?, regulatory*,(cmpnom?, mfrpnr)+) >
<!ATTLIST partinfo
          model     CDATA                            #IMPLIED    >

<!ELEMENT cmpnom    - - (#PCDATA | sub | super)*                 >
<!ELEMENT mfrpnr    - - (pnr, mfr, altpnr*)                      >
<!ELEMENT pnr       - - (#PCDATA)                                >
<!ELEMENT mfr       - - (#PCDATA)                                >
<!ELEMENT altpnr    - - (pnr, mfr)                               >

<!-- ========================================================= -->
<!--       CMM FRONT MATTER                                    -->
<!-- ========================================================= -->

<!ELEMENT mfmatr    - - (transltr?, trlist?, sblist, hazmtlst?)  >
<!ELEMENT transltr  - - (chgdesc*, title, (prclist1 | %text;))   >

<!ELEMENT trlist    - - (title, (%text;)*, (trdata+ | isempty))  >
<!ATTLIST trlist
          %revatt;                                               >
<!ELEMENT trdata    - - (trnbr, trstatus, trloc+)                >
<!ELEMENT trnbr     - - (#PCDATA)                                >
<!ELEMENT trstatus  - - (#PCDATA)                                >
<!ELEMENT trloc     - - (#PCDATA)                                >

<!ELEMENT sblist    - - (chgdesc*, title, (%text;)?,
                        (sbdata+ | isempty))                     >
<!ATTLIST sblist
          %revatt;                                               >
<!ELEMENT sbdata    - - (effect?, sbnbr, sbtitle?, mdnbr*,
                        issdate?, sbrev?, ics?)                  >

<!ELEMENT sbnbr     - - (#PCDATA)                                >
<!ELEMENT sbtitle   - - (#PCDATA)                                >
<!ELEMENT mdnbr     - - (#PCDATA)                                >
<!ELEMENT issdate   - - (#PCDATA)                                >
<!ELEMENT sbrev     - - (#PCDATA)                                >
<!ELEMENT ics       - - (#PCDATA)                                >
<!ATTLIST ics
          status    CDATA                         #IMPLIED       >

<!ELEMENT hazmtlst  - - (title, pretopic*, hazmt+)               >
<!ATTLIST hazmtlst
          %revatt;                                               >
<!ELEMENT hazmt     - - (title, warning)                         >
<!ATTLIST hazmt
          id       ID                             #REQUIRED      >
<!ELEMENT pretopic  - - (title, (%text; | list1)) +(effect)      >

<!-- ========================================================= -->
<!--       CMM PAGEBLOCK                                       -->
<!-- ========================================================= -->

<!ELEMENT pgblk     - - ((effect?, chgdesc*, title, regulatory*,
                        task+) | (%deleted; | isempty))          >
<!ATTLIST pgblk
          chappref  CDATA                         #IMPLIED
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          pgblknbr  NUMBER                        #REQUIRED
          confnbr   NUMBER                        #IMPLIED
          %revatt;                                               >

<!-- ========================================================= -->
<!--       TASK                                                -->
<!-- ========================================================= -->
<!ELEMENT task      - - ((effect?, chgdesc*, title, %g.r;,
                          regulatory*, topic+) | %deleted;)      >

<!ATTLIST task
          chappref  CDATA                         #IMPLIED
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          func      CDATA                         " "
          seq       NUMBER                        #REQUIRED
          confltr   CDATA                         " "
          varnbr    NUMBER                        #REQUIRED
          pgblknbr  NUMBER                        #REQUIRED
          confnbr   NUMBER                        #IMPLIED
          %revatt;                                               >

<!-- ========================================================= -->
<!--       TASK ASSOCIATED ELEMENTS                            -->
<!-- ========================================================= -->

<!ELEMENT topic     - - (effect?, title?, (%g.r;), (%w.c;),
                         note*, (subtask+ | prclist1))           >

<!ELEMENT subtask   - - ((effect?, chgdesc*, title?, %g.r;,
                        regulatory*, (%w.c;), note*, prclist1)
                        | %deleted;)                             >

<!ATTLIST subtask
          chappref  CDATA                         #IMPLIED
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          func      CDATA                         " "
          seq       NUMBER                        #REQUIRED
          confltr   CDATA                         " "
          varnbr    NUMBER                        #REQUIRED
          pgblknbr  NUMBER                        #REQUIRED
          confnbr   NUMBER                        #IMPLIED
          %revatt;                                               >

<!-- ========================================================= -->
<!--       PROCEDURE LIST STRUCTURE                            -->
<!-- ========================================================= -->

<!ELEMENT prclist1  - - (prcitem1+) +(effect)                    >
<!ELEMENT prclist2  - - (prcitem2+)                              >
<!ELEMENT prclist3  - - (prcitem3+)                              >
<!ELEMENT prclist4  - - (prcitem4+)                              >
<!ELEMENT prclist5  - - (prcitem5+)                              >
<!ELEMENT prclist6  - - (prcitem6+)                              >
<!ELEMENT prclist7  - - (prcitem7+)                              >

<!ELEMENT prcitem1  - - (prcitem, prclist2?, graphic*)           >
<!ATTLIST prcitem1
          id        ID                            #IMPLIED       >
<!ELEMENT prcitem2  - - (prcitem, prclist3?)                     >
<!ATTLIST prcitem2
          id        ID                            #IMPLIED       >
<!ELEMENT prcitem3  - - (prcitem, prclist4?)                     >
<!ATTLIST prcitem3
          id        ID                            #IMPLIED       >
<!ELEMENT prcitem4  - - (prcitem, prclist5?)                     >
<!ATTLIST prcitem4
          id        ID                            #IMPLIED       >
<!ELEMENT prcitem5  - - (prcitem, prclist6?)                     >
<!ATTLIST prcitem5
          id        ID                            #IMPLIED       >
<!ELEMENT prcitem6  - - (prcitem, prclist7?)                     >
<!ATTLIST prcitem6
          id        ID                            #IMPLIED       >
<!ELEMENT prcitem7  - - (prcitem)                                >
<!ATTLIST prcitem7
          id        ID                            #IMPLIED       >

<!ELEMENT prcitem   - - ((title, regulatory*) | (%w.c;,
                        regulatory*, (para | table | unlist
                        | numlist | deflist),note*) | arlist?)   >



<!-- ========================================================= -->
<!--     STANDARD LISTS -->
<!-- ========================================================= -->
<!ELEMENT list1     - - (l1item+)                                >
<!ELEMENT list2     - - (ltitle?, l2item+)                       >
<!ELEMENT list3     - - (l3item+)                                >
<!ELEMENT list4     - - (l4item+)                                >
<!ELEMENT list5     - - (l5item+)                                >
<!ELEMENT list6     - - (l6item+)                                >
<!ELEMENT list7     - - (l7item+)                                >

<!ELEMENT l1item    - - (%w.c;, regulatory*, %text;, (list2
                         , note*)*)                              >
<!ATTLIST l1item
          id        ID                             #IMPLIED      >
<!ELEMENT l2item    - - (%w.c;, regulatory*, %text;, (list3
                         , note*)?)                              >
<!ATTLIST l2item
          id        ID                             #IMPLIED      >
<!ELEMENT l3item    - - (%w.c;, regulatory*, %text;, (list4
                         , note*)?)                              >
<!ATTLIST l3item
          id        ID                             #IMPLIED      >
<!ELEMENT l4item    - - (%w.c;, regulatory*, %text;, (list5
                         , note*)?)                              >
<!ATTLIST l4item
          id        ID                             #IMPLIED      >
<!ELEMENT l5item    - - (%w.c;, regulatory*, %text;, (list6
                         , note*)?)                              >
<!ATTLIST l5item
          id        ID                             #IMPLIED      >
<!ELEMENT l6item    - - (%w.c;, regulatory*, %text;, (list7
                         , note*)?)                              >
<!ATTLIST l6item
          id        ID                             #IMPLIED      >
<!ELEMENT l7item    - - (%w.c;, regulatory*, %text;)             >
<!ATTLIST l7item
          id        ID                             #IMPLIED      >

<!-- ========================================================= -->
<!--       ACTION RESULT LIST STRUCTURE                        -->
<!-- ========================================================= -->

<!ELEMENT arlist    - - (title, regulatory*, arlist1) +(effect)  >
<!ATTLIST arlist
          chappref  CDATA                         #IMPLIED
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          func      CDATA                         " "
          seq       NUMBER                        #REQUIRED
          confltr   CDATA                         " "
          varnbr    NUMBER                        #REQUIRED
          pgblknbr  NUMBER                        #REQUIRED
          confnbr   NUMBER                        #IMPLIED
          id        ID                            #IMPLIED       >

<!ELEMENT arlist1   - - (aritem1+)                               >
<!ELEMENT arlist2   - - (aritem2+)                               >
<!ELEMENT arlist3   - - (aritem3+)                               >
<!ELEMENT arlist4   - - (aritem4+)                               >
<!ELEMENT arlist5   - - (aritem5+)                               >
<!ELEMENT arlist6   - - (aritem6+)                               >
<!ELEMENT arlist7   - - (aritem7+)                               >

<!ELEMENT aritem1   - - (aritem, arlist2?, graphic*)             >
<!ELEMENT aritem2   - - (aritem, arlist3?)                       >
<!ELEMENT aritem3   - - (aritem, arlist4?)                       >
<!ELEMENT aritem4   - - (aritem, arlist5?)                       >
<!ELEMENT aritem5   - - (aritem, arlist6?)                       >
<!ELEMENT aritem6   - - (aritem, arlist7?)                       >
<!ELEMENT aritem7   - - (aritem)                                 >

<!ELEMENT aritem    - - (title?, regulatory*, action*)           >
<!ELEMENT action    - - ((%w.c;), ((para | table| unlist|
                        numlist), note*), limit*, result*,
                        comment*)                                >

<!ELEMENT limit     - - ((%w.c;), (para | table | unlist |
                        numlist), note*)                         >
<!ELEMENT result    - - ((%w.c;), (para | table | unlist |
                        numlist), note*)                         >
<!ELEMENT comment   - - ((%w.c;), (para | table | unlist |
                        numlist), note*)                         >

<!-- ========================================================= -->
<!--       TABLE (CELLULAR, CALS BASED)                        -->
<!-- ========================================================= -->

<!ELEMENT table     - - ((title?, tgroup, ftnote*) | graphic+)
                                                       -(table)  >
<!ATTLIST table
          chappref  CDATA                         #IMPLIED
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          func      CDATA                         " "
          seq       NUMBER                        #REQUIRED
          confltr   CDATA                         " "
