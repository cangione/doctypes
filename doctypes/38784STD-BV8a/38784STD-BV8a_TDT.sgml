	<ele>
		<tag>graphic</tag>
		<long>Graphic</long>
		<desc>Identifies a graphic within a figure, or a graphic within running text or tables. If used within running text, no figure number or title will be generated. Note that the HCP and ESDS symbols can be placed in running text by using the hcp and esds elements. This element is included to allow the author flexibility in composing the manual in accordance with this spec.</desc>
		<source>None.</source>
		<contmdl>(bindById | bindByName | bindByCoords)*</contmdl>
		<usedin>figure, icon, subfig, subfigfo, abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>graphatt and secur</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>boardno</attr>
				<type>ENTITY</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows the author to place the name of the graphic entity here.</attrdesc>

				<attr>graphsty</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Graphic style</attrdesc>

				<attr>llcordra</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Lower left world coordinates (1,1).  If scalefit=0 and reprowid is not specified default is lower left.</attrdesc>

				<attr>rucordra</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Upper right world coordinates (10000,10000).  If scalefit=0 and reprodep i not specified default is upper right.</attrdesc>

				<attr>reprowid</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies the horizontal dimension of a graphic bounding box (width).</attrdesc>

				<attr>reprodep</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies the vertical dimension of a graphic bounding box (depth).</attrdesc>

				<attr>hscale</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Horizontal Scaling</attrdesc>

				<attr>vscale</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Vertical Scaling</attrdesc>

				<attr>scalefit</attr>
				<type>number</type>
				<default>#IMPLIED</default>
				<attrdesc>Scale to fit.  No affect if hscale and vscale set to zero.</attrdesc>

				<attr>hplace</attr>
				<type>(left | right | center)</type>
				<default>#IMPLIED</default>
				<attrdesc>Horizontal Placement</attrdesc>

				<attr>vplace</attr>
				<type>(top | middle | bottom)</type>
				<default>#IMPLIED</default>
				<attrdesc>Vertical Placement. This attribute is not currently supported by the FOSI</attrdesc>

				<attr>coordst</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies coordinate to start graphic.</attrdesc>

				<attr>coordend</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies coordinate to end graphic.</attrdesc>

				<attr>color</attr>
				<type>number</type>
				<default>0</default>
				<attrdesc>Option to choose color.</attrdesc>

				<attr>icon</attr>
				<type>(yes | no)</type>
				<default>no</default>
				<attrdesc>Specifies whether the graphic is full size or icon. Specifying icon will eliminate the textbrk surrounding the graphic.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>hazmat</tag>
