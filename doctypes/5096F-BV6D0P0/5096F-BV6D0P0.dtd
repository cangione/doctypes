<!--
                      ENTITY DECLARATIONS
-->

<!ENTITY % doc "(docfcf)" >

<!ENTITY % bodyele "(chapter+)" >

<!-- CCB #: 00137-00-14 -->
<!ENTITY % sect "(title, ((phase*) | para0+))" >

<!-- CCB# 5096-B-02044-01 -->
<!-- CCB #: 00137-00-13 -->
<!-- CCB #: 00137-00-06 -->
<!-- CCB #: 00137-00-02 -->
<!ENTITY % idinf    "(tmidno+,  (chgnum, chgdate, chghistory)?, pretmidno*, doctype?, prtitle, subtitle?,
	graphic?, (mfr, contractno+)?, supersed?, suppl*, discl?, distrib, 
	expcont?, destr?, copyright*, note?, moveddata?, authnot, downgrd?, pubdate )" >

<!ENTITY % frnt " (idinfo, lep, verstat?, contents, illuslist?, tablelist?, 
		foreword)" >	

<!-- CCB# 5096-B-02044-02 -->
<!-- CCB #: 00137-00-07 -->		
<!ENTITY % fpi "para0, (para0 | applicdef | symsect | abbrsect |
internatlstd | lrp | tctolist | warning | caution | note)*" >

<!-- ATI:  added change to mixture - DTD oversight, USAF added it to the V8 version -->
<!ENTITY % text "(#PCDATA | tabmat | ftnref | xref | graphic | extref |
		emphasis | change)+" >		

<!ENTITY % secur "security (u | c | s | n) 'n'" >

<!ENTITY % chgatt
"deltype (delete  | real | reserve | NA) #IMPLIED
inschlvl NMTOKEN #IMPLIED
delchlvl NMTOKEN #IMPLIED
status  (empty | deleted | reserved | notapp) #IMPLIED
revchg NUMBER '0'" > 

<!ENTITY % bodyatt
"label CDATA #IMPLIED
sssn CDATA #IMPLIED
indexid  CDATA  #IMPLIED 
%chgatt;" >

<!-- CCB# 5096-B-02044-04 -->
<!ENTITY % chapatt
"id ID #IMPLIED
crewposition (P | CP | NAV | E | FE | LM | BO | GC | OSO | DSO | EW | G | O | RN | CSO | SCN | WSO) #REQUIRED
%secur;
%bodyatt;" >

<!ENTITY % sectatt 
"id ID #IMPLIED
%secur;
%bodyatt;" >

<!-- using 7700F front matter - jls -->
<!-- CCB #: 00137-00-14 -->
<!ENTITY % chap "(title, ((section, section+) | (phase*) | para0+))" >

<!-- CCB#: 00137-00-09  -->
<!ENTITY % stepcon    "(note?, (clitem, action?, amplify?), para?, warning?, 
caution?, note?)" >

<!-- CCB #: 00137-00-01 -->
<!-- ATI added entity to 38784 -->
<!ENTITY % m38784       PUBLIC "-//USA-DOD//DTD 38784STD-BV7//EN" >
%m38784;

<!-- ELEMENT and ATTRIBUTE LIST DECLARATIONS -->

<!-- CCB# 5096-B-02044-03 -->

<!ELEMENT action     - o  (%text;) >
<!ATTLIST action     %secur; >

<!ELEMENT amplify     - o  (%text;) >
<!ATTLIST amplify     %secur; 
                      %chgatt; >

<!ELEMENT clitem     - o  (%text;) >
<!ATTLIST clitem     %secur; >

<!ELEMENT docfcf     - -  (front, body)  +(pgbrk | brk | subjinfo |
			  line | modreq | location | ftnote) >
<!ATTLIST docfcf     service %service; 'AF'
                     %docatt;
                     %secur; >

<!-- CCB #: 00137-00-13 -->

<!ELEMENT phase     - o  (title?, para0+) >
<!ATTLIST phase     %sectatt; >

