conrule='!<colspec colname="fpf" colwidth="1.5*"><colspec colname="vstat" colwidth="1.0*"><colspec colname="datever" colwidth="1.5*"><colspec colname="rem" colwidth="3*"><spanspec spanname="tonum" namest="fpf" nameend="vstat"><spanspec spanname="chngnum" namest="fpf" nameend="rem">!'
placemnt="after" append="0">
<savetext textid="vsmatterbody-vol.tdv"
conrule="!<tbody>!,vsmatter-vol.tiv,!</tbody>!" placemnt="after">
<savetext textid="vstable-vol.tiv"
conrule='!<table frame="all"><tgroup cols="4">!,vsmatterhead.tdv,vsmatterbody-vol.tdv,!</tgroup></table>!'
placemnt="after"></charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
