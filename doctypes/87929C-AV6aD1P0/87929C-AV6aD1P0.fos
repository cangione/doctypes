<span span="1">
<float flidref="top-page.flt" width="page" scope="numindx.psu"
pagetype="forward"></subchars>
</usetext>
<usetext
source="<NI-rule-col1.fmt>,</NI-rule-col1.fmt>,<NI-rule-col2.fmt>,</NI-rule-col2.fmt>,<NI-rule-col3.fmt>,</NI-rule-col3.fmt>">
<subchars>
<font style="sanserif" size="8pt">
