<!-- DOCTYPE aipc  [    -->

<!-- The following set of declarations may be referred to 
     using a public entity as follows: 
<!DOCTYPE aipc PUBLIC 
    "-//ATA-TEXT//DTD AIPC-VER20-LEVEL2//EN" [ ]                  -->
 
<!-- ============================================================ -->
<!--                      NOTATIONS                               -->
<!-- ============================================================ -->
 
<!NOTATION     cgm       PUBLIC
    "-//USA-DOD//NOTATION Computer Graphics Metafile//EN"           >
 
<!NOTATION     ccitt4    PUBLIC
    "-//USA-DOD//NOTATION CCITT Group 4 Facsimile//EN"              >

<!NOTATION     gcf       PUBLIC
    "-//ATA-TEXT//NOTATION Graphic Companion File//EN"              >
	
<!NOTATION  mcp       PUBLIC
    "-//ATA-TEXT//NOTATION Media Companion File//EN"                >

<!NOTATION pdf PUBLIC
    "-//Adobe Inc.//NOTATION Portable Document Format//EN"          >

<!NOTATION png PUBLIC
    "-//W3C//NOTATION Portable Network Graphics//EN"                >

<!NOTATION jpeg PUBLIC
    "+//ISBN 0-7923-9432-1::Graphic Notation//NOTATION Joint
     Photographic Experts Group Raster//EN"                         >

<!NOTATION vrml PUBLIC 
    "-//ATA-TEXT//NOTATION Virtual Reality Modeling Language//EN"   >

<!NOTATION mpeg PUBLIC
    "-//ATA-TEXT//NOTATION Motion Pictures Expert Group//EN"        >

<!NOTATION mp3 PUBLIC
    "-//ATA-TEXT//NOTATION Motion Pictures Expert Group, Audio
     Layer 3//EN"                                                   >

<!-- ============================================================ -->

<!-- ============================================================ -->
<!--                      ENTITIES                                -->
<!-- ============================================================ -->
<!ENTITY  % text   "(para | graphic | unlist | txtgrphc | note 
                    | table | numlist)+"                            >
<!ENTITY  % revatt
            "chg      (N|R|D|U)                       #REQUIRED
             key       ID                             #REQUIRED
             revdate   NUMBER                         #REQUIRED"    >
 
<!ENTITY  % yesorno      "NUMBER"                                   >
<!ENTITY  % ein    "(ein | einmfr)"                                 >
 
<!ENTITY   % ISOtech      PUBLIC 
     "ISO 8879-1986//ENTITIES   General Technical//EN"              >
<!ENTITY   % ISOpub      PUBLIC 
     "ISO 8879-1986//ENTITIES Publishing//EN"                       >
<!ENTITY   % ISOnum      PUBLIC 
   "ISO 8879-1986//ENTITIES   Numeric and Special Graphic//EN"      >
<!ENTITY   % ISOgrk1     PUBLIC 
     "ISO 8879-1986//ENTITIES   Greek Letters//EN"                  >
<!ENTITY   % ISOgrk2     PUBLIC 
     "ISO 8879-1986//ENTITIES Monotoniko Greek//EN"                 >
<!ENTITY   % ISOgrk3     PUBLIC 
     "ISO 8879-1986//ENTITIES Greek Symbols//EN"                    >
<!ENTITY   % ISOgrk4     PUBLIC 
     "ISO 8879-1986//ENTITIES Alternative Greek Symbols//EN"        >
<!ENTITY   % ISOlat1     PUBLIC 
     "ISO 8879-1986//ENTITIES Added Latin 1//EN"                    >
<!ENTITY   % ISObox      PUBLIC
     "ISO 8879-1986//ENTITIES Box and Line Drawing//EN"             >
<!ENTITY   % ISOamso     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Ordinary//EN"     >
<!ENTITY   % ISOamsc     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Delimiters//EN"   >

%ISOtech; %ISOpub; %ISOnum; %ISOgrk1; %ISOgrk2; %ISOgrk3;
%ISOgrk4; %ISOlat1; %ISObox; %ISOamso; %ISOamsc;

<!-- ============================================================ -->
 
<!-- ============================================================ -->
<!--                   AIPC HIGH LEVEL STRUCTURE                  -->
<!-- ============================================================ -->
 
<!ELEMENT aipc      - -  ((title, legalntc?, mfmatr, dplist, 
                           pnrfile) | increv | tr+)
                         +(revst | revend | cocst | cocend 
                         | hotlink)                                 >
<!ATTLIST aipc
          model     CDATA                             #REQUIRED
          oidate    NUMBER                            #REQUIRED
          revdate   NUMBER                            #REQUIRED
          tsn       CDATA                             #REQUIRED
          docnbr    CDATA                             #IMPLIED
          cus       CDATA                             #IMPLIED
          chg       (N|R|U)                           #REQUIRED
          lang      CDATA                             #REQUIRED
          cusname   CDATA                             #IMPLIED
          spl       CDATA                             #REQUIRED
          efflen    NUMBER                            #IMPLIED
          efftype   CDATA                             #IMPLIED      >

<!-- ============================================================ -->

<!-- ============================================================ -->
<!--              INCREMENTAL and TEMPORARY REVISION              -->
<!-- ============================================================ -->
 
<!ELEMENT increv    - -  (transltr?, legalntc?, (intro | illtech
                         | effxref | stadiag | zoning | fmkitlst 
                         | vendlist | sblist | majdwg | glossary 
                         | chapter | section | unit | figure 
                         | item | sheet | pnrdata | trlist 
                         | einlst)+)                                >

<!ELEMENT transltr  - -  (title, ((title?, %text;)+ | list1))       >
<!ATTLIST transltr 
          oldkey    NAME                              #IMPLIED
          %revatt;                                                  >

<!ELEMENT tr        - -  (legalntc?, trfmatr, trlist?, (chapter
                         | section+ | unit+ | (figure+, pnrdata*,
                         vendlist?) | pnrdata+ | legalntc | intro
                         | effxref | vendlist | sblist | coclist
                         | einlst))                                 >

<!ELEMENT trfmatr   - -  (title, trreason?, (%text;)?)              >
<!ATTLIST trfmatr 
          trnbr     CDATA                             #REQUIRED
          trdel     CDATA                             #IMPLIED
          trrepl    CDATA                             #IMPLIED
          issdate   CDATA                             #IMPLIED      >
<!ELEMENT trreason  - -  (#PCDATA)                                  >

<!-- ============================================================ -->

<!-- ============================================================ -->
<!--       Legal Notice Information                               -->
<!-- ============================================================ -->

<!ELEMENT legalntc  - - (exprtcl | cpyrght | proptary | geninfo)+   >
<!ATTLIST legalntc
          %revatt;                                                  >

<!ELEMENT proptary  - - (fullstmt, partstmt?)                       >
<!ELEMENT fullstmt  - - (title?, cpyrght?, para+)                   >
<!ELEMENT partstmt  - - (title?, para+)                             >
<!ELEMENT exprtcl   - - (para | unlist | numlist | note)+           >
<!ELEMENT cpyrght   - - (year*, holder*, geninfo)                   >
<!ELEMENT year      - - (#PCDATA)                                   >
<!ELEMENT holder    - - (#PCDATA)                                   >
<!ELEMENT geninfo   - - (para | unlist | numlist | note)+           >

<!-- ============================================================ -->

<!-- ============================================================ -->
<!--                    FRONT MATTER                              -->
<!--  Front Matter consists of a temporary revision list ,        -->
<!--  an introduction, an airplane cross-reference list, station  -->
<!--  diagrams, zones, filter maintenance kit list, vendor list,  -->
<!--  service bulletin list, major drawing list, and glossary.    -->
<!-- ============================================================ -->
 
<!ELEMENT mfmatr    - -  (transltr?, trlist?, intro, illtech?, 
                          effxref, stadiag?, zoning?, fmkitlst?, 
                          vendlist, sblist, coclist?, majdwg?, 
                          glossary?, einlst?) +(refint | refext)    >
 
<!ELEMENT refint    - -  (#PCDATA)                                  >
<!ATTLIST refint
          refid          IDREF                        #IMPLIED
          reftype        CDATA                        #IMPLIED      >
 
<!ELEMENT refext    - -  (#PCDATA)                                  >
<!ATTLIST refext
          refloc         CDATA                        #IMPLIED
          refmodel       CDATA                        #IMPLIED
          refspl         CDATA                        #IMPLIED
          refman         CDATA                        #IMPLIED
          docnbr         CDATA                        #IMPLIED      >

<!ELEMENT trlist    - - (title, (%text;)*, (trdata+ | isempty))     >
<!ATTLIST trlist
          %revatt;                                                  >

<!ELEMENT trdata    - -  (trnbr, trstatus, trloc+)                  >
<!ELEMENT trnbr     - -  (#PCDATA)                                  >
<!ELEMENT trstatus  - -  (#PCDATA)                                  >
<!ELEMENT trloc     - -  (#PCDATA)                                  >

 
<!ELEMENT intro     - -  (title, ((title?, %text;)+ | list1))       >
<!ATTLIST intro
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
 
<!ELEMENT illtech   - -  ((title, %text;) | deleted)                >
<!ATTLIST illtech
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
 
<!ELEMENT effxref   - -  (title, (%text;)?, effdata+)               >
<!ATTLIST effxref
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
<!ELEMENT effdata   - -  (cus?, modtype, cec, linenbr?, ect?,
                          venbr?, esnbr?, benbr?, msnbr, acn?,
                          operator?, fslgnbr?, cac?, cusaid?)       >
<!ELEMENT linenbr   - -  (#PCDATA)                                  >
<!ELEMENT operator  - -  (#PCDATA)                                  >
<!ELEMENT cac       - -  (#PCDATA)                                  >

<!ELEMENT modtype   - -  (#PCDATA)                                  >

<!ELEMENT cec       - -  (#PCDATA)                                  >
<!ELEMENT ect       - -  (#PCDATA)                                  >
<!ELEMENT venbr     - -  (#PCDATA)                                  >
<!ELEMENT esnbr     - -  (#PCDATA)                                  >
<!ELEMENT benbr     - -  (#PCDATA)                                  >
<!ELEMENT msnbr     - -  (#PCDATA)                                  >
<!ELEMENT acn       - -  (#PCDATA)                                  >
<!ELEMENT fslgnbr   - -  (#PCDATA)                                  >
<!ELEMENT cusaid    - -  (#PCDATA)                                  >
 
<!ELEMENT stadiag   - -  ((title, stadata+) | deleted)              >
<!ATTLIST stadiag
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
 
<!ELEMENT stadata   - -  (%text;)                                   >
 
<!ELEMENT zoning    - -  ((title, zondata+) | deleted)              >
<!ATTLIST zoning
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
 
<!ELEMENT zondata   - -  (%text;)                                   >
 
<!ELEMENT fmkitlst  - -  ((title, fmktdata+) | deleted)             >
<!ATTLIST fmkitlst
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
 
<!ELEMENT fmktdata  - -  (kitnbr, rplktnbr?, fltrdata, ktdata+)     >
<!ELEMENT kitnbr    - -  (#PCDATA)                                  >
<!ELEMENT rplktnbr  - -  (#PCDATA)                                  >
<!ELEMENT fltrdata  - -  (kitdescr, (pnr, csd?)*)                   >
<!ELEMENT kitdescr  - -  (#PCDATA)                                  >
<!ELEMENT ktdata    - -  (pnr, opt*, upa)                           >
 
<!ELEMENT vendlist  - -  (title, (%text;)?, vendata+)               >
<!ATTLIST vendlist
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
 
<!ELEMENT vendata   - -  (mfr, mad)                                 >
<!ELEMENT mfr       - -  (#PCDATA)                                  >
<!ATTLIST mfr
          amfr           %yesorno;                    #IMPLIED      >
<!ELEMENT mad       - -  (venname?, venaddr*, veninfo*, venrpl*)    >
<!ELEMENT venname   - -  (#PCDATA)                                  >
<!ELEMENT venaddr   - -  (#PCDATA)                                  >
<!ELEMENT veninfo   - -  (#PCDATA)                                  >
<!ELEMENT venrpl    - -  (#PCDATA)                                  >
<!ATTLIST venrpl
          rplstatus      (rpls | rplby)               #REQUIRED     >
 
<!ELEMENT sblist    - -  (title, (%text;)?, (sbdata+ | isempty))    >
<!ATTLIST sblist
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
<!ELEMENT sbdata    - -  (sbnbr?, sbrev?, title?, sbnrmfr*, eonbr*,
                          mdnrmfr*, cocnrmfr*, sc?, aclist*, ics,
                          custeff?)                                 >
<!ELEMENT sbnrmfr   - -  (sbnbr, mfr?)                              >
<!ELEMENT mdnrmfr   - -  (mdnbr, mfr?)                              >
