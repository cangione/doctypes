conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixsub2>,alphaidxlvl3.txt,</ixsub2>,<ixsub3>,alphaidxlvl4.txt,</ixsub3>,<ixpgstr>,wpct.txt[BO],\/\,foliostr[BO],</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
