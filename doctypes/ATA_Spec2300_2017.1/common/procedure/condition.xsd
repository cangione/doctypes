	  <xs:include schemaLocation="../basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="../basicDataTypes/case.xsd"/>
	  <xs:include schemaLocation="./endOfProc.xsd"/>
	  <!--=============================================-->
	<!-- condition element								  		 		   			   -->
	<!--=============================================-->
	<xs:element name="condition" type="conditionType">
		    <xs:annotation>
			      <xs:documentation>A procedural content dependant of a condition</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="conditionType">
		    <xs:attribute name="direct" type="xs:boolean" use="optional">
			      <xs:annotation>
				        <xs:documentation>Used to write a condition on a single line. only useful when the procedural conditional content content is composed of a single action/command.</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- exclusiveConditions element								  		 		   			   -->
	<!--=============================================-->
	<xs:element name="exclusiveConditions" type="exclusiveConditionsType">
		    <xs:annotation>
			      <xs:documentation>List of exclusive conditions.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="exclusiveConditionsType">
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- conditionGroupType element								     -->
	<!--=============================================-->
	<xs:group name="conditionGroup">
		    <xs:choice>
			      <xs:element ref="condition"/>
			      <xs:element ref="exclusiveConditions"/>
		    </xs:choice>
	  </xs:group>
</xs:schema>