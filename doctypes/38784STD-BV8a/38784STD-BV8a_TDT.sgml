	<ele><tag>tabdisplay
<long>Table data displayed inside a figure.
<desc>Identifies a table data contained within a figure.
<source>
<contmdl>(tgroup+)   -(figure | table | foldout | objmedia) +(tfoot|tfnref|tfndisplay)
<usedin>figure, foldout, subfig, and subfigfo
<specatts><attrtbl>
<attr>label
<type>CDATA

<default>#IMPLIED
<attrdesc>Allows you to label this paragraph manually.  The fosi will automatically do this for
you, so its use is not necessary unless a label out of the ordinary is desired.
<attr>frame
<type>top | bottom | topbot
	| all | sides | none
<default>all
<attrdesc>Defines the frame for the table.
<attr>colsep
<type>%yesorno;
<default>1
<attrdesc>Allows you to include a vertical line to seperate columns.  A value
of 1. for this attribute will generate column separators.
<attr>rowsep
<type>%yesorno;
<default>0
<attrdesc>Allows you to include a horizontal line to seperate rows.  A value
of 1. for this attribute will generate row separators.
<attr>tbwidth
<type>NUTOKEN 
<default>#IMPLIED
<attrdesc>
<attr>tbdepth
<type>NUTOKEN
<default>#IMPLIED
<attrdesc>
<attr>horrefpt
<type>(left | right)
<default>left
<attrdesc>Defines the horizontal reference point for the table.
<attr>verrefpt
<type>(vtop | vbottom)
<default>vtop
<attrdesc>Defines the vertical reference point for the table.
<attr>coordst
<type>CDATA
<default>0,10000
<attrdesc>Ability to define the coordinates to start the table.
<attr>assocfig
<type>IDREF
<default>#IMPLIED
<attrdesc>Provides a means to add the id to an associated figure.
<attr>deltype
<type>delete  | real | reserve | NA
<default>#IMPLIED
<attrdesc>Used to generate change packages - Delete Type
<attr>inschlvl
<type>nmtoken
<default>#IMPLIED
<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.
<attr>delchlvl
<type>nmtoken
<default>#IMPLIED
<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated
<attr>status
<type>empty | deleted | reserved | notapp
<default>#IMPLIED
<attrdesc>Used during the change package process to indicate the current status of the element.
<attr>revchg
<type>NUMBER
<default>0
<attrdesc>Toggle between a revision or a change.  Attribute is set to 1 to indicate a revision.
<attr>security
<type>(u | c | s | n)
<default>n
<attrdesc>Identifies security level of the document</attrtbl></ele>


	
	<ele>
		<tag>table</tag>
		<long>Table</long>
		<desc>Identifies a table. </desc>
		<source>4.2.7</source>
		<contmdl>(title, tgroup+) -(figure | table | foldout | objmedia) +(tfnref | tfoot | tfndisplay | tfnid)</contmdl>
		<usedin>Globally included in appendix, chapter, ddchapter, foreword, intro, ipbfwordchap, preface, and safesum</usedin>
		<ents>tabl, exclus, tabatts, and yesorno</ents>
		<specatts>
			<attrtbl>
				<attr>tabstyle</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Describes the type of table.</attrdesc>

				<attr>frame</attr>
				<type>(top | bottom | topbot | all | sides | none )</type>
				<default>all</default>
				<attrdesc>Defines the frame for the table.</attrdesc>

				<attr>colsep</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Allows you to include a vertical line to seperate columns. A value of "1" for this attribute will generate column separators.</attrdesc>

				<attr>rowsep</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Allows you to include a horizontal line to seperate rows. A value of "1" for this attribute will generate row separators.</attrdesc>

				<attr>orient</attr>
				<type>(port | land1)</type>
				<default>port</default>
				<attrdesc>Defines orientation of table on the page.</attrdesc>

				<attr>pgwide</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Defines whether the figure will fill the entire width of the page.</attrdesc>

				<attr>cellcont</attr>
				<type>(Continued | Cont)</type>
				<default>Continued</default>
				<attrdesc>Specifies whether cell contents can be continued.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides means to specify an ID number for the table.</attrdesc>

				<attr>footnotes</attr>
				<type>(page | end)</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to specify whether table footnotes appear at the end of the table or at the end of the page.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies all IDs of elements or data items that have an applicable reference.</attrdesc>

				<attr>leftind</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left indent of the table in relationship to the page.</attrdesc>

				<attr>rightind</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies right indent of the table in relationship to the page.</attrdesc>

				<attr>leftmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>rightmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>topmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>botmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>mindepth</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies the minimum depth of the table.</attrdesc>

				<attr>pgdeep</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Allows you to specify whether that table is equal to the depth of the page.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>continued</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>This attribute indicates whether the table is continued from the previous page. This tag was only added to allow for proper formatting of table footnotes. It is to be used in conjunction with the 38784 Table Footnotes script.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tablelist</tag>
		<long>List of Tables</long>
		<desc>Identifies the list of tables in the manual. This information is automatically compiled by the FOSI. If this element is not used, no list of tables will appear in the manual.</desc>
		<source>4.5.8</source>
		<contmdl>(tbllistrow | (tabno, title, pageno))* -(note)</contmdl>
		<usedin>front and auxfront</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>autobuild</attr>
				<type>CDATA</type>
				<default>#CONREF</default>
				<attrdesc>This attribute should be set equal to 1. when the Table of Contents is autogenerated.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tabmat</tag>
		<long>Table Material</long>
		<desc>Identifies tabular material that is to be displayed without the Table heading.</desc>
		<source>4.3.9</source>
		<contmdl>(tgroup+)  -(figure | table | foldout | objmedia)</contmdl>
		<usedin>chglist, legend, verstat, abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>exclus and tabatts</ents>
		<specatts>
			<attrtbl>
				<attr>tabstyle</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Describes the type of table.</attrdesc>

				<attr>frame</attr>
				<type>(top | bottom | topbot | all | sides | none )</type>
				<default>all</default>
				<attrdesc>Defines the frame for the table.</attrdesc>

				<attr>colsep</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Allows you to include a vertical line to seperate columns. A value of "1" for this attribute will generate column separators.</attrdesc>

				<attr>rowsep</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Allows you to include a horizontal line to seperate rows. A value of "1" for this attribute will generate row separators.</attrdesc>

				<attr>orient</attr>
				<type>(port | land1)</type>
				<default>port</default>
				<attrdesc>Defines orientation of table on the page.</attrdesc>

				<attr>pgwide</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Defines whether the figure will fill the entire width of the page.</attrdesc>

				<attr>cellcont</attr>
				<type>(Continued | Cont)</type>
				<default>Continued</default>
				<attrdesc>Specifies whether cell contents can be continued.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides means to specify an ID number for the table.</attrdesc>

				<attr>footnotes</attr>
				<type>(page | end)</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to specify whether table footnotes appear at the end of the table or at the end of the page.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies all IDs of elements or data items that have an applicable reference.</attrdesc>

				<attr>leftind</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left indent of the table in relationship to the page.</attrdesc>

				<attr>rightind</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies right indent of the table in relationship to the page.</attrdesc>

				<attr>leftmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>rightmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>topmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>botmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies left margin of the table.</attrdesc>

				<attr>mindepth</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Specifies the minimum depth of the table.</attrdesc>

				<attr>pgdeep</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Allows you to specify whether that table is equal to the depth of the page.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tabno</tag>
		<long>Table Number</long>
		<desc>Identifies the Table number within the table list when the table list is manually tagged.</desc>
		<source>None.</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>tablelist, tbllistrow, and voltablelist</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tbllistrow</tag>
		<long>Table List Row</long>
		<desc>Identifies a row in the List of Tables. Element added to allow for the insertion/deletion of an entire row.</desc>
		<source>4.5.8</source>
		<contmdl>(tabno, title, pageno)</contmdl>
		<usedin>tablelist and voltablelist</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tbody</tag>
		<long>Table Body</long>
		<desc>Identifies the body of a table (e.g. material below the boxheads).</desc>
		<source>4.3.9</source>
		<contmdl>(row+)</contmdl>
		<usedin>entrytbl, and tgroup</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>valign</attr>
				<type>(top | middle | bottom)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the vertical alignment of text within a cell.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tctolist</tag>
		<long>Time Compliance Technical Orders Paragraph</long>
		<desc>Identifies the time compliance technical orders paragraph and the associated table.</desc>
		<source>4.5.9.3</source>
		<contmdl>((title, warning*, caution?, note?, (para, note?)?, (step1, step1+)?, subpara1*)?, tctotbl?)</contmdl>
		<usedin>foreword, intro, and preface</usedin>
		<ents>parazero and para0att</ents>
		<specatts>
			<attrtbl>
				<attr>emergency</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates that the primary paragraph will produce an emergency border on the page when set equal to 1.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>esds</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Electrostatic Discharge Sensitive. All paragraphs which address handling or maintenance which could damage *** ESDS *** parts shall be identified by the esds symbol by setting attribute equal to 1.</attrdesc>

				<attr>nsp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Nuclear Surety Procedures.  A **NSP** symbol will appear when set equal to 1.</attrdesc>

				<attr>fcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Fracture Critical Process. All paragraphs which address Fracture Critical Process shall be identified by the *** FCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Process. All paragraphs which address Hardness Critical Process shall be identified by the *** HCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Item. All paragraphs which address Hardness Critical Item shall be identified by the *** HCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>ocp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Process. All paragraphs which address observable critical processes shall be identified by the *** OCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>oci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Item. All paragraphs which address observable critical items shall be identified by the *** OCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tctono</tag>
		<long>Time Compliance Technical Order Number</long>
		<desc>Identifies an entry in the TCTO Number column in the TCTO table.</desc>
		<source>4.5.9.3</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>tctorow</usedin>
		<ents>text, exclus, chgatt, and secur</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tctorow</tag>
		<long>Time Compliance Technical Orders Row</long>
		<desc>Identifies a row in the time compliance technical orders table.</desc>
		<source>4.5.9.3</source>
		<contmdl>(tctono, title, date)</contmdl>
		<usedin>tctotbl</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tctotbl</tag>
		<long>Time Compliance Technical Order Table</long>
		<desc>Identifies the table that lists all TCTOs applicable to the manual. The FOSI will automatically generate the table title and the column headings (boxheads).</desc>
		<source>4.5.9.3</source>
		<contmdl>(tctorow+)</contmdl>
		<usedin>tctolist</usedin>
		<ents>bodyatt and secur</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>term</tag>
		<long>Term</long>
		<desc>Identifies an entry in the term portion of a list.  This element is included to allow the author flexibility in composing the manual in accordance with this spec.</desc>
		<source>4.3.4</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>acronym, acronymlist, acronymlistrow, applic, applichd, defhd, deflist, glosslist, glossrow, ipbuseoncodelist, symrow, and symsect</usedin>
		<ents>text, exclus, secur and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tfnid</tag>
		<long>Table Footnote Id</long>
		<desc>This element is for placing a footnote in a 38784 table model. A superscript will be placed at this point in the table and the footnote value will be placed at the bottom of the table if a table footnote display is created.</desc>
		<source>4.2.7.5</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>tfoot. Globally included in table.</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>tfntype</attr>
				<type>(num | alpha | sym)</type>
				<default>num</default>
				<attrdesc>Defines the type of symbol used to indicate a table footnote.</attrdesc>

				<attr>tfnsymbol</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to define the actual symbol to serve as a table footnote reference.</attrdesc>

				<attr>tfnval</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the text value of the reference. The actual data to be generated at the bottom of the table should be placed with this attribute.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tfnref</tag>
		<long>Table Footnote Reference</long>
		<desc>This element is for referencing a footnote in a 38784 table model that was created with a table footnote id. The superscript that was generated from the table footnote id will be placed at this point in the table and the footnote value will be placed at the bottom of the table if a table footnote display is created.</desc>
		<source>4.2.7.5</source>
		<contmdl>EMPTY</contmdl>
		<usedin>Globally included in ipbcagecodes and table</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>xrefid</attr>
				<type>IDREF</type>
				<default>#REQUIRED</default>
				<attrdesc>Defines the ID of the element that you are referencing. The value of this attribute should match the value of an ID attribute elsewhere in the manual.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tfndisplay</tag>
		<long>Table Footnote Display</long>
		<desc>This element is for displaying footnotes in a 38784 table model. Footnotes to tables will be displayed at the end of the table. This element should be placed in a span in the last row of the table.</desc>
		<source>4.2.7.5</source>
		<contmdl>EMPTY</contmdl>
		<usedin>Globally included in ipbpl0tbl and table</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tfoot</tag>
		<long>Table Foot</long>
		<desc>The foot of the table.</desc>
		<source>4.2.7.5</source>
		<contmdl>((colspec*, spanspec*, row+) | tfnid+)	-(entrytbl)</contmdl>
		<usedin>tgroup. Globally included in ipbcagecodes and table.</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tgroup</tag>
		<long>Table Group</long>
		<desc>Identifies a table group, which consists of a table heading (boxheads) and a table body.</desc>
		<source>4.2.7</source>
		<contmdl>(colspec*, spanspec*, (thead?, tfoot?, tbody))</contmdl>
		<usedin>table and tabmat</usedin>
		<ents>yesorno and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>cols</attr>
				<type>NUMBER</type>
				<default>#REQUIRED</default>
				<attrdesc>Defines the number of columns within the table.</attrdesc>

				<attr>colsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a vertical line to seperate columns. A value of "1" for this attribute will generate column separators.</attrdesc>

				<attr>rowsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a horizontal line to seperate rows. A value of "1" for this attribute will generate row separators.</attrdesc>

				<attr>align</attr>
				<type>(left | right | center | justify | char)</type>
				<default>left</default>
				<attrdesc>Allows the author to align text within the cell.</attrdesc>

				<attr>leftind</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the left indent of text within the cell.</attrdesc>

				<attr>rightind</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines a right indent of the text within the cell.</attrdesc>

				<attr>leftmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the left margin of the cell.</attrdesc>

				<attr>rightmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the right margin of the cell.</attrdesc>

				<attr>topmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the top margin of the cell.</attrdesc>

				<attr>botmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the bottom margin of the cell.</attrdesc>

				<attr>mindepth</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the minimum depth of the table.</attrdesc>

				<attr>charoff</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Determines the distance the cell content should offset from the horizontal alignment character.</attrdesc>

				<attr>char</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the alignment character that can be used to align values within a column.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>thead</tag>
		<long>Table Heading (Boxheads)</long>
		<desc>Identifies a table heading (boxheads). The table heading (boxheads) repeat when the table breaks across a column or page.</desc>
		<source>4.2.7.3</source>
		<contmdl>(colspec*, spanspec*, row+)   -(entrytbl)</contmdl>
		<usedin>entrytbl and tgroup</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>valign</attr>
				<type>(top | middle | bottom)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the vertical alignment of text within a cell.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>title</tag>
		<long>Title</long>
		<desc>Identifies a title (e.g. chapter, paragraph, table, etc.). The title should be tagged exactly as it is to appear in the table of contents. Titles that are placed on tables will appear in the List of Tables, and titles that are placed on figures and figure tables will be placed in the List of Illustrations. This element is included to allow the author flexibility in composing the manual in accordance with this spec.</desc>
		<source>MIL-STD-38784</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia | note)</contmdl>
		<usedin>abbrsect, appendix, applicdef, chapter, cntentry, dddesc, ddindex, deflist, figure, foldout, illlistrow, illuslist, ipbesdsdesc, ipbfinding, ipbhcidesc, ipbmfrlist, ipbmodelcover, ipbpartstd, ipbquickchgexpl, ipbserialization, ipbsertable, ipbshtnoexpl, ipbsimassem, ipbsmrexpl, ipbuseonexpl, lrp, lrpentry, objmedia, para0, randlist, ratddesc, ratdentry, section, seqlist, subpara1, subpara2, subpara3, subpara4, subpara5, subpara6, subpara7, subpara8, symsect, table, tablelist, tbllistrow, tctolist, tctorow, tmimprep, volilluslist, voltablelist, and wpgentry</usedin>
		<ents>text, exclus, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tmidno</tag>
		<long>Technical Manual Identification Number</long>
		<desc>Identifies the technical manual identification number. When used on the title page (<![ CDATA [<idinfo>]]>), it will cause the technical manual number to appear on the title page and at the top of each page in the manual. When used in the list of related publications (<![ CDATA [<lrp>]]>), will cause the technical manual number to be placed in the Publication Number column.</desc>
		<source>4.2.1.5 & 4.5.9.2</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>idinfo and lrpentry</usedin>
		<ents>chgatt, exclus, service, chgatt, and secur</ents>
		<specatts>
			<attrtbl>
				<attr>service</attr>
				<type>(AF | NAVAIR | NAVSEA | SPAWARS | ARMY | MC | DLA | CG | DOD | FRN)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the branch of service.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>tmimprep</tag>
		<long>Technical Manual Improvement Report</long>
		<desc>Identifies the technical manual improvement report paragraph.</desc>
		<source>4.5.9</source>
		<contmdl>(title, warning*, caution?, note?, (para, note?)?, (step1, step1+)?, subpara1*)</contmdl>
		<usedin>foreword, intro, and preface</usedin>
		<ents>parazero and para0att</ents>
		<specatts>
			<attrtbl>
				<attr>emergency</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates that the primary paragraph will produce an emergency border on the page when set equal to 1.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>esds</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Electrostatic Discharge Sensitive. All paragraphs which address handling or maintenance which could damage *** ESDS *** parts shall be identified by the esds symbol by setting attribute equal to 1.</attrdesc>

				<attr>nsp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Nuclear Surety Procedures.  A **NSP** symbol will appear when set equal to 1.</attrdesc>

				<attr>fcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Fracture Critical Process. All paragraphs which address Fracture Critical Process shall be identified by the *** FCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Process. All paragraphs which address Hardness Critical Process shall be identified by the *** HCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Item. All paragraphs which address Hardness Critical Item shall be identified by the *** HCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>ocp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Process. All paragraphs which address observable critical processes shall be identified by the *** OCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>oci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Item. All paragraphs which address observable critical items shall be identified by the *** OCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
