	<ele>
		<tag>nameloc</tag>
		<long>Name Location - HyTime Element</long>
		<desc>One of several elements added to facilitate use of HyTime. This element serves as a locator for external references and contains several nmlist elements. Useful for referncing objects that do not have the traditional SGML id.</desc>
		<source>None.</source>
		<contmdl>(nmlist)*</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>HyBase</attr>
				<type>NAME #FIXED</type>
				<default>nameloc</default>
				<attrdesc>Assigns nameloc as the HyBase attribute.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>nmlist</tag>
		<long>Name List - HyTime Element</long>
		<desc>One of several elements added to facilitate use of HyTime. This element serves as a description of the location of the entity or element reference in the nameloc element. Useful for referncing objects that do not have the traditional SGML id and/or entities that reside in external documents.</desc>
		<source>None.</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>nameloc</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>HyBase</attr>
				<type>NAME #FIXED</type>
				<default>nmsploc</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>impsrc</attr>
				<type>NAME #FIXED</type>
				<default>grovert</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>HyBnames</attr>
				<type>CDATA #FIXED</type>
				<default>locsrc docorsub<line></line>namespc nametype<line></line>#MAPTOKEN elements element<line></line>#MAPTOKEN entities entity</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>nametype</attr>
				<type>(entity | element)</type>
				<default>entity</default>
				<attrdesc>Identifies whether the external reference is an element or entity.</attrdesc>

				<attr>docorsub</attr>
				<type>ENTITY</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the entity name of the external document as declared in the entity declarations at the top of the tagged instance. Other attributes are not included because at this time - they are not applicable during a period of alpha test and will be added to the TDT as the options are explored and implement.</attrdesc>

				<attr>notspace</attr>
				<type>NAME</type>
				<default>ERROR</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>notname</attr>
				<type>NAME</type>
				<default>ERROR</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>notprop</attr>
				<type>NAME</type>
				<default>ERROR</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>direct</attr>
				<type>(direct | indirect)</type>
				<default>indirect</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>locsrc</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>cantcnst</attr>
				<type>NAME</type>
				<default>ERROR</default>
				<attrdesc>Used in conjunction with HyTime to set up independent and contextual links.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>nomen</tag>
		<long>Nomenclature</long>
		<desc>Identifies the nomenclature of the equipment on the title page and the difference data sheet.</desc>
		<source>4.5.1.3.4 & 4.7.3.3.1</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>ddsheet, ipbdesc, ipbserrow, ipbsertable, and prtitle</usedin>
		<ents>text, exclus, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>none</tag>
		<long>None</long>
		<desc>Allows you to opt for none instead of having the tpdrtbl.</desc>
		<source>None.</source>
		<contmdl>EMPTY</contmdl>
		<usedin>tpdr</usedin>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>note</tag>
		<long>Note</long>
		<desc>Identifies a NOTE in the manual.</desc>
		<source>4.3.10</source>
		<contmdl>(para*)  -(randlist | deflist | seqlist | figure | table | foldout | objmedia | warning | caution)</contmdl>
		<usedin>Allowed anywhere except: lep, contents, illuslist, volillustlist, tablelist, voltablelist, ipbnumindex, ipbrfdsindx, glossary, foldoutsect, title, index</usedin>
		<ents>list, exclus, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>nsn</tag>
		<long>National Stock Number</long>
		<desc>Identifies the national stock number of the equipment on the title page.</desc>
		<source>4.5.1.3.4</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>prtitle</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>nsp</tag>
		<long>Nuclear Surety Procedures</long>
		<desc>Identifies the nsp symbol. Use of this element will cause the nsp symbol to appear at that point in the running text. The nsp attribute should be used to place the nsp symbol between a paragraph/step number and text.</desc>
		<source>4.3.10.2</source>
		<contmdl>EMPTY</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>oadr</tag>
		<long>Official Authority Downgrade Review Notice</long>
		<desc>Identifies the official authority downgrade review notice on the title page. This notice is used only on classified manuals.</desc>
		<source>4.4 & 4.5.1.10</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>downgrd</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>object</tag>
		<long>Multimedia Object</long>
		<desc>Developed for use in interactive manuals to evoke multimedia applications.</desc>
		<source>None.</source>
		<contmdl>(param*)</contmdl>
		<usedin>objmedia, subobjmed, abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>secur and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>objectno</attr>
				<type>ENTITY</type>
				<default>#REQUIRED</default>
				<attrdesc>References the object number of the application being referenced.</attrdesc>

				<attr>reprowid</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides width of object being invoked, especially if graphic or foldout from external document.</attrdesc>

				<attr>reprodep</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides depth of object being invoked, especially if graphic or foldout from external document.</attrdesc>

				<attr>type</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides details about the type of applications being referenced.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>objmedia</tag>
		<long>Object Media</long>
		<desc>Developed for use in interactive manuals to evoke multimedia applications. Defines details about the external application being invoked.</desc>
		<source>None.</source>
		<contmdl>(title, ((subobjmed, subobjmed+) | object)) -(figure | table | foldout | objmedia)</contmdl>
		<usedin>Globally included in appendix, chapter, and ddchapter</usedin>
		<ents>exclus, yesorno, bodyatt, and secur</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>esds</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Electrostatic Discharge Sensitive. All paragraphs which address handling or maintenance which could damage *** ESDS *** parts shall be identified by the esds symbol by setting attribute equal to 1.</attrdesc>

				<attr>nsp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Nuclear Surety Procedures.  A **NSP** symbol will appear when set equal to 1.</attrdesc>

				<attr>fcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Fracture Critical Process. All paragraphs which address Fracture Critical Process shall be identified by the *** FCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Process. All paragraphs which address Hardness Critical Process shall be identified by the *** HCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Item. All paragraphs which address Hardness Critical Item shall be identified by the *** HCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>ocp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Process. All paragraphs which address observable critical processes shall be identified by the *** OCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>oci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Item. All paragraphs which address observable critical items shall be identified by the *** OCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>oci</tag>
		<long>Observable Critical Item</long>
		<desc>Identifies the OCI symbol. Use of this element will cause the OCI symbol to appear at that point in the running text. This element should only be used in running text, e.g. to define the OCI symbol in a paragraph. The oci attribute should be used to place the OCI symbol between a paragraph/step number and text.</desc>
		<source>4.3.10.6</source>
		<contmdl>EMPTY</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
