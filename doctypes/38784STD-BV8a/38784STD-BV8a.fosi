</att>

<att logic="and">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<reset resetlist="para0ct tabct figct">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<savetext textid="foliostr" conrule="#CONTENT(label),\-\">
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="\Chapter \,#CONTENT(label)">
	<savetext textid="prefix.st" conrule="#CONTENT(label),\.\">
	<savetext textid="labelstr" conrule="#CONTENT(label)">
	<savetext textid="tabfigprefix.st" conrule="#CONTENT(label),\-\">
	<usetext source="\CHAPTER \,startuline,labelstr,enduline">
	<subchars charsubsetref="allcap14.csub">
	<postsp nominal="8pt">	</subchars>
	</usetext>

	<usetext source="dd-chapsecur.str,\DIFFERENCE DATA SHEETS\">
	<subchars charsubsetref="allcap14.csub">
	<postsp nominal="8pt">	</subchars>
	</usetext>

	<savetext textid="voltocmatter" conrule="<toclinea>,labelstr,@1.5em,dd-chapsecur.str,\DIFFERENCE DATA SHEETS\,tocfill,</toclinea>" append="1">
	<savetext textid="voltocmatter" conrule="<tocnumchap>,pgnumber,</tocnumchap>" append="1">
	<savetext textid="voltocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinea>,labelstr,@1.5em,dd-chapsecur.str,\DIFFERENCE DATA SHEETS\,tocfill,</toclinea>" append="1">
	<savetext textid="tocmatter" conrule="<tocnumchap>,pgnumber,</tocnumchap>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<charsubset>
	<reset resetlist="para0ct tabct figct">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<enumerat increm="1" enumid="chapenum">
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="\Chapter \,chapenum">
	<savetext textid="tabfigprefix.st" conrule="chapenum,\-\">
