	  <!--=============================================-->
	<!-- qualficiation element content model								 -->
	<!--=============================================-->
	<xs:complexType name="qualificationType">
		    <xs:sequence>
			      <xs:element name="value" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Specific value provided in case of a local qualfier Value must match pattern or an enumerated value if provided in qualifierRep.</xs:documentation>
				        </xs:annotation>
				        <xs:complexType mixed="true">
					          <xs:choice minOccurs="0" maxOccurs="unbounded">
						            <xs:element ref="emphasis"/>
						            <xs:element ref="symbol"/>
						            <xs:element ref="dmRef"/>
						            <xs:element ref="externalRef"/>
						            <xs:element ref="multimedia"/>
						            <xs:element ref="extApplication"/>
					          </xs:choice>
				        </xs:complexType>
			      </xs:element>
		    </xs:sequence>
		    <xs:attribute name="qualifierIdent" type="xs:NCName" use="required">
			      <xs:annotation>
				        <xs:documentation>identification of a qualifier defined in the qualifier repository DM</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
</xs:schema>