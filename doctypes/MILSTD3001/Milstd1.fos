<!--OPERATIONS PROCEDURES-->
<e-i-c gi="opproc"><?Pub Dtl>
<charlist envname="tableenv">
<presp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<postsp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<textbrk startln="1" endln="1">
<span span="1">
<usetext
source='!<table rowsep="0"><tgroup cols="3"><colspec colname="col1" align="left"/><colspec colname="col2"
align="left"/><colspec colname="col3"
align="left"/><spanspec spanname="span1to3" namest="col1" nameend="col3"/><thead><row rowsep="1"><entry align="center"><bold>PROCEDURE</bold></entry><entry align="center"><bold>NORMAL INDICATION</bold></entry><entry align="center"><bold>CORRECTIVE ACTION</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
<reset
resetlist="table.app tableconttxt tabletxt reftxt condtxt col1.app col2.app col3.app">
<reset resetlist="tfnnumct tfnalphact">
<reset resetlist="paract step1ct">&ic.characteristics.clear.savetext;
</charlist>&ic.characteristics.att;&task.number.set;</e-i-c>
<e-i-c gi="title" context="opproc"><?Pub Dtl>
<charlist charsubsetref="title1">
<indent inherit="0" leftind="@3pi" firstln="*-3pi">
<postsp minimum="11" nominal="12" maximum="12" priority="high">
<keeps next="1">
<textbrk startln="1" endln="1">
<span span="1">
<savetext textid="alphaidxlvl3.txt" conrule="#CONTENT" append="0">
<savetext textid="alphaindex.app"
conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixsub2>,alphaidxlvl3.txt,</ixsub2>,<ixpgstr>,wpct.txt[BO],\/\,foliostr[BO],</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
append="1">
<savetext textid="alphaindex2.app"
conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixsub2>,alphaidxlvl3.txt,</ixsub2>,<ixpgstr>,wpct.txt[BO],\/\,foliostr[BO],</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
append="1">
<savetext textid="strAlphaLvl3.Pg" conrule="foliostr[BO]">
<savetext textid="a-volX.txt"
conrule="<aisystementry>,<name>,alphaidxlvl1.txt,</name>,<aiwpvolentry>,<title>,alphaidxlvl2.txt,</title>,<tmidno>,dashstr,</tmidno>,<reference>,wpct.txt[BO],</reference>,<aiwpsubentry>,<title>,alphaidxlvl3.txt,</title>,<reference>,wpct.txt[BO],\/\,foliostr[BO],</reference>,</aiwpsubentry>,</aiwpvolentry>,</aisystementry>,\&#RE;\"
append="1">
<usetext source="taskparanum,\. \" placemnt="before">
<subchars charsubsetref="titlefont"></subchars>
</usetext>
<usetext source="\. \" placemnt="after">
<subchars charsubsetref="titlefont"></subchars>
</usetext>&ic.characteristics.usetext;</charlist>
</e-i-c>
<e-i-c gi="table" context="opproc"><?Pub Dtl>
<charlist envname="tableenv"></charlist>
</e-i-c>
<!--Step-->
<e-i-c gi="step" context="* opproc" occur="all"><?Pub Dtl>
<charlist charsubsetref="calist1">
<savetext textid="table.app"
conrule='!<row>!,nobrk.txt,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">&ic.characteristics.clear.savetext;
<reset
resetlist="nobrk.txt row.app col1.app col2.app col3.app tabletxt reftxt condtxt">
</charlist>&ic.characteristics.att;
<att>
<specval attname="label" attval="#NONE">
<charsubset><?Pub Dtl>
<enumerat increm="1" enumid="step1ct">
<savetext textid="step1cttxt" conrule="step1ct,\.\,@1.7pi">
<savetext textid="step1num" conrule="step1ct"></charsubset>
</att>
<att>
<specval attname="label" attval="#ANY">
<fillval attname="label" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="step1txt">
<savetext textid="step1cttxt" conrule="step1txt,\.\,@1.7pi">
<savetext textid="step1num" conrule="step1cttxt"></charsubset>
</att>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="step1num"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="step * opproc" occur="first"><?Pub Dtl>
