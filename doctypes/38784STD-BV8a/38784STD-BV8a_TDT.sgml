				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>lrpentry</tag>
		<long>List of Related Publications Entry</long>
		<desc>Identifies an entry in the list of related publications. When the value of the id attribute is specified via the xrefid attribute of the extref element, the title of the publication appears. Please note: According to spec, only the tmidno and title elements may be used for the lrp. The partno, modelno, and typedes elements were left in only for backwards compatability and possible future expansion.</desc>
		<source>4.5.9.2</source>
		<contmdl>((partno | (modelno | typedes))*, tmidno+, title)</contmdl>
		<usedin>lrptable</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
