	</ele>
	<ele>
		<tag>ipbrfdsindx</tag>
		<long>Reference Designator Index</long>
		<desc>Identifies the fourth section of the ipb chapter.</desc>
		<source>3.8.1 MIL-PRF-38807</source>
		<contmdl>(ipbrfdsgrp) -(note) +(ipbgroup10)</contmdl>
		<usedin>ipbchap</usedin>
		<ents>chapatt</ents>
		<specatts>
			<attrtbl>
				<attr>autobuild</attr>
				<type>CDATA</type>
				<default>#CONREF</default>
				<attrdesc>This attribute should be set equal to 1 when the reference designator index is autogenerated.</attrdesc>

				<attr>type</attr>
				<type>(refdes | sssn | both)</type>
				<default>refdes</default>
				<attrdesc>Defines whether the reference designator index includes the refdes element, the sssn element or both.</attrdesc>

				<attr>cols</attr>
				<type>(2 | 3)</type>
				<default>3</default>
				<attrdesc>Defines the number of columns for the reference designator index.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>ipbserialization</tag>
		<long>Serialization</long>
		<desc>Identifies the serialization paragraph in the ipb foreword.</desc>
		<source>3.5.2 MIL-PRF-38807</source>
		<contmdl>(title, warning*, caution?, note?, (para, note?)?, (step1, step1+)?, subpara1*, ipbsertable)</contmdl>
		<usedin>ipbfwordchap</usedin>
		<ents>parazero and para0att</ents>
		<specatts>
			<attrtbl>
				<attr>emergency</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates that the primary paragraph will produce an emergency border on the page when set equal to 1.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>esds</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Electrostatic Discharge Sensitive. All paragraphs which address handling or maintenance which could damage *** ESDS *** parts shall be identified by the esds symbol by setting attribute equal to 1.</attrdesc>

				<attr>nsp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Nuclear Surety Procedures.  A **NSP** symbol will appear when set equal to 1.</attrdesc>

				<attr>fcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Fracture Critical Process. All paragraphs which address Fracture Critical Process shall be identified by the *** FCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hcp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Process. All paragraphs which address Hardness Critical Process shall be identified by the *** HCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>hci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Hardness Critical Item. All paragraphs which address Hardness Critical Item shall be identified by the *** HCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>ocp</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Process. All paragraphs which address observable critical processes shall be identified by the *** OCP *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>oci</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Observable Critical Item. All paragraphs which address observable critical items shall be identified by the *** OCI *** symbol by setting attribute equal to 1.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>ipbserrow</tag>
		<long>Serialization Table Row</long>
		<desc>Container element for the row of the serialization table. Element added to allow for the insertion/deletion of entire rows.</desc>
		<source>3.5.2 MIL-PRF-38807</source>
		<contmdl>(nomen, modelno, serno)</contmdl>
		<usedin>ipbsertable</usedin>
