<span span="1"></charlist>
</e-i-c>
<!--WP/Page and Figure Change History-->
<e-i-c gi="chghist"><?Pub Dtl>
<charlist charsubsetref="listspace">
<span span="3">
<usetext
source="\WP/Page No.\,2.2pi,\Change No.\,3pi,\WP/Page No.\,2.2pi,\Change No.\,3pi,\WP/Page No.\,2.2pi,\Change No.\">
<subchars charsubsetref="titlefont">
<textbrk startln="1" endln="1">
<span span="1">&nie.hist.rule;</subchars>
</usetext>
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext
source="\WP/Page No.\,2.2pi,\Change No.\,3pi,\WP/Page No.\,2.2pi,\Change No.\,3pi,\WP/Page No.\,2.2pi,\Change No.\">
<subchars charsubsetref="titlefont">
<textbrk startln="1" endln="1">
<span span="1">
<float flidref="pagefloat" width="page" scope="chghist">&nie.hist.rule;
</subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="figchist"><?Pub Dtl>
