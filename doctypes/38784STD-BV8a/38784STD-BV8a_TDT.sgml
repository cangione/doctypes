	<ele>
		<tag>subfig</tag>
		<long>Subfigure</long>
		<desc>Identifies a subfigure. This element is used for multisheet illustrations, each sheet being a subfigure. The FOSI will automatically generate the sheet count (e.g Sheet 1 of 10, Sheet 2, etc.)</desc>
		<source>4.2.4.2</source>
		<contmdl>((graphic, legend?) | tabdisplay)</contmdl>
		<usedin>figure and foldout</usedin>
		<ents>chgatt and secur</ents>
		<specatts>
			<attrtbl>
				<attr>orient</attr>
				<type>(port | land1)</type>
				<default>port</default>
				<attrdesc>Defines the orientation of the figure.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>subfigfo</tag>
		<long>Subfigure Foldout</long>
		<desc>Identifies a subfigure used on a foldout. This element allows the author to switch between foldouts and regular page sizes inside a figure.</desc>
		<source>4.2.4.2</source>
		<contmdl>((graphic, legend?) | tabdisplay)</contmdl>
		<usedin>figure and foldout</usedin>
		<ents>yesorno, chgatt, and secur</ents>
		<specatts>
			<attrtbl>
				<attr>orient</attr>
				<type>(port | land1)</type>
				<default>port</default>
				<attrdesc>Defines the orientation of the figure.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to assign an applicability/effectivity reference to this element.</attrdesc>

				<attr>pgstyle</attr>
				<type>(11x17 | 11x20.5 | 11x24 | 11x27.5 | 11x31 | 11x34.5 | 11x38 | 11x41.5 | 11x45)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the pagesize for the foldout</attrdesc>

				<attr>blankapron</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Toggle to indicate whether the foldout includes a blank apron. A value of '1' indicates that the foldout will have a blank apron, a value of '0' indicates that the foldout will not have a blank apron.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

