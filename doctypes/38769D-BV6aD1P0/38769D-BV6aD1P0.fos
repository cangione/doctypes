<spanspec namest="col3" nameend="col4" spanname="SPAN2">
<spanspec namest="col1" nameend="col9" spanname="SPANall">!'
placemnt="before">
<savetext textid="ipbpl0tbl-header.txt"
conrule='!<thead>
<row rowsep="1">
<?PubTbl row rht="0pt">
<entry spanname="SPAN1" colsep="0" rowsep="1" align="center"></entry>
<entry spanname="SPAN2" colsep="0" rowsep="1" align="center"></entry>
<entry colsep="0" rowsep="1" align="center"></entry>
<entry colsep="0" rowsep="1" align="center"></entry>
<entry colsep="0" rowsep="1" align="center"></entry>
<entry colsep="0" rowsep="1" align="center"></entry>
<entry colsep="0" rowsep="1" align="center"></entry>
</row>
<row valign="bottom">
<entry spanname="SPAN1" morerows="1" colsep="1" rowsep="1" align="center">!,\FIGURE & INDEX/ SHEET NO.\,<sp.fmt>,\ \,</sp.fmt>,!</entry>
<entry spanname="SPAN2" morerows="1" colsep="1" rowsep="1" align="center">!,\PART NUMBER\,<sp.fmt>,\ \,</sp.fmt>,!</entry>
<entry morerows="1" colsep="1" rowsep="1" align="center">!,\CAGE\,<sp.fmt>,\ \,</sp.fmt>,!</entry>
<entry rowsep="0" align="center" valign="bottom">!,\DESCRIPTION\,!</entry>
<entry morerows="1" rowsep="1" align="center">!,\UNITS PER ASSY\,<sp.fmt>,\ \,</sp.fmt>,!</entry>
<entry morerows="1" rowsep="1" align="center">!,\USABLE ON CODE\,<sp.fmt>,\ \,</sp.fmt>,!</entry>
<entry morerows="1" rowsep="1" align="center">!,\SMR CODE\,<sp.fmt>,\ \,</sp.fmt>,!</entry>
</row>
<row valign="bottom">
<entry rowsep="1" align="left">!,\1\,0.5em,\2\,0.5em,\3\,0.5em,\4\,0.5em,\5\,0.5em,\6\,0.5em,\7\,<sp.fmt>,\ \,</sp.fmt>,!</entry>
</row>
</thead>!'>
<usetext
source='<font-8pt.fmt>,!<table frame="all">
<tgroup cols="9">
<?PubTbl tgroup ctmarg="2pt" cbmarg="0.5pt">!,ipbpl0tbl-structure.txt,ipbpl0tbl-header.txt,!<tbody>!,pl0tbl-tgroups.txt,!</tbody>
</tgroup>
</table>!,</font-8pt.fmt>' placemnt="after"></usetext>
