<e-i-c gi="TITLE" context="dddesc * ddchapter * body" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="para0.title.csub">
	<quadding quad="left" lastquad="relative">
	<keeps keep="1" scope="col" next="1">
	<savetext textid="title-appear" conrule="\yes\">
	<usetext source="LABELSTR,1em">
	<subchars>
	<highlt scoring="0">
	<textbrk startln="1">	</subchars>
	</usetext>

	<usetext source="secur.str,graphic.str,applicref.str">
	<subchars>
	<highlt scoring="0">	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="inschlvl" attloc="dddesc" attval="#NE#0">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

