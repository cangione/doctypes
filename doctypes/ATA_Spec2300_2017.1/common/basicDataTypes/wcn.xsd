	<xs:annotation>
		    <xs:documentation>Version Number: 2017.1</xs:documentation>
		    <xs:documentation>Revision Date: 2017-10-31</xs:documentation>
		    <xs:documentation>Revision Comments: Spec 2300 revision 2017.1</xs:documentation>
	  </xs:annotation>
	  <xs:include schemaLocation="../attrs/commonAttrs.xsd"/>
	  <xs:include schemaLocation="text.xsd"/>
	  <xs:include schemaLocation="./figure.xsd"/>
	  <xs:annotation>
		    <xs:documentation>This Schema file contains definitions for Warning, Caution and Note elements.</xs:documentation>
	  </xs:annotation>
	  <!--=====================================================-->
	<!--  Warning element definition -->
	<!--=====================================================-->
	<xs:element name="warning" type="warningType">
		    <xs:annotation>
			      <xs:documentation>Call attention to the use of materials, processes, methods, procedures, or limits, which must be followed precisely to avoid injury to persons.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=====================================================-->
	<xs:complexType name="warningType">
		    <xs:choice minOccurs="0" maxOccurs="unbounded">
			      <xs:group ref="textGroupType"/>
			      <xs:element ref="figure"/>
		    </xs:choice>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=====================================================-->
	<!--  Caution element definition -->
	<!--=====================================================-->
	<xs:element name="caution" type="cautionType">
		    <xs:annotation>
			      <xs:documentation>Call attention to the use of materials, processes, methods, procedures, or limits, which must be followed precisely to avoid damage to equipment.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=====================================================-->
	<xs:complexType name="cautionType">
		    <xs:choice minOccurs="0" maxOccurs="unbounded">
			      <xs:group ref="textGroupType"/>
			      <xs:element ref="figure"/>
		    </xs:choice>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=====================================================-->
	<!--  Note element definition -->
	<!--=====================================================-->
	<xs:element name="note" type="noteType">
		    <xs:annotation>
			      <xs:documentation>Descriptive information used to provide recommendations or additional information, but not directly required for the accomplishment of a procedure.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=====================================================-->
	<xs:complexType name="noteType">
		    <xs:annotation>
			      <xs:documentation>Descriptive information used to provide recommendations or additional information, but not directly required for the accomplishment of a procedure.</xs:documentation>
		    </xs:annotation>
		    <xs:choice minOccurs="0" maxOccurs="unbounded">
			      <xs:group ref="textGroupType"/>
			      <xs:element ref="figure"/>
		    </xs:choice>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=====================================================-->
	<!--  WCN group  -->
	<!--=====================================================-->
	<xs:group name="wcnGroupType">
		    <xs:annotation>
			      <xs:documentation>A grouping of elements that provide advisory information of special significance or emphasis.</xs:documentation>
		    </xs:annotation>
		    <xs:choice>
			      <xs:element ref="warning"/>
			      <xs:element ref="caution"/>
			      <xs:element ref="note"/>
		    </xs:choice>
	  </xs:group>
</xs:schema>