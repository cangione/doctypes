		<source>4.3.10.3</source>
		<contmdl>EMPTY</contmdl>
		<usedin>ipbfwordchap, abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

