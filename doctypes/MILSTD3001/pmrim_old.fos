<!ENTITY TaskCard.PageRes.Screen "<savetext textid='card.rules.text' conrule='!<row>!,row.height.text,!<entry></entry><entry></entry><entry spanname=&#34;span3to11&#34;></entry></row>!'>
<savetext textid='card.header.text' placemnt='after' conrule='!<row rowsep=&#34;1&#34;><entry align=&#34;left&#34; valign=&#34;top&#34; spanname=&#34;span1to2&#34;><p.bold>CARD </p.bold><p.para-noindent><p.caps>!,card.number.screen.text[BO],!</p.caps></p.para-noindent></entry><entry align=&#34;left&#34; spanname=&#34;span3to7&#34;><p.ninept><p.caps>!,service.tm.id.number.text[BO],!</p.caps></p.ninept><p.para-noindent><p.ninept><p.bold>DATE </p.bold><p.caps>!,pub.date.text,!</p.caps></p.ninept></p.para-noindent></entry><entry spanname=&#34;span8to9&#34; valign=&#34;top&#34; align=&#34;left&#34;><p.bold>CHANGE</p.bold><p.para-noindent><p.bold>NO.   </p.bold>!,change.number.text[BO],!</p.para-noindent></entry><entry spanname=&#34;span10to11&#34;><p.caps>!,card.title.text,!</p.caps></entry></row><row rowsep=&#34;1&#34;><entry><p.bold>WORK</p.bold><p.para-noindent><p.bold>AREA/</p.bold></p.para-noindent><p.para-noindent><p.bold>ZONE</p.bold></p.para-noindent></entry><entry align=&#34;center&#34;><p.bold>C</p.bold><p.para-noindent><p.bold>R</p.bold></p.para-noindent><p.para-noindent><p.bold>S</p.bold></p.para-noindent><p.para-noindent><p.bold>N</p.bold></p.para-noindent></entry><entry spanname=&#34;span3to4&#34; valign=&#34;top&#34; align=&#34;center&#34;><p.bold>TIME </p.bold><p.para-noindent>!,time.1.text,! </p.para-noindent></entry><entry colsep=&#34;0&#34; align=&#34;left&#34;><p.bold>RTG. </p.bold><p.para-noindent><p.bold>NO. </p.bold></p.para-noindent></entry><entry spanname=&#34;span6to7&#34;>!,rtg.text,!<p.para-noindent>!,rtg.block.text,!</p.para-noindent></entry><entry colsep=&#34;0&#34;><p.bold>MOS. </p.bold><p.para-noindent><p.bold>NO. </p.bold></p.para-noindent></entry><entry>!,mos.text,!<p.para-noindent>!,mos.block.text,!</p.para-noindent></entry><entry><p.caps>!,task.title.text,!</p.caps></entry><entry align=&#34;left&#34; valign=&#34;middle&#34;><p.bold>ELEC PWR </p.bold>!,elecpwrtxt,!<p.para-noindent><p.bold>HYD PWR </p.bold>!,hydpwrtxt,!</p.para-noindent><p.para-noindent><p.bold>COND AIR </p.bold>!,condairtxt,!</p.para-noindent></entry></row>!'><savetext textid='card.footer.text' placemnt='after' conrule='!<row><entry></entry><entry></entry><entry spanname=&#34;span3to9&#34; align=&#34;left&#34; colsep=&#34;0&#34;>!,card.delete.note.text,!</entry><entry spanname=&#34;span10to11&#34; align=&#34;left&#34;>!,card.end.text,!</entry></row>!'>">
