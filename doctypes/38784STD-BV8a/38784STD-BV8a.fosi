<e-i-c gi="LEGEND" context="figure" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1"></charlist>

<att logic="and">
<specval attname="nxtpg" attloc="figure" attval="#EQ#0">
<charsubset>
	<keeps keep="1" scope="page" next="1" prev="1">
	<textbrk startln="1" endln="1"></charsubset>
</att>

<att logic="and">
<specval attname="nxtpg" attloc="figure" attval="#EQ#1">
<charsubset>
	<textbrk startpg="next" startln="1" endln="1"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attloc="figure" attval="#NONE">
<specval attname="subfig.flag" attloc="#FOSI" attval="#EQ#\no\">
<specval attname="legend" attloc="figure" attval="#EQ#1">
<specval attname="nxtpg" attloc="figure" attval="#EQ#0">
<charsubset>
	<usetext source="\Figure \,fignum,\.\,1em,figtitle,\.\" placemnt="after">
	<subchars>
	<font weight="bold">
	<quadding quad="center" lastquad="lcenter">
	<presp nominal="1pi">
	<postsp nominal="2pi">
	<textbrk startln="1" endln="1">	</subchars>
	</usetext>
</charsubset>
