conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixpgstr>,wpct.txt[BO],\/  \,</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
placemnt="after" append="1">
<savetext textid="a-volX.txt"
conrule="<aisystementry>,<name>,alphaidxlvl1.txt,</name>,<aiwpvolentry>,<title>,alphaidxlvl2.txt,</title>,<tmidno>,dashstr,</tmidno>,<reference>,wpct.txt[BO],</reference>,</aiwpvolentry>,</aisystementry>,\&#RE;\"
placemnt="after" append="1"></charlist>
</e-i-c>
