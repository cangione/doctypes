<savetext textid="table.app" conrule="!<row>!,row.app,!</row>!"
placemnt="after" append="1"></charlist>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tableftnotenum"></charsubset>
</att>
</e-i-c>
<!--WIRE TYPE LIST-->
<e-i-c gi="wtypelist"><?Pub Dtl>
<charlist charsubsetref="paragraph space">
<enumerat increm="1" enumid="tablect">
<savetext textid="tablenum" conrule="tablect">
<usetext
source='!<table><tgroup cols="5"><colspec colname="col1" align="center" colwidth="6pi"/><colspec colname="col2"
align="center" colwidth="5pi"/><colspec colname="col3" align="left" colwidth="11pi"/><colspec colname="col4" align="center" colwidth="10pi"/><colspec colname="col5" align="left" colwidth="10pi"/><spanspec
spanname="span1to5" namest="col1" nameend="col5"/><thead><row><entry align="center"><bold>WIRE TYPE CODE</bold></entry><entry align="center"><bold>WIRE GAGE</bold></entry><entry align="center"><bold>PART NUMBER</bold></entry><entry align="center"><bold>WIRE STRIPPER</bold></entry><entry align="center"><bold>WIRE/CABLE DESCRIPTION</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
<reset
resetlist="table.app row.app col1.app col2.app col3.app col4.app col5.app">
</charlist>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tablenum"></charsubset>
</att>
</e-i-c>
<e-i-c gi="title" context="wtypelist"><?Pub Dtl>
<charlist charsubsetref="table.title">
<postsp minimum=".5em" nominal=".5em" maximum=".5em" priority="none">
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="tablenumtxt,#CONTENT,\ (Cont)\">
<subchars charsubsetref="table.title.cont">
<float scope="wtypelist"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="table" context="wtypelist"><?Pub Dtl>
<charlist envname="tableenv"></charlist>
</e-i-c>
<e-i-c gi="wtypeentry"><?Pub Dtl>
<charlist charsubsetref="paragraph space">
<savetext textid="row.app"
conrule='!<entry align="center" colname="col1">!,col1.app,!</entry><entry align="center" colname="col2">!,col2.app,!</entry><entry align="left" colname="col3">!,col3.app,!</entry><entry align="center" colname="col4">!,col4.app,!</entry><entry align="left" colname="col5">!,col5.app,!</entry>!'
placemnt="after">
<savetext textid="table.app" conrule="!<row>!,row.app,!</row>!"
placemnt="after" append="1">
<reset resetlist="col1.app col2.app col3.app col4.app col5.app">
</charlist>&table.number.set;</e-i-c>
<e-i-c gi="wtype" context="* wtypelist"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col1.app"
conrule="<ppara-noindent>,#CONTENT,</ppara-noindent>"></charlist>
</e-i-c>
