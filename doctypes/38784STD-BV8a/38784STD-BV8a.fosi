<e-i-c gi="TITLE" context="subpara2 * body" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="subpara2.title.csub">
	<keeps keep="1" scope="col" next="1">
	<savetext textid="title-appear" conrule="\yes\">
	<usetext source="LABELSTR,1em">
	<subchars>
	<highlt scoring="0">
	<textbrk startln="1">	</subchars>
	</usetext>

	<usetext source="secur.str,graphic.str,applicref.str">
	<subchars>
	<highlt scoring="0">	</subchars>
	</usetext>

	<usetext source="1.5em" placemnt="after">
	<subchars>
	<highlt scoring="0">
	<keeps scope="line" prev="1">	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="index" attloc="doc" attval="#EQ#0">
<charsubset>
	<savetext textid="voltocmatter" conrule="<toclinec>,1.5em,labelstr,@6.5em,secur.str,applicref.str,#CONTENT,sssn.st,tocfill,<tocnumx>,sp20pgnum,</tocnumx>,</toclinec>" append="1">
	<savetext textid="tocmatter" conrule="<toclinec>,1.5em,labelstr,@6.5em,secur.str,applicref.str,#CONTENT, sssn.st,tocfill,<tocnumx>,sp20pgnum, </tocnumx>,</toclinec>" append="1"></charsubset>
</att>
</e-i-c>

<e-i-c gi="PARA" context="subpara2" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="clearstrings">
