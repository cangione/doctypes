	  <xs:include schemaLocation="../basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="../dataManagement/modelIdent.xsd"/>
	  <!--=============================================-->
	<!-- digitalPerformanceInfo element									   -->
	<!--=============================================-->
	<xs:element name="digitalPerformanceInfo">
		    <xs:annotation>
			      <xs:documentation>provided information of a digital performance software</xs:documentation>
		    </xs:annotation>
		    <xs:complexType>
			      <xs:sequence>
				        <xs:element ref="modelIdent"/>
				        <xs:element ref="perfoSoftwareRef"/>
				        <xs:element ref="perfoSoftwareVersion"/>
				        <xs:element ref="perfoDatabaseVersion"/>
			      </xs:sequence>
		    </xs:complexType>
	  </xs:element>
	  <!--=============================================-->
	<!-- perfoSoftwareRef element					  						   -->
	<!--=============================================-->
	<xs:element name="perfoSoftwareRef" type="emphType">
		    <xs:annotation>
			      <xs:documentation>Performance software reference, such as serial number</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=============================================-->
	<!-- perfoSoftwareVersion element					  				   -->
	<!--=============================================-->
	<xs:element name="perfoSoftwareVersion" type="emphType">
		    <xs:annotation>
			      <xs:documentation>Performance software version</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=============================================-->
	<!-- perfoDatabaseVersion element					  				   -->
	<!--=============================================-->
	<xs:element name="perfoDatabaseVersion" type="emphType">
		    <xs:annotation>
			      <xs:documentation>Performance database version</xs:documentation>
		    </xs:annotation>
	  </xs:element>
</xs:schema>