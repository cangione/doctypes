<e-i-c gi="ipbsertable" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<span span="1"></charlist>

<att logic="and">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="xreftype" conrule="\Table\">
	<savetext textid="xrefstr" conrule="#CONTENT(label)">
	<savetext textid="labelstr" conrule="#CONTENT(label)">
	<savetext textid="tabtitle" conrule="\Serialization\">
	<savetext textid="lotmatter" conrule="<lotlinec>,labelstr,@3em,secur.str,applicref.str,tabtitle[BO],tocfill,<tocnumx>,pgnumber,</tocnumx>,</lotlinec>" append="1">
	<usetext source="<s.table>" placemnt="before">	</usetext>

	<usetext source="\Table \,labelstr,\.\,1em,secur.str,applicref.str,tabtitle[BO]">
	<subchars>
	<font weight="bold">
	<leading lead="12pt">
	<quadding quad="center" lastquad="lcenter">
	<postsp nominal="18pt" condit="keep" priority="high">
	<subsetatts subsettype="title" titlepos="above" subsetusage="normal">	</subsetatts>
	</subchars>
	</usetext>

	<usetext source="\Table \,labelstr,\.\,1em,tabtitle[BO],\&mdash;Continued\">
	<subchars>
	<font weight="bold">
	<leading lead="12pt">
	<quadding inherit="0" quad="center" lastquad="lcenter">
	<presp nominal="18pt" condit="keep" priority="high">
	<postsp nominal="18pt" condit="keep" priority="high">
	<subsetatts subsettype="title" titlepos="above" subsetusage="continued">	</subsetatts>
	</subchars>
	</usetext>

	<usetext source="<s.tablehead>,<nomen.hd>,\Nomenclature\,</nomen.hd>,   <modelno.hd>,\Model No.\,</modelno.hd>,   <serial.hd>,\Serial No.\,</serial.hd>,   </s.tablehead>">	</usetext>

	<usetext source="<s.tablebody>" placemnt="before">	</usetext>

	<usetext source="</s.tablebody>" placemnt="after">	</usetext>

	<usetext source="</s.table>" placemnt="after">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<charsubset>
	<enumerat increm="1" enumid="tabct">
	<savetext textid="xreftype" conrule="\Table\">
	<savetext textid="xrefstr" conrule="chapenum,\-\,tabct">
	<savetext textid="labelstr" conrule="chapenum,\-\,tabct[AR]">
	<savetext textid="label" conrule="labelstr" saverule="1">
	<savetext textid="tabtitle" conrule="\Serialization\">
	<savetext textid="lotmatter" conrule="<lotlinec>,labelstr,@3em,secur.str,applicref.str,tabtitle[BO],tocfill,<tocnumx>,pgnumber,</tocnumx>,</lotlinec>" append="1">
	<usetext source="<s.table>" placemnt="before">	</usetext>

	<usetext source="\Table \,labelstr,\.\,1em,secur.str,applicref.str,tabtitle[BO]">
	<subchars>
	<font weight="bold">
	<leading lead="12pt">
	<quadding quad="center" lastquad="lcenter">
	<presp nominal="18pt" condit="keep" priority="high">
	<postsp nominal="18pt" condit="keep" priority="high">
	<subsetatts subsettype="title" titlepos="above" subsetusage="normal">	</subsetatts>
	</subchars>
	</usetext>

	<usetext source="\Table \,labelstr,\.\,1em,tabtitle[BO],\&mdash;Continued\">
	<subchars>
	<font weight="bold">
	<leading lead="12pt">
	<quadding inherit="0" quad="center" lastquad="lcenter">
	<presp nominal="18pt" condit="keep" priority="high">
	<postsp nominal="18pt" condit="keep" priority="high">
	<subsetatts subsettype="title" titlepos="above" subsetusage="continued">	</subsetatts>
	</subchars>
	</usetext>

	<usetext source="<s.tablehead>,<nomen.hd>,\Nomenclature\,</nomen.hd>,   <modelno.hd>,\Model No.\,</modelno.hd>,   <serial.hd>,\Serial No.\,</serial.hd>,   </s.tablehead>">	</usetext>

