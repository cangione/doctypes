<e-i-c gi="DATE" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<suppress sup="1">
	<savetext textid="chghiststr" conrule="<chghistline>,chglabel,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.\,1pt,\.                  \,chgenum,                         lepfill,#CONTENT,1em,</chghistline>" append="1"></charlist>

