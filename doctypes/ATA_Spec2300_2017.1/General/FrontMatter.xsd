	<xs:annotation>
		    <xs:documentation>Version Number: 2017.1</xs:documentation>
		    <xs:documentation>Revision Date: 2017-10-31</xs:documentation>
		    <xs:documentation>Revision Comments: Spec 2300 revision 2017.1</xs:documentation>
	  </xs:annotation>
	  <xs:include schemaLocation="../common/basicDataTypes/figure.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/multimedia.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/extApplication.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/wcn.xsd"/>
	  <xs:include schemaLocation="../common/procedure/introducedActions.xsd"/>
	  <xs:redefine schemaLocation="../common/dataManagement/dmodule.xsd">
		    <xs:complexType name="contentElemType">
			      <xs:complexContent>
				        <xs:extension base="contentElemType">
					          <xs:sequence>
						            <xs:element ref="frontMatter"/>
					          </xs:sequence>
				        </xs:extension>
			      </xs:complexContent>
		    </xs:complexType>
	  </xs:redefine>
	  <xs:include schemaLocation="../common/basicDataTypes/extensibleInterface.xsd"/>
	  <!--=============================================-->
	<!-- dmodule Element Declaration-->
	<!--=============================================-->
	<xs:element name="dmodule" type="dmoduleElemType"/>
	  <!--=============================================-->
	<!-- frontMatter Element Declaration (DM  root) -->
	<!--=============================================-->
	<xs:element name="frontMatter" type="frontMatterType">
		    <xs:annotation>
			      <xs:documentation>front Matter info from regulatory agency</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=============================================-->
	<!-- frontMatter Type Definition -->
	<!--=============================================-->
	<xs:complexType name="frontMatterType">
		    <xs:sequence>
			      <xs:element name="title" type="nameType">
				        <xs:annotation>
					          <xs:documentation>a heading for the info to follow</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:choice>
				        <xs:element name="description" type="frontMatterDescriptionType">
					          <xs:annotation>
						            <xs:documentation>front Matter content</xs:documentation>
					          </xs:annotation>
				        </xs:element>
				        <xs:element name="subLevel" type="frontMatterSubLevelType">
					          <xs:annotation>
						            <xs:documentation>container to allow for hierarchy of info</xs:documentation>
					          </xs:annotation>
				        </xs:element>
			      </xs:choice>
			      <xs:element name="subLevel" type="frontMatterSubLevelType" minOccurs="0"
                     maxOccurs="unbounded"/>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!--  Description Type Element Definition -->
	<!--=============================================-->
	<xs:complexType name="frontMatterDescriptionType">
		    <xs:choice maxOccurs="unbounded">
			      <xs:group ref="textGroupType"/>
			      <xs:element ref="figure"/>
			      <xs:element ref="multimedia"/>
			      <xs:element ref="extApplication"/>
			      <xs:group ref="wcnGroupType"/>
			      <xs:element name="elementIntroduction" type="elementIntroductionType">
				        <xs:annotation>
					          <xs:documentation>Introduce the presentation of data elements that may be presented elsewhere in the publication.</xs:documentation>
					
				        </xs:annotation>
			      </xs:element>
		    </xs:choice>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <xs:complexType name="elementIntroductionType">
		    <xs:choice maxOccurs="unbounded">
			      <xs:element ref="land"/>
			      <xs:element ref="continueFlight"/>
		    </xs:choice>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- frontMatter subLevel Type Definition -->
	<!--=============================================-->
	<xs:complexType name="frontMatterSubLevelType">
		    <xs:annotation>
			      <xs:documentation>container to allow for hierarchy of info</xs:documentation>
		    </xs:annotation>
		    <xs:sequence>
			      <xs:element name="title" type="nameType">
				        <xs:annotation>
					          <xs:documentation>a heading for the info to follow</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:choice>
				        <xs:element name="description" type="frontMatterDescriptionType">
					          <xs:annotation>
						            <xs:documentation>front Matter content</xs:documentation>
					          </xs:annotation>
				        </xs:element>
				        <xs:element name="subLevel" type="frontMatterSubLevelType">
					          <xs:annotation>
						            <xs:documentation/>
					          </xs:annotation>
				        </xs:element>
			      </xs:choice>
			      <xs:element name="subLevel" type="frontMatterSubLevelType" minOccurs="0"
                     maxOccurs="unbounded"/>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
</xs:schema>