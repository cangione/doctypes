<reset resetlist="page.next.ctr">
<usetext source="\NUMERICAL INDEX OF EFFECTIVE WORK PACKAGES\"
placemnt="before">
<subchars>
<font style="sanserif" size="12pt" weight="bold">
<quadding quad="center">
<postsp minimum="12pt" nominal="12pt" maximum="12pt">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
<usetext source="\NOTE\" placemnt="before">
<subchars>
<font style="sanserif" size="10pt" weight="bold">
<quadding quad="center">
<postsp minimum="12pt" nominal="12pt" maximum="12pt">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
<usetext
source="<niewp.psu>,\Only those work packages and subordinate work packages assigned to this manual are listed in this index, therefore, WP/SWP numbers may not be sequential.\,</niewp.psu>"
placemnt="before">
<subchars>
<font style="serif" size="10pt">
<indent leftind="55pt" rightind="55pt" firstln="55pt">
<quadding quad="center">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
<savetext textid="bookmark-1.tmp"
conrule="\NUMERICAL INDEX OF EFFECTIVE WORK PACKAGES\" append="0">
<savetext textid="bookmarks-1.app"
conrule="!<atidmd:Bookmark><atidmd:Title>!,bookmark-1.tmp,!</atidmd:Title></atidmd:Bookmark>!"
placemnt="after" append="1"></charlist>&att-content-cbar;
<att><?Pub Lcl
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'>
<specval attname="chglevel" attloc="doc" attval="#GE#1">
<charsubset>
<usetext
source="<niewp.psu>,\Insert Change No. \,chgenum,\, work packages and subordinate work packages, dated \,chgdate.txt[BO],\.  Dispose of superseded work packages and subordinate work packages.  If changed pages are issued to a work package or subordinate work package, insert the changed pages in the applicable work package or subordinate work package.  The portion of the text affected in a change or revised WP or SWP is indicated by change bars in the outer margin of each column of text.  Changes to illustrations and diagrams are indicated by pointing hands or shaded areas.\,</niewp.psu>"
placemnt="before">
<subchars>
<font style="serif" size="10pt">
<indent leftind="55pt" rightind="55pt" firstln="55pt">
<quadding quad="center">
<presp minimum="12pt" nominal="12pt" maximum="12pt" condit="discard"
priority="high">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<charsubset>
<usetext
source='!<tabmat frame="topbot"><tgroup cols="4">
<colspec colname="col1" colwidth="5.25pi"><colspec colname="col2" colwidth="7pi">
<colspec colname="col3" colwidth="13.5pi"><colspec colname="col4" colwidth="1.06*">
<thead>
<row rowsep="1"><entry colsep="0" rowsep="1" valign="top" align="center">WP/SWP No.</entry>
<entry colsep="0" rowsep="1" valign="top" align="center">Change<?Pub _newline>
No.</entry><entry colsep="0" rowsep="1" valign="top" align="center">Model<?Pub _newline>
Application</entry><entry colsep="0" rowsep="1" align="center">Title</entry>
</row>
</thead><tbody>
!,niewp-row.app,!
</tbody></tgroup></tabmat>!' placemnt="after"></usetext>
</charsubset>
</att>
<att>
