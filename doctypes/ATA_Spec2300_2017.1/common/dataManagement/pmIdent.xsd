	  <xs:include schemaLocation="./dmIdent.xsd"/>
	  <!--=============================================-->
	<!-- pmIdent Content model												 -->
	<!--=============================================-->
	<xs:element name="pmIdent" type="pmIdentElemType">
		    <xs:annotation>
			      <xs:documentation>PM Status List identification</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="pmIdentElemType">
		    <xs:sequence>
			      <xs:element ref="identExtension" minOccurs="0"/>
			      <xs:element ref="pmCode"/>
			      <xs:element ref="language" minOccurs="0"/>
		    </xs:sequence>
	  </xs:complexType>
	  <xs:element name="pmCode" type="pmCodeElemType">
		    <xs:annotation>
			      <xs:documentation>publication module list code</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="pmCodeElemType">
		    <xs:attribute name="modelIdentCode" type="modelIdentCodeAttType" use="required">
			      <xs:annotation>
				        <xs:documentation>the model identifier using NSPA Model Identification Code list</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="pmIssuer" type="pmIssuerAttType" use="required">
			      <xs:annotation>
				        <xs:documentation>the CAGE code of the publication module issuing company.</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="pmNumber" type="xs:string" use="required">
			      <xs:annotation>
				        <xs:documentation>a unique alphanumeric identifier depending on the model identification code (attribute modelIdentCode) and the issuing authority (attribute pmIssuer).</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="pmVolume" type="pmVolumeAttType" use="required">
			      <xs:annotation>
				        <xs:documentation>the volume of the publication module. Set to "00" if only one volume.</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <xs:simpleType name="pmIssuerAttType">
		    <xs:restriction base="xs:string">
			      <xs:pattern value="[A-Z0-9]{5}"/>
		    </xs:restriction>
	  </xs:simpleType>
	  <xs:simpleType name="pmVolumeAttType">
		    <xs:restriction base="xs:nonNegativeInteger">
			      <xs:pattern value="\d{2}"/>
		    </xs:restriction>
	  </xs:simpleType>
</xs:schema>