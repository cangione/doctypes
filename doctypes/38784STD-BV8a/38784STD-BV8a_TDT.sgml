	<ele>
		<tag>location</tag>
		<long>Location &notuse;</long>
		<desc>Identifies the placement of a floating object such as a figure, table or figure table. This element is globally included on the document element.</desc>
		<source>None.</source>
		<contmdl>EMPTY</contmdl>
		<usedin>Globally included in doc</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>xrefid</attr>
				<type>IDREF</type>
				<default>#REQUIRED</default>
				<attrdesc>Defines the ID of the element that you are referencing. The value of this attribute should match the value of an ID attribute elsewhere in the manual.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
