<!ELEMENT bombliftruck - o (%sect;) >
<!ATTLIST bombliftruck %sectatt; >

<!ELEMENT bombtypemun - o (%sect;) >
<!ATTLIST bombtypemun %sectatt; >

<!ELEMENT cartchafflar - o (%sect;) >
<!ATTLIST cartchafflar %sectatt; >

<!ELEMENT docnnmunbas - - (front, body, rear?) +(pgbrk | brk
				| subjinfo | line | modreq | location) >
				
<!ELEMENT fuzes - o (%sect;) >
<!ATTLIST fuzes %sectatt; >

<!ELEMENT gunpods - o (%sect;) >
<!ATTLIST gunpods %sectatt; >

<!ELEMENT gunpodsdesc - - (%titles;, guns, gunpods?)
				+(figure | table) >
<!ATTLIST gunpodsdesc %chapatt; >

<!ELEMENT guns - o (%sect;) >
<!ATTLIST guns %sectatt; >

<!ELEMENT lnchdispensers - o (%sect;) >
<!ATTLIST lnchdispensers %sectatt; >

<!ELEMENT missrockammo - o (%sect;) >
<!ATTLIST missrockammo %sectatt; >

<!ELEMENT munadapters - o (%sect;) >
<!ATTLIST munadapters %sectatt; >

<!ELEMENT munitacc - o (%sect;) >
<!ATTLIST munitacc %sectatt; >

<!ELEMENT munitdesc - - (%titles;, missrockammo, bombtypemun,
				fuzes, cartchafflar, munitacc)
				+(figure | table) >
<!ATTLIST munitdesc %chapatt; >

<!ELEMENT munitrailers - o (%sect;) >
<!ATTLIST munitrailers %sectatt; >

<!ELEMENT racks - o (%sect;) >
<!ATTLIST racks %sectatt; >

<!ELEMENT sedesc - - (%sedesc;) +(figure | table) >
<!ATTLIST sedesc %chapatt; >

<!-- CCB#: 9977-C-04021-01 -->
<!ELEMENT seic - o (%sect;) >
<!ATTLIST seic %sectatt; >

<!-- CCB#: 9977-C-04021-01 -->
<!ELEMENT seipb - - (seipbfwordpart, seipbplpart, seipbnumindxpart?, seipbrfdsindxpart?) >
<!ATTLIST seipb %sectatt; >

<!-- CCB#: 9977-C-04021-01 -->
<!ELEMENT seipbfwordpart - -  (%ipbforwd;)   +(figure | table) >
<!ATTLIST seipbfwordpart %sectatt; >

<!-- CCB#: 9977-C-04021-01 -->
<!ELEMENT seipbplpart - -  (ipbplgrp+) +(ipbplbrk)>
<!ATTLIST seipbplpart %sectatt; >

<!-- added chgatt to this element. jls -->
<!-- CCB#: 9977-C-04021-01 -->
<!ELEMENT seipbnumindxpart - o  (ipbnumgrp)  +(ipbgroup10) >
<!ATTLIST seipbnumindxpart cols (2 | 3) "3"
                     autobuild NUMBER #CONREF
                     id ID #IMPLIED
		     label CDATA #IMPLIED
		     sssn CDATA #IMPLIED
		     indexid  CDATA  #IMPLIED
		     %secur;
		     %chgatt; > 

<!-- CCB#: 9977-C-04021-01 -->
<!ELEMENT seipbrfdsindxpart - o  (ipbrfdsgrp)  +(ipbgroup10) >
<!ATTLIST seipbrfdsindxpart autobuild NUMBER #CONREF 
                       type (refdes | sssn | both) "refdes"
                       cols (2 | 3) "3"
                       %sectatt; >

<!ELEMENT spectools - o (%sect;) >
<!ATTLIST spectools %sectatt; >

<!-- CCB#: 9977-C-04021-01 -->
<!ELEMENT suppeq - - (%titles;, seic?, seipb?) +(figure | table) >
<!ATTLIST suppeq %chapatt; >

<!ELEMENT suppinfo - - (%titles;, (para0+ | (spectools,
				suppinfosect+))) +(figure | table) >
<!ATTLIST suppinfo %chapatt; >

<!ELEMENT suppinfosect - o (%titles;, para0+) >
<!ATTLIST suppinfosect %sectatt; >

<!ELEMENT suspequipdesc - o (%titles;, racks, lnchdispensers)
				+(figure | table) >
<!ATTLIST suspequipdesc %chapatt; >

<!ELEMENT testadapters - o (%sect;) >
<!ATTLIST testadapters %sectatt; >

<!ELEMENT testequip - o (%sect;) >
<!ATTLIST testequip %sectatt; >

