<?xml version="1.0"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           elementFormDefault="qualified"
           attributeFormDefault="qualified">

<!--**********************************************************************
    *                                                                    *
    *                        S1000D Issue 2                              *
    *                   Document Type Definition                         *
    *                                                                    *
    *                     Release Version 2.0                            *
    *                       Date: 2003-05-31                             *
    *                                                                    *
    * Amendment:-                                                        *
    * 1. New public identifier: Defines element seqnum for data dispatch *
    *                           notes.                                   *
    *====================================================================*
    * Typical invocation:-                                               *
    * <!ENTITY % SEQNUMDDN PUBLIC                                        *
    *   "-//S1000D//ELEMENTS Sequential Number for DDNs 20030531//EN">   *
    * SEQNUMDDN;                                                         *
    ********************************************************************** -->



	<xs:element name="seqnum">
		<xs:annotation>
			<xs:documentation>
    **********************************************************************
    * Define Element seqnum (Sequence Number of DDN within current year) *
    * containing:-                                                       *
    *  Hexadecimal 2-digit number starting at 00.                        *
    **********************************************************************
			</xs:documentation>
		</xs:annotation>
		<xs:simpleType>
		<xs:restriction base="xs:string">
			 <xs:pattern value="[A-Fa-f0-9]{2}"/>
		</xs:restriction>
	</xs:simpleType>
	</xs:element>


</xs:schema>