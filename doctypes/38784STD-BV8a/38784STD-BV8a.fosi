<e-i-c gi="step1" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<savetext textid="graphic.str" conrule="">
	<savetext textid="applicref.str" conrule="">
	<savetext textid="applicref.str" conrule=""></charlist>

<att logic="and">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="steplabelstr" conrule="#CONTENT(label)">
	<savetext textid="step1labelstring" conrule="#CONTENT(label)">
	<savetext textid="xreftype" conrule="\Step\">
	<savetext textid="xrefstr" conrule="steplabelstr"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<charsubset>
	<reset resetlist="step2ct">
	<enumerat increm="1" enumid="step1ct">
	<savetext textid="steplabelstr" conrule="step1ct">
	<savetext textid="step1labelstring" conrule="steplabelstr">
	<savetext textid="label" conrule="steplabelstr" saverule="1">
	<savetext textid="xreftype" conrule="\Step\">
	<savetext textid="xrefstr" conrule="steplabelstr"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
	<suppress sup="1"></charsubset>
