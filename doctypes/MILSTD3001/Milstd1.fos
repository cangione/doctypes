<!--Sequence List-->
<e-i-c gi="seqlist" context="* note * opproc"><?Pub Dtl>
<charlist charsubsetref="outline.lev1"></charlist>
</e-i-c>
<e-i-c gi="title" context="seqlist * opproc"><?Pub Dtl>
<charlist charsubsetref="standalone space underscore">
<suppress sup="1">
<savetext textid="tabletxt"
conrule="<ppara>,<bold>,#CONTENT,</bold>,</ppara>" append="1">
</charlist>
</e-i-c>
<e-i-c gi="item" context="seqlist * opproc"><?Pub Dtl>
<charlist inherit="1">
<enumerat increm="1" enumid="outline.lev1.ct"></charlist>
</e-i-c>
<e-i-c gi="para" context="* seqlist * note * opproc" occur="all">
<charlist inherit="1">
<suppress sup="1"></charlist>
<att>
<specval attname="label" attloc="item" attval="#ANY">
<charsubset charsubsetref="outline.text outline.lev1.item.indent"><?Pub Dtl>
<savetext textid="labeltxt">
<savetext textid="tabletxt"
conrule="<ppara>,<bold>,labeltxt,\. \,#CONTENT,</bold>,</ppara>"
append="1"></charsubset>
</att>
<att>
<specval attname="label" attloc="item" attval="#NONE">
<charsubset>
<savetext textid="tabletxt"
conrule="<ppara2>,outline.lev1.ct,\. \,#CONTENT,</ppara2>" append="1">
</charsubset>
</att>
</e-i-c>
<!--TROUBLESHOOTING-->
<e-i-c gi="trblsht"><?Pub Dtl>
<charlist>
<savetext textid="qaptxt" conrule="\\">
<savetext textid="hcptxt" conrule="\\">
<savetext textid="esdstxt" conrule="\\">
<savetext textid="number" conrule="taskparanum,\. \"></charlist>
<att>
<specval attname="qap" attval="qap-app">
<charsubset><?Pub Dtl>
<savetext textid="qaptxt" conrule="\(QA) \"></charsubset>
</att>
<att>
<specval attname="hcp" attval="hcp-app">
<charsubset><?Pub Dtl>
<savetext textid="hcptxt" conrule="\[HCP] \"></charsubset>
</att>
<att>
<specval attname="esds" attval="esds-app">
<charsubset><?Pub Dtl>
<savetext textid="esdstxt" conrule="\[ESD] \"></charsubset>
</att>&change.marks.att;</e-i-c>
<e-i-c gi="title" context="intro trblsht"><?Pub Dtl>
<charlist inherit="1" charsubsetref="title1">
<indent inherit="0" leftind="@3pi" firstln="*-3pi">
<savetext textid="alphaidxlvl3.txt" conrule="#CONTENT" append="0">
<savetext textid="alphaindex.app"
conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixsub2>,alphaidxlvl3.txt,</ixsub2>,<ixpgstr>,wpct.txt[BO],\/\,foliostr[BO],</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
append="1">
<savetext textid="alphaindex2.app"
conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixsub2>,alphaidxlvl3.txt,</ixsub2>,<ixpgstr>,wpct.txt[BO],\/\,foliostr[BO],</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
append="1">
<savetext textid="strAlphaLvl3.Pg" conrule="foliostr[BO]">
<savetext textid="a-volX.txt"
conrule="<aisystementry>,<name>,alphaidxlvl1.txt,</name>,<aiwpvolentry>,<title>,alphaidxlvl2.txt,</title>,<tmidno>,dashstr,</tmidno>,<reference>,wpct.txt[BO],</reference>,<aiwpsubentry>,<title>,alphaidxlvl3.txt,</title>,<reference>,wpct.txt[BO],\/\,foliostr[BO],</reference>,</aiwpsubentry>,</aiwpvolentry>,</aisystementry>,\&#RE;\"
append="1">
<usetext source="taskparanum,\. \" placemnt="before">
<subchars charsubsetref="titlefont"></subchars>
</usetext>
<usetext source="qaptxt" placemnt="before">
<subchars>
<font weight="bold"></subchars>
</usetext>
<reset resetlist="alphaidxlvl4.txt">
<usetext source="hcptxt" placemnt="before">
<subchars>
<font weight="bold"></subchars>
</usetext>
<usetext source="esdstxt" placemnt="before">
<subchars>
<font weight="bold"></subchars>
</usetext>
<usetext source="\. \" placemnt="after">
<subchars charsubsetref="titlefont"></subchars>
</usetext>
</charlist>
</e-i-c>
<!--TROUBLESHOOTING PROCEDURE-A-->
<e-i-c gi="trblproc-a"><?Pub Dtl>
<charlist envname="tableenv">
<presp minimum="8pt" nominal="12pt" maximum="16pt" priority="med">
<postsp minimum="8pt" nominal="12pt" maximum="16pt" priority="med">
<textbrk startln="1" endln="1">
<span span="1">
<usetext
source='!<table rowsep="0"><tgroup cols="3"><colspec colname="col1" align="left"/><colspec colname="col2"
align="center" colwidth="3pi"/><colspec colname="col3"
align="center" colwidth="3pi"/><spanspec spanname="span1to3" namest="col1" nameend="col3"/><thead><row rowsep="1"><entry><bold>PROCEDURE</bold></entry><entry><bold>NO</bold></entry><entry><bold>YES</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
<reset resetlist="entrytablect table.app tableconttxt tabletxt">
<reset resetlist="tfnnumct tfnalphact">
<reset resetlist="qaptxt hcitxt hcptxt esdstxt paract step1ct">
&ic.characteristics.clear.savetext;</charlist>&table.number.set;
&ic.characteristics.att;&change.marks.att;</e-i-c>
<e-i-c gi="table" context="trblproc-a"><?Pub Dtl>
<charlist envname="tableenv"></charlist>
</e-i-c>
<e-i-c gi="table" context="* step trbl-step"><?Pub Dtl>
<charlist envname="tableenv" inherit="1">
<suppress sup="1">
<enumerat increm="1" enumid="entrytablect">
<savetext textid="tablenum" conrule="entrytablect">
<savetext textid="tablenumtxt" conrule="\Table \,tablenum,\.\,8pt">
<savetext textid="wholetable" conrule="#CONTENT" placemnt="before">
<usetext source="<pseudo>,wholetable,</pseudo>" placemnt="after">
</usetext>
</charlist>
<att>
<fillval attname="id" attloc="" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tablenum"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="trblproc-a" occur="all"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="tabletxt" conrule="<ppara>,#CONTENT,</ppara>">
<savetext textid="row.app"
conrule='!<entry colname="col1">!,tabletxt,!</entry>!, !<entry>!,!</entry>!,!<entry>!,!</entry>!'>
<savetext textid="table.app"
conrule='!<row rowsep="0">!,row.app,!</row>!' placemnt="after"
append="1">
<reset resetlist="pparatxt reftxt tabletxt"></charlist>
</e-i-c>
<e-i-c gi="para" context="note * trblproc-a"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="wcntxt" conrule="\\" placemnt="after"></charlist>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\true\">
<charsubset><?Pub Dtl>
<savetext textid="tabletxt"
conrule="<pnote>,wcntxt,</pnote>,<ppara-noindent>,<bold>,#CONTENT,</bold>,</ppara-noindent>"
append="1"></charsubset>
</att>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\false\">
<charsubset><?Pub Dtl>
<savetext textid="row.app"
conrule="<pnote>,wcntxt,</pnote>,<ppara-noindent>,#CONTENT,</ppara-noindent>"
append="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="caution * trblproc-a"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="wcntxt" conrule="\\" placemnt="after"></charlist>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\true\">
<charsubset><?Pub Dtl>
<savetext textid="tabletxt"
conrule="<pnote>,wcntxt,</pnote>,<ppara-noindent>,<bold>,#CONTENT,</bold>,</ppara-noindent>"
append="1"></charsubset>
</att>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\false\">
<charsubset><?Pub Dtl>
<savetext textid="row.app"
conrule="<pnote>,wcntxt,</pnote>,<ppara-noindent>,#CONTENT,</ppara-noindent>"
append="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="warning * trblproc-a"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="wcntxt" conrule="\\" placemnt="after"></charlist>
<att>
<specval attname="warning-type" attloc="warning" attval="not-hazmat">
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\true\">
<charsubset><?Pub Dtl>
<savetext textid="tabletxt"
conrule="<pnote>,wcntxt,</pnote>,<ppara-noindent>,<bold>,#CONTENT,</bold>,</ppara-noindent>"
append="1">
<savetext textid="row.app"
conrule='!<entry colname="col1">!,tabletxt,!</entry>!, !<entry>!,!</entry>!,!<entry>!,!</entry>!'
append="1"></charsubset>
</att>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\false\">
<specval attname="warning-type" attloc="warning" attval="not-hazmat">
<charsubset><?Pub Dtl>
<savetext textid="row.app"
conrule="<pnote>,wcntxt,</pnote>,<ppara-noindent>,<bold>,#CONTENT,</bold>,</ppara-noindent>"
append="1"></charsubset>
</att>
</e-i-c>
<!--Symptom Table-->
<e-i-c gi="symptom" context="trblproc-a"><?Pub Dtl>
<charlist charsubsetref="table.title">
<span span="1">
<usetext
source="qaptxt,caitxt,csitxt,csptxt,esdstxt,hcitxt,hcptxt,ocitxt,ocptxt,odstxt"
placemnt="before">
<subchars>
<font weight="bold"></subchars>
</usetext>
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext
source="tablenumtxt,<bold>,qaptxt,caitxt,csitxt,csptxt,esdstxt,hcitxt,hcptxt,ocitxt,ocptxt,odstxt,</bold>,#CONTENT,\ (Cont)\">
<subchars charsubsetref="table.title.cont">
<float scope="trblproc-a"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="reference" context="* trblproc-a"><?Pub Dtl>
<charlist>
<suppress sup="1">
<savetext textid="reftxt" conrule="\ \,#CONTENT" placemnt="after">
</charlist>
</e-i-c>
<e-i-c gi="decision" context="trblproc-a"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph space">
<savetext textid="table.app" conrule="row.app,!</row>!" placemnt="after"
append="1">
<reset resetlist="nobrk.txt row.app"></charlist>
</e-i-c>
<e-i-c gi="decision" context="condition-group trblproc-a"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph space">
<savetext textid="table.app" conrule="row.app,!</row>!" placemnt="after"
append="1">
<reset resetlist="row.app"></charlist>
</e-i-c>
<!--Action-->
<e-i-c gi="action" context="trbl-step" occur="all"><?Pub Dtl>
<charlist charsubsetref="calist1">
<savetext textid="table.app"
conrule='!<row>!,nobrk.txt,!<entry colname="col1">!,row.app,!</entry><entry colname="col2"></entry><entry colname="col3"></entry></row>!'
placemnt="after" append="1">
<reset resetlist="row.app">
<reset resetlist="nobrk.txt pparatxt tabletxt"></charlist>
<!--ERROR: DTD DOES NOT DEFINE @LABEL-->
<att>
<specval attname="label" attval="#NONE">
<charsubset><?Pub Dtl>
<enumerat increm="1" enumid="step1ct">
<savetext textid="step1cttxt" conrule="step1ct,\.\,@1.7pi">
<savetext textid="step1num" conrule="step1ct"></charsubset>
</att>
<!--ERROR: DTD DOES NOT DEFINE @LABEL-->
<att>
<specval attname="label" attval="#ANY">
<fillval attname="label" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="step1txt">
<savetext textid="step1cttxt" conrule="step1txt,\.\,@1.7pi">
<savetext textid="step1num" conrule="step1cttxt"></charsubset>
</att>
<att>
<fillval attname="id" attloc="trbl-step" fillcat="savetext"
fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="step1num"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="action * trbl-step" occur="first"><?Pub Dtl>
<charlist>
<suppress sup="1">
<savetext textid="row.app"
conrule="<ppara>,step1cttxt,<bold>,qaptxt,caitxt,csitxt,csptxt,esdstxt,hcitxt,hcptxt,ocitxt,ocptxt,odstxt,</bold>,#CONTENT,reftxt,</ppara>"
append="1"></charlist>
</e-i-c>
<e-i-c gi="para" context="action * trbl-step" occur="notfirst">
<charlist>
<suppress sup="1">
<savetext textid="row.app" conrule="<ppara2>,#CONTENT,</ppara2>"
append="1"></charlist>
</e-i-c>
<!--Final Action-->
<e-i-c gi="finalaction" context="trblproc-a"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph space">
<savetext textid="table.app"
conrule='!<row>!,nobrk.txt,!<entry colname="col1">!,row.app,!</entry>!,!<entry colname="col2">!,!</entry>!,!<entry colname="col3">!,!</entry>!,!</row>!'
placemnt="after" append="1">
<reset resetlist="nobrk.txt row.app"></charlist>
