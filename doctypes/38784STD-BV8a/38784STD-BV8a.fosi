<e-i-c gi="term" context="acronym" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<hyphen hyph="0">
	<suppress sup="1"></charlist>

<att logic="and">
<specval attname="deltype" attval="#NE#\delete\">
<charsubset>
	<usetext source="\ (\,#CONTENT,\)\">	</usetext>

	<savetext textid="acronym.ist" conrule="<acronym.ps>,                 <acr.term.ps>,#CONTENT,</acr.term.ps>,                 <acr.def.ps>,acronym.def.hold.st,</acr.def.ps>,              </acronym.ps>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

