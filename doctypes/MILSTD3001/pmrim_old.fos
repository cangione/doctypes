<!ENTITY syscompXPath "<att>
<specval attname='name(preceding-sibling::node()[1])=&#34;name&#34;' attloc='#XPATH' attval='0'>
<charsubset>
<textbrk startln='0'>
<usetext source='\, \' placemnt='before'></usetext>
</charsubset>
</att><att>
<specval attname='name(following-sibling::node()[1])=&#34;typedes&#34; or count(following-sibling::node()[1])=0' attloc='#XPATH' attval='1'>
<charsubset>
<textbrk endln='1'></charsubset>
</att>">
<!ENTITY Check.Title.Att "<att>
  <specval attname='leaderdots' attloc='check' attval='0'>
  <charsubset>
    <usetext source='space.fill' placemnt='after'></usetext>
  </charsubset>
</att>
<att>
  <specval attname='leaderdots' attloc='check' attval='1'>
  <charsubset>
    <usetext source='dot.fill' placemnt='after'></usetext>
  </charsubset>
</att>
<att>
  <charsubset>
    <usetext source='step.pre.text,step.number.text,step.post.text,@1.5em' placemnt='before'></usetext>
  </charsubset>
</att>
<att>
  <fillval attname='id' attloc='check' fillcat='savetext' fillchar='textid'>
  <charsubset>
    <savetext conrule='step.number.text'>
  </charsubset>
</att>">
<!ENTITY TaskCard "<charlist>
  <reset resetlist='bottom.rule.text card.body.text card.footer.text card.header.text card.change.status.att card.title.text change.number.text card.delete.note.text figure.ct label.txt step.1.ct table.row.text table.ct task.title.text'>
  <savetext textid='page.classified.att' conrule='\no\'>
  <savetext textid='card.pageset.type.att' conrule='\none\'>
  <savetext textid='row.height.text' conrule='!<?PubTbl row rht=&#34;225pt&#34;?>!'>
  <savetext textid='card.end.text' conrule='space.fill,\Continued\,3pt'>
 </charlist>
<att>
  <fillval attname='change' fillcat='savetext' fillchar='conrule'>
  <charsubset>
    <savetext textid='card.change.status.att'>
  </charsubset>
</att>
<att>
  <specval attname='security.highest' attloc='#FOSI' attval='#NE#\u\'>
  <charsubset>
    <savetext textid='page.classified.att' conrule='\yes\'>
    <savetext textid='row.height.text' conrule='!<?PubTbl row rht=&#34;190pt&#34;?>!'>
  </charsubset>
</att>
<att>
  <specval attname='change' attval='insert'>
  <charsubset>
    <savetext textid='card.pageset.type.att' conrule='\insert\'>
  </charsubset>
</att>
<att>
  <specval attname='label' attval='#ANY'>
  <charsubset>
    <savetext textid='card.pageset.type.att' conrule='\label\'>
  </charsubset>
</att>
<att>
  <specval attname='deletenote' attval='#ANY'>
  <fillval attname='deletenote' fillcat='savetext' fillchar='conrule'>
  <charsubset>
    <savetext textid='card.delete.note.text' placemnt='after'>
  </charsubset>
</att>
<att>
  <fillval attname='id' fillcat='savetext' fillchar='textid'>
  <charsubset>
    <savetext conrule='card.number.screen.text' placemnt='after'>
  </charsubset>
</att>
<att>
  <specval attname='chgnum' attval='#ANY'>
  <fillval attname='chgnum' fillcat='savetext' fillchar='conrule'>
  <charsubset>
    <savetext textid='change.number.text'>
  </charsubset>
</att>
&Card.TaskTime;
<att>
  <testgroup logic='or'>
    <specval attname='change' attval='delete'>
    <specval attname='with-supportcards' attval='no'>
  </testgroup>
  <charsubset>
    <savetext textid='card.end.text' conrule='@7pi,\End of Card\' placemnt='after'>
    <savetext textid='bottom.rule.text' conrule='!<?PubTbl table border-bottom-style=&#34;solid&#34;?>!' placemnt='after'>
  </charsubset>
</att>
&TaskCard.Delete;
<att>
  <specval attname='screen-only' attloc='system-var' attval='#ANY'>
  <charsubset>
    &TaskCard.EndOfCard.Screen;
  </charsubset>
</att>
<att>
  <specval attname='screen-only' attloc='system-var' attval='#ANY'>
  <specval attname='card.screen.show.option' attloc='#FOSI' attval='on'>
  <charsubset>
    &TaskCard.Screen;
  </charsubset>
</att>">
