<!--**********************************************************************
    *                                                                    *
    *                        S1000D Issue 2                              *
    *                   Document Type Definition                         *
    *                                                                    *
    *                     Release Version 2.2                            *
    *                       Date: 2005-05-01                             *
    *                                                                    *
    * Amendment:-                                                        *
    * 1. Update public identifier date.                                  *
    * 2. CPF 2004-46US: Add optional subelements <dsc.econtact> and      *
    *                   <dsc.statedes> to the content models of elements *
    *                   <dsc.elecequip> and <dsc.connector>.             *
    *                   Add optional subelement <dsc.nomenc> to the      *
    *                   content model of element <dsc.elecequip>.        *
    *                                                                    *
    * Typical invocation:-                                               *
    * <!ENTITY % WRNGFLDS PUBLIC                                         *
    *   "-//S1000D//ELEMENTS WRNGFLDS Breakdown 20050501//EN" >          *
    * %WRNGFLDS;                                                         *
    ********************************************************************** -->


<!--**********************************************************************
    * Define Entity %CONTENT; (Content Breakdown) containing:- wrngflds. *
    ********************************************************************** -->

<!ENTITY % CONTENT "wrngflds">


<!--**********************************************************************
    * Define Entity %DSCDECL; (Description and Declaration) containing:- *
    *  fldname    - Mandatory Single   contains   Parsed Character Data. *
    *  dscr       - Optional  Single   contains   Parsed Character Data. *
    *  refs       - Optional  Single   contains   refdm, reftp.          *
    ********************************************************************** -->

<!ENTITY % DSCDECL "fldname, dscr?, refs?">


<!--**********************************************************************
    * Define Element wrngflds (Wiring Data Description/Fields Container) *
    * containing:-                                                       *
    *  dsc.wires      - Optional  Single   contains dsc.circode,         *
    *                                       dsc.wireno, dsc.secid,       *
    *                                       dsc.wiretype, dsc.wiregauge, *
    *                                       dsc.harnid, dsc.emc-code,    *
    *                                       dsc.length, dsc.colour,      *
    *                                       dsc.twist, dsc.coax,         *
    *                                       dsc.triax, dsc.signal,       *
    *                                       dsc.rfd, dsc.contact,        *
    *                                       dsc.wireconcode,             *
    *                                       dsc.netanacode, dsc.screen,  *
    *                                       dsc.pre, dsc.fin, dsc.rpc,   *
    *                                       dsc.routing, dsc.wireroute,  *
    *                                       dsc.restriction,             *
    *                                       dsc.fdescref, dsc.illref.    *
    *  dsc.harness    - Optional  Single   contains dsc.harnid, dsc.pnr, *
    *                                       dsc.altpnr, dsc.mfc,         *
    *                                       dsc.harnvar, dsc.harnissue,  *
    *                                       dsc.illref, dsc.routing,     *
    *                                       dsc.rpc, dsc.fdescref.       *
    *  dsc.elecequip  - Optional  Single   contains dsc.rfd, dsc.pnr,    *
    *                                       dsc.altpnr, dsc.mfc,         *
    *                                       dsc.instloc, dsc.accdopl,    *
    *                                       dsc.assy, dsc.nhassy,        *
    *                                       dsc.sbc, dsc.sibplugid,      *
    *                                       dsc.trl, dsc.clc,            *
    *                                       dsc.econtact, dsc.statedes,  *
    *                                       dsc.rpc, dsc.nomenc,         *
    *                                       dsc.equdescref, dsc.fdescref,*
    *                                       dsc.illref.                  *
    *  dsc.stdparts   - Optional  Single   contains dsc.connector,       *
    *                                       dsc.vpart, dsc.accessory,    *
    *                                       dsc.solder-sleeve,           *
    *                                       dsc.shrink-sleeve,           *
    *                                       dsc.ident-sleeve,            *
    *                                       dsc.conduit, dsc.wire-mat.   *
    ********************************************************************** -->

<!ELEMENT wrngflds - - (dsc.wires?, dsc.harness?, dsc.elecequip?, 
                        dsc.stdparts?)>


<!--**********************************************************************
    * Define Element dsc.wires (Wire Data/Field Descriptions)            *
    * containing:-                                                       *
    *  dsc.circode     - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.wireno      - Mandatory Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.secid       - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.wiretype    - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.wiregauge   - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.harnid      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.emc-code    - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.length      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.colour      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.twist       - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.coax        - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.triax       - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.signal      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.rfd         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.contact     - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.wireconcode - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.netanacode  - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.screen      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.pre         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.fin         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.rpc         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.routing     - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.wireroute   - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.restriction - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.fdescref    - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.illref      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    ********************************************************************** -->

<!ELEMENT dsc.wires - - (dsc.circode?, dsc.wireno, dsc.secid?, 
                         dsc.wiretype?, dsc.wiregauge?, dsc.harnid?, 
                         dsc.emc-code?, dsc.length?, dsc.colour?, 
                         dsc.twist?, dsc.coax?, dsc.triax?, dsc.signal?, 
                         dsc.rfd?, dsc.contact?, dsc.wireconcode?, 
                         dsc.netanacode?, dsc.screen?, dsc.pre?, dsc.fin?,
                         dsc.rpc?, dsc.routing?, dsc.wireroute?, 
                         dsc.restriction?, dsc.fdescref?, dsc.illref?)>


