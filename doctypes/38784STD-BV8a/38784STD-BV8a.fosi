	<savetext textid="authnotst" conrule="#CONTENT">
	<savetext textid="t2st" conrule="\ \"></charsubset>
</att>

<att logic="and">
<specval attname="t2page" attloc="front" attval="#EQ#1">
<charsubset>
	<savetext textid="authnotst" conrule="#CONTENT">
