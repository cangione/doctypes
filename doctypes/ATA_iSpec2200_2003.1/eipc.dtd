<!-- DOCTYPE eipc   [ -->
<!-- The following set of declarations may be referred to
    using the public entity as follows:
<!DOCTYPE eipc PUBLIC
    "-//ATA-TEXT//DTD EIPC-VER13-LEVEL2//EN" [ ]>                   -->
<!--                                                                -->
<!-- ============================================================== -->
<!--                           NOTATIONS                            -->
<!-- ============================================================== -->
<!--                                                                -->
<!NOTATION cgm       PUBLIC
    "-//USA-DOD//NOTATION Computer Graphics Metafile//EN"             >

<!NOTATION ccitt4 PUBLIC
    "-//USA-DOD//NOTATION CCITT Group 4 Facsimile//EN"                >

<!NOTATION gcf PUBLIC
 "-//ATA-TEXT//NOTATION Graphic Companion File//EN"                   >

<!NOTATION pdf PUBLIC
 "-//Adobe Inc.//NOTATION Portable Document Format//EN"               >

<!NOTATION png PUBLIC
 "-//W3C//NOTATION Portable Network Graphics//EN"                     >

<!NOTATION jpeg PUBLIC
 "+//ISBN 0-7923-9432-1::Graphic Notation//NOTATION Joint
  Photographic Experts Group Raster//EN"                              >

<!NOTATION vrml PUBLIC
 "-//ATA-TEXT//NOTATION Virtual Reality Modeling Language//EN"        >

<!NOTATION mpeg PUBLIC
 "-//ATA-TEXT//NOTATION Motion Pictures Expert Group//EN"             >

<!NOTATION mp3 PUBLIC
 "-//ATA-TEXT//NOTATION Motion Pictures Expert Group, Audio
  Layer 3//EN"                                                        >
<!--                                                                -->
<!-- ============================================================== -->
<!--                           ENTITIES                             -->
<!-- ============================================================== -->
<!--                                                                -->
<!ENTITY  % text     "(para | table | unlist | numlist)*"             >

<!ENTITY  % w.c      "(warning*, caution*)"                           >

<!ENTITY  % yesorno  "NUMBER"                                         >

<!ENTITY  % revatt
           "chg       (N | D | R | I | U)             #REQUIRED
            key       ID                              #REQUIRED
            revdate   NUMBER                          #REQUIRED"      >

<!ENTITY   % ISOtech      PUBLIC
     "ISO 8879-1986//ENTITIES   General Technical//EN"                >
<!ENTITY   % ISOpub      PUBLIC
     "ISO 8879-1986//ENTITIES Publishing//EN"                         >
<!ENTITY   % ISOnum      PUBLIC
   "ISO 8879-1986//ENTITIES   Numeric and Special Graphic//EN"        >
<!ENTITY   % ISOgrk1     PUBLIC
     "ISO 8879-1986//ENTITIES   Greek Letters//EN"                    >
<!ENTITY   % ISOgrk2     PUBLIC
     "ISO 8879-1986//ENTITIES Monotoniko Greek//EN"                   >
<!ENTITY   % ISOgrk3     PUBLIC
     "ISO 8879-1986//ENTITIES Greek Symbols//EN"                      >
<!ENTITY   % ISOgrk4     PUBLIC
     "ISO 8879-1986//ENTITIES Alternative Greek Symbols//EN"          >
<!ENTITY   % ISOlat1     PUBLIC
     "ISO 8879-1986//ENTITIES Added Latin 1//EN"                      >
<!ENTITY   % ISObox      PUBLIC
     "ISO 8879-1986//ENTITIES Box and Line Drawing//EN"               >
<!ENTITY   % ISOamso     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Ordinary//EN"       >
<!ENTITY   % ISOamsc     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Delimiters//EN"     >

%ISOtech; %ISOpub; %ISOnum; %ISOgrk1; %ISOgrk2; %ISOgrk3;
%ISOgrk4; %ISOlat1; %ISObox; %ISOamso; %ISOamsc;

<!-- ============================================================== -->
<!--              EIPC  TOP LEVEL STRUCTURE                         -->
<!-- ============================================================== -->

<!ELEMENT eipc   - -  ((title, legalntc?, mfmatr, dplist)
                      | increv | tr+)
                      +(revst | revend | cocst | cocend | hotlink)    >
<!ATTLIST eipc
          model     CDATA                             #REQUIRED
          oidate    NUMBER                            #REQUIRED
          docnbr    CDATA                             #IMPLIED
          cus       CDATA                             #IMPLIED
          cusname   CDATA                             #IMPLIED
          tsn       CDATA                             #REQUIRED
          lang      CDATA                             #REQUIRED
          revdate   NUMBER                            #REQUIRED
          spl       CDATA                             #REQUIRED
          chg       (N|R|U)                           #REQUIRED
          efflen    NUMBER                            #IMPLIED
          efftype   CDATA                             #IMPLIED        >

<!-- ============================================================== -->
<!--              INCREMENTAL REVISION                              -->
<!-- ============================================================== -->

<!ELEMENT increv    - - (transltr?, legalntc?, (intro | appendix
                        | optlist | nutopt | matlist | vendlist
                        | sblist | clmpopt | glossary | effclist
                        | chapter | section | unit | figure | sheet
                        | graphic)+)                                  >

<!ELEMENT tr        - - (legalntc?, trfmatr, trlist?, (chapter
                        | section+ | unit+ | figure+ | legalntc
                        | intro | vendlist | glossary | optlist
                        | sblist | effclist | nutopt | clmpopt
                        | matlist | appendix | sheet+ | graphic))     >

<!ELEMENT trfmatr   - -  (title, trreason?, (%text;)?)                >
<!ATTLIST trfmatr
          trnbr     CDATA                             #REQUIRED
          trdel     CDATA                             #IMPLIED
          trrepl    CDATA                             #IMPLIED
          issdate   CDATA                             #IMPLIED        >

<!ELEMENT trreason  - -  (#PCDATA)                                    >

<!-- ============================================================== -->
<!--       Legal Notice Information                                 -->
<!-- ============================================================== -->

<!ELEMENT legalntc  - - (chgdesc*, (exprtcl | cpyrght | proptary 
                        | geninfo)+)                                  >
<!ATTLIST legalntc
          %revatt;                                                    >

<!ELEMENT proptary  - - (fullstmt, partstmt?)                         >
<!ELEMENT fullstmt  - - (title?, cpyrght?, para+)                     >
<!ELEMENT partstmt  - - (title?, para+)                               >
<!ELEMENT exprtcl   - - (para | unlist | numlist | note)+             >
<!ELEMENT cpyrght   - - (year*, holder*, geninfo)                     >
<!ELEMENT year      - - (#PCDATA)                                     >
<!ELEMENT holder    - - (#PCDATA)                                     >
<!ELEMENT geninfo   - - (para | unlist | numlist | note)+             >

<!-- ============================================================== -->
<!--                    FRONT MATTER                                -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT mfmatr    - -  (transltr?, trlist?, intro, (vendlist
                         | glossary | optlist | sblist | effclist
                         | nutopt | clmpopt | matlist | appendix)+)   >
<!--                                                                -->
<!ELEMENT trlist    - -  (title, (%text;)*, (trdata+ | isempty))      >
<!ATTLIST trlist
          %revatt;                                                    >

<!ELEMENT trdata    - -  (trnbr, trstatus, trloc+)                    >
<!ELEMENT trnbr     - -  (#PCDATA)                                    >
<!ELEMENT trstatus  - -  (#PCDATA)                                    >
<!ELEMENT trloc     - -  (#PCDATA)                                    >
<!--                                                                -->
<!ELEMENT intro     - -  (chgdesc*, title, ((title?, %text;)+ | list1),
                          graphic*)                                   >
<!ATTLIST intro
          %revatt;                                                    >

<!ELEMENT transltr  - -  (chgdesc*, title, (%text;))+                 >
<!ATTLIST transltr
          oldkey    NAME                              #IMPLIED
          %revatt;                                                    >
<!ELEMENT chgdesc   - -  (#PCDATA)                                    >
<!ATTLIST chgdesc
          chgdtype        (edit|tech|effect|sgml)     #IMPLIED        >
<!--                                                                -->
<!ELEMENT vendlist  - -  (chgdesc*, title, %text;, vendata+)          >
<!ATTLIST vendlist
          %revatt;                                                    >
<!ELEMENT vendata   - -  (mfr, mad+)                                  >
<!ELEMENT mfr       - -  (#PCDATA)                                    >
<!ELEMENT mad       - -  (madline | phone | fax | url | email
                         | mfrcont)+                                  >
<!ATTLIST mad
          mfropt    CDATA                             #IMPLIED        >
<!ELEMENT madline   - -  (#PCDATA)                                    >
<!ELEMENT phone     - -  (#PCDATA)                                    >
<!ELEMENT fax       - -  (#PCDATA)                                    >
<!ELEMENT url       - -  (#PCDATA)                                    >
<!ELEMENT email     - -  (#PCDATA)                                    >
<!ELEMENT mfrcont   - -  (#PCDATA)                                    >
<!--                                                                -->
<!ELEMENT glossary  - -  (chgdesc*, title, %text;, glosdata+)         >
<!ATTLIST glossary
          %revatt;                                                    >
<!ELEMENT glosdata  - -  (term, def)                                  >
<!ELEMENT term      - -  (#PCDATA)                                    >
<!ELEMENT def       - -  (#PCDATA)                                    >
<!--                                                                -->
<!ELEMENT optlist   - -  (chgdesc*, title?, %text;, optdata+)         >
<!ATTLIST optlist
          %revatt;                                                    >
<!ELEMENT optdata   - -  (pnr, kwd, (lookdif?, pnr)+)                 >
<!ELEMENT lookdif   - -  (#PCDATA)                                    >
<!--                                                                -->
<!ELEMENT sblist    - -  (chgdesc*, title, %text;, sbdata*)           >
<!ATTLIST sblist
          %revatt;                                                    >
<!ELEMENT sbdata    - -  (sbnbr, issdate?, ics?)                      >
<!ELEMENT sbnbr     - -  (#PCDATA)                                    >
<!ATTLIST sbnbr
          sbtype    CDATA                             #IMPLIED
          sbcat     %yesorno;                         "0"
          sbpart    CDATA                             #IMPLIED        >
<!--                                                                -->
<!ELEMENT issdate   - -  (#PCDATA)                                    >
<!ELEMENT ics       - -  (#PCDATA)                                    >
<!ELEMENT nutopt    - -  (chgdesc*, title?, %text;, option+)          >
<!ATTLIST nutopt
          %revatt;                                                    >
<!ELEMENT option    - -  (pnr, detail+)                               >
<!ELEMENT detail    - -  (pnr, nom, mfr?, csd?)                       >
<!--                                                                -->
<!ELEMENT effclist  - -  (chgdesc*,title, effcdata+)                  >
<!ATTLIST effclist
          %revatt;                                                    >
<!ELEMENT effcdata  - -  (effcode, effect, effcdesc, effcloc*)        >
<!ELEMENT effcloc   - O   EMPTY                                       >
<!ATTLIST effcloc
          chapnbr   NUMBER                            #IMPLIED
          sectnbr   NUMBER                            #IMPLIED
          unitnbr   NUMBER                            #IMPLIED
          fignbr    NUTOKEN                           #IMPLIED
          itemnbr   NUTOKEN                           #IMPLIED        >
<!ELEMENT effcode   - -  (#PCDATA)                                    >
<!ELEMENT effcdesc  - -  (#PCDATA)                                    >
<!--                                                                -->
<!ELEMENT clmpopt   - -  (chgdesc*, title, %text;)                    >
<!ATTLIST clmpopt
          %revatt;                                                    >
<!--                                                                -->
<!ELEMENT matlist   - -  (chgdesc*, title, %text;)+                   >
<!ATTLIST matlist
          %revatt;                                                    >

<!ELEMENT appendix  - -  (chgdesc*, title, (( title?, %text;)+ 
                          | list1),graphic*)                          >
<!ATTLIST appendix
          appnbr    CDATA                             #REQUIRED
          %revatt;                                                    >
<!--                                                                -->
<!-- ============================================================== -->
<!--                        DETAIL PARTS LIST                       -->
<!--  Contains all the information associated with an item in       -->
<!--  the Detailed Parts List.                                      -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT dplist    - -  (chapter+)                                   >

<!ELEMENT chapter   - -  ((effect?, chgdesc*, title, section+) 
                         | deleted)                                   >
<!ATTLIST chapter
          chapnbr   NUMBER                            #REQUIRED
          %revatt;                                                    >
<!--                                                                -->
<!ELEMENT section   - -  ((effect?, chgdesc*, title?, unit+) 
                         | deleted)                                   >
<!ATTLIST section
          chapnbr   NUMBER                            #REQUIRED
          sectnbr   NUMBER                            #REQUIRED
          %revatt;                                                    >
<!--                                                                -->
<!ELEMENT unit      - -  ((effect?, chgdesc*, title?, figure+) 
                         | deleted)                                   >
<!ATTLIST unit
          chapnbr   NUMBER                            #REQUIRED
          sectnbr   NUMBER                            #REQUIRED
          unitnbr   NUMBER                            #REQUIRED
          %revatt;                                                    >
<!--                                                                -->
<!ELEMENT figure    - -  ((effect?, chgdesc*, regulatory*, title, 
                         graphic, (prtlist | %text;)+) | deleted)     >
<!ATTLIST figure
          sym       %yesorno;                         #IMPLIED
          chapnbr   NUMBER                            #REQUIRED
          sectnbr   NUMBER                            #REQUIRED
          unitnbr   NUMBER                            #REQUIRED
          fignbr    NUTOKEN                           #REQUIRED
          %revatt;                                                    >
<!--                                                                -->
<!ELEMENT prtlist   - - (((effect?, %text;) | item)+)                 >
<!--                                                                -->
<!ELEMENT item      - - ((effect?, regulatory*, part, itemspec)+
                        | deleted)                                    >
<!ATTLIST item
          chapnbr   NUMBER                            #REQUIRED
          sectnbr   NUMBER                            #REQUIRED
          unitnbr   NUMBER                            #REQUIRED
          fignbr    NUTOKEN                           #REQUIRED
          itemnbr   NUTOKEN                           #REQUIRED
          attach    %yesorno;                         "0"
          illusind  %yesorno;                         "1"
          indent    NUMBER                            #IMPLIED
          transport %yesorno;                         "0"
          key       ID                                #REQUIRED       >

<!-- ============================================================== -->
<!--                       PART                                     -->
<!-- ============================================================== -->
<!ELEMENT part      - -  (pnr, nom, regulatory*, (np | matl | refint
                         | refext| csd | afp | opn | optmfr |ee | sp
                         | alprtnbr | mfr| dd | cusnom | venptnbr
                         | osc | spl)*)                               >
<!ATTLIST part
          mp        CDATA                             #IMPLIED
          leadtime  CDATA                             #IMPLIED
          propart   CDATA                             #IMPLIED        >
<!--                                                                -->
<!ELEMENT pnr       - -  (#PCDATA)                                    >
<!ELEMENT np        - -  (#PCDATA)                                    >
<!ELEMENT matl      - -  (#PCDATA)                                    >
<!ELEMENT csd       - -  (#PCDATA)                                    >
<!ELEMENT afp       - -  (#PCDATA)                                    >
<!ELEMENT opn       - -  (#PCDATA)                                    >
<!ELEMENT optmfr    - -  (opt, mfr?)                                  >
<!ELEMENT opt       - -  (#PCDATA)                                    >
<!ELEMENT ee        - -  (#PCDATA)                                    >
<!ELEMENT sp        - -  (#PCDATA)                                    >
<!ELEMENT alprtnbr  - -  (#PCDATA)                                    >
<!ELEMENT dd        - -  (#PCDATA)                                    >
<!ELEMENT kwd       - -  (#PCDATA)                                    >
<!ELEMENT adt       - -  (#PCDATA)                                    >
<!ELEMENT cusnom    - -  (#PCDATA)                                    >
<!ELEMENT venptnbr  - -  (#PCDATA)                                    >
<!ELEMENT osc       - -  (#PCDATA)                                    >
<!ELEMENT spl       - -  (#PCDATA)                                    >

<!ELEMENT nom       - -  (kwd, adt?)                                  >
<!ATTLIST nom
          toc       %yesorno;                         "0"             >

<!-- ============================================================== -->
<!--                       ITEMSPEC                                 -->
<!-- ============================================================== -->
<!ELEMENT itemspec  - -  (upa, sym?, regulatory*, (symbol | tqe | sftq
                         | sfn | msc | effcode | os | us| uoa | refint
                         | refext | uwp | apn | rp | rps| sd | sdes
                         |rwk | sbnbr | ron | ein | or | repnbrs
                         | mdty)*)                      +(effect)     >
<!--                                                                -->
<!ELEMENT sym       - O  EMPTY                                        >
<!ATTLIST sym
          side      (LH|RH|LO|RO|LR)                  #IMPLIED        >

<!ELEMENT symbol    - -  (#PCDATA)                                    >
<!ELEMENT sftq      - -  (#PCDATA)                                    >
<!ELEMENT sfn       - -  (#PCDATA)                                    >
<!ELEMENT uoa       - -  (#PCDATA)                                    >
<!ELEMENT upa       - -  (#PCDATA)                                    >
<!ELEMENT tqe       - -  (#PCDATA)                                    >
<!ELEMENT uwp       - -  (#PCDATA)                                    >
<!ELEMENT apn       - -  (#PCDATA)                                    >
<!ELEMENT rwk       - -  (#PCDATA)                                    >
<!ELEMENT ein       - -  (#PCDATA)                                    >
<!ATTLIST ein
          type      CDATA                             #IMPLIED        >
<!ELEMENT rp        - -  (#PCDATA)                                    >
<!ELEMENT rps       - -  (#PCDATA)                                    >
<!ELEMENT sd        - -  (#PCDATA)                                    >
<!ELEMENT sdes      - -  (#PCDATA)                                    >
<!ELEMENT repnbrs   - -  (#PCDATA)                                    >
<!--                                                                -->
<!ELEMENT os        - O   EMPTY                                       >
<!ELEMENT us        - O   EMPTY                                       >
<!ELEMENT ron       - O   EMPTY                                       >
<!ATTLIST ron
          rontype   CDATA                             #IMPLIED        >
<!ELEMENT msc       - -  (para)                                       >
<!ELEMENT or        - O   EMPTY                                       >
<!ATTLIST or
          interchg  %yesorno;                         "0"             >

<!ELEMENT mdty       - O  EMPTY                                       >
<!ATTLIST mdty
          mdtytype   CDATA                            #IMPLIED        >

<!--                                                                -->
<!-- ============================================================== -->
<!--         INTERNAL & EXTERNAL CROSS REFERENCE                    -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT refext    - -  (#PCDATA)                                    >
<!ATTLIST refext
          refloc    CDATA                             #IMPLIED
          refmodel  CDATA                             #IMPLIED
          refspl    CDATA                             #IMPLIED
          refman    CDATA                             #IMPLIED
          docnbr    CDATA                             #IMPLIED        >
<!--                                                                -->
<!ELEMENT refint    - -  (#PCDATA)                                    >
<!ATTLIST refint
          refid     IDREF                             #REQUIRED
          reftype   CDATA                             #IMPLIED        >

<!ELEMENT refmedia - - (#PCDATA)                                      >
<!ATTLIST refmedia
          mednbr    ENTITY                            #REQUIRED       >


<!-- ============================================================== -->
<!--                         GRAPHIC                                -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT graphic   - -   ((effect?, title?, sheet+) | deleted)       >
<!ATTLIST graphic
          chapnbr   NUMBER                            #IMPLIED
          sectnbr   NUMBER                            #IMPLIED
          unitnbr   NUMBER                            #IMPLIED
          fignbr    NUTOKEN                           #IMPLIED
          %revatt;                                                    >
<!--                                                                -->
<!ELEMENT sheet     - -  (effect?, ((title?, gdesc?) | deleted))      >
<!ATTLIST sheet
          gnbr      ENTITY                            #REQUIRED
          cfnbr     ENTITY                            #IMPLIED
          sheetnbr  CDATA                             #REQUIRED
          imgarea   (AP|BP|CP|DL|EL|FP|GP|HL|IL)      #IMPLIED
          %revatt;                                                    >
<!--                                                                -->
<!ELEMENT gdesc     - -  (effect?, %text;)                            >
