<e-i-c gi="para" context="step4" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<indent leftind="85pt" firstln="65pt">
	<postsp minimum="11pt" nominal="11pt" maximum="11pt" priority="low">
	<textbrk startln="1">
	<usetext source="<stepunderline.ps>, steplabelstr, </stepunderline.ps>, @15pt">	</usetext>

	<usetext source="graphic.str,applicref.str">
	<subchars>	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="inschlvl" attval="#ANY">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
	<suppress sup="1"></charsubset>
</att>
</e-i-c>

<e-i-c gi="stepunderline.ps" occur="all" scope="usetext" elemtype="gi">
