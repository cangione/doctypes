<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<reset resetlist="para0ct sectenum">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<savetext textid="foliostr" conrule="#CONTENT(label)">
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="\Appendix \,#CONTENT(label)">
	<savetext textid="prefix.st" conrule="#CONTENT(label),\.\">
	<savetext textid="labelstr" conrule="#CONTENT(label)">
	<savetext textid="tabfigprefix.st" conrule="#CONTENT(label),\-\">
	<usetext source="\APPENDIX \,labelstr">
	<subchars charsubsetref="allcap14.csub">
	<postsp nominal="8pt">	</subchars>
	</usetext>

	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinerear>,1.5em,app-secur.str,\Appendix \,labelstr,tocfill,<tocnumrear>,pgnumber,</tocnumrear>,</toclinerear>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="voltocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="voltocmatter" conrule="<toclinerear>,1.5em,app-secur.str,\Appendix \,labelstr,tocfill,<tocnumrear>,pgnumber,</tocnumrear>,</toclinerear>" append="1">
	<savetext textid="voltocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<charsubset>
	<reset resetlist="para0ct tabct figct">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<enumerat increm="1" enumid="chapenum">
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="\Appendix \,chapenum[AU],\-\">
	<savetext textid="tabfigprefix.st" conrule="chapenum[AU],\-\">
	<savetext textid="label" conrule="chapenum[AU],\-\" saverule="1">
	<savetext textid="labelstr" conrule="chapenum[AU]">
	<savetext textid="prefix.st" conrule="chapenum[AU],\.\">
	<savetext textid="foliostr" conrule="chapenum[AU],\-\">
	<usetext source="\APPENDIX \, labelstr">
	<subchars>
	<font style="sanserif" size="14pt" weight="bold">
	<leading inherit="0" lead="20pt">
	<quadding quad="center" lastquad="lcenter">
	<postsp minimum="0" nominal="12pt" maximum="12pt">
	<keeps next="1">
	<span span="1">	</subchars>
	</usetext>

	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinerear>,1.5em,app-secur.str,\Appendix \,labelstr,tocfill,<tocnumrear>,pgnumber,</tocnumrear>,</toclinerear>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="voltocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="voltocmatter" conrule="<toclinerear>,1.5em,app-secur.str,\Appendix \,labelstr,tocfill,<tocnumrear>,pgnumber,</tocnumrear>,</toclinerear>" append="1">
	<savetext textid="voltocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1"></charsubset>
</att>

<att logic="or">
