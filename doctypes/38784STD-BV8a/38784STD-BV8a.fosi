<e-i-c gi="EMPHASIS" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1"></charlist>

<att logic="and">
<specval attname="type" attval="b">
<charsubset>
	<font weight="bold"></charsubset>
</att>

<att logic="and">
<specval attname="type" attval="i">
<charsubset>
	<font posture="italic"></charsubset>
</att>

<att logic="and">
<specval attname="type" attval="bi">
<charsubset>
	<font posture="italic" weight="bold"></charsubset>
</att>

<att logic="and">
<specval attname="type" attval="x">
<charsubset>
	<boxing boffset="-1.8pt" loffset="1pt" roffset="1pt" siderel="content" ttype="tsingle" btype="bsingle" ltype="lsingle" rtype="rsingle"></charsubset>
</att>

<att logic="and">
<specval attname="type" attval="o">
<charsubset>
	<highlt scoring="1" scorewt="0.5pt" scoreoff="-9pt"></charsubset>
</att>

<att logic="and">
<specval attname="type" attval="sub">
<charsubset>
	<font size="8pt" offset="-3pt"></charsubset>
</att>

<att logic="and">
<specval attname="type" attval="sup">
<charsubset>
	<font size="8pt" offset="3pt">
	<keeps keep="1" scope="line"></charsubset>
