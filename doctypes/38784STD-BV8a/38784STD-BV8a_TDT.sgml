	<ele>
		<tag>pslist</tag>
		<long>Part/Serial Number List</long>
		<desc>Identifies a listing on the title page that corresponds a particular part number with associated serial numbers. This element could also be used to correspond model numbers with serial numbers, etc.</desc>
		<source>4.5.1.3.4</source>
		<contmdl>(partno, serno+)+</contmdl>
		<usedin>prtitle</usedin>
