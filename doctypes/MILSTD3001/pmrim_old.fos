</att>">
<!ENTITY FrontCard "<charlist>
  <reset resetlist='change.number.text card.body.text card.change.status.att card.delete.note.text front.card.id.text label.text'>
  <savetext textid='card.number.screen.text' conrule='\i\'>
  <savetext textid='card.change.status.att' conrule='\None\'>
  <savetext textid='phase.first.card.att' conrule='\False\'>
  <savetext textid='card.number.screen.text' conrule='phase.text,\i\'>
  <savetext textid='card.end.text' conrule='space.fill,\Continued\,3pt'>
  <savetext textid='card.end.text' conrule='@32pi,\End of Card\,space.fill' placemnt='after'> <!-- USED TO HAVE END OF CARD FOR EACH FRONT CARD TYPE -->
</charlist>
<!--
THIS ATT IS USED TO HAVE ONLY 1 END OF CARD FOR FRONT CARDS.
<att>
  <specval attname='contains(name(following-sibling::node()[1]),&#34;tskcd&#34;)' attloc='#XPATH' attval='1'>
  <charsubset>
    <savetext textid='card.end.text' conrule='@32pi,\End of Card\,space.fill' placemnt='after'></charsubset>
</att>
-->
<att>
  <specval attname='change' attval='#ANY'>
  <fillval attname='change' fillcat='savetext' fillchar='conrule'>
  <charsubset>
    <savetext textid='card.change.status.att'>
  </charsubset>
</att>
<att>
  <specval attname='chgnum' attval='#ANY'>
  <fillval attname='chgnum' fillcat='savetext' fillchar='conrule'>
  <charsubset>
    <savetext textid='change.number.text'>
  </charsubset>
</att>
<att>
  <specval attname='deletenote' attval='#ANY'>
  <fillval attname='deletenote' fillcat='savetext' fillchar='conrule'>
  <charsubset>
    <savetext textid='card.delete.note.text' placemnt='after'>
  </charsubset>
</att>
<att>
  <specval attname='label' attval='#ANY'>
  <charsubset>
    <savetext textid='card.number.screen.text' append='1' conrule='\ (Using the &#34;label&#34; attribute is NOT supported for front matter)\'>
 </charsubset>
</att>
<att>
  <specval attname='print-only' attval='#ANY' attloc='system-var'>
  <specval attname='change' attval='delete'>
  <charsubset>
    <suppress sup='1'>
  </charsubset>
</att>
<att>
  <fillval attname='id' fillcat='savetext' fillchar='textid'>
  <charsubset>
    <savetext conrule='front.card.id.text'>
  </charsubset>
</att>
<att>
  <specval attname='screen-only' attval='#ANY' attloc='system-var'>
  <charsubset>
    &TaskCard.EndOfCard.Screen;
  </charsubset>
</att>
&Security.Screen;">
