<e-i-c gi="subpara8" context="* docwc"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="para clearstrings">
<reset resetlist="step1.ctr">
<enumerat increm="1" enumid="subp8.ctr">
<savetext textid="label.txt"
conrule="sect.ctr,\.\,para0.ctr,\.\,subp1.ctr,\.\,subp2.ctr,\.\,subp3.ctr,\.\,subp4.ctr,\.\,subp5.ctr,\.\,subp6.ctr,\.\,subp7.ctr,\.\,subp8.ctr">
