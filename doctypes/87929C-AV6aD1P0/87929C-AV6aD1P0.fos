<e-i-c gi="title" context="wpidinfo wp" occur="all"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="0">
<font inherit="1" size="16pt">
<leading inherit="1" lead="18pt">
<suppress sup="1"></charlist>&att-content-cbar;
<att>
<charsubset>
<savetext textid="niewp-title.txt"
conrule="scontent.txt,#CONTENT,econtent.txt">
<savetext textid="aiwp-title.txt"
conrule="scontent.txt,#CONTENT,econtent.txt">
<savetext textid="wptitle.txt"
conrule="scontent.txt,#CONTENT,econtent.txt">
<usetext source="\TECHNICAL PROCEDURES\">
<subchars>
<font style="sanserif" size="16pt">
<leading lead="18pt">
<quadding quad="center">
<presp minimum="2pt" nominal="2pt" maximum="2pt" condit="keep">
<postsp minimum="20pt" nominal="20pt" maximum="20pt" condit="discard"
priority="force">
<keeps scope="col" keep="7" next="7">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
<usetext source="nomen.st">
<subchars charsubsetref="wdinfo-nomen-postspace">
<font style="sanserif" size="16pt" weight="bold">
<leading lead="18pt">
<quadding quad="center">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
<usetext source="scontent.txt,#CONTENT,econtent.txt">
<subchars>
<font style="sanserif" size="16pt" weight="bold">
<leading lead="18pt">
<quadding quad="center">
<presp minimum="11pt" nominal="11pt" maximum="11pt" condit="keep">
<postsp minimum="30pt" nominal="30pt" maximum="30pt" condit="discard"
priority="force">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
<savetext textid="bookmark-1.tmp"
conrule="bm-wpno.txt,bm-swpno.txt,#CONTENT" append="0">
<savetext textid="ailist.app"
conrule="<ixpt>,#CONTENT,</ixpt>,<ixsub1>,bm-wpno.txt,bm-swpno.txt,</ixsub1>,<ixpgstr>,folio.txt[BO],</ixpgstr>"
append="1"></charsubset>
</att>
<att>
<specval attname="aiwp-auto" attloc="#FOSI" attval="yes">
