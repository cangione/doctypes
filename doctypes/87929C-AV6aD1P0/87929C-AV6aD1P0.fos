conrule='!<thead><row valign="bottom"><entry colsep="0">!,<underlinewp.ps>,\Part No.\,</underlinewp.ps>,!</entry><entry colsep="0">!,<underlinewp.ps>,\Tool Name\,</underlinewp.ps>,!</entry><entry colsep="0">!,<underlinewp.ps>,\Figure No.\,</underlinewp.ps>,!</entry></row></thead>!'
