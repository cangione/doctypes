	  <!--=============================================-->
	<!-- simultaneousActions and simultaneousActionsGroup Type Element Definition -->
	<!--=============================================-->
	<xs:element name="simultaneousActions" type="simultaneousActionsType">
		    <xs:annotation>
			      <xs:documentation>One or two set of actions with CRM, One action with CRM = both, or PF or PNF, etc.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="simultaneousActionsType">
		    <xs:sequence>
			      <xs:element name="title" type="nameType" minOccurs="0"/>
			      <xs:element name="simultaneousStep" type="simultaneousStepType" maxOccurs="2">
				        <xs:annotation>
					          <xs:documentation>A set of actions done by one or two crew members</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <xs:complexType name="simultaneousStepType">
		    <xs:sequence>
			      <xs:element name="title" type="nameType" minOccurs="0"/>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="crm" type="xs:string" use="required">
			      <xs:annotation>
				        <xs:documentation>crew member responsible for the action</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="both" type="xs:boolean" use="optional">
			      <xs:annotation>
				        <xs:documentation>flag to indicate that the step is performed by all the actors (by default, false)</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
</xs:schema>