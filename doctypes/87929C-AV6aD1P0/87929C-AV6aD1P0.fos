<charsubset>
<savetext textid="tabnum" conrule="label.txt"></charsubset>
</att>
<att logic="and"><?Pub Lcl
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'>
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,label.txt"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<presp nominal="10pt" priority="force">
<textbrk startln="1" endln="1">
<span span="1">
<suppress sup="1">
<usetext source="\Table \,label.txt,\. Deleted\" placemnt="before">
<subchars>
<font inherit="0" weight="bold">
<quadding quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="6pt" nominal="10pt" maximum="12pt" condit="discard">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="wptablelist.app"
conrule="<uinput.psu>,<ulabel.psu>,label.txt,</ulabel.psu>,<utitle.psu>,\(Deleted)\,</utitle.psu>,folio.txt[BO],</uinput.psu>"
placemnt="after" append="1"></charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext
source="\Table \, label.txt,\.\,1em,\Inspection and Maintenance Criteria.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp nominal="6pt" condit="keep" priority="force">
<postsp minimum="6pt" nominal="6pt" maximum="6pt" condit="keep"
priority="high">
<keeps scope="col" keep="7" next="7">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="inspm-structure.txt"
conrule='!<colspec colname="col1" colwidth="1*"><colspec colname="col2" colwidth="1.7*"><colspec colname="col3" colwidth="1.7*"><colspec colname="col4" colwidth="1.7*"><colspec colname="col5" colwidth="1.7*"><spanspec namest="col1" nameend="col5" spanname="SPAN1">!'
placemnt="before">
<savetext textid="inspm-header.txt"
conrule='!<thead><row valign="bottom"><entry rowsep="1" align="center">!,\Nomenclature\,!</entry><entry rowsep="1" align="center">!,\Inspect For\,!</entry><entry rowsep="1" align="center">!,\Repair\,!</entry><entry rowsep="1" align="center">!,\Ready\,!<linectr>!,\Storage\,!</entry><entry rowsep="1" align="center">!,\Extended\,!<linectr>!,\Storage\,!</entry></row></thead>!'
placemnt="before">
<usetext
source='!<tabmat pgwide="1"><tgroup cols="5">!,inspm-structure.txt,inspm-header.txt,!<tbody>!,inspm-body.txt,!</tbody></tgroup></tabmat>!'
placemnt="after"></usetext>
<savetext textid="inspm-body.txt" conrule="\\" placemnt="after"
append="0">
<savetext textid="lotmatter"
conrule="<toclinecfig>,<toctitle.fmt>,label.txt,@2.5em,secur.str,scontent.txt,\Inspection and Maintenance Criteria\,econtent.txt,tocfill,</toctitle.fmt>,<tocnumx>,0.25in,folio.txt[BO],</tocnumx>,</toclinecfig>"
append="1">
<savetext textid="wptablelist.app"
conrule="<toclined>,<toctitle.fmt>,label.txt,@3.5em,\Inspection and Maintenance Criteria\,tocfill,</toctitle.fmt>,<tocnumchap>,folio.txt[BO],</tocnumchap>,</toclined>"
placemnt="after" append="1">
