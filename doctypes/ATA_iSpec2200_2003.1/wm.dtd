<!-- ============================================================ -->
<!--           PARAGRAPH, CHANGE DESCR. & TITLE                   -->
<!-- ============================================================ -->
<!ELEMENT para      - -  (#PCDATA | hwinfo | matlinfo | toolinfo
                         | terminfo | wiretype | pnr | mfrname
                         | toolpnr | matlpnr | zone | termpnr
                         | grphcref | refext | refint | sub 
                         | super | txtgrphc | refblock | refmedia
                         | grsymbol)+                               >

<!ELEMENT hwinfo    - -  (mfrname, pnr, hwname, altentry*)          >
<!ELEMENT mfrname   - -  (#PCDATA)                                  >
<!ELEMENT hwname    - -  (#PCDATA)                                  >
<!ELEMENT altentry  - -  (#PCDATA)                                  >

<!ELEMENT matlinfo  - -  (mfrname, matlpnr, matlname, altentry*)    >
<!ELEMENT matlpnr   - -  (#PCDATA)                                  >
<!ELEMENT matlname  - -  (#PCDATA)                                  >

<!ELEMENT toolinfo  - -  (mfrname, toolpnr, toolname, altentry*)    >
<!ELEMENT toolpnr   - -  (#PCDATA)                                  >
<!ELEMENT toolname  - -  (#PCDATA)                                  >

<!ELEMENT terminfo  - -  (mfrname, termpnr, termname, altentry*)    >

<!ELEMENT termname  - -  (#PCDATA)                                  >

<!ELEMENT sub       - -  (#PCDATA)                                  >
<!ELEMENT super     - -  (#PCDATA)                                  >

<!ELEMENT chgdesc   - -  (#PCDATA)                                  >
<!ATTLIST chgdesc
          chgdtype   (edit|tech|effect|sgml)          #IMPLIED      >
<!ELEMENT title     - -  (#PCDATA | sub | super)+                   >

<!-- ============================================================ -->
<!--              TABLE (CELLULAR, CALS BASED)                    -->
<!-- ============================================================ -->
<!ELEMENT table     - -  ((title?, tgroup, ftnote*) | graphic+)
                         -(table)                                   >
<!ATTLIST table
          tabstyle  NMTOKEN                           #IMPLIED
          frame     (top | bottom | topbot 
                     | all | sides | none)            #IMPLIED
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED
          orient    (port | land)                     #IMPLIED
          pgwide    %yesorno;                         #IMPLIED
          id        ID                                #IMPLIED      >

<!ELEMENT tgroup    - O  (colspec*, spanspec*, thead?, tfoot?,
                         tbody)                                     >
<!ATTLIST tgroup
          cols      NUMBER                            #REQUIRED
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED
          align     (left | right | center 
                     | justify | char)                "left"
          charoff   NUTOKEN                           "50"
          char      CDATA                             ""            >

<!ELEMENT colspec   - O  EMPTY                                      >
<!ATTLIST colspec
          colnum    NUMBER                            #IMPLIED
          colname   NMTOKEN                           #IMPLIED
          align     (left | right | center
                    | justify | char)                 #IMPLIED
          charoff   NUTOKEN                           #IMPLIED
          char      CDATA                             #IMPLIED
          colwidth  CDATA                             #IMPLIED
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED      >

<!ELEMENT spanspec  - O  EMPTY                                      >
<!ATTLIST spanspec
          namest    NMTOKEN                           #REQUIRED
          nameend   NMTOKEN                           #REQUIRED
          spanname  NMTOKEN                           #IMPLIED
          align     (left | right | center
                     | justify | char)                "center"
          charoff   NUTOKEN                           #IMPLIED
          char      CDATA                             #IMPLIED
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED      >

<!ELEMENT thead     - O  (colspec*, row+)                           >
<!ATTLIST thead
          valign    (top | middle | bottom)           "bottom"      >

<!ELEMENT tfoot     - O  (colspec*, row+)                           >
<!ATTLIST tfoot
          valign    (top | middle | bottom)           "top"         >

<!ELEMENT tbody     - O  (row+)                                     >
<!ATTLIST tbody
          valign    (top | middle | bottom)           "top"         >

<!ELEMENT row       - O  (entry+)                                   >
<!ATTLIST row
          rowsep    %yesorno;                         #IMPLIED      >

<!ELEMENT entry     - O  ((regulatory | para | numlist | unlist)* 
                          | graphic)                                >
<!ATTLIST entry
          colname   NMTOKEN                           #IMPLIED
          namest    NMTOKEN                           #IMPLIED
          nameend   NMTOKEN                           #IMPLIED
          spanname  NMTOKEN                           #IMPLIED
          morerows  NUMBER                            "0"
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED
          rotate    %yesorno;                         "0"
          valign    (top | middle | bottom)           "top"
          align     (left | right | center
                     | justify | char)                #IMPLIED
          charoff   NUTOKEN                           #IMPLIED
          char      CDATA                             #IMPLIED      >

<!ELEMENT ftnote    - -  (%text;)                                   >
<!ATTLIST ftnote
          ftnoteid  ID                                #REQUIRED     >

<!-- ============================================================ -->
<!--   REFERENCE BLOCK and GRAPHIC REFERENCING MECHANISMS         -->
<!-- ============================================================ -->
<!ELEMENT refblock  - - (#PCDATA | refint | refext | grphcref)*     >

<!ELEMENT grphcref  - - (effect?, #PCDATA)                          >
<!ATTLIST grphcref
          refid          IDREF                        #IMPLIED
          sheetnbr       CDATA                        #IMPLIED
          structid       CDATA                        #IMPLIED
          shownow        %yesorno;                    "0"           >

<!ELEMENT graphic   - -  ((effect, chgdesc*, title?, sheet+)
                          | %deleted;)                              >
<!ATTLIST graphic
          chappref       CDATA                        #IMPLIED
          gtype          (ss | wd | il)               #IMPLIED
          chapnbr        NUMBER                       #IMPLIED
          sectnbr        NUMBER                       #IMPLIED
          subjnbr        NUMBER                       #IMPLIED
          pagenbr        CDATA                        #IMPLIED
          schemnbr       NUMBER                       #IMPLIED
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >

<!ELEMENT sheet     - -  ((effect, chgdesc*, title?, gdesc?) 
                          | %deleted;)                              >
<!ATTLIST sheet
          gnbr           ENTITY                       #REQUIRED
          cfnbr          ENTITY                       #IMPLIED
          gtype          (ss|wd|il)                   #IMPLIED
          chapnbr        NUMBER                       #IMPLIED
          sectnbr        NUMBER                       #IMPLIED
          subjnbr        NUMBER                       #IMPLIED
          pagenbr        CDATA                        #IMPLIED
          schemnbr       NUMBER                       #IMPLIED
          sheetnbr       CDATA                        #REQUIRED
          imgarea      (AP|BP|CP|DL|EL|FP|GP|HL|I-L)  #IMPLIED
          %revatt;                                                  >

<!ELEMENT gdesc     - -  (unlist | numlist)                         >

<!ELEMENT grsymbol    - O  EMPTY                                    >
<!ATTLIST grsymbol
          gnbr           ENTITY                       #REQUIRED 
          reprowid       CDATA                        #IMPLIED 
          reprohgt       CDATA                        #IMPLIED 
          reproscl       CDATA                        #IMPLIED      >

