	<span span="2">
	<tabatts widthtype="colrelative" relwidth="50" frame="all">
	<stdcellatts colsep="1" rowsep="0" colsepon="1" leftmar="5pt" rightmar="2pt" topmar="2pt">	</tabatts>

	<tgroupatts cols="3">	</tgroupatts>

	<colatts colname="col1" colwidth="7*">	</colatts>

	<colatts colname="col2" colwidth="5*">	</colatts>

	<colatts colname="col3" colwidth="5*">	</colatts>

	<usetext source="<header.ps>,<refhd>,\REFERENCE\, </refhd>,         <sssnhd>,\\, </sssnhd>, <fighd>,\FIGURE &\, </fighd>,         <refhd>,\DESIGNATION\, </refhd>,         <sssnhd>,\S/S/SN\, </sssnhd>,         <fighd>,\INDEX NO.\, </fighd>, </header.ps>,<body.ps>">	</usetext>
</charsubset>
