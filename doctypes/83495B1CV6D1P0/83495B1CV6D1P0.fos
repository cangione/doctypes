<textbrk startln="1" endln="1">
<savetext textid="title-appear" conrule="\no\"></charlist>
&att-38784-front-para0-atts;</e-i-c>
<e-i-c gi="ratddesc" context="* auxfront"><?Pub Lcl _id="f1"
_comment="usetext
source='<font-8pt.fmt&gt;,!<table frame=&#34;all&#34;&gt;<tgroup cols=&#34;9&#34;&gt;<?PubTbl tgroup ctmarg=&#34;2pt&#34; cbmarg=&#34;0.5pt&#34;&gt;!,ipbpl0tbl-structure.txt,ipbpl0tbl-header.txt,!<tbody&gt;!,ipbpl0tbl-body.txt,!</tbody&gt;</tgroup&gt;</table&gt;!,</font-8pt.fmt&gt;'
placemnt=&#34;after&#34;&gt;</usetext"><?Pub Dtl>
<charlist inherit="1" charsubsetref="clearstrings">
<textbrk startln="1" endln="1">
<savetext textid="title-appear" conrule="\no\"></charlist>
&att-set-label;&att-content-cbar;&security-mark;&att-stringdecl-reset;
&sssn-proc;&att-save-symbols;&att-use-label-front;&att-use-security;
&att-save-label-xref;&deleted-children;&mark.changed;
&para0-sub3-change.front;</e-i-c>
<e-i-c gi="title" context="ratddesc"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="para0.title.csub clearstrings">
<quadding quad="left" lastquad="relative">
<presp minimum="6pt" nominal="6pt" maximum="6pt" condit="discard">
<keeps scope="col" keep="1" next="1"></charlist>&security-mark;
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
