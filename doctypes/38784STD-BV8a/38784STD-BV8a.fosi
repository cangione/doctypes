	<usetext source="spfill,\REVISION NO. \,#CONTENT">
	<subchars>
	<font style="sanserif" size="14pt">
	<quadding quad="right" lastquad="lright">
	<presp minimum="12pt" nominal="12pt" maximum="12pt">
	<textbrk endln="1">	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="doctype" context="idinfo" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0" charsubsetref="ttlpg-allcap14.csub">
	<presp minimum="2pt" nominal="2pt" maximum="2pt" condit="keep" priority="high">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="verstatpg" attloc="doc" attval="#EQ#\unver\">
<charsubset>
	<usetext source="\WARNING\">
	<subchars>
	<font style="sanserif" size="8pt" weight="exbold">
	<quadding quad="center" lastquad="lcenter">
	<postsp minimum="6pt" nominal="10pt" maximum="6pt" priority="high">
	<textbrk startln="1" endln="1">
	<boxing toffset="10pt" boffset="4pt" loffset="4pt" roffset="4pt" trel="first" brel="last" siderel="content" thick="1pt" ttype="tdouble" btype="bdouble" ltype="ldouble" rtype="rdouble">	</subchars>
	</usetext>

	<usetext source="\This manual contains unverified procedures.  Refer to the Verification Status Page(s) prior to performing any operation or maintenance procedures.\">
	<subchars>
	<font style="sanserif" size="8pt" weight="bold">
	<leading lead="9pt">
	<indent leftind="1in" rightind="1in" firstln="*">
	<quadding quad="left" lastquad="lleft">
	<presp minimum="0pt" nominal="10pt" maximum="10pt">
	<postsp minimum="0pt" nominal="20pt" maximum="20pt">
	<textbrk startln="1" endln="1">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="docstat" attloc="doc" attval="#EQ#\prelim\">
<charsubset>
	<usetext source="\PRELIMINARY\">
	<subchars charsubsetref="ttlpg-allcap14.csub">
	<presp condit="keep">	</subchars>
	</usetext>

	<usetext source="\TECHNICAL MANUAL\">
	<subchars charsubsetref="ttlpg-allcap14.csub">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="service" attloc="doc" attval="#NE#\af\">
<specval attname="docstat" attloc="doc" attval="#EQ#\draft\">
<charsubset>
	<usetext source="\DRAFT\">
	<subchars charsubsetref="ttlpg-allcap14.csub">
	<presp condit="keep">	</subchars>
	</usetext>

	<usetext source="\TECHNICAL MANUAL\">
	<subchars charsubsetref="ttlpg-allcap14.csub">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="service" attloc="doc" attval="#EQ#\af\">
<specval attname="docstat" attloc="doc" attval="#EQ#\draft\">
<charsubset>
	<usetext source="\PRELIMINARY\">
	<subchars charsubsetref="ttlpg-allcap14.csub">
	<presp condit="keep">	</subchars>
	</usetext>

	<usetext source="\TECHNICAL MANUAL\">
	<subchars charsubsetref="ttlpg-allcap14.csub">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
