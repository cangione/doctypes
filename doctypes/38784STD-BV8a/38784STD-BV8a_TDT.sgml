			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>downgrd</tag>
		<long>Downgrade Notice</long>
		<desc>Identifies the classification downgrade notice on the title page.</desc>
		<source>4.4</source>
		<contmdl>(phrase | oadr)</contmdl>
		<usedin>idinfo</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>ecpno</tag>
		<long>Engineering Change Proposal Number</long>
		<desc>Identifies the ECP Number in the record of applicable technical directives.</desc>
		<source>4.5.9.4</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>ratdentry</usedin>
		<ents>text, exclus and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>effdatenot</tag>
		<long>Effective Date Notice</long>
		<desc>Identifies the effective date notice on the title page.</desc>
		<source>4.5.1.8</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>idinfo and chginssht</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>emphasis</tag>
		<long>Emphasis</long>
		<desc>Identifies portions of text to be highlighted (e.g. italic, bold, etc.). This element is included to allow the author flexibility in composing the manual in accordance with this spec.</desc>
		<source>None.</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>text, exclus, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>type</attr>
				<type>(b | i | bi | x | o | sup | sub)</type>
				<default>#REQUIRED</default>
				<attrdesc>Displays different types of emphasis. 
	  b=bold
	  i=italics
	  bi=bold/italics
	  q=quotes
	  x=box
	  o=overscore
	  sup=superscript
	  sub=subscript</attrdesc>

				<attr>fontsize</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows author to set the font size which will be applied to the text within the emphasis tags.</attrdesc>

				<attr>color</attr>
				<type>(black | white | red | orange | yellow | green | blue | violet | brown | gray)</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows author to set the color which will be applied to the text within the emphasis tags.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>entry</tag>
		<long>Table Entry</long>
		<desc>Identifies a table entry (cell).</desc>
		<source>4.2.7</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+ | randlist | deflist | seqlist | warning | caution | note )+</contmdl>
		<usedin>row</usedin>
		<ents>entry, entryatt, and secur</ents>
		<specatts>
			<attrtbl>
				<attr>colname</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to specify the name of the column to use</attrdesc>

				<attr>spanname</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to define a span name.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>morerows</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Allows you to define a vertical span on entries within a table.</attrdesc>

				<attr>colsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a vertical line to seperate columns. A value of 1. for this attribute will generate column separators.</attrdesc>

				<attr>rowsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a horizontal line to seperate rows. A value of 1. for this attribute will generate row separators.</attrdesc>

				<attr>rotate</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle switch to rotate the contents of the entry 90 degrees.</attrdesc>

				<attr>valign</attr>
				<type>(top | middle | bottom)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the vertical alignment of text within a cell.</attrdesc>

				<attr>align</attr>
				<type>(left | right | center | justify | char)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the horizontal alignment of text within a cell.</attrdesc>

				<attr>charoff</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Determines the distance the cell content should offset from the horizontal alignment character.</attrdesc>

				<attr>char</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the alignment character that can be used to align values within a column.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>entrytbl</tag>
		<long>Entry Table</long>
		<desc>Identifies a table within a table entry. This element allows a table cell to be divided into a sub-table, with its own set of rows, columns, and entries. Use of this element basically allows the author to create a table within a table.</desc>
		<source>4.2.7</source>
		<contmdl>(colspec*, spanspec*, thead?, tbody)  -(entrytbl)</contmdl>
		<usedin>row</usedin>
		<ents>yesorno, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>cols</attr>
				<type>NUMBER</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows you to define the number of columns.</attrdesc>

				<attr>colname</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to specify the name of the column to use</attrdesc>

				<attr>spanname</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to define a span name.</attrdesc>

				<attr>colsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a vertical line to seperate columns. A value of 1. for this attribute will generate column separators.</attrdesc>

				<attr>rowsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a horizontal line to seperate rows. A value of 1. for this attribute will generate row separators.</attrdesc>

				<attr>align</attr>
				<type>(left | right | center | justify | char)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the horizontal alignment of text within a cell.</attrdesc>

				<attr>charoff</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Determines the distance the cell content should offset from the horizontal alignment character.</attrdesc>

				<attr>char</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the alignment character that can be used to align values within a column.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>esds</tag>
		<long>Electrostatic Discharge Sensitive Symbol</long>
		<desc>Identifies the ESDS symbol. Use of this element will cause the ESDS symbol to appear at that point in the running text. The esds attribute should be used to place the ESDS symbol between a paragraph/step number and text.</desc>
		<source>4.3.10.4</source>
		<contmdl>EMPTY</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>expcont</tag>
		<long>Export Control Notice</long>
		<desc>Identifies the export control notice on the title page. Note that the export control notice entity (<![ CDATA [&expcontnot;]]>) may be used in place of entering the text manually.</desc>
		<source>4.5.1.12</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+) +(underline)</contmdl>
		<usedin>idinfo and chginssht</usedin>
		<ents>text</ents>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>extapplicabil</tag>
		<long>External Applicability/Effectivity</long>
		<desc>Identifies a portion of text as being applicable to a specific model, serial number, part number, etc. Use of this element will cause the applicabilty/effectivity markings to appear at that point in running text.</desc>
		<source>4.3f</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(applicabil | extapplicabil | figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>text, exclus, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>targetdoc</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the external document that you are referencing. This value should equal an ID specified in the List of Related Publications. For implementing external references in digital data - this ID must equal the ID of the external document.</attrdesc>

				<attr>targetid</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides the ID for the element being referenced in the external document. The value of this attribute should equal the ID of an element in the referenced document.</attrdesc>

				<attr>displayvalue</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>If the author needs to add additional, unique information for purposes of referencing an external document, this attribute should be tagged. This attribute should be used for providing paragraph titles, system numbers, task numbers and for author-generated TO numbers where applicable.</attrdesc>

				<attr>HyTime</attr>
				<type>NAME #FIXED</type>
				<default>clink</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>HyNames</attr>
				<type>CDATA #FIXED</type>
				<default>linkend xrefid</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>extref</tag>
		<long>External Reference</long>
		<desc>Generates a reference to an external document.</desc>
		<source>4.3.1m</source>
		<contmdl>EMPTY</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>targetdoc</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the external document that you are referencing. This value should equal an ID specified in the List of Related Publications. For implementing external references in digital data - this ID must equal the ID of the external document.</attrdesc>

				<attr>targetid</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides the ID for the element being referenced in the external document. The value of this attribute should equal the ID of an element in the referenced document.</attrdesc>

				<attr>displayvalue</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>If the author needs to add additional, unique information for purposes of referencing an external document, this attribute should be tagged. This attribute should be used for providing paragraph titles, system numbers, task numbers and for author-generated TO numbers where applicable.</attrdesc>

				<attr>HyTime</attr>
				<type>NAME #FIXED</type>
				<default>clink</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>HyNames</attr>
				<type>CDATA #FIXED</type>
				<default>linkend xrefid</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
