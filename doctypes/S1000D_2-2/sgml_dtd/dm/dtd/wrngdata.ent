    *  applics     - Optional  Single     contains applic.               *
    ********************************************************************** -->

<!ELEMENT conduit - - (pnr, altids?, size?, mass?, colour?, wallthk?, 
                       temp?, fdescref?, illref?, applics?)>


<!--**********************************************************************
    * Define Element wallthk (Wall Thickness) containing:-               *
    *  Definition stored in Entity %PCDATA;.                             *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  uom     - CDATA  - IMPLIED   - Unit of Measurement.               *
    ********************************************************************** -->

<!ELEMENT wallthk - - (%PCDATA;)>
<!ATTLIST wallthk
          uom   	CDATA  	#IMPLIED >
          

<!--**********************************************************************
    * Define Element wire-mats (List of Wire Materials) containing:-     *
    *  wire-mat  - Mandatory Repeatable   contains pnr, altids, wirecode,*
    *                                       core, size, mass, colour,    *
    *                                       outjackcol, outdia, res,     *
    *                                       voltage, amerage, temp,      *
    *                                       screencount, coax, triax,    *
    *                                       freqchar, fdescref, illref,  *
    *                                       applics.                     *
    ********************************************************************** -->

<!ELEMENT wire-mats - - (wire-mat+)>


<!--**********************************************************************
    * Define Element wire-mat (Wire Material Information) containing:-   *
    *  pnr         - Mandatory Single     contains Parsed Character Data.*
    *  altids      - Optional  Single     contains altid.                *
    *  wirecode    - Optional  Single     contains wiretype, wiregauge.  *
    *  core        - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  size        - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  mass        - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  colour      - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  outjackcol  - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  outdia      - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  res         - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  voltage     - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  amperage    - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  temp        - Optional  Single     contains mint, maxt.           *
    *  screencount - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  coax        - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  triax       - Optional  Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  freqchar    - Optional  Single     contains impedance, freqatt.   *
    *  fdescref    - Optional  Single     contains refs.                 *
    *  illref      - Optional  Single     contains refs.                 *
    *  applics     - Optional  Single     contains applic.               *
    ********************************************************************** -->

<!ELEMENT wire-mat - - (pnr, altids?, wirecode?, core?, size?, mass?, 
                        colour?, outjackcol?, outdia?, res?, voltage?, 
                        amperage?, temp?, screencount?, coax?, triax?, 
                        freqchar?, fdescref?, illref?, applics?)>
                        

<!--**********************************************************************
    * Define Element freqchar (Frequency Characteristics) containing:-   *
    *  impedance - Mandatory Single       contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  freqatt   - Optional  Repeatable   contains freq, attenuation.    *
    ********************************************************************** -->

<!ELEMENT freqchar - - (impedance, freqatt*)>


<!--**********************************************************************
    * Define Element freqatt (Frequency and Attenuation) containing:-    *
    *  freq        - Mandatory Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
    *  attenuation - Mandatory Single     contains Definition stored in  *
    *                                              entity %PCDATA;.      *
