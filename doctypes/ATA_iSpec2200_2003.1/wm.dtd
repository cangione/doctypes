     using a public entity as follows:
<!DOCTYPE wm PUBLIC
     "-//ATA-TEXT//DTD WM-VER18-LEVEL2//EN" [ ]>                  -->

<!-- ============================================================ -->
<!--                       NOTATIONS                              -->
<!-- ============================================================ -->
<!NOTATION cgm      PUBLIC
     "-//USA-DOD//NOTATION Computer Graphics Metafile//EN"          >

<!NOTATION ccitt4   PUBLIC
     "-//USA-DOD//NOTATION CCITT Group 4 Facsimile//EN"             >

<!NOTATION gcf PUBLIC
     "-//ATA-TEXT//NOTATION Graphic Companion File//EN"             >

<!NOTATION pdf PUBLIC
    "-//Adobe Inc.//NOTATION Portable Document Format//EN"          >

<!NOTATION png PUBLIC
    "-//W3C//NOTATION Portable Network Graphics//EN"                >

<!NOTATION jpeg PUBLIC
    "+//ISBN 0-7923-9432-1::Graphic Notation//NOTATION Joint
     Photographic Experts Group Raster//EN"                         >

<!NOTATION vrml PUBLIC 
    "-//ATA-TEXT//NOTATION Virtual Reality Modeling Language//EN"   >

<!NOTATION mpeg PUBLIC
    "-//ATA-TEXT//NOTATION Motion Pictures Expert Group//EN"        >

<!NOTATION mp3 PUBLIC
    "-//ATA-TEXT//NOTATION Motion Pictures Expert Group, Audio
     Layer 3//EN"                                                   >

<!-- ============================================================ -->
<!--                       ENTITIES                               -->
<!-- ============================================================ -->

<!ENTITY % wcn      "(warning | caution | note)+"                   >

<!ENTITY % text     "(para | table | unlist | numlist | graphic
                     | %wcn; | list1)+"                             >

<!ENTITY % deleted  "(deleted, chgdesc*)"                           >

<!ENTITY % yesorno  "NUMBER"                                        >

<!ENTITY % revatt
        "chg        (N | R | U | D)                   #REQUIRED
         key        ID                                #REQUIRED
         revdate    NUMBER                            #REQUIRED"    >

<!ENTITY % ein    "(ein | einmfr)"                                  >

<!ENTITY   % ISOtech      PUBLIC 
     "ISO 8879-1986//ENTITIES   General Technical//EN"              >
<!ENTITY   % ISOpub      PUBLIC 
     "ISO 8879-1986//ENTITIES Publishing//EN"                       >
<!ENTITY   % ISOnum      PUBLIC 
   "ISO 8879-1986//ENTITIES   Numeric and Special Graphic//EN"      >
<!ENTITY   % ISOgrk1     PUBLIC 
     "ISO 8879-1986//ENTITIES   Greek Letters//EN"                  >
<!ENTITY   % ISOgrk2     PUBLIC 
     "ISO 8879-1986//ENTITIES Monotoniko Greek//EN"                 >
<!ENTITY   % ISOgrk3     PUBLIC 
     "ISO 8879-1986//ENTITIES Greek Symbols//EN"                    >
<!ENTITY   % ISOgrk4     PUBLIC 
     "ISO 8879-1986//ENTITIES Alternative Greek Symbols//EN"        >
<!ENTITY   % ISOlat1     PUBLIC 
     "ISO 8879-1986//ENTITIES Added Latin 1//EN"                    >
<!ENTITY   % ISObox      PUBLIC
     "ISO 8879-1986//ENTITIES Box and Line Drawing//EN"             >
<!ENTITY   % ISOamso     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Ordinary//EN"     >
<!ENTITY   % ISOamsc     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Delimiters//EN"   >

%ISOtech; %ISOpub; %ISOnum; %ISOgrk1; %ISOgrk2; %ISOgrk3;
%ISOgrk4; %ISOlat1; %ISObox; %ISOamso; %ISOamsc;

<!-- ============================================================ -->
<!--      WIRING MANUAL TOP LEVEL STRUCTURE                       -->
<!-- ============================================================ -->
<!ELEMENT wm        - -  ((title, legalntc?, mfmatr, spchap?,  
                          chapter*, wmlist?) | increv | tr+)
                        +(revst | revend | cocst | cocend | hotlink)>
<!ATTLIST wm
          model          CDATA                        #REQUIRED
          oidate         NUMBER                       #REQUIRED
          revdate        NUMBER                       #REQUIRED
          tsn            CDATA                        #REQUIRED
          docnbr         CDATA                        #IMPLIED
          spl            CDATA                        #REQUIRED
          chg            (N|R|U)                      #REQUIRED
          lang           CDATA                        #REQUIRED
          cus            CDATA                        #IMPLIED
          cusname        CDATA                        #IMPLIED
          spc            %yesorno;                    "1"
          wdm            %yesorno;                    "1"
          ssm            %yesorno;                    "1"
          wmlist         %yesorno;                    "1"
          efflen         NUMBER                       #REQUIRED
          efftype        CDATA                        #REQUIRED     >

<!ELEMENT increv    - -  (ttlpage | transltr | trlist | mfrevrec 
                         | sblist | coclist | effxref | intro 
                         | eqiplist | condlist | eqrow | condrow 
                         | extwlist | extwrow | spchap| spsect 
                         | spsubj | chapter | section | subject 
                         | graphic | sheet | l1item | l2item
                         | l3item | legalntc | hazmtlst | vendlist
                         | glossary)+                               >

<!ELEMENT tr        - -  (legalntc?, trfmatr, trlist?,(sblist
                         | coclist | effxref | intro | eqrow+
                         | condrow+ | extwrow+ | spchap | spsect+
                         | spsubj+ | chapter | section+ | subject+
                         | graphic+ | sheet+ | l1item+ | l2item+
                         | l3item+ | legalntc | hazmtlst | vendlist
                         | glossary))                               >

<!ELEMENT trfmatr   - -  (title, trxref?, trinfo)                   >
<!ATTLIST trfmatr
          trnbr          CDATA                        #REQUIRED
          issdate        NUMBER                       #REQUIRED
          trdel          CDATA                        #IMPLIED
          trrepl         CDATA                        #IMPLIED      >

<!ELEMENT trxref    - -  (paptrnbr+)                                >
<!ELEMENT paptrnbr  - -  (#PCDATA)                                  >
<!ATTLIST paptrnbr
          issdate        NUMBER                       #REQUIRED     >
<!ELEMENT trinfo    - -  (%text;)                                   >

<!-- ============================================================ -->
<!--       Legal Notice Information                               -->
<!-- ============================================================ -->
<!ELEMENT legalntc  - - (exprtcl | cpyrght | proptary | geninfo)+   >
<!ATTLIST legalntc
          %revatt;                                                  >

<!ELEMENT proptary  - - (fullstmt, partstmt?)                       >
<!ELEMENT fullstmt  - - (title?, cpyrght?, para+)                   >
<!ELEMENT partstmt  - - (title?, para+)                             >
<!ELEMENT exprtcl   - - (para | unlist | numlist | note)+           >
<!ELEMENT cpyrght   - - (year*, holder*, geninfo)                   >
<!ELEMENT year      - - (#PCDATA)                                   >
<!ELEMENT holder    - - (#PCDATA)                                   >
<!ELEMENT geninfo   - - (para | unlist | numlist | note)+           >

<!-- ============================================================ -->
<!--                     WM FRONT MATTER                          -->
<!-- ============================================================ -->
<!ELEMENT mfmatr    - -  (ttlpage?, transltr?, trlist?, mfrevrec?,
                         cusrevrec?, vendlist?, sblist?, coclist?, 
                         effxref?, intro, hazmtlst?, glossary?)  
                                            +(refint | refext)      >

<!ELEMENT ttlpage   - -  (chgdesc*, title, graphic?, para*)         >
<!ATTLIST ttlpage
          %revatt;                                                  >

<!ELEMENT transltr  - -  ((chgdesc*, title, %text;) | %deleted;)    >
<!ATTLIST transltr
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >

<!ELEMENT trlist    - -  (trdata+ | isempty)                        >
<!ATTLIST trlist
          %revatt;                                                  >

<!ELEMENT trdata    - -  (trnbr, trstatus, trloc+)                  >

<!ELEMENT trnbr     - -  (#PCDATA)                                  >
<!ELEMENT trstatus  - -  (#PCDATA)                                  >
<!ELEMENT trloc     - -  (#PCDATA)                                  >

<!ELEMENT mfrevrec  - -  (chgdesc*, title, %text;)                  >
<!ATTLIST mfrevrec
          %revatt;                                                  >

<!ELEMENT cusrevrec - -  (chgdesc*, title, %text;)                  >

<!ELEMENT vendlist  - -  (title, (%text;)?, vendata+)               >
<!ATTLIST vendlist
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
<!ELEMENT vendata   - -  (mfr, mad)                                 >
<!ELEMENT mad       - -  (venname?, venaddr*, veninfo*, venrpl*)    >
<!ELEMENT venname   - -  (#PCDATA)                                  >
<!ELEMENT venaddr   - -  (#PCDATA)                                  >
<!ELEMENT veninfo   - -  (#PCDATA)                                  >
<!ELEMENT venrpl    - -  (#PCDATA)                                  >
<!ATTLIST venrpl
          rplstatus      (rpls|rplby)                 #REQUIRED     >

<!ELEMENT sblist    - -  (chgdesc*, title, %text;, (sbdata+ 
                          | isempty))                               >
<!ATTLIST sblist
          %revatt;                                                  >
<!ELEMENT sbdata    - -  (sbnbr?, sbrev?, sbnrmfr*, eonbr*, atanbr?,
                          mdnbr*, cocnbr*, custeff?, sc?, aclist*,
                          title?, (ics | icdate))                   >
<!ELEMENT sbnrmfr   - -  (sbnbr, mfr?)                              >
<!ELEMENT aclist    - O  EMPTY                                      >
<!ATTLIST aclist
          status         CDATA                        #IMPLIED
          effrg          CDATA                        #IMPLIED      >

<!ELEMENT sbnbr     - -  (#PCDATA)                                  >
<!ELEMENT sbrev     - -  (#PCDATA)                                  >
<!ELEMENT atanbr    - -  (#PCDATA)                                  >
<!ELEMENT mdnbr     - -  (#PCDATA)                                  >
<!ELEMENT custeff   - -  (cus, effrc)+                              >
<!ELEMENT cus       - -  (#PCDATA)                                  >
<!ELEMENT effrc     - -  (#PCDATA)                                  >
<!ELEMENT sc        - -  (#PCDATA)                                  >
<!ELEMENT icdate    - -  (#PCDATA)                                  >
<!ELEMENT ics       - -  (#PCDATA)                                  >
<!ATTLIST ics
          status         CDATA                        #IMPLIED      >

<!ELEMENT coclist   - -  (chgdesc*, title, %text;, (cocdata+ 
                          | isempty))                               >
<!ATTLIST coclist
          %revatt;                                                  >
<!ELEMENT cocdata   - -  (cocnbr?, cocrev?, eonbr*, atanbr?, mdnbr*,
                          custeff?, sc?, aclist*, title?, (icdate
                          | ics))                                   >

<!ELEMENT cocnbr    - -  (#PCDATA)                                  >
<!ELEMENT cocrev    - -  (#PCDATA)                                  >
<!ELEMENT eonbr     - -  (#PCDATA)                                  >

<!ELEMENT effxref   - -  (chgdesc*, title, %text;, effdata+)        >
<!ATTLIST effxref
          %revatt;                                                  >
<!ELEMENT effdata   - -  (cus?, modtype?, venbr?, cec, cac?, acn?,
                          linenbr?, ect?, msnbr, esnbr?, benbr?,
                          operator?, fslgnbr?, cusaid?)>
<!ELEMENT benbr     - -  (#PCDATA)                                  >
<!ELEMENT operator  - -  (#PCDATA)                                  >
<!ELEMENT ect       - -  (#PCDATA)                                  >
<!ELEMENT esnbr     - -  (#PCDATA)                                  >
<!ELEMENT cusaid    - -  (#PCDATA)                                  >
<!ELEMENT fslgnbr   - -  (#PCDATA)                                  >

<!ELEMENT modtype   - -  (#PCDATA)                                  >
<!ELEMENT venbr     - -  (#PCDATA)                                  >
<!ELEMENT cec       - -  (#PCDATA)                                  >
<!ELEMENT cac       - -  (#PCDATA)                                  >
<!ELEMENT acn       - -  (#PCDATA)                                  >
<!ELEMENT linenbr   - -  (#PCDATA)                                  >
<!ELEMENT msnbr     - -  (#PCDATA)                                  >

<!ELEMENT intro     - -  (chgdesc*, title, para?, list1)            >
<!ATTLIST intro
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >

<!ELEMENT hazmtlst  - -  (title, pretopic*, hazmt+)                 >
<!ATTLIST hazmtlst
          %revatt;                                                  >
<!ELEMENT hazmt     - -  (title, warning)                           >
<!ATTLIST hazmt
          id             ID                           #REQUIRED     >
<!ELEMENT pretopic  - -  (title, %text;)               +(effect)    >
<!ELEMENT glossary  - -  ((chgdesc*, title, (%text;)?, glosdata*) 
                         | %deleted;)                               >
<!ATTLIST glossary
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >
 
<!ELEMENT glosdata  - -  (term, def)                                >
<!ELEMENT term      - -  (#PCDATA)                                  >
<!ELEMENT def       - -  (#PCDATA)                                  >

<!-- ============================================================ -->
<!--               Standard Practices CHAPTER 20                  -->
<!-- ============================================================ -->
<!ELEMENT spchap    - -  ((effect?, chgdesc*, title, spsect+)
                          | %deleted;)                              >
<!ATTLIST spchap
          chapnbr        NUMBER                       "20"
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >

<!-- ============================================================ -->
<!--                     S P SECTION                              -->
<!-- ============================================================ -->
<!ELEMENT spsect    - -  ((effect?, chgdesc*, title?, spsubj+)
                          | %deleted;)                              >
<!ATTLIST spsect
          chapnbr        NUMBER                       #REQUIRED
          sectnbr        NUMBER                       #REQUIRED
          %revatt;                                                  >

<!-- ============================================================ -->
<!--                   S P SUBJECT                                -->
<!-- ============================================================ -->
<!ELEMENT spsubj    - -  ((effect?, chgdesc*, title?, %text;)
                          | %deleted;)                              >

<!ATTLIST spsubj
          chapnbr        NUMBER                       #REQUIRED
          sectnbr        NUMBER                       #REQUIRED
          subjnbr        NUMBER                       #REQUIRED
          %revatt;                                                  >

<!-- ============================================================ -->
<!--                     CHAPTER                                  -->
<!-- ============================================================ -->
<!ELEMENT chapter   - -  ((effect?, chgdesc*, title, section+)
                          | %deleted;)                              >
<!ATTLIST chapter
          chappref       CDATA                        #IMPLIED
          chapnbr        NUMBER                       #REQUIRED
          %revatt;                                                  >

<!-- ============================================================ -->
