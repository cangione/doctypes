	<ele>
		<tag>body</tag>
		<long>Body</long>
		<desc>Identifies the portion of the manual where chapters are used, exclusive of front matter and appendices, indexes, etc.</desc>
		<source>4.2.9.3 & 4.5.1.3.2 & 3.2.38</source>
		<contmdl>(chapter, chapter+, ipbchap?, ddchapter?)   +(ftnote)</contmdl>
		<usedin>doc, docpart, and volume</usedin>
		<ents>bodyele</ents>
		<specatts>
			<attrtbl>
				<attr>numcols</attr>
				<type>(1 | 2)</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows the author to define the page format as one or two columns for this section of the manual.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>brk</tag>
		<long>Break</long>
		<desc>This element is used to indicate that a column, line, or page break should be forced at that point. This element is included to allow the author flexibility in composing the manual in accordance with this spec.</desc>
		<source>None.</source>
		<contmdl>EMPTY</contmdl>
		<usedin>Globally included in doc</usedin>
		<specatts>
			<attrtbl>
				<attr>type</attr>
				<type>(col | line | npg)</type>
				<default>line</default>
				<attrdesc>Allows the author to define what type of break will occur when the brk element is used - column, line, or page.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>caution</tag>
		<long>Caution</long>
	 	<desc>Identifies a CAUTION in the manual.</desc>
		<source>4.3.10</source>
		<contmdl>(para*) -(randlist | deflist | seqlist | figure | table | foldout | objmedia | warning | caution)</contmdl>
		<usedin>entry, step1, step2, step3, step4, subpara1, subpara2, subpara3, subpara4, subpara5, subpara6, subpara7, subpara8, abbrsect, applicdef, dddesc, ddindex, ipbfinding, ipbesdsdesc, ipbhcidesc, ipbmfrlist, ipbmodelcover, ipbpartstd, ipbquickchgexpl, ipbserialization, ipbshtnoexplm, ipbsimassm, ipbsmrexpl, ipbuseonexpl, para0, ratddesc, tctolist, tmimprep, symsect, and lrp. Globally included in safesum.</usedin>
		<ents>list, exclus, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>change</tag>
		<long>Changed Information</long>
		<desc>Identifies material that has been changed. In order to add material, the type attribute should be set to add, and the change element should surround the added material. In order to delete material where a complete history of all changes to the document are being preserved, the type attribute should be set to delete and the change element should surround the deleted material. If all changes are not being preserved, change the material and surround it with a change element, setting the type attribute to add.</desc>
		<source>4.7.3.9</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)  -(figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>text, exclus, yesorno, and secur</ents>
		<specatts>
			<attrtbl>
				<attr>level</attr>
				<type>NMTOKEN</type>
				<default>#REQUIRED</default>
				<attrdesc>Defines the change level for the modification.</attrdesc>

				<attr>change</attr>
				<type>(add | delete)</type>
				<default>add</default>
				<attrdesc>Defines the type of change - addition or deletion of text.</attrdesc>

				<attr>mark</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Allows the author to define if a change mark will appear for this change.  1. will produce a change bar on the page - 0. will suppress it.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Allows the author to tag whether this modification is for a revision or a change.  0. indicates a change.  1. for a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chapter</tag>
		<long>Chapter</long>
		<desc>Identifies a chapter.</desc>
		<source>4.2.9.3</source>
		<contmdl>(title, ((section, (note?, section)+) | para0+))  +(figure | table | foldout | objmedia)</contmdl>
		<usedin>body</usedin>
		<ents>chap, inclus, and chapatt</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chgdate</tag>
		<long>Change Date</long>
		<desc>Identifies the date of the latest change.</desc>
		<source>4.5.1.17</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>idinfo</usedin>
		<ents>text</ents>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chghistory</tag>
		<long>Change History</long>
		<desc>Identifies the beginning of the change history dates. The first date in the chghist is the original date and subsequent dates are change 1, change 2, etc.</desc>
		<source>4.5.3</source>
		<contmdl>(chginfo*)</contmdl>
		<usedin>idinfo</usedin>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chginfo</tag>
		<long>Change Information</long>
		<desc>Container element to identify the change information contained in the change history of the document.</desc>
		<source>4.5.3</source>
		<contmdl>(chgtxt?, date)</contmdl>
		<usedin>chghistory</usedin>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chginssht</tag>
		<long>Change Instruction Sheet</long>
		<desc>Identifies the change instruction sheet.</desc>
		<source>4.7.3.10.2</source>
		<contmdl>(chgnum, address, date, prtitle, effdatenot?, discl?, distrib, expcont?, destr?, chgpara+, chglist, sigblock?)</contmdl>
		<usedin>front and auxfront</usedin>
		<ents>chgsht</ents>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chglist</tag>
		<long>Change List</long>
		<desc>Identifies the Remove Pages and Insert Pages columns on the change instruction sheet.</desc>
		<source>4.7.3.10.2</source>
		<contmdl>(tabmat | (removepg, insertpg)+)</contmdl>
		<usedin>chginssht</usedin>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chgnum</tag>
		<long>Change Number/Letter</long>
		<desc>Identifies the latest change number/letter.</desc>
		<source>4.7.3.1, 4.2.1.4.2.3, 4.5.1.17, & 4.5.3.1</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>idinfo and chginssht</usedin>
		<ents>text</ents>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chgpara</tag>
		<long>Change Paragraph</long>
		<desc>Identifies the paragraph change status.</desc>
		<source>4.7.3.11.2</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>chginssht</usedin>
		<ents>text</ents>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chgrec</tag>
		<long>Change Record</long>
		<desc>Identifies the change record page. This page will be an empty table whose contents will be completed by the person filing the change pages in the manual. The change record page will be automatically generated by the FOSI.</desc>
		<source>4.5.5</source>
		<contmdl>EMPTY</contmdl>
		<usedin>front and auxfront</usedin>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>chgtxt</tag>
		<long>Change Text</long>
		<desc>This element is optional and is used to provide an alpha representation of the current change level. This element will only be tagged by those branches of the armed services that require alpha change numbers. For all other users, this element is optional and should not be tagged.</desc>
		<source>4.5.3</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>chginfo</usedin>
		<ents>text</ents>
		<specatts>
			<attrtbl>
				<attr>None.</attr>
				<type></type>
				<default></default>
				<attrdesc></attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>clink</tag>
		<long>Contextual Link</long>
		<desc>One of several HyTime elements. Can be used in any situation similar to the xref or extref element - will reference any nameloc declared.</desc>
		<source>None</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>HyBase</attr>
				<type>NAME #FIXED</type>
				<default>hylink</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>HyBnames</attr>
				<type>CDATA #FIXED</type>
				<default>"refsub linkend"</default>
				<attrdesc>Used in combination with HyTime to establish contextual link.</attrdesc>

				<attr>anchrole</attr>
				<type>CDATA #FIXED</type>
				<default>"refmark refsub #LIST"</default>
				<attrdesc>Used in combination with HyTime to establish an anchor role for contextual links.</attrdesc>

				<attr>anchcstr</attr>
				<type>NAMES</type>
				<default>self required</default>
				<attrdesc>Used in combination with HyTime to establish type of anchor string defined for a contextual link.</attrdesc>

				<attr>linkend</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>References a linkend declared within a nameloc element. Other attributes are not included because at this time - they are not applicable during a period of alpha test and will be added to the TDT as the options are explored and implement.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>cntentry</tag>
		<long>Table of Contents Entry</long>
		<desc>Identifies an entry for a manually tagged Table of Contents</desc>
		<source>4.5.6</source>
		<contmdl>(label, title, pageno)</contmdl>
		<usedin>contents and volcontents</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>inlevel</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the indenture level of the entry.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>cogact</tag>
		<long>Cognizant Field Activity</long>
		<desc>Identifies Cognizant Field Activity on the title page and is included in the distribution statement. This is a Navy requirement.</desc>
		<source>4.5.1.11</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>idinfo</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>colspec</tag>
		<long>Column Specification</long>
		<desc>Defines a column in a table. Each column must have a column specification. The column specification defines the width of the column and an optional name used when column is starting or ending a horizontal span or referenced in a table entry. Column specifications in a table group apply to the table heading (boxheads) and the table body. The table heading can redefine the column specifications if needed, however, the table body must use the column specifications defined in the table group.</desc>
		<source>4.3.9</source>
		<contmdl>EMPTY</contmdl>
		<usedin>entrytbl, tfoot, tgroup, and thead</usedin>
		<ents>yesorno and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>colname</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to define a column name.</attrdesc>

				<attr>colnum</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to define a column number.</attrdesc>

				<attr>align</attr>
				<type>(left | right | center | justify | char)</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to align text within the cell.</attrdesc>

				<attr>charoff</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Determines the distance the cell content should offset from the horizontal alignment character.</attrdesc>

				<attr>char</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the alignment character that can be used to align values within a column.</attrdesc>

				<attr>leftmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the left margin for the cell.</attrdesc>

				<attr>rightmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the right margin for the cell.</attrdesc>

				<attr>topmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the top margin for the cell.</attrdesc>

				<attr>botmar</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the bottom margin for the cell.</attrdesc>

				<attr>mindepth</attr>
				<type>NUTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to define a minimum depth if desired.</attrdesc>

				<attr>colwidth</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to define the column widths.</attrdesc>

				<attr>colsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a vertical line to seperate columns. A value of 1. for this attribute will generate column separators.</attrdesc>

				<attr>rowsep</attr>
				<type>NUMBER</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to include a horizontal line to seperate rows. A value of 1. for this attribute will generate row separators.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>contents</tag>
		<long>Table of Contents</long>
		<desc>Identifies the table of contents. For Army documents, the table of contents consists of chapter and section titles. For all other services, the table of contents consists of chapter, section, and paragraph titles. If an index is used, the table of contents consists of chapter, section, and primary paragraph titles. This information is automatically compiled by the FOSI.</desc>
		<source>4.5.6</source>
		<contmdl>(cntentry* | #PCDATA)*</contmdl>
		<usedin>front and auxfront</usedin>
		<ents>cntnt and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>autobuild</attr>
				<type>CDATA</type>
				<default>#CONREF</default>
				<attrdesc>This attribute should be set equal to 1. when the Table of Contents is autogenerated.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>contractno</tag>
		<long>Contract Number</long>
		<desc>Identifies the contract number on the title page.</desc>
		<source>4.5.1.4</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>idinfo</usedin>
		<ents>text and secur</ents>
		<specatts>
			<attrtbl>
				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>copyright</tag>
		<long>Copyright Notice</long>
		<desc>Identifies the copyright notice on the title page.</desc>
		<source>4.1.2 & 4.5.1.14</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>idinfo</usedin>
		<ents>text and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>dataiden</tag>
		<long>Data Identification</long>
		<desc>May be used to identify specific types of data (e.g. hazardous materials, special tools, etc.). Use of this element does not affect the formatted output, but is intended to be used in database functions and data searches.</desc>
		<source>4.5.1.7, 4.5.1.16, 4.5.1.17, & 4.5.3.1</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(dataiden | figure | table | foldout | objmedia)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>text, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>type</attr>
				<type>CDATA</type>
				<default>#REQUIRED</default>
				<attrdesc>Defines the type of data being used in the database functions and database searches.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>date</tag>
		<long>Date</long>
		<desc>Identifies a date.</desc>
		<source>4.5.1.17 & 4.5.9.4b</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>chginssht, chginfo, ratdentry, and tctorow</usedin>
