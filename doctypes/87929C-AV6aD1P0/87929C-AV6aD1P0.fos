<e-i-c gi="ficatbl" occur="all"><?Pub Lcl _id="f1"
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'><?Pub Dtl>
<charlist>
<textbrk startln="1" endln="1">
<span span="1">
<reset resetlist="tbl.ftnote.ctr">
<savetext textid="tbl.ftnote.sym.txt" conrule="\\">
<enumerat increm="1" enumid="tbl.ctr">
<savetext textid="label.txt" conrule="tbl.ctr">
<reset resetlist="atftnct.ctr">
<savetext textid="prefix.tdv" conrule="\Table \" placemnt="before">
<savetext textid="prefix.tdv" conrule="\\" placemnt="after">
<savetext textid="symbol.tdv" conrule="\*\" placemnt="before" append="0">
<savetext textid="set-next-symbol.tdv"
conrule="<double-asterisk.psu>,</double-asterisk.psu>" placemnt="before"
append="0">
<savetext textid="fica-data.txt"
conrule="!<entry>!,contentcbar.txt,!</entry><entry></entry><entry></entry>!"
placemnt="before" append="0"></charlist>&att-set-label;
<att>
<charsubset>
<savetext textid="tabnum" conrule="label.txt"></charsubset>
</att>
<att logic="and"><?Pub Lcl
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'>
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,label.txt"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<presp nominal="10pt" priority="force">
<textbrk startln="1" endln="1">
<span span="1">
<suppress sup="1">
<usetext source="\Table \,tabnum,\. Deleted\" placemnt="before">
<subchars>
<font inherit="0" weight="bold">
<quadding quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="6pt" nominal="10pt" maximum="12pt" condit="discard">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="lotmatter"
conrule="<toclinecfig>,<toctitle.fmt>,label.txt,@2.5em,secur.str,scontent.txt,\(Deleted)\,econtent.txt,tocfill,</toctitle.fmt>,<tocnumx>,0.25in,folio.txt[BO],</tocnumx>,</toclinecfig>"
append="1">
<savetext textid="wptablelist.app"
conrule="<uinput.psu>,<ulabel.psu>,label.txt,</ulabel.psu>,<utitle.psu>,\(Deleted)\,</utitle.psu>,folio.txt[BO],</uinput.psu>"
placemnt="after" append="1"></charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext
source="\Table \,tabnum,\.\,1em,\Fault Isolation and Corrective Action.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp nominal="6pt" condit="keep" priority="force">
<postsp nominal="6pt" condit="keep" priority="force">
<keeps scope="col" keep="7" next="7">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="fica-structure.txt"
conrule='!<colspec colname="col1" colwidth="1*"><colspec colname="col2" colwidth="1.7*"><colspec colname="col3" colwidth="1.7*"><spanspec namest="col1" nameend="col3" spanname="SPAN1">!'
placemnt="before">
<savetext textid="fica-header.txt"
conrule='!<thead><row valign="bottom"><entry rowsep="1" align="center">!,\Trouble\,!</entry><entry rowsep="1" align="center">!,\Probable Cause\,!</entry><entry rowsep="1" align="center">!,\Corrective Action\,!</entry></row></thead>!'
placemnt="before">
<usetext
source='!<tabmat pgwide="1"><tgroup cols="3">!,fica-structure.txt,fica-header.txt,!<tbody>!,fica-body.txt,!</tbody></tgroup></tabmat>!'
placemnt="after"></usetext>
<savetext textid="fica-body.txt" conrule="\\" placemnt="after"
append="0">
<savetext textid="lotmatter"
conrule="<toclinecfig>,<toctitle.fmt>,label.txt,@2.5em,secur.str,scontent.txt,\Fault Isolation and Corrective Action\,econtent.txt,tocfill,</toctitle.fmt>,<tocnumx>,0.25in,folio.txt[BO],</tocnumx>,</toclinecfig>"
append="1">
<savetext textid="wptablelist.app"
conrule="<toclined>,<toctitle.fmt>,label.txt,@3.5em,\Fault Isolation and Corrective Action\,tocfill,</toctitle.fmt>,<tocnumchap>,folio.txt[BO],</tocnumchap>,</toclined>"
placemnt="after" append="1">
<!--<savetext textid="wptablelist.app"
conrule="<uinput.psu>,<ulabel.psu>,label.txt,</ulabel.psu>,<utitle.psu>,\Fault Isolation and Corrective Action\,</utitle.psu>,folio.txt[BO],</uinput.psu>"
placemnt="after" append="1">-->
</charsubset>
</att>
<att logic="and">
<specval attname="print-only" attloc="system-var" attval="#ANY">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext
source="\Table\, 0.5em, tabnum,\.\, 1em, \Fault Isolation and Corrective Action  -  Continued.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<textbrk startln="1" endln="1">
<float flidref="top-page.flt" width="page" scope="ficatbl"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>&deleted-children;&mark.changed;
