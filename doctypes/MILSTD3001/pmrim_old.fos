<!ENTITY Note "<charlist charsubsetref='alert.font.STYLE'></charlist>
<att>
  <specval attname='screen-only' attloc='system-var' attval='#ANY'>
  <charsubset charsubsetref='alert.indent.STYLE' >
    <textbrk endln='1'>
    <usetext source='\NOTE\'>
      <subchars charsubsetref='alert.title.STYLE'></subchars>
    </usetext>
  </charsubset>
</att>
<att>
  <specval attname='card.change.status.att' attloc='#FOSI' attval='#NE#\delete\'>
  <specval attname='alert.valign.option' attloc='#FOSI' attval='middle'>
  <specval attname='before.step.att' attloc='#FOSI' attval='no'>
  <charsubset>
    <savetext textid='table.row.text' placemnt='after' conrule='!<row><entry></entry><entry></entry><entry spanname=&#34;span3to4&#34; align=&#34;left&#34; colsep=&#34;0&#34; valign=&#34;middle&#34;><p.note.title></p.note.title></entry><entry spanname=&#34;span5to11&#34; align=&#34;left&#34; valign=&#34;top&#34;><p.para-alert>!,#CONTENT,!</p.para-alert></entry></row>!'>
    <savetext textid='card.body.text' append='1' placemnt='after' conrule='table.row.text'>
  </charsubset>
</att>
