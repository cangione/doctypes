<!--  PUBLIC "-//USA-DOD//ELEMENTS 3001 Part 4 Draft XML V307 08242016"-->

<!-- 		DTD for Maintenance Information 
		With Illustrated Parts Breakdown 
-->


<!ENTITY % tasks "(prepuse | handling | stow | remove | dissam | clncorr  | insp | service | repair  | align | paint | lube | assem | test-inspect | install | rig | adjust | calibrate | pss | envircond | safe | engstart | softload | fabricate | packing | unpacking | preserve | track | fuel | defuel | canning | decanning)*">

<!ENTITY % wpmaintreqipb  "(titleblk,  wpinfo,  intro?, %tasks;, ipb?, figsect?, foldsect?)">

<!ENTITY % wpmaintoptipb  "(titleblk,  wpinfo,  intro?, %tasks;, ipb?, figsect?, foldsect?)">

<!ENTITY % wpmaintnoipb  "(titleblk,  wpinfo,  intro?, %tasks;,  figsect?, foldsect?)">

<!-- ======================== -->

<!--	 Root Element for Maintenance Information Module -->
<!ELEMENT maintim  (maintwp |  genmaintwp | servicewp | grndopwp | semaintwp | locmfgwp| geninfomaintwp | qeckdescwp | qecawp | nonqecawp | bldupwp | preindinspwp | compindwp | brktwp | extcompwp | extubwp | critclwp | ipbwp | wirelistwp | wirediawp | scc)* >
<!ATTLIST maintim 	  %docatt;
					   %secur;>

<!--Maintenance Work Packages-->
<!ELEMENT maintwp  (%wpmaintreqipb;) >
<!ATTLIST maintwp 	%wpatt;
				 %secur;>

<!--Ground Handling Work Packages-->
<!ELEMENT grndopwp (titleblk,  wpinfo,  intro?, (grndop | handling)*, ipb?, figsect?, foldsect?) >
<!ATTLIST grndopwp 	%wpatt;
					 %secur;>

<!--General Maintenance Procedures Work Package-->
<!ELEMENT genmaintwp  (%wpmaintoptipb;) >
<!ATTLIST genmaintwp 	%wpatt;
				 %secur;>

<!--Servicing Work Package-->
<!ELEMENT servicewp  (%wpmaintnoipb;) >
<!ATTLIST servicewp 	%wpatt;
				 %secur;>

<!--Support Equipment Maintenance Work Package -->
<!ELEMENT semaintwp  (%wpmaintoptipb;) >
<!ATTLIST semaintwp 	%wpatt;
				 %secur;>

<!--Local Manufacturing and Assembly Work Package-->
<!ELEMENT locmfgwp  (%wpmaintoptipb;) >
<!ATTLIST locmfgwp 	%wpatt;
				 %secur;>

<!--General Information Maintenance Work Package-->
<!ELEMENT geninfomaintwp   (%wpmaintreqipb;) >
<!ATTLIST geninfomaintwp 	%wpatt;
				 	%secur;>

<!--Quick Engine Change Kit Description Work Package -->
<!ELEMENT qeckdescwp  (titleblk,  wpinfo,  intro?, qeckdesc,  figsect?, foldsect?) >
<!ATTLIST qeckdescwp 	%wpatt;
				 %secur;>

<!-- A listing and description of the components and equipment which comprise the QECK. Part of the Quick Engine Change Kit Description Work Package. -->
<!ELEMENT qeckdesc (title, (%paracon;)*, qecklist, qeckcompdesc+)>
<!ATTLIST qeckdesc 	%bodyatt;
				 	%secur;>

<!-- A listing of the components and equipment which comprise the QECK. Part of the Quick Engine Change Kit Description Work Package. -->
<!ELEMENT qecklist (title?, qeckentry+)>
<!ATTLIST qecklist 	%bodyatt;
				 	%secur;>

<!-- An individual entry of the QECK component listing. Part of the Quick Engine Change Kit Description Work Package. -->
<!ELEMENT qeckentry (#PCDATA | %pctext;)*>
<!ATTLIST qeckentry 	 %secur;>

<!-- A description of the components and equipment which comprise the QECK. Part of the Quick Engine Change Kit Description Work Package. -->
<!ELEMENT qeckcompdesc (title, desc, qeckcompdesc*)>
<!ATTLIST qeckcompdesc 	%bodyatt;
				 			%secur;>

<!--Quick Engine Change Assembly Work Package -->
<!ELEMENT qecawp  (%wpmaintreqipb;) >
<!ATTLIST qecawp 	%wpatt;
				 %secur;>

<!--Non-Quick Engine Change Assembly Work Package -->
<!ELEMENT nonqecawp  (%wpmaintreqipb;) >
<!ATTLIST nonqecawp 	%wpatt;
				 %secur;>

<!--Additional Power Plant Build-up Work Package -->
<!ELEMENT bldupwp  (%wpmaintreqipb;) >
<!ATTLIST bldupwp 	%wpatt;
				 %secur;>

<!--Preinduction and Mandatory Inspection Work Package -->
<!ELEMENT preindinspwp  (%wpmaintoptipb;) >
<!ATTLIST preindinspwp 	%wpatt;
				 %secur;>

<!--Numerical Index Work Package -->
<!ELEMENT compindwp    (titleblk, intro?, compind, figsect?, foldsect?) >
<!ATTLIST compindwp 	%wpatt;
				 %secur;>

<!--Numerical Index of External Part Numbers -->
<!ELEMENT compind (title,  compindentry+, noteslist?)>
<!ATTLIST compind 	%bodyatt;
				 	%secur;>

<!--Individual Entry in the Numerical Index of External Part Numbers -->
<!ELEMENT compindentry (partno, seqno)>
<!ATTLIST compindentry 	%refs;
				 		%secur;>

<!--Bracket Installation Work Package -->
<!ELEMENT brktwp   (titleblk,  wpinfo,  intro?, (%proccon;), %tasks;,  figsect?, foldsect?) >
<!ATTLIST brktwp 	%wpatt;
				 %secur;>

<!--External Components Work Package -->
<!ELEMENT extcompwp  (titleblk,  wpinfo,  intro?, %tasks;,  figsect?, foldsect?) >
<!ATTLIST extcompwp 	%wpatt;
				 %secur;>

<!--External Tubing, Cabling, and Clamping Installation Work Package -->
<!ELEMENT extubwp  (titleblk,  wpinfo,  intro?, %tasks;,  figsect?, foldsect?) >
<!ATTLIST extubwp 	%wpatt;
				 %secur;>

<!--Critical Clearances Work Package -->
<!ELEMENT critclwp  (titleblk,  wpinfo,  intro?, %tasks;,  figsect?, foldsect?) >
<!ATTLIST critclwp 	%wpatt;
				 %secur;>

<!--Separate IPB Work Package -->
<!ELEMENT ipbwp (titleblk,  wpinfo,  intro?, plgrp*)>
<!ATTLIST ipbwp 	%wpatt;
				 %secur;>

<!-- Wire List Work Package -->
 <!ELEMENT wirelistwp (titleblk,  wpinfo,  intro, (foldout | figure | table)+)>
<!ATTLIST wirelistwp 	%wpatt;
				 %secur;>

<!-- Wiring Diagram Work Package -->
<!ELEMENT wirediawp (titleblk,  wpinfo,  intro, (foldout | figure | table)+)>
<!ATTLIST wirediawp 	%wpatt;
			%secur;>

<!--Sequence Control Chart-->
<!ELEMENT scc  (graphic)>
<!ATTLIST scc 	%bodyatt;
		%secur;>

<!-- TASKS -->

<!--  %tasks:
	Preparation for use and assembly <prepuse> (defined in common.ent)
	Handling <handling>
	Stowage <stow>
	Removal <remove>
	Disassembly <dissam>
	Cleaning and corrosion control <clncorr>
	Inspection <insp>
	Service <service>
	Repair <repair>
	Alignment <align>
	Painting <paint>
	Lubrication <lube>
	Assembly <assem>
	Test and inspection <test-inspect>
	Installation <install>
	Rigging <rig>
	Adjustment <adjust>
	Calibration <calibrate>
	Preparation for storage or shipment <pss>
	Environmental conditioning <envircond>
	Safety information <safe>
	Engine start and run-up <engstart> (defined in common.ent)
	Software loading <softload>
	Fabrication <fabricate>
	Packing <packing>
	Unpacking <unpacking>
	Preservation <preserve>
	Tracking <track>
	Ground Operations <grndop>
	Canning <canning>
	Decanning <decanning>
--> 

