<!ELEMENT termcode  - -  (#PCDATA)                                  >
<!ELEMENT length    - -  (#PCDATA)                                  >
<!ATTLIST length
          unit           (ft | in | mm | cm | m)      #REQUIRED     >
<!ELEMENT wiretype  - -  (#PCDATA)                                  >
<!ATTLIST wiretype
          wtcode         (us | mt)                    #IMPLIED      >
<!ELEMENT fam       - -  (#PCDATA)                                  >
<!ELEMENT wirerte   - -  (#PCDATA)                                  >
<!ELEMENT bundpnr   - -  (#PCDATA)                                  >
<!ELEMENT bunddesc  - -  (#PCDATA)                                  >
<!ELEMENT feedthru  - -  (%ein;, connect?, termnbr?)                >
<!ELEMENT sensep    - -  (#PCDATA)                                  >
<!ELEMENT pnrnha    - -  (#PCDATA)                                  >

