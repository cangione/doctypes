<span span="1">
<savetext textid="tctotbl-body.txt" conrule="\\" placemnt="before">
<savetext textid="tfn.st" conrule="\\" placemnt="before"></charlist>
<att logic="or">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext source="\List of Time Compliance Technical Orders.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="10pt" nominal="10pt" maximum="10pt" condit="keep"
priority="force">
<keeps scope="col" orphanct="2" next="1">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<usetext
source='!<tabmat frame="none"><tgroup cols="3"><colspec colname="col1" colwidth="1.5*"><colspec colname="col2" colwidth="4.5*"><colspec colname="col3" colwidth="1.5*"><thead><row><entry align="center" colsep="0">!,\TCTO\,<brk>,\Number\,</brk>,!</entry><entry align="center" colsep="0">!,\TCTO\,<brk>,\Title\,</brk>,!</entry><entry align="center" colsep="0">!,\TCTO\,<brk>,\Date\,</brk>,!</entry></row></thead><tbody>!,tctotbl-body.txt,!</tbody></tgroup></tabmat>!'
placemnt="after">
<subchars>
<span span="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext
source="\List of Time Compliance Technical Orders &ndash; Continued.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<textbrk startln="1" endln="1">
<float flidref="top-page.flt" width="col" scope="tctotbl"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>
<att logic="or">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<usetext source="\List of Time Compliance Technical Orders - DELETED.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="10pt" nominal="10pt" maximum="10pt" condit="keep"
priority="force">
<keeps scope="col" orphanct="2" next="1">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att logic="and">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
