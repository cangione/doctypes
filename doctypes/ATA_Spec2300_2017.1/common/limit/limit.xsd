	<xs:annotation>
		    <xs:documentation>Version Number: 2017.1</xs:documentation>
		    <xs:documentation>Revision Date: 2017-10-31</xs:documentation>
		    <xs:documentation>Revision Comments: Spec 2300 revision 2017.1</xs:documentation>
	  </xs:annotation>
	  <xs:include schemaLocation="../basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="../basicDataTypes/comment.xsd"/>
	  <!--=============================================-->
	<!-- limit  element								  										-->
	<!--=============================================-->
	<xs:element name="limit" type="limitPerfoType">
		    <xs:annotation>
			      <xs:documentation>limitation (perfValue or literal) optionally followed by a comment. Used if the operation of the airplane is restricted.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=============================================-->
	<!-- perfo element						  		  					 -->
	<!--=============================================-->
	<xs:element name="perform" type="limitPerfoType">
		    <xs:annotation>
			      <xs:documentation>Listing of performance decrements (list, table, statements, graphics, etc.). Used if the airplane’s baseline performance is affected</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=============================================-->
	<!-- limitPerfoType  element						  		  						  -->
	<!--=============================================-->
	<xs:complexType name="limitPerfoType">
		    <xs:sequence>
			      <xs:choice>
				        <xs:element name="perfValue" type="perfValueType">
					          <xs:annotation>
						            <xs:documentation>limitation composed of a couple perf-value</xs:documentation>
					          </xs:annotation>
				        </xs:element>
				        <xs:group ref="literalLimitPerfoGroup" maxOccurs="unbounded"/>
			      </xs:choice>
			      <xs:element name="comment" type="commentType" minOccurs="0"/>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- perfValueType element								  						-->
	<!--=============================================-->
	<xs:complexType name="perfValueType">
		    <xs:sequence>
			      <xs:element name="perf" type="paraType">
				        <xs:annotation>
					          <xs:documentation>Performance parameter related to a performance limitation.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="value" type="paraType">
				        <xs:annotation>
					          <xs:documentation>Value of the performance limitation.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- literalLimitType								  								-->
	<!--=============================================-->
	<xs:group name="literalLimitPerfoGroup">
		    <xs:choice>
			      <xs:group ref="textGroupType"/>
			      <xs:element ref="figure"/>
			      <xs:element ref="multimedia"/>
			      <xs:element ref="extApplication"/>
			      <xs:group ref="wcnGroupType"/>
		    </xs:choice>
	  </xs:group>
	  <xs:group name="caseExtensionGroup">
		    <xs:choice>
			      <xs:element ref="limit"/>
		    </xs:choice>
	  </xs:group>
	  <xs:group name="listItemExtensionGroup">
		    <xs:choice>
			      <xs:element ref="limit"/>
		    </xs:choice>
	  </xs:group>
	  <xs:group name="entryExtensionGroup">
		    <xs:choice>
			      <xs:element ref="limit"/>
		    </xs:choice>
	  </xs:group>
</xs:schema>