	  <xs:include schemaLocation="./norm.xsd"/>
	  <!--=============================================-->
	<!-- product Content model												 -->
	<!--=============================================-->
	<xs:element name="productIdent" type="productIdentType">
		    <xs:annotation>
			      <xs:documentation>Identification info about the product</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="productIdentType">
		    <xs:sequence>
			      <xs:element ref="norm" minOccurs="0" maxOccurs="unbounded"/>
		    </xs:sequence>
		    <xs:attributeGroup ref="productCodeAttGrp"/>
		    <xs:attribute name="productNumber" type="xs:string" use="required">
			      <xs:annotation>
				        <xs:documentation>Uniquely assigned product code or designator</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="productPubScope" use="required">
			      <xs:annotation>
				        <xs:documentation>Scope of publication that a product is issued for (ALL, ENVMOD, FLEET(+COC), MSN(+COC))</xs:documentation>
				
			      </xs:annotation>
			      <xs:simpleType>
				        <xs:restriction base="xs:string">
					          <xs:enumeration value="all"/>
					          <xs:enumeration value="envmod"/>
					          <xs:enumeration value="fleet"/>
					          <xs:enumeration value="fleetCoc"/>
					          <xs:enumeration value="msn"/>
					          <xs:enumeration value="msnCoc"/>
				        </xs:restriction>
			      </xs:simpleType>
		    </xs:attribute>
		    <xs:attribute name="productPubType" use="required">
			      <xs:annotation>
				        <xs:documentation>Type of publication that a product is issued for (NR, TR, CP, OSD)</xs:documentation>
				
			      </xs:annotation>
			      <xs:simpleType>
				        <xs:restriction base="xs:string">
					          <xs:enumeration value="nr"/>
					          <xs:enumeration value="tr"/>
					          <xs:enumeration value="cp"/>
					          <xs:enumeration value="osd"/>
				        </xs:restriction>
			      </xs:simpleType>
		    </xs:attribute>
	  </xs:complexType>
	  <xs:attributeGroup name="productCodeAttGrp">
		    <xs:attribute name="productCode" type="xs:string" use="required">
			      <xs:annotation>
				        <xs:documentation>General product acronym or abbreviation</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:attributeGroup>
</xs:schema>