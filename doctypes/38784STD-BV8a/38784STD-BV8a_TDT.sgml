		<contmdl>(tmidno+, (chgnum, chgdate)?, chghistory, pretmidno*, volnum?, revnum?, doctype, maintlvl?, prtitle, subtitle?, (mfr+, contractno+)?, seal?, supersed?, suppl*, effdatenot?, volnot?, discl?, distrib, expcont?, destr?, copyright*, cogact?, moveddata?, authnot, downgrd?, pubdate)</contmdl>
