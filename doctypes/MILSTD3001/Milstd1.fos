</charlist>
</e-i-c>
<e-i-c gi="syscomp" context="* titlepg"><?Pub Dtl>
<charlist charsubsetref="titlefont">
<font size="10pt">
<leading lead="12pt">
<hyphen hyph="0">
<quadding quad="center" lastquad="lcenter">
<highlt allcap="1">
<presp nominal="1em" priority="high">
<textbrk startln="1" endln="1"></charlist>
</e-i-c>
<e-i-c gi="name" context="sysnomen * titlepg"><?Pub Dtl>
<charlist>
<font style="sanserif" size="18pt" posture="upright" weight="bold"
width="regular">
<leading lead="20pt">
<quadding quad="center" lastquad="lcenter">
<highlt allcap="1">
<textbrk startln="1">
<savetext textid="alphaidxlvl1.txt" conrule="\, \,#CONTENT" append="1">
<savetext textid="sysnomentitle" conrule="#CONTENT"></charlist>
&change.marks.att;&security.after.atts;</e-i-c>
<e-i-c gi="name" context="* frnt"><?Pub Dtl>
<charlist>
<font weight="bold">
<quadding quad="center" lastquad="lcenter">
<highlt allcap="1">
<textbrk startln="1"></charlist>
<att>
<specval attname="index-entry-title" attloc="sysnomen" attval="#NONE">
<charsubset><?Pub Dtl>
<savetext textid="alphaidxlvl1.txt" conrule="#CONTENT"></charsubset>
</att>
<att>
<specval attname="index-entry-title" attloc="sysnomen" attval="#ANY">
<fillval attname="index-entry-title" attloc="sysnomen"
fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="alphaidxlvl1.txt"></charsubset>
</att>&change.marks.att;</e-i-c>
<e-i-c gi="modeldes" context="* frnt"><?Pub Dtl>
<charlist inherit="1">
<textbrk startln="0" endln="0">
<savetext textid="heading.on" conrule="\\">
<savetext textid="multiple" conrule="\S\"></charlist>
<att>
<specval attname="type" attval="aircraft">
<charsubset><?Pub Dtl>
<savetext textid="heading" conrule="\NAVY MODEL\"></charsubset>
</att>
<att>
<specval attname="type" attval="other">
<charsubset><?Pub Dtl>
<savetext textid="heading" conrule="\MODEL NUMBER\"></charsubset>
</att>
<att>
<specval attname='name(following-sibling::node()[1])="modeldes"'
attloc="#XPATH" attval="0">
<charsubset><?Pub Dtl>
<textbrk endln="1">
<savetext textid="multiple" conrule="\\"></charsubset>
</att>
<att>
<specval attname='name(preceding-sibling::node()[1])="modeldes"'
attloc="#XPATH" attval="0">
<charsubset><?Pub Dtl>
<textbrk startln="1">
<savetext textid="heading.on" conrule="heading,multiple,\ \">
</charsubset>
</att>
<att>
<specval attname="modelno-head" attval="on">
<charsubset><?Pub Dtl>
<usetext source="heading.on"></usetext>
</charsubset>
</att>
<att>
<specval attname='name(following-sibling::node()[1])="modeldes"'
attloc="#XPATH" attval="1">
<charsubset><?Pub Dtl>
<usetext source="\, \" placemnt="after"></usetext>
</charsubset>
</att>
</e-i-c>
