  </charsubset>
</att>">
<!ENTITY Warning "<charlist charsubsetref='alert.font.STYLE'>
  <font weight='medium'>
</charlist>
<att>
  <specval attname='screen-only' attloc='system-var' attval='#ANY'>
  <charsubset>
    <indent leftind='40pt' rightind='40pt' firstln='*'>
    <presp minimum='12pt' nominal='12pt' maximum='12pt' priority='force'>
    <postsp minimum='12pt' nominal='12pt' maximum='12pt' priority='force'>
    <textbrk startln='1' endln='1'>
  </charsubset>
</att>
<att>
  <specval attname='screen-only' attloc='system-var' attval='#ANY'>
  <specval attname='warning-type' attloc='warning' attval='not-hazmat'>
  <charsubset charsubsetref='alert.indent.STYLE' >
    <usetext source='\WARNING\'>
      <subchars charsubsetref='alert.title.STYLE'></subchars>
    </usetext>
  </charsubset>
</att>
<att>
  <specval attname='screen-only' attloc='system-var' attval='#ANY'>
  <specval attname='warning-type' attloc='warning' attval='hazmat'>
  <charsubset charsubsetref='alert.indent.STYLE' ></charsubset>
</att>
<att>
  <specval attname='card.change.status.att' attloc='#FOSI' attval='#NE#\delete\'>
  <specval attname='warning-type' attloc='warning' attval='not-hazmat'>
  <specval attname='alert.valign.option' attloc='#FOSI' attval='middle'>
  <charsubset>
    <savetext textid='table.row.text' placemnt='after' conrule='!<row><?PubTbl row breakpenalty=&#34;10000&#34;?><entry></entry><entry></entry><entry spanname=&#34;span3to4&#34; align=&#34;left&#34; colsep=&#34;0&#34; valign=&#34;middle&#34;><p.warning.title></p.warning.title></entry><entry spanname=&#34;span5to11&#34; align=&#34;left&#34; valign=&#34;top&#34;><p.para-alert>!,#CONTENT,!</p.para-alert></entry></row>!'>
    <savetext textid='card.body.text' placemnt='after' conrule='table.row.text' append='1'>
  </charsubset>
</att>
<att>
  <specval attname='card.change.status.att' attloc='#FOSI' attval='#NE#\delete\'>
  <specval attname='warning-type' attloc='warning' attval='not-hazmat'>
  <specval attname='alert.valign.option' attloc='#FOSI' attval='top'>
  <charsubset>
    <savetext textid='table.row.text' placemnt='after' conrule='!<row><?PubTbl row breakpenalty=&#34;10000&#34;?><entry></entry><entry></entry><entry spanname=&#34;span3to4&#34; align=&#34;left&#34; colsep=&#34;0&#34; valign=&#34;top&#34;><p.warning.title></p.warning.title></entry><entry spanname=&#34;span5to11&#34; align=&#34;left&#34; valign=&#34;top&#34;><p.para-alert>!,#CONTENT,!</p.para-alert></entry></row>!'>
    <savetext textid='card.body.text' placemnt='after' conrule='table.row.text' append='1'>
  </charsubset>
</att>
<att>
  <specval attname='card.change.status.att' attloc='#FOSI' attval='#NE#\delete\'>
  <specval attname='warning-type' attloc='warning' attval='hazmat'>
  <charsubset>
    <savetext textid='table.row.text' conrule='!<row><?PubTbl row breakpenalty=&#34;10000&#34;?><entry></entry><entry></entry><entry spanname=&#34;span3to11&#34; align=&#34;left&#34;><p.para-alert>!,#CONTENT,!</p.para-alert></entry></row>!'>
    <savetext textid='card.body.text' placemnt='after' conrule='table.row.text' append='1'>
  </charsubset>
</att>">
