<!--**********************************************************************
    *                                                                    *
    *                        S1000D Issue 2                              *
    *                SGML Document Type Definition                       *
    *                                                                    *
    *                     Release Version 2.2                            *
    *                       Date: 2005-05-01                             *
    *                                                                    *
    * Amendment:-                                                        *
    * 1. Update public identifier date.                                  *
    * 2. CPF 2002-11FR: Add new entity %FFT; to <mainfunc>.              *
    *                   Remove inclusion of <figure>, <foldout>, <table> *
    *                   from <mainfunc>.                                 *
    *                   Move call of entities %PRELREQ;, %PARACONSTATIC;,*
    *                   %EXTLIST;, %EXTFTAB;, %WCNP;, %CAPGRP; and       *
    *                   %CLOSEREQ; to file PROCED.DTD.                   *
    * 3. CPF 2004-03SE: Replace element <closeup> by new element         *
    *                   <closereqs> in the content model of <proced>.    *
    * 4. CPF 2004-32US: Expand Process DM to include <step1> content:    *
    *                   Move element <closereqs> to new file CLOSEREQ.ENT*
    *                   Include call of new entity %STEPSTATIC;.         * 
    *                                                                    *
    * Typical invocation:-                                               *
    * <!ENTITY % PROCED                                                  *
    *   PUBLIC "-//S1000D//ELEMENTS Procedural Breakdown 20050501//EN" > *
    * %PROCED;                                                           *
    ********************************************************************** -->



<!--**********************************************************************
    * Define Entity %CONTENT; (Content Breakdown) containing:- proced.   *
    ********************************************************************** -->

<!ENTITY % CONTENT "proced" >



<!--**********************************************************************
    * Define Element proced (Procedural Information) containing:-        *
    *   prelreqs   - Mandatory  Single   contains pmd, reqconds, reqpers,*
    *                                             supequip, supplies,    *
    *                                             spares, safety.        *
    *   mainfunc   - Mandatory  Single   contains step1, Definition      *
    *                                             stored in entity %FFT;.*
    *   closereqs  - Mandatory  Single   contains reqconds.              *
    ********************************************************************** -->

<!ELEMENT proced - O (prelreqs,mainfunc,closereqs) >
<!-- Content model changed -->


<!--**********************************************************************
    * Define Element mainfunc (Maintenance Function) containing:-        *
    *====================================================================*
    * Mandatory Repeatable Group                                         *
    *====================================================================*
    *   step1    - Mandatory Single      contains Definition stored in   *
    *                                    entity %stepcon;, step2.        *
    *  or                                                                *
    *   Definition stored in entity %FFT;.                               *
    *====================================================================*
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute Definition list stored in entity %bodyatt;              *
    ********************************************************************** -->

<!ELEMENT mainfunc - O (step1 | %FFT;)+ >
<!ATTLIST mainfunc
            %bodyatt; >
<!-- Call of entity %FFT; added to content model -->
<!-- Inclusion removed -->


<!--**********************************************************************
    * Call the Static Steps Public Text.                                 *
    * The formal public identifier is stored in the entity %STEPSTATIC;. *
    ********************************************************************** -->

%STEPSTATIC;
<!-- Call of this new entity included -->



<!--**********************************************************************
    * Call the Steps Public Text.                                        *
    * The formal public identifier is stored in the entity %EXTSTEP;     *
    ********************************************************************** -->

%EXTSTEP;




