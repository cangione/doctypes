<e-i-c gi="table" context="* para * front"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="clearstrings">
<quadding quad="center">
<presp minimum="6pt" nominal="12pt" maximum="12pt" condit="discard">
<postsp minimum="6pt" nominal="12pt" maximum="12pt" condit="discard">
<textbrk startln="1" endln="1">
<enumerat increm="1" enumid="tbl.ctr">
<savetext textid="label.txt" conrule="tbl.ctr">
<savetext textid="prefix.tdv" conrule="\Table \" placemnt="before">
<savetext textid="dlctcont" conrule="">
<savetext textid="prefix.tdv" conrule="\\" placemnt="after">
<savetext textid="symbol.tdv" conrule="\*\" placemnt="before" append="0">
<savetext textid="set-next-symbol.tdv"
conrule="<double-asterisk.psu>,</double-asterisk.psu>" placemnt="before"
append="0">
<savetext textid="object.str" conrule="\Table\">
<savetext textid="tfn.st" conrule="\\" placemnt="before"></charlist>
&att-set-label;
<att>
<charsubset>
<savetext textid="tabnum" conrule="label.txt">
<savetext textid="xrefstr" conrule="\Table \,tabnum"></charsubset>
</att>&att-content-cbar;&security-mark;
<att>
<specval attname="pgwide" attloc="table" attval="#GT#0">
<specval attname="status" attloc="table" attval="#NONE">
<charsubset>
<span span="1"></charsubset>
</att>
<att>
<specval attname="orient" attval="land1">
<charsubset>
<textbrk startpg="next" pageid="bodypgland" newpgmdl="local">
</charsubset>
</att>&att-stringdecl-reset;
<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Deleted)\">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Reserved)\">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="na">
<specval attname="status" attval="notapp">
<charsubset>
<savetext textid="deltypestr"
conrule="contentcbar.txt,\(Not Applicable)\"></charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
<suppress sup="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<usetext source="object.str,\ \,label.txt,\. \,deltypestr"
placemnt="before">
<subchars>
<font inherit="0" weight="bold">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
