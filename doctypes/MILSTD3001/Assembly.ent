 <!--PUBLIC "-//USA-DOD//ELEMENTS ASSEMBLY 3001 Part 1 Draft XML V307 08242016//EN"-->

<!--  Manual DTD for Assembling NAVAIR Work Package Technical Manuals
-->

<!--	Technical Manual Element used to assembly front matter and all appropriate information modules.-->
<!ELEMENT manual ( (volume-manual+)| (frnt, (genacim | descopim | testrblim | maintim  | structim | acwirim | acwirbunim | acconnrepim)*))>
<!ATTLIST manual %docatt;
 %numberoftmidnos;
%secur;>

<!-- Volume of a 3001 Technical Manual. Attribute "volumeno" generates the Volume Number on the title page.  The attribute "dashtmidno" provides the dash numbers of the tmidno that differentiate the volumes.  For example, if the volumes are numbered 01-F14AAA-3.1, 01-F14AAA-3.2,  01-F14AAA-3.3, etc then the dashtmidno should be captured as "-3.1", "-3.2", "-3.3", etc. This number will be part of the Consolidated Alphabetical Index in volume 1. -->
<!ELEMENT volume-manual (frnt, (genacim | descopim | testrblim | maintim  | structim | acwirim | acwirbunim | acconnrepim)*)>
<!ATTLIST volume-manual
volid 		ID 		#IMPLIED
volumeno         CDATA          #REQUIRED
dashtmidno        CDATA          #REQUIRED
%secur;>
