_id="f1"><?Pub Dtl>
<charlist inherit="1">
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp nominal="11pt">
<postsp nominal="11pt" condit="keep" priority="force">
<keeps scope="col" next="7">
<textbrk startln="1" endln="1"></charlist>&att-content-cbar;
<att>
