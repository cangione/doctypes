	<savetext textid="labelstr" conrule="tabct">
	<savetext textid="xreftype" conrule="\Table\">
	<savetext textid="xrefstr" conrule="tabct">
	<savetext textid="label" conrule="labelstr" saverule="1"></charsubset>
</att>

<att logic="and">
