valign="bottom"><row><entry morerows="1" align="center">
<bold>NOMENCLATURE</bold></entry><entry spanname="span2to4" align="center" rowsep="0"><bold>DEGREE OF INTERMEDIATE MAINTENANCE</bold></entry><entry morerows="1" align="center"><bold>FUNCTION</bold></entry><entry morerows="1" align="center"><bold>WP</bold></entry></row><row><entry colname="col2" align="center" colsep="0"><bold>1</bold></entry><entry colname="col3" align="center" colsep="0"><bold>2</bold></entry><entry colname="col4" align="center"><bold>3</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
