</att>
<att logic="and"><?Pub Lcl
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'>
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,tabnum"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<presp nominal="10pt" priority="force">
<textbrk startln="1" endln="1">
<span span="1">
<suppress sup="1">
<usetext source="\Table \,tabnum,\. (Deleted)\" placemnt="before">
<subchars>
<font inherit="0" weight="bold">
<quadding quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="6pt" nominal="10pt" maximum="12pt" condit="discard">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="wptablelist.app"
conrule="<uinput.psu>,<ulabel.psu>,label.txt,</ulabel.psu>,<utitle.psu>,\(Deleted)\,</utitle.psu>,folio.txt[BO],</uinput.psu>"
placemnt="after" append="1"></charsubset>
</att>
<att logic="and">
<specval attname="print-only" attloc="system-var" attval="#ANY">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext
source="\Table\, 0.5em, label.txt,\.\, 1em, \Master List of Containers  -  Continued.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<textbrk startln="1" endln="1">
<float flidref="top-page.flt" width="page" scope="contlisttbl"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="conttbl-structure.txt"
conrule='!<colspec colname="col1" colwidth="1.33*"><colspec colname="col2"
colwidth="0.79*"><colspec colname="col3" colwidth="0.86*"><colspec
colname="col4" colwidth="1.58*"><colspec colname="col5" colwidth="0.63*"><colspec
colname="col6" colwidth="1.37*"><colspec colname="col7" colwidth="0.80*"><colspec
colname="col8" colwidth="0.88*"><colspec colname="col9" colwidth="0.85*"><spanspec namest="col1" nameend="col9" spanname="SPAN1">!'
placemnt="before">
<savetext textid="conttbl-header.txt"
conrule='!<thead><row rowsep="1"><entry valign="top">Nomenclature</entry><entry valign="top">Figure No.</entry><entry valign="top">Use</entry><entry valign="top">Part No.</entry><entry valign="top">Units</entry><entry valign="top">Dimensions</entry><entry valign="top">Cube</entry><entry valign="top">Weight Loaded</entry><entry valign="top">Weight Empty</entry></row></thead>!'
placemnt="before">
<usetext
source="\Table \,label.txt,\.\,1em,\Master List of Containers.\">
<subchars>
<font inherit="0" weight="bold">
<quadding quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="6pt" nominal="10pt" maximum="12pt" condit="discard">
<keeps scope="col" keep="7" next="7">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<usetext
source='!<tabmat pgwide="1"><tgroup cols="9">!,conttbl-structure.txt,conttbl-header.txt,!<tbody>!,conttbl-body.txt,!</tbody></tgroup></tabmat>!'
placemnt="after"></usetext>
