	<xs:annotation>
		    <xs:documentation>Version Number: 2017.1</xs:documentation>
		    <xs:documentation>Revision Date: 2017-10-31</xs:documentation>
		    <xs:documentation>Revision Comments: Spec 2300 revision 2017.1</xs:documentation>
	  </xs:annotation>
	  <xs:include schemaLocation="./text.xsd"/>
	  <xs:annotation>
		    <xs:documentation>Schema for case (condition) Structures</xs:documentation>
	  </xs:annotation>
	  <xs:include schemaLocation="./figure.xsd"/>
	  <xs:include schemaLocation="./multimedia.xsd"/>
	  <xs:include schemaLocation="./extApplication.xsd"/>
	  <!--=============================================-->
	<!--  Case element Type declaration                                       -->
	<!-- WARNING : a specific definition of case content model  -->
	<!-- is also provided in common/limit/limit.xsd 	                       -->
	<!--  caseWithLimitType                                                         -->
	<!-- check to impact changes if necessary                           -->
	<!--=============================================-->
	<xs:complexType name="caseType">
		    <xs:annotation>
			      <xs:documentation>A part of description content under a condition</xs:documentation>
		    </xs:annotation>
		    <xs:sequence>
			      <xs:element ref="caseCond"/>
			      <xs:choice maxOccurs="unbounded">
				        <xs:group ref="textGroupType"/>
				        <xs:element ref="figure"/>
				        <xs:element ref="multimedia"/>
				        <xs:element ref="extApplication"/>
				        <xs:group ref="wcnGroupType"/>
				        <xs:group ref="caseExtensionGroup"/>
			      </xs:choice>
		    </xs:sequence>
		    <xs:attributeGroup ref="caseAttrGrp"/>
	  </xs:complexType>
	  <xs:attributeGroup name="caseAttrGrp">
		    <xs:attribute name="direct" type="xs:boolean" use="optional">
			      <xs:annotation>
				        <xs:documentation>Used to write a condition on a single line.</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:attributeGroup>
	  <!--=============================================-->
	<!--  caseCond declaration-->
	<!--=============================================-->
	<xs:element name="caseCond" type="nameType">
		    <xs:annotation>
			      <xs:documentation>A condition</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=============================================-->
	<!-- caseCondBlock element								     				-->
	<!--=============================================-->
	<xs:complexType name="caseCondBlockType">
		    <xs:annotation>
			      <xs:documentation>a block of condition</xs:documentation>
		    </xs:annotation>
		    <xs:sequence>
			      <xs:element ref="caseCond" minOccurs="2" maxOccurs="unbounded">
				        <xs:annotation>
					          <xs:documentation>A condition statement</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attributeGroup ref="logicalOperatorAttGrp"/>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- conditionIntroGroup element								     -->
	<!--=============================================-->
	<xs:group name="conditionIntroGroup">
		    <xs:annotation>
			      <xs:documentation>content group for condition element</xs:documentation>
		    </xs:annotation>
		    <xs:choice>
			      <xs:element ref="caseCond">
				        <xs:annotation>
					          <xs:documentation>A condition statement</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="caseCondBlock" type="caseCondBlockType">
				        <xs:annotation>
					          <xs:documentation>A block of condition statements</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:choice>
	  </xs:group>
	  <!--=============================================-->
	<!--  Case element Type declaration									-->
	<!--=============================================-->
	<xs:complexType name="exclusiveCasesType">
		    <xs:annotation>
			      <xs:documentation>List of exclusive conditional descriptive content</xs:documentation>
		    </xs:annotation>
		    <xs:sequence>
			      <xs:group ref="conditionIntroGroup" minOccurs="0"/>
			      <xs:element name="case" type="caseType" minOccurs="2" maxOccurs="unbounded"/>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=============================================-->
	<!--  Case elements group													  -->
	<!-- WARNING : a specific group 										 -->
	<!-- is also provided in common/limit/limit.xsd 	                       -->
	<!--  caseWithLimitGroup                                                       -->
	<!-- check to impact changes if necessary                           -->
	<!--=============================================-->
	<xs:group name="caseGroup">
		    <xs:choice>
			      <xs:element name="case" type="caseType">
				        <xs:annotation>
					          <xs:documentation>A part of content under a condition</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="exclusiveCases" type="exclusiveCasesType">
				        <xs:annotation>
					          <xs:documentation>Two or more exclusive conditional descriptive content</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:choice>
	  </xs:group>
</xs:schema>