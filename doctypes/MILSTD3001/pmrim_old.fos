<!--
TITLE CARD - PAGE SETS 
-->
<pageset id="titlecard.page">
<rectopg width="8in" nomdepth="5in" xvjstretch="none">
<pageres>
<reset
resetlist="card.task.ct card.qeca.component.ct card.front.ct card.front.blank.ct">
</pageres>
<pagespec>&Page.Margins;
<header nomdepth="18pt" spaflow="0pt"></header>
<footer nomdepth="36pt" spaflow="0pt">
<usetext source="service.nsn.text[BO],space.fill,pub.date.text[BO]">
<subchars charsubsetref="sysnomen.STYLE">
<quadding quad="left">
<postsp minimum="0" nominal="0" maximum="0" priority="force">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<usetext source="change.number.date.text[BO]">
<subchars>
<font style="sanserif" size="10pt" weight="medium">
<quadding quad="right">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</footer>
<flowtext numcols="1" chgmkplc="pout">
<column width="7.5in" vjprior="comp"></flowtext>
</pagespec>
</rectopg>&Card.BlankPg;</pageset>
