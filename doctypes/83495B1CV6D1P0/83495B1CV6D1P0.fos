<textbrk startpg="recto" pageid="frontpg" newpgmdl="global" startln="1"
endln="1">
<span span="1"></charsubset>
</att>
<att logic="and">
<specval attname="pagesize" attloc="docjg" attval="8.5x11">
<specval attname="numcols" attloc="front" attval="#ANY">
