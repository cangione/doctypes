<e-i-c gi="subfigfo" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<quadding quad="right" lastquad="lright">
	<span span="1">
	<savetext textid="foldsubfig.ist" conrule="">
	<savetext textid="foldsubfigno.ist" conrule="" placemnt="before">
	<savetext textid="secur.str" conrule="">
	<savetext textid="applicref.str" conrule="">
	<savetext textid="subfigno.ist" conrule="subfigttl.ctr" placemnt="after">
	<usetext source="\ \">
	<subchars>
	<textbrk startln="1">	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="inschlvl" attval="#NE#0">
<charsubset>
	<enumerat increm="1" enumid="subfigpoint.ctr">
	<enumerat increm="1" enumid="subfigttl.ctr"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#EQ#0">
<charsubset>
	<enumerat increm="0" enumid="subfigpoint.ctr" setvalue="1">
	<enumerat increm="1" enumid="subfig.ctr">
	<enumerat increm="1" enumid="subfigttl.ctr"></charsubset>
</att>

<att logic="and">
<specval attname="subfig.ctr" attloc="#FOSI" attval="#EQ#1">
<charsubset>
	<keeps keep="1" scope="page">
	<savetext textid="figpg" conrule="pgnumber[BO]" placemnt="before">
	<savetext textid="subfig.flag" conrule="\yes\">
	<savetext textid="xreftype" conrule="\Figure\">
	<savetext textid="xrefstr" conrule="labelstr,\ (Sheet \,subfig.ctr,\)\">
	<savetext textid="foldtitle.ftr" conrule="\Figure  \,labelstr[BO],\.\,1em,secur.str,applicref.str,figtitle,\. (Sheet \,subfig.ctr,\ of \,subfigno.ist,\)\" placemnt="after"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#NE#0">
<specval attname="subfig.ctr" attloc="#FOSI" attval="#NE#1">
<charsubset>
	<keeps keep="1" scope="page">
	<savetext textid="figpg" conrule="pgnumber[BO]">
	<savetext textid="subfig.flag" conrule="\yes\">
