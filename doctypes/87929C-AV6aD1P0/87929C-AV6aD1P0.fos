<charlist inherit="1" charsubsetref="clearstrings">
<textbrk startln="1" endln="1">
<reset resetlist="step1.ctr">
<reset resetlist="subp1.ctr">
<enumerat increm="1" enumid="para0.ctr">
<savetext textid="label.txt" conrule="para0.ctr">
<savetext textid="title-appear" conrule="\no\"></charlist>
&att-set-label;&att-content-cbar;&att-stringdecl-reset;
&att-save-symbols;&sssn-proc;&security-mark;&att-emergency-wpgroup;
<att>
<specval attname="inbody.st" attloc="#FOSI" attval="#EQ#\no\">
<charsubset>
<usetext source="label.txt,1em,secur.str">
<subchars>
<font inherit="1" style="sanserif">
<highlt scoring="0">
<textbrk startln="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="inbody.st" attloc="#FOSI" attval="#EQ#\yes\">
<charsubset>
<usetext source="label.txt,1em,secur.str">
<subchars>
<font inherit="1" style="sanserif">
<highlt scoring="0">
<textbrk startln="1"></subchars>
</usetext>
</charsubset>
</att>&para0-sub3-change-noindex.body;
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<savetext textid="wpcontents.app"
conrule="<uinput.psu>,<ugi.psu>,\manstru\,</ugi.psu>,<ulabel.psu>,label.txt,</ulabel.psu>, <utitle.psu>,deltypestr,</utitle.psu>,folio.txt[BO],</uinput.psu>"
placemnt="after" append="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Paragraph \,label.txt">
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Paragraph Deleted \,label.txt">
</charsubset>
</att>&deleted-children;&mark.changed;
<att><?Pub Lcl
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'>
