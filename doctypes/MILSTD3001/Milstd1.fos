<suppress sup="1">
<savetext textid="col1.app"
conrule="<ppara>,step1cttxt,<bold>,qaptxt,caitxt,csitxt,csptxt,esdstxt,hcitxt,hcptxt,ocitxt,ocptxt,odstxt,</bold>,#CONTENT,</ppara>"
append="1"></charlist>
</e-i-c>
