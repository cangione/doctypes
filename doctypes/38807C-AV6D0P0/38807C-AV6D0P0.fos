<savetext textid="label.txt" conrule="seqlist.ctr"></charlist>
&security-mark;
<att>
<charsubset>
<usetext source="label.txt,\.\,0.25em,secur.str" placemnt="before">
<subchars>
<indent inherit="1" rightind="*+0.4in" firstln="*">
<quadding quad="right" lastquad="lright">
<textbrk startln="1" endln="0">
<algroup refpoint="first"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext source="scontent.txt,#CONTENT,econtent.txt">
<subchars>
<indent inherit="1" leftind="@0.5in" firstln="@0.5in">
<quadding quad="left" lastquad="lleft">
<textbrk startln="0" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attloc="seqlist" attval="delete">
<specval attname="status" attloc="seqlist" attval="deleted">
<charsubset>
<suppress sup="1">
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Deleted)\">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<specval attname="deltype" attval="#EQ#\delete\">
<charsubset>
<suppress sup="1">
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Deleted)\">
<usetext source="deltypestr">
<subchars>
<indent inherit="1" leftind="@0.5in" firstln="@0.5in">
<quadding quad="left" lastquad="lleft">
<textbrk startln="0" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attloc="seqlist" attval="reserve">
<specval attname="status" attloc="seqlist" attval="reserved">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Reserved)\">
<usetext source="deltypestr">
<subchars>
<indent leftind="0.5in" firstln="0.5in">
<quadding quad="left" lastquad="lleft">
<textbrk startln="0" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attloc="seqlist" attval="na">
