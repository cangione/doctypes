<e-i-c gi="title" context="table * wpgroup"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1">
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="relative">
<presp minimum="11pt" nominal="11pt" maximum="11pt" condit="discard"
priority="force">
<postsp minimum="11pt" nominal="11pt" maximum="11pt" condit="keep"
priority="force">
<keeps scope="col" next="7">
<textbrk startln="1" endln="1">
<savetext textid="prefix.tdv" conrule="\Table \"></charlist>
&security-mark;&att-content-cbar;
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="applicref" attloc="table" attval="#ANY">
<fillval attname="applicref" attloc="table" fillcat="savetext"
fillchar="conrule">
<charsubset>
<savetext textid="applicrefid.txt">
<savetext textid="applicrefidtxt.txt"
conrule="<applicref.psu>,<applicabil>,applicrefid.txt,</applicabil>,</applicref.psu>">
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="tabletitle"
conrule="scontent.txt,#CONTENT,econtent.txt">
<savetext textid="tabletitle.txt"
conrule="scontent.txt,applicrefidtxt.txt,#CONTENT,econtent.txt">
<usetext source="\Table \,tabnum,\.\,1em,secur.str, applicrefidtxt.txt"
placemnt="before">
<subchars></subchars>
</usetext>
<usetext source="\.\" placemnt="after">
<subchars></subchars>
</usetext>
<savetext textid="lotmatter"
conrule="<toclinecfig>,<toctitle.fmt>,tabnum,@2.5em,secur.str,scontent.txt,#CONTENT,econtent.txt,tocfill,</toctitle.fmt>,<tocnumx>,0.25in,folio.txt[BO],</tocnumx>,</toclinecfig>"
append="1">
<savetext textid="wptablelist.app"
conrule="<toclined>,<toctitle.fmt>,label.txt,@3.5em,tabletitle.txt,tocfill,</toctitle.fmt>,<tocnumchap>,folio.txt[BO],</tocnumchap>,</toclined>"
placemnt="after" append="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext
source="\Table \,tabnum,\.\,1em,secur.str,tabletitle,\  &ndash; Continued.\">
<subchars>
<float flidref="top-col.flt" width="col" scope="table"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
<e-i-c gi="table" context="* pl0tbl * docwp"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="clearstrings">
<quadding quad="center">
<presp minimum="12pt" nominal="12pt" maximum="12pt" condit="discard"
priority="high">
<postsp minimum="6pt" nominal="12pt" maximum="12pt" condit="discard">
<textbrk startln="1" endln="1">
<savetext textid="prefix.tdv" conrule="\Table \" placemnt="before">
<savetext textid="dlctcont" conrule="">
<savetext textid="prefix.tdv" conrule="\\" placemnt="after">
<savetext textid="symbol.tdv" conrule="\*\" placemnt="before" append="0">
<savetext textid="set-next-symbol.tdv"
conrule="<double-asterisk.psu>,</double-asterisk.psu>" placemnt="before"
append="0">
<savetext textid="object.str" conrule="\Table\">
<savetext textid="tfn.st" conrule="\\" placemnt="before"></charlist>
<att>
<specval attname="pgwide" attloc="table" attval="#GT#0">
<charsubset>
<span span="1"></charsubset>
</att>
<att>
<specval attname="orient" attval="land1">
<charsubset>
<textbrk startpg="next" pageid="bodypgland" newpgmdl="local">
</charsubset>
</att>
<att>
<specval attname="orient" attval="land1">
<specval attname="id" attloc="swp" attval="#ANY">
<charsubset>
<textbrk startpg="next" pageid="bodypgland" newpgmdl="local">
</charsubset>
</att>&att-set-label;
<att>
<charsubset>
<savetext textid="tabnum" conrule="label.txt"></charsubset>
</att>&att-content-cbar;
<att logic="and">
<specval attname="inbody.st" attloc="#FOSI" attval="#EQ#\no\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,tabnum"></charsubset>
</att>
<att logic="and">
<specval attname="inbody.st" attloc="#FOSI" attval="#EQ#\yes\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,tabnum"></charsubset>
</att>
<att logic="and">
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,label.txt"></charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
<savetext textid="deltypestr" conrule="\(Deleted)\"></charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
<charsubset>
<savetext textid="deltypestr" conrule="\(Reserved)\"></charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="na">
<specval attname="status" attval="notapp">
<charsubset>
<savetext textid="deltypestr" conrule="\(Not Applicable)\"></charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
<suppress sup="1"></charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<charsubset charsubsetref="delchlvlfig"></charsubset>
</att>
<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
<charsubset charsubsetref="delchlvlfig"></charsubset>
</att>
<att><?Pub Lcl
_comment=' att logic="and"&gt;
<specval attname="print-only" attloc="system-var" attval="#ANY"&gt;
<specval attname="delchlvl" attval="#NONE"&gt;
<specval attname="legend" attloc="foldout" attval="#EQ#0"&gt;
<charsubset&gt;
<usetext
source="\Figure \,fignum,\.\,1em,foldtitle,\ &ndash; Continued.\"&gt;<?Pub Dtl&gt;
<subchars&gt;
<font weight="bold"&gt;
<quadding quad="center" lastquad="lcenter"&gt;
<presp minimum="1pi" nominal="1pi" maximum="1pi"&gt;
<postsp minimum="2pi" nominal="2pi" maximum="2pi"&gt;
<textbrk startln="1" endln="0"&gt;
<float flidref="bot-col.flt" width="col" scope="figtable"
pagetype="forward"&gt;</subchars&gt;
</usetext&gt;
</charsubset&gt;
</att '>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<savetext textid="lotmatter"
conrule="<toclinec>,tabnum, @72pt, deltypestr, tocfill1,
                           </toclinec>" append="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="\ \">
<subchars>
<font offset="-15pt">
<leading lead="0pt">
<postsp minimum="-15pt" nominal="-15pt" maximum="-15pt" priority="force">
<float flidref="bot-col.flt" width="col" scope="table"
pagetype="samecol">
<ruling thick="1.5pt" rellen="col" voffset="10pt" placemnt="before"
ruleclr="black" type="single"></ruling>
</subchars>
</usetext>
</charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
