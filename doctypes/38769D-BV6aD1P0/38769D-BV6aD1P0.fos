<savetext textid="ipbpl0tbl-structure.txt"
conrule='!<colspec colname="col1" colwidth="0.25*">
<colspec colname="col2" colwidth="0.5*" align="left">
<colspec colname="col3" colwidth="1.1*">
<colspec colname="col4" colwidth="0.17*" align="right">
