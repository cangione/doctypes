<!-- GPSL MILSPEC 38769D-BV6aD1P0 Entity File -->
<!ENTITY pagespec-region-recto-standard-8 '<!-- GPSL:RK Entity "pagespec-region-recto-standard-8" -->
<region xoff="-0.125in" yoff="-0.125in" layer="-1">
<usetext source="<emergency-border-recto-8.psu>,</emergency-border-recto-8.psu>">
</usetext>
</region>
'>
<!ENTITY pagespec-region-verso-standard-8 '<!-- GPSL:RK Entity "pagespec-region-verso-standard-8" -->
<region xoff="-0.125in" yoff="-0.125in" layer="-1">
<usetext source="<emergency-border-verso-8.psu>,</emergency-border-verso-8.psu>">
</usetext>
</region>
'>
<!ENTITY att-38769-front-para0-atts '<!-- GPSL:RK Entity "att-38769-front-para0-atts" -->
<!-- Typically a para0/semantic para0 in the front matter of a document will have all or most of these -->
&att-set-label;
&att-content-cbar;
&security-mark;
&att-stringdecl-reset;
&sssn-proc;
&att-save-symbols;
&att-emergency-front;
&att-use-label-front;
&att-use-security;
&att-save-label-xref;
&mark.changed;
&para0-sub3-change.front;
'>
<!ENTITY att-38769-front-subpara-atts '<!-- GPSL:RK Entity "att-38769-front-subpara-atts" -->
<!-- Typical subparaX in the front matter of a document will have all or most of these.  This differs from the para0/semantic para0 entity as this does not have the emergency att test -->
&att-set-label;
&att-content-cbar;
&security-mark;
&att-stringdecl-reset;
&sssn-proc;
&att-save-symbols;
&att-use-label-subpara1;
&att-use-security;
&att-save-label-xref;
&mark.changed;
&para0-sub3-change.front;
'>
<!ENTITY para0-sub3-change.front '<!-- GPSL:RK Entity "para0-sub3-change.front" -->
<!-- para0s/subparas in front are not saved to the toc -->
&set-deltypstr;
<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
<suppress sup="1">
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<charsubset charsubsetref="delchlvl.front">
</charsubset>
</att>
<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
<charsubset charsubsetref="delstatus.front"> 
</charsubset>
</att>
'>
<!ENTITY att-use-label-front '<!-- GPSL:RK Entity "att-use-label-front" -->
<att>
<!-- in front labels of para0s/subparas do have a trailing "." and have a trailing 1em (not used for subparas due to optional title and elements that could be before title) -->
<charsubset>
<usetext source="label.txt,\.\,1em">
<subchars>
<font inherit="1" style="sanserif">
<highlt scoring="0">
<textbrk startln="1">
</subchars>
</usetext>
</charsubset>
</att>
'>
<!ENTITY att-use-label-subpara1 '<!-- GPSL:RK Entity "att-use-label-subpara1" -->
<att>
<!-- in front labels of para0s/subparas do have a trailing "." and have a trailing 1em (not used for subparas due to optional title and elements that could be before title) -->
<charsubset>
<usetext source="label.txt,1em">
<subchars>
<font inherit="1" style="sanserif">
<highlt scoring="0">
<textbrk startln="1">
</subchars>
</usetext>
</charsubset>
</att>
'>
<!ENTITY att-delete-label-front '<!-- GPSL:RK Entity "att-delete-label-front" -->
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<usetext source="label.txt,\.\,1em">
<subchars>
<font inherit="1" style="sanserif">
<highlt scoring="0">
<textbrk startln="1">
</subchars>
</usetext>
</charsubset>
</att>
'>
<!ENTITY pagespec-flowtext-3col-notbalance '<!-- GPSL:RK Entity "pagespec-flowtext-3col-notbalance" -->
<flowtext numcols="3" balance="0" chgmkplc="plftrt">
&pagespec-flowtext-column-3col-lep;
&pagespec-flowtext-footnote-flowtext;
</flowtext>
'>
<!ENTITY header-lep-recto '<!-- GPSL:RK Entity "header-lep-recto" -->
<usetext source="<tmidno-algroup-rule>,</tmidno-algroup-rule>">
<subchars>
<font size="1pt">
<leading lead="1pt">
<indent leftind="@-7pi" rightind="*+1pi" firstln="*">
<textbrk startln="1" endln="1">
<algroup refpoint="last">
</subchars>
</usetext>
<usetext source="<tmidnostr-header-recto.psu>,</tmidnostr-header-recto.psu>">
<subchars>
<font style="sanserif" size="10pt" weight="bold">
<indent leftind="@-9pt" firstln="*" rightind="0">
<quadding quad="right" lastquad="lright">
<postsp minimum="4pt" nominal="7pt" maximum="9pt" priority="high">
<textbrk startln="1" endln="1">
<algroup refpoint="last">
</subchars>
</usetext>
<usetext source="\List of Effective Pages\">
<subchars>
<font style="sanserif" famname="Helvetica" size="14pt" weight="bold">
<indent leftind="@-.5pi" rightind="*+15.5pi" firstln="*">
<highlt allcap="1">
<textbrk startln="1" endln="0">
<algroup refpoint="top">
<boxing toffset="4pt" boffset="6pt" loffset="6pt" roffset="6pt" siderel="content" tthick="3pt" bthick="3pt" lthick="3pt" rthick="3pt">
<ruling thick="2pt" lentype="spec" speclen="2pi" placemnt="before" ruleclr="white" type="blank">
<leading lead="0">
<textbrk startln="1" endln="1">
</ruling>
</subchars>
</usetext>
<usetext source="\Insert Latest Changed Pages. Destroy Superseded Pages.\">
<subchars>
<font style="sanserif" famname="Helvetica" size="8pt" weight="bold">
<indent leftind="16.5pi" firstln="*">
<highlt allcap="1">
<textbrk startln="0" endln="1">
<algroup refpoint="top">
</subchars>
</usetext>
<ruling thick="1pt" lentype="rel" rellen="text">
<leading lead="0">
<indent leftind="@+15.5pi" rightind="*+27.5pi" firstln="*">
<textbrk startln="1" endln="1">
</ruling>
<usetext source="\ \">
<subchars>
<leading lead="0pt">
<indent leftind="0" rightind="-6pi" firstln="*">
<textbrk startln="1" endln="1">
<boxing toffset="0pi" boffset="54.9pi" loffset="11pt" roffset="11.25pt" siderel="col" tthick="0pt" bthick="1pt" lthick="1pt" rthick="1pt">
</subchars>
</usetext>
'>
<!ENTITY header-lep-verso '<usetext source="<!-- GPSL:RK Entity "header-lep-verso" -->
