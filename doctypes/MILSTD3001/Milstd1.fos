<specval attname="rotation" attloc="graphic" attval="90">
<charsubset><?Pub Dtl>
<usetext source="%\setbox\BoxA=\vbox{%" placemnt="before"></usetext>
<usetext
source="%}\DimenH=\ht\BoxA\vbox{\vskip\wd\BoxA\special{pub:rotate 90}\unvbox\BoxA\vskip -\DimenH}%"
placemnt="after"></usetext>
</charsubset>
</att>
<att>
<specval attname="hplace" attval="left">
<charsubset><?Pub Dtl>
<quadding quad="left"></charsubset>
</att>
<att>
<specval attname="hplace" attval="right">
<charsubset><?Pub Dtl>
<quadding quad="right"></charsubset>
</att>
<att>
<specval attname="hplace" attval="center">
<charsubset><?Pub Dtl>
<quadding quad="center"></charsubset>
</att>&change.marks.att;</e-i-c>
