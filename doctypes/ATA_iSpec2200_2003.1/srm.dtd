<!--  PART NUMBER FILE                                             -->
<!--  Contains all the information associated with a part number.  -->
<!-- ============================================================= -->
<!ELEMENT pnrfile  - - ((chgdesc*, pnrdata+) | %deleted;)            >
<!ATTLIST pnrfile
          %revatt;                                                   >

<!ELEMENT pnrdata  - - ((chgdesc*, pnrmfr, pnrissue?, nom, pnspec?, 
                         pnsec?, (dd, dd?)?, (thick, thick?)?, mdfrm?, 
                         rplby*)| %deleted)                          >
<!ATTLIST pnrdata
          %revatt;                                                   >

<!ELEMENT pnrissue - - (#PCDATA)                                     >

<!-- Part Name (nomenclature)                                      -->
<!ELEMENT nom      - - (#PCDATA)                                     >

<!-- Specification                                                 -->
<!ELEMENT pnspec   - - (memat | nmemat)                              >

<!-- Section code                                                  -->
<!ELEMENT pnsec    - - (#PCDATA)                                     >

<!-- Dimensions of the part. Element may be repeated for metric or
     anglo-saxon units. 
     A part can be composed of several raw materials. 
     A raw material must be defined by dimension(s) with a unit.   -->

<!ELEMENT dd       - O EMPTY                                         >
<!ATTLIST dd
          length   NMTOKEN                            #IMPLIED
          width    NMTOKEN                            #IMPLIED
          height   NMTOKEN                            #IMPLIED
          dia      NMTOKEN                            #IMPLIED
          unit     (ft|in|mm|cm|m)                    #IMPLIED       >

<!-- Thickness                                                     -->
<!ELEMENT thick    - - (#PCDATA)                                     >
<!ATTLIST thick
          unit     (ft|in|mm|cm|m)                    #IMPLIED       >

<!-- Container for MADE FROM clause. The content of all
     sub-elements must be a valid part number                      -->
<!ELEMENT mdfrm    - - (mdfdrw | mdfpnr | mdfnha)                    >

<!-- Made from a drawing. Reference to a drawing                   -->
<!ELEMENT mdfdrw   - - (#PCDATA)                                     >

<!-- Made from a part. Another part                                -->
<!ELEMENT mdfpnr   - - (#PCDATA)                                     >

<!-- Made from a NHA drawing. Reference to a NHA                   -->
<!ELEMENT mdfnha   - - (#PCDATA)                                     >

<!-- Interchangeability with another part.
     Contains a reference to another part and an interchangeability 
     code.                                                         -->
<!-- The Interchangeability refers to another part that must be
     available as a part in the same document instance, possibly
     in pnrfile                                                    -->

<!ELEMENT rplby    - - (pnrmfr, condint?)                            >
<!ATTLIST rplby
          inc      CDATA                              #IMPLIED       >

<!-- Interchangeability Condition                                  -->
<!ELEMENT condint  - - (#PCDATA)                                     >

