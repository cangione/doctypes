<!-- DOCTYPE mpd [   -->
<!-- The following set of declarations may be referred by using
      a public identifier as follows:  
<!DOCTYPE mpd  PUBLIC 
          "-//ATA-TEXT//DTD MPD-VER15-LEVEL2//EN"  [  ]>            -->

<!-- ============================================================== -->
<!--                       NOTATIONS                                -->
<!-- ============================================================== -->
<!NOTATION cgm      PUBLIC
     "-//USA-DOD//NOTATION Computer Graphics Metafile//EN"            >

<!NOTATION ccitt4   PUBLIC
 "-//USA-DOD//NOTATION CCITT Group 4 Facsimile//EN"                   >

<!NOTATION gcf PUBLIC
 "-//ATA-TEXT//NOTATION Graphic Companion File//EN"                   >

<!NOTATION pdf PUBLIC
 "-//Adobe Inc.//NOTATION Portable Document Format//EN"               >

<!NOTATION png PUBLIC
 "-//W3C//NOTATION Portable Network Graphics//EN"                     >

<!NOTATION jpeg PUBLIC
 "+//ISBN 0-7923-9432-1::Graphic Notation//NOTATION Joint
  Photographic Experts Group Raster//EN"                              >

<!NOTATION vrml PUBLIC 
 "-//ATA-TEXT//NOTATION Virtual Reality Modeling Language//EN"        >

<!NOTATION mpeg PUBLIC
 "-//ATA-TEXT//NOTATION Motion Pictures Expert Group//EN"             >

<!NOTATION mp3 PUBLIC
 "-//ATA-TEXT//NOTATION Motion Pictures Expert Group, Audio
  Layer 3//EN"                                                        >

 
<!-- ============================================================== -->
<!-- ENTITIES                                                       -->
<!-- ============================================================== -->
<!ENTITY % wcn      "(warning | caution | note)"                      >
<!ENTITY % text     "(para | table | note | unlist | numlist | list1
                     | graphic | txtgrphc)+"                          >
<!ENTITY % yesorno  "NUMBER"                                          >
<!ENTITY % deleted  "(deleted, chgdesc*)"                             >
<!ENTITY % revatt
          "chg      (N | R | U | D)                        #REQUIRED
           key      ID                                     #REQUIRED
           revdate  NUMBER                                 #REQUIRED" >
<!ENTITY % unitlist
           "unitcode (FH | FC | MO | WK | YR | DY | PC | OC | LD |
                     HR | OH | SC | SH | AH)"                         >
<!ENTITY % codelist
           "chkcode  (A|B|C|D|E|DL|TR|WL|PF|OV|ST|SV|RT)"             >
<!ENTITY % secintro  "(chgdesc*, title, intro)"                       >
<!ENTITY % w.c       "(warning*, caution*)"                           >

<!ENTITY   % ISOtech      PUBLIC 
     "ISO 8879-1986//ENTITIES   General Technical//EN"                >
<!ENTITY   % ISOpub      PUBLIC 
     "ISO 8879-1986//ENTITIES Publishing//EN"                         >
<!ENTITY   % ISOnum      PUBLIC 
   "ISO 8879-1986//ENTITIES   Numeric and Special Graphic//EN"        >
<!ENTITY   % ISOgrk1     PUBLIC 
     "ISO 8879-1986//ENTITIES   Greek Letters//EN"                    >
<!ENTITY   % ISOgrk2     PUBLIC 
     "ISO 8879-1986//ENTITIES Monotoniko Greek//EN"                   >
<!ENTITY   % ISOgrk3     PUBLIC 
     "ISO 8879-1986//ENTITIES Greek Symbols//EN"                      >
<!ENTITY   % ISOgrk4     PUBLIC 
     "ISO 8879-1986//ENTITIES Alternative Greek Symbols//EN"          >
<!ENTITY   % ISOlat1     PUBLIC 
     "ISO 8879-1986//ENTITIES Added Latin 1//EN"                      >
<!ENTITY   % ISObox      PUBLIC
     "ISO 8879-1986//ENTITIES Box and Line Drawing//EN"               >
<!ENTITY   % ISOamso     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Ordinary//EN"       >
<!ENTITY   % ISOamsc     PUBLIC
     "ISO 8879-1986//ENTITIES Added Math Symbols: Delimiters//EN"     >

%ISOtech; %ISOpub; %ISOnum; %ISOgrk1; %ISOgrk2; %ISOgrk3;
%ISOgrk4; %ISOlat1; %ISObox; %ISOamso; %ISOamsc;

<!-- ============================================================== -->
<!-- MPD TOP LEVEL STRUCTURE                                        -->
<!-- ============================================================== -->
<!ELEMENT mpd      - - ((title, legalntc?, mfmatr, prodlist, intro, 
                         glossary?, section, append ) | tr+)
                        +(revst | revend | hotlink)                   >
<!ATTLIST mpd
          docnbr   CDATA                                   #REQUIRED
          spl      CDATA                                   #REQUIRED
          oidate   NUMBER                                  #REQUIRED
          revdate  NUMBER                                  #REQUIRED
          tsn      CDATA                                   #REQUIRED
          lang     CDATA                                   #REQUIRED
          chg      (N | R | U)                             #REQUIRED
          efflen   NUMBER                                  #IMPLIED
          efftype  CDATA                                   #IMPLIED   >

<!-- ============================================================== -->
<!-- TEMPORARY REVISION                                             -->
<!-- ============================================================== -->
<!ELEMENT tr       - - (legalntc?, trfmatr, (legalntc | mfmatr | intro 
                       | section | syspower | structur | zonal 
                       | srclist | smtask+ | graphic+ | sheet+ | append
                       | acclist | jobcard |  reltali | chkcodli
                       | refaftli | otherapp+ | glossary))            >

<!ELEMENT trfmatr  - - (title, trreason, (%text;)?)                   >
<!ATTLIST trfmatr
          trnbr    CDATA                                   #REQUIRED
          issdate  NUMBER                                  #REQUIRED
          trdel    CDATA                                   #IMPLIED
          trrepl   CDATA                                   #IMPLIED   >

<!ELEMENT trreason - - (#PCDATA)                                      >

<!-- ============================================================== -->
<!-- MPD FRONT MATTER                                               -->
<!-- ============================================================== -->
<!ELEMENT mfmatr   - - ((%text; | prclist1))                          >
<!ATTLIST mfmatr
          %revatt;                                                    >

<!-- ============================================================== -->
<!-- PRODUCT LIST                                                   -->
<!-- ============================================================== -->
<!ELEMENT prodlist - - (prodnum)+                                     >
<!ATTLIST prodlist
          cagecode CDATA                                   #REQUIRED  >

<!ELEMENT prodnum  - - (prodnum+ | msnxref)?                          >
<!ATTLIST prodnum
          prodnum  CDATA                                   #REQUIRED  >

<!ELEMENT msnxref  - - (msnbr, acn?, cusnbr?, venbr?, benbr?, esnbr?,
                        linenbr?, verrank?)+                          >
<!ELEMENT cusnbr   - - (cus, cec)                                     >
<!ELEMENT verrank  - - (vers, rnk)                                    >
<!ELEMENT msnbr    - - (#PCDATA)                                      >
<!ELEMENT acn      - - (#PCDATA)                                      >
<!ELEMENT cus      - - (#PCDATA)                                      >
<!ELEMENT cec      - - (#PCDATA)                                      >
<!ELEMENT venbr    - - (#PCDATA)                                      >
<!ELEMENT benbr    - - (#PCDATA)                                      >
<!ELEMENT esnbr    - - (#PCDATA)                                      >
<!ELEMENT linenbr  - - (#PCDATA)                                      >
<!ELEMENT vers     - - (#PCDATA)                                      >
<!ELEMENT rnk      - - (#PCDATA)                                      >

<!-- ============================================================== -->
<!-- INTRODUCTION                                                   -->
<!-- ============================================================== -->
<!ELEMENT intro    - - (chgdesc*, (%text; | prclist1), chkcodli?, 
                        refaftli?)                                    >
<!ATTLIST intro
          %revatt;                                                    >

<!-- ============================================================== -->
<!-- INTRODUCTION: Check Code Reference List                        -->
<!-- ============================================================== -->
<!ELEMENT chkcodli - - (checkcod+)                                    >
<!ATTLIST chkcodli
          %revatt;                                                    >

<!ELEMENT checkcod - - (unitval+)                                     >
<!-- chkcode/key is referenced by chkcodva/refid                    -->
<!ATTLIST checkcod
          %codelist;                                       #REQUIRED
          key      ID                                      #REQUIRED  >

<!ELEMENT unitval  - - (#PCDATA)                                      >
<!ATTLIST unitval
          chg      (N | R | U | D)                         #IMPLIED
          %unitlist;                                       #REQUIRED  >

<!-- ============================================================== -->
<!-- INTRODUCTION: Reference Average Flight Time List               -->
<!-- ============================================================== -->
<!ELEMENT refaftli - - (refaftda+ | %deleted;)                        >
<!ATTLIST refaftli
           %revatt;                                                   >

<!ELEMENT refaftda - - (refaft, toleranc, modtype)                    >
<!ELEMENT refaft   - - (#PCDATA)                                      >
<!ELEMENT toleranc - - (#PCDATA)                                      >
<!ELEMENT modtype  - - (#PCDATA)                                      >

<!-- ============================================================== -->
<!--  GLOSSARY                                                      -->
<!-- ============================================================== -->
<!ELEMENT glossary - -  ((chgdesc*, title, (%text;)?, glosdata*) 
                        | %deleted;)                                  >
<!ATTLIST glossary
          oldkey   NAME                                    #IMPLIED
          %revatt;                                                    >
 
<!ELEMENT glosdata - -  (term, def)                                   >
<!ELEMENT term     - -  (#PCDATA)                                     >
<!ELEMENT def      - -  (#PCDATA)                                     >

<!-- ============================================================== -->
<!-- SCHEDULED MAINTENANCE TASK SECTION                             -->
<!-- ============================================================== -->
<!ELEMENT section  - - (effect?, syspower, structur, zonal, srclist)  >
<!ATTLIST section
          %revatt;                                                    >

<!ELEMENT syspower - - (%secintro;, smtask+)                          >
<!ATTLIST syspower
          %revatt;                                                    >

<!ELEMENT structur - - (%secintro;, smtask+)                          >
<!ATTLIST structur
          %revatt;                                                    >

<!ELEMENT zonal    - - (%secintro;, smtask+)                          >
<!ATTLIST zonal
          %revatt;                                                    >

<!-- ============================================================== -->
<!-- SCHEDULED MAINTENANCE TASK                                     -->
<!-- ============================================================== -->
<!ELEMENT smtask   - - ((effect, chgdesc*, title, regulatory?, smtdesc, 
                         note*, tahour, nbrpers, source+, periobox+, 
                         prepref*, procbox*, primzone+, reltask*,  
                         oldref*)| %deleted;)                         >
<!ATTLIST smtask
          tasknbr  CDATA                                   #REQUIRED
          taskcode (GVI | DET | SDI | VCK | FNC | OPC | LUB | SVC
                   | RST | DIS | TPS)                      #REQUIRED
          atach    CDATA                                   #REQUIRED
          atasect  CDATA                                   #IMPLIED
          atasubj  CDATA                                   #IMPLIED
          msiseqn  NUMBER                                  #IMPLIED
          mpdseqn  NUMBER                                  #IMPLIED
          remorequ %yesorno;                               #REQUIRED
          fatirat  NUMBER                                  #IMPLIED
          %revatt;                                                    >

<!-- ============================================================== -->
<!-- SMTASK  : Description / Labour Hours / Number of Persons       -->
<!-- ============================================================== -->
<!ELEMENT smtdesc  - - (#PCDATA)                                      >

<!ELEMENT tahour   - - (#PCDATA)                                      >
<!ATTLIST tahour
          dweltime CDATA                                   #IMPLIED   >

<!ELEMENT nbrpers  - - (#PCDATA)                                      >

<!-- ============================================================== -->
<!-- SMTASK  : Source                                               -->
<!-- ============================================================== -->
<!-- source/refid refers to srcdoc/key                              -->
<!ELEMENT source   - O EMPTY                                          >
<!ATTLIST source
          revdate  NUMBER                                  #IMPLIED
          tsn      CDATA                                   #IMPLIED
          refid    IDREF                                   #REQUIRED  >

<!-- ============================================================== -->
<!-- SMTASK  : Periodicity                                          -->
<!-- ============================================================== -->
<!-- the repetition of periodic indicates a sequence of periodicity
      statement - all of them have to be done                       -->
<!ELEMENT periobox - - (effect, (limit+ | periodic+ | specacc))       >
<!ATTLIST periobox
          periorel (first | last)                          "first"     
          limdate  NUMBER  #IMPLIED
          effdate  NUMBER  #IMPLIED                                   >

<!-- the repetition of (threshol+, interval) indicates a choice
     of (first of) periodicity statements expressed in different
     units                                                          -->
<!ELEMENT periodic - - (regulatory?, threshol+, interval)+            >
<!ELEMENT threshol - - (minthr?, (chkcodva | unitval), sampperc?, 
                        note?)                                        >

<!ELEMENT minthr   - - (chkcodva | unitval)                           >

<!-- chkcodva/refid refers to chkcode/key                           -->
<!ELEMENT chkcodva - - (#PCDATA)                                      >
<!ATTLIST chkcodva
          refid    IDREF                                   #IMPLIED
          %codelist;                                       #REQUIRED  >

<!ELEMENT interval - - ((chkcodva | unitval), tolperc?, sampperc?, 
                         note?)                                       >
<!ELEMENT tolperc  - - (#PCDATA)                                      >
<!ELEMENT sampperc - - (#PCDATA, note?)                               >
<!ELEMENT limit    - - (#PCDATA)                                      >
<!ATTLIST limit
          %unitlist;                                       #REQUIRED  >
<!ELEMENT specacc  - - (#PCDATA)                                      >

<!-- ============================================================== -->
<!-- SMTASK : Procedure References                                  -->
<!-- ============================================================== -->
<!ELEMENT procbox  - - (effect, procref+)                             >
<!ELEMENT procref  - - (refext)                                       >
<!ATTLIST procref
          procdoc  (AMM |EMM |CMM |WM |SB |JC |SRM | NDT)  #REQUIRED
          proctype (AMTOSS | JEMTOSS | pageblock)          #IMPLIED
          procseq  NUMBER                                  #REQUIRED  >

<!-- ============================================================== -->
<!-- SMTASK  : Access/Boundary                                      -->
<!-- ============================================================== -->
<!ELEMENT primzone - - (zone, accbox?, boundbox?)                     >
<!ATTLIST primzone
          nbrocc   NUMBER                                  #REQUIRED  >

<!ELEMENT zone     - - (#PCDATA)                                      >
<!ELEMENT accbox   - - (effect, accpan+)                              >

<!-- accpan/refid refers to accdata/key                             -->
<!ELEMENT accpan   - O EMPTY                                          >
<!ATTLIST accpan
          refid    IDREF                                   #REQUIRED  >

<!ELEMENT boundbox - - (effect, boundary+)                            >
<!ELEMENT boundary - - (#PCDATA)                                      >

<!-- ============================================================== -->
<!-- SMTASK  : Related Tasks                                        -->
<!-- ============================================================== -->
<!-- reltask/teltaid refers to smtask/key                           -->
<!ELEMENT reltask  - O EMPTY                                          >
<!ATTLIST reltask
          relcode  (A | P | B | S | W | C)                 #REQUIRED
          reltaid  IDREF                                   #REQUIRED  >

<!-- ============================================================== -->
<!-- SMTASK  : prepref                                              -->
<!-- ============================================================== -->
<!-- source/refid refers to srcdoc/key                              -->
<!ELEMENT prepref   - O EMPTY                                         >
<!ATTLIST prepref
          revdate  NUMBER                                  #IMPLIED
          tsn      CDATA                                   #IMPLIED
          refid    IDREF                                   #REQUIRED  >
		  
<!-- ============================================================== -->
<!-- REGULATORY                                                     -->
<!-- ============================================================== -->
<!ELEMENT regulatory  - - (effect?, regulation+)                      >
<!ELEMENT regulation  - - (effect?, grsymbol?, #PCDATA)               >
<!ATTLIST regulation
          regtype   CDATA                                  #REQUIRED 
          regsource CDATA                                  #IMPLIED
          regvalue  CDATA                                  #IMPLIED   >

<!-- ============================================================== -->
<!-- Source Documents for Scheduled Maintenance Tasks               -->
<!-- ============================================================== -->
<!ELEMENT srclist  - - (%secintro;, srcdoc+)                          >
<!ATTLIST srclist
          %revatt;                                                    >

<!-- srcdoc/key is referenced by source/refid                       -->
<!ELEMENT srcdoc   - - (refext, (fec+ | cmr | lhirf+ | str+)?)        >
<!ATTLIST srcdoc
          srctype  (TCDS | MRB | CMR | ALI | ALL | CPCP | AD | NR
                   | SB | SL | REC | AOT | AMM05 | FSL)     #REQUIRED
          mand     %yesorno;                                #REQUIRED
          %revatt;                                                    >

<!ELEMENT fec      - O EMPTY                                          >
<!ATTLIST fec      
