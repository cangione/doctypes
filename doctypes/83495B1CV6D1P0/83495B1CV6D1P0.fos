<charlist inherit="1">
<reset resetlist="subfig.ctr">
<savetext textid="personstr" conrule=""></charlist>&set-deltypstr;
<att>
<charsubset>
<savetext textid="onlytask.flag" conrule="\y\"></charsubset>
</att>&att-set-label;
<att>
<charsubset>
<savetext textid="task-label.txt" conrule="label.txt"></charsubset>
</att>
<att logic="and">
<specval attname="pagesize" attloc="docjg" attval="5x8">
<charsubset>
<textbrk startpg="verso" pageid="jgchap5x8.pgset" newpgmdl="local">
</charsubset>
</att>&att-emergency-body;
<att logic="and">
<specval attname="sssn" attval="#ANY">
<charsubset>
<savetext textid="SSSN.ST" conrule="1em,#CONTENT(sssn)">
<savetext textid="SSSN.FOOTER.ST" conrule="#CONTENT(sssn)">
<savetext textid="sssn-tasktoc.txt" conrule="#CONTENT(sssn)">
</charsubset>
</att>
<att>
<specval attname="id" attval="#ANY">
<specval attname="sssn" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="#CONTENT(sssn)"></charsubset>
</att>
<att>
<specval attname="id" attval="#ANY">
<specval attname="sssn" attval="#NONE">
<charsubset>
<savetext textid="xrefstr" conrule="\Task \,task-label.txt">
</charsubset>
</att>
<att logic="and">
<charsubset>
<savetext textid="figlabelstr" conrule="label.txt"></charsubset>
</att>
<att>
<specval attname="pagesize" attloc="docjg" attval="8.5x11">
<specval attname="numcols" attloc="body" attval="1">
<charsubset>
<span span="1"></charsubset>
</att>
<att>
<specval attname="pagesize" attloc="docjg" attval="8.5x11">
<specval attname="numcols" attloc="body" attval="2">
<charsubset>
<span span="2"></charsubset>
</att>
<att logic="or">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<font style="sanserif" weight="bold">
<hyphen hyph="0">
<quadding quad="left" lastquad="lleft">
<highlt scoring="1" allcap="1" scorespc="1">
<presp minimum="10pt" nominal="10pt" maximum="10pt" priority="med">
<postsp minimum="10pt" nominal="10pt" maximum="10pt" priority="force">
<textbrk startln="1" endln="1">
<suppress sup="1">
<usetext source="task-label.txt,1em,deltypestr">
<subchars>
<highlt scoring="0"></subchars>
</usetext>
<savetext textid="sssn.footer.st" conrule="sssn.footer.st.temp"
placemnt="after"><?Pub Lcl
_comment=' att logic="and"&gt;
<specval attname="print-only" attloc="system-var" attval="#ANY"&gt;
<specval attname="delchlvl" attval="#NONE"&gt;
<specval attname="legend" attloc="foldout" attval="#EQ#0"&gt;
<charsubset&gt;
<usetext
source="\Figure \,fignum,\.\,1em,foldtitle,\ &ndash; Continued.\"&gt;<?Pub Dtl&gt;
<subchars&gt;
<font weight="bold"&gt;
<quadding quad="center" lastquad="lcenter"&gt;
<presp minimum="1pi" nominal="1pi" maximum="1pi"&gt;
<postsp minimum="2pi" nominal="2pi" maximum="2pi"&gt;
<textbrk startln="1" endln="0"&gt;
<float flidref="bot-col.flt" width="col" scope="figtable"
pagetype="forward"&gt;</subchars&gt;
</usetext&gt;
</charsubset&gt;
</att '></charsubset>
</att>
