<e-i-c gi="LINE" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<fillval attname="prespace" fillcat="presp" fillchar="nominal">
<charsubset>
	<presp></charsubset>
</att>

<att logic="and">
<fillval attname="postspace" fillcat="postsp" fillchar="nominal">
<charsubset>
	<postsp></charsubset>
</att>

<att logic="or">
<specval attname="quad" attval="left">
<specval attname="quad" attval="#NONE">
<charsubset>
	<quadding quad="left" lastquad="lleft"></charsubset>
</att>

<att logic="and">
<specval attname="quad" attval="center">
<charsubset>
	<quadding quad="center" lastquad="lcenter"></charsubset>
</att>

<att logic="and">
<specval attname="quad" attval="right">
<charsubset>
	<quadding quad="right" lastquad="lright"></charsubset>
</att>

<att logic="and">
<specval attname="quad" attval="justify">
<charsubset>
	<quadding quad="justify" lastquad="ljustify"></charsubset>
</att>

<att logic="and">
<specval attname="indent" attval="#ANY">
<fillval attname="indent" fillcat="indent" fillchar="leftind">
<charsubset>
	<indent inherit="1" firstln="*"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

