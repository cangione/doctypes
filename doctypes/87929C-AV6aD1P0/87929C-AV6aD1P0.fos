</att>
<att logic="and"><?Pub Lcl
_comment='savetext textid="lofmatter" conrule=<toclinecfig&gt;,<toctitle.fmt&gt;,label.txt,@3em,deltypestr,</toctitle.fmt&gt;,</toclinecfig&gt; append=1'>
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,tabnum"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<presp nominal="10pt" priority="force">
<textbrk startln="1" endln="1">
<span span="1">
<suppress sup="1">
<usetext source="\Table \,tabnum,\. Deleted\" placemnt="before">
<subchars>
<font inherit="0" weight="bold">
<quadding quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="6pt" nominal="10pt" maximum="12pt" condit="discard">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="wptablelist.app"
conrule="<uinput.psu>,<ulabel.psu>,label.txt,</ulabel.psu>,<utitle.psu>,\(Deleted)\,</utitle.psu>,folio.txt[BO],</uinput.psu>"
placemnt="after" append="1"></charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext
source="\Table \, tabnum,\.\,1em,\Periodic/Special Inspection Requirements.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp nominal="6pt" condit="keep" priority="force">
<postsp minimum="6pt" nominal="6pt" maximum="6pt" condit="keep"
priority="high">
<keeps scope="col" keep="7" next="7">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="inspr-structure.txt"
conrule='!<colspec colname="col1" colwidth="1.25*"><colspec colname="col2" colwidth="1.5*"><colspec colname="col3" colwidth="1.25*"><colspec colname="col4" colwidth="1.125*"><spanspec namest="col1" nameend="col4" spanname="SPAN1">!'
placemnt="before">
<savetext textid="inspr-header.txt"
conrule='!<thead><row valign="bottom"><entry rowsep="1" align="center">!,\Inspection\,<brk>,</brk>,\Requirements\,!</entry><entry rowsep="1" align="center">!,\Type of Inspection\,!<linectr>!,\Periodic | Special\,!</entry><entry rowsep="1" align="center">!,\Applicability\,!</entry><entry rowsep="1" align="center">!,\Man-\,<brk>,</brk>,\Minutes\,!</entry></row></thead>!'
placemnt="before">
<usetext
source='!<tabmat pgwide="1"><tgroup cols="4">!,inspr-structure.txt,inspr-header.txt,!<tbody>!,inspr-body.txt,!</tbody></tgroup></tabmat>!'
placemnt="after"></usetext>
<savetext textid="inspr-body.txt" conrule="\\" placemnt="after"
append="0">
<savetext textid="lotmatter"
conrule="<toclinecfig>,<toctitle.fmt>,label.txt,@2.5em,secur.str,scontent.txt,\Periodic/Special Inspection Requirements\,econtent.txt,tocfill,</toctitle.fmt>,<tocnumx>,0.25in,folio.txt[BO],</tocnumx>,</toclinecfig>"
append="1">
<savetext textid="wptablelist.app"
conrule="<toclined>,<toctitle.fmt>,label.txt,@3.5em,\Periodic/Special Inspection Requirements\,tocfill,</toctitle.fmt>,<tocnumchap>,folio.txt[BO],</tocnumchap>,</toclined>"
placemnt="after" append="1">
<!--<savetext textid="wptablelist.app"
conrule="<uinput.psu>,<ulabel.psu>,label.txt,</ulabel.psu>,<utitle.psu>,\Periodic/Special Inspection Requirements\,</utitle.psu>,folio.txt[BO],</uinput.psu>"
placemnt="after" append="1">-->
</charsubset>
</att>
