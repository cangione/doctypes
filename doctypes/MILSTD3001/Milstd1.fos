conrule='!<row>!,nobrk.txt,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">&ic.characteristics.clear.savetext;
<reset
resetlist="nobrk.txt row.app col1.app col2.app col3.app tabletxt reftxt condtxt">
</charlist>&ic.characteristics.att;
<att>
<specval attname="label" attval="#NONE">
<charsubset><?Pub Dtl>
