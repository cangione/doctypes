<!--**********************************************************************
    *                                                                    *
    *                        S1000D Issue 2                              *
    *                SGML Document Type Definition                       *
    *                                                                    *
    *                     Release Version 2.2                            *
    *                       Date: 2005-05-01                             *
    *                                                                    *
    * Amendment:-                                                        *
    * 1. New public identifier.                                          *
    * 2. CPF 2002-11FR: Remove exclusion of <figure>, <foldout>, <table> *
    *                   from <note>.                                     *
    *                   Move elements <note> and <para> from file        *
    *                   WCNP.ENT to here, i.e. split WCNP.ENT into WC.ENT*
    *                   and PARAGRAPHS.ENT.                              *
    *                                                                    *
    * Typical invocation:-                                               *
    * <!ENTITY % PARAGRAPHS PUBLIC                                       *
    *   "-//S1000D//ELEMENTS Running Text Paragraphs 20050501//EN" >     *
    * %PARAGRAPHS;                                                       *
    ********************************************************************** -->



<!--**********************************************************************
    * Define Element note (Note) containing:-                            *
    *   applic  - Optional   Single      contains type, model.           *
    *====================================================================*
    * Mandatory Repeatable Group.                                        *
    *====================================================================*
    *   symbol  - Mandatory  Single      contains No Other Tags.         *
    *  or                                                                *
    *   para    - Mandatory  Single      contains applic, Definition     *
    *                                     stored in entity %paracon;.    *
    *  or                                                                *
    *   Definition stored in entity %list;                               *
    *====================================================================*
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  type     - CDATA    - IMPLIED  - Specifies the type of Note.      *
    *  xrefid   - IDREF    - IMPLIED  - Specifies a unique identifier of *
    *                                   an element.                      *
    *  Attribute Definition List stored in entity %bodyatt;              *
    ********************************************************************** -->

<!ELEMENT note - - (applic?,(symbol | para | %list;)+) >
<!ATTLIST note
            type        CDATA       #IMPLIED
            xrefid      IDREF       #IMPLIED
            %bodyatt; >
<!-- Exclusion removed -->



<!--**********************************************************************
    * Define Element para (Paragraph) containing:-                       *
    *   applic  - Optional   Single      contains type, model.           *
    *   Definition stored in entity %paracon;                            *
    *@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@*
    * Attribute(s):-                                                     *
    *  Attribute definition list stored in entity %bodyatt;              *
    *  Attribute Definition List stored in entity %secur;                *
    ********************************************************************** -->

<!ELEMENT para - O (applic?,(%paracon;)) >
<!ATTLIST para
            %bodyatt;
            %secur; >
