<!-- SYSTEM:     NISO Standards Tag Suite (NISO STS)               -->
<!--                                                               -->
<!--             This new module extends the capabilities of       -->
<!--             NISO STS <adoption> for OASIS tables              -->
<!--                                                               -->
<!-- PURPOSE:    Defines override attributes for <adoption> that   -->
<!--             include the OASIS table namespace.                -->
