	<font style="sanserif" size="8pt">
	<rowatts>	</rowatts>

	<cellatts colname="col1">
	<stdcellatts colsep="1pt" colsepon="1" topmar="2pt" halign="left">	</cellatts>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
