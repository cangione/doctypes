</att>
<att>
<specval attname="numberoftmidnos" attloc="manual" attval="2">
<specval attname="security" attloc="manual" attval="#NE#\u\">
<charsubset charsubsetref="securnumberedpage2"><?Pub Dtl></charsubset>
</att>
<att>
<specval attname="numberoftmidnos" attloc="manual" attval="2">
<specval attname="security" attloc="manual" attval="u">
<charsubset charsubsetref="numberedpage2"><?Pub Dtl></charsubset>
</att>
<att>
<specval attname="numberoftmidnos" attloc="manual" attval="3">
<specval attname="security" attloc="manual" attval="#NE#\u\">
<charsubset charsubsetref="securnumberedpage3"><?Pub Dtl></charsubset>
</att>
<att>
<specval attname="numberoftmidnos" attloc="manual" attval="3">
<specval attname="security" attloc="manual" attval="u">
<charsubset charsubsetref="numberedpage3"><?Pub Dtl></charsubset>
</att>
<att>
<specval attname="numberoftmidnos" attloc="manual" attval="4">
<specval attname="security" attloc="manual" attval="#NE#\u\">
<charsubset charsubsetref="securnumberedpage4"><?Pub Dtl></charsubset>
</att>
<att>
<specval attname="numberoftmidnos" attloc="manual" attval="4">
<specval attname="security" attloc="manual" attval="u">
<charsubset charsubsetref="numberedpage4"><?Pub Dtl></charsubset>
</att>
<att>
