		<long>Page Number</long>
		<desc>Identifies the page number associated with each table/figure that appears in the tablelist or illuslist when the list is manually tagged.</desc>
		<source>None.</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+)</contmdl>
		<usedin>cntentry, ddlist, illlistrow, illuslist, tablelist, tbllistrow, volilluslist, and voltablelist</usedin>
		<ents>text and chgatt</ents>
