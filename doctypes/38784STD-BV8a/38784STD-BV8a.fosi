<e-i-c gi="ipbuseoncodelist" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<cellatts colname="col.pl4">
	<stdcellatts colsep="1pt" colsepon="1" topmar="20pt" halign="left" valign="top">	</cellatts>

	<usetext source="<undl.ps>,\CODE\,</undl.ps>">
	<subchars>
	<indent leftind="18pt" rightind="2.8in" firstln="18pt">
	<keeps next="1">
	<algroup refpoint="top">	</subchars>
	</usetext>

	<usetext source="<undl.ps>,\USABLE ON\,</undl.ps>">
	<subchars>
	<font style="sanserif">
