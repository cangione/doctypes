</e-i-c>

<e-i-c gi="ipbpl0tbl" context="ipbplgrp" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<presp minimum="10pt" nominal="12pt" maximum="18pt" condit="discard" priority="force">
	<postsp minimum="0pt" nominal="8pt" maximum="16pt" condit="discard" priority="force">
	<textbrk startln="1">
	<tabatts widthtype="specific" specwidth="7.1in" frame="all" thick="1pt">
	<stdcellatts colsep="1" rowsep="0" colsepon="1" leftmar="1pt" rightmar="1pt" valign="top" brkrow="0" celconflict="append">	</tabatts>

	<tgroupatts cols="8">	</tgroupatts>

	<colatts colname="col.pl1a" colwidth="0.52in">	</colatts>

	<colatts colname="col.pl1b" colwidth="0.52in">	</colatts>

	<colatts colname="col.pl2" colwidth="1.24in">	</colatts>

	<colatts colname="col.pl2.1" colwidth="0.15in">	</colatts>

	<colatts colname="col.pl3" colwidth="0.44in">	</colatts>

	<colatts colname="col.pl4" colwidth="3.03in">	</colatts>

	<colatts colname="col.pl5" colwidth="0.47in">	</colatts>

	<colatts colname="col.pl6" colwidth="0.57in">	</colatts>

	<colatts colname="col.pl7" colwidth="0.60in">	</colatts>

	<colatts spanname="partspan" namest="col.pl2" nameend="col.pl2.1">	</colatts>

	<colatts spanname="figurecol" namest="col.pl1a" nameend="col.pl1b">	</colatts>

	<savetext textid="shown.footer" conrule="\\">
	<savetext textid="sssn.hdr.ist" conrule="#CONTENT(sssn)">
	<usetext source="\ \" placemnt="before">
	<subchars>
	<presp nominal="10pt" priority="force">
	<postsp nominal="10pt" priority="force">
	<textbrk startln="1" endln="1">	</subchars>
	</usetext>

	<usetext source="<hd>,    <fig>,\FIGURE &\,</fig>, <pc>,\\,</pc>, <cg>,\\,</cg>, <dc>,\\,</dc>,     <ut>,\UNITS\,</ut>, <uoc>,\USABLE\,</uoc>, <smr>,\\,</smr>,    <fig>,\INDEX/\,</fig>, <pc>,\PART\,</pc>,<cg>,\\,</cg>, <dc>,\DESCRIPTION\,</dc>,     <ut>,\PER\,</ut>, <uoc>,\ON\,</uoc>, <smr>,\SMR\,</smr>,    <figr>,\SHEET NO.\,</figr>,<pcr>,\NUMBER\,</pcr>, <cgr>,\CAGE\,</cgr>,     <l.dc>,\1\,0.5em,\2\,0.5em,\3\,0.5em,\4\,0.5em,\5\,0.5em,\6\,0.5em,\7\,</l.dc>,     <utr>,\ASSY\,</utr>, <uocr>,\CODE\,</uocr>, <smrr>,\CODE\,</smrr>,    </hd>,<body.ps>">	</usetext>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="TITLE" context="ipbpl0tbl" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<font weight="bold">
	<leading lead="12pt">
	<quadding inherit="0" quad="center" lastquad="lcenter">
	<presp nominal="11pt">
	<postsp nominal="11pt" condit="keep" priority="force">
	<keeps next="1">
	<span span="1">
	<enumerat increm="1" enumid="tabct">
	<usetext source="\Table \,tabct,\.\,1em">
	<subchars>	</subchars>
	</usetext>

	<usetext source="<line>,\ \,</line>" placemnt="after">
	<subchars>
	<textbrk endln="1">	</subchars>
	</usetext>

	<savetext textid="lotmatter" conrule="<lotlinec>,tabct,@3em, #CONTENT,tocfill,<tocnumx>,  pgnumber,</tocnumx>,</lotlinec>" append="1"></charlist>

<att logic="and">
<specval attname="inschlvl" attloc="ipbpl0tbl" attval="#NE#0">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>

<att logic="and">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="dlctcont" conrule="<tabconta>,\Table \,labelstr,\.\,1em,#CONTENT,  \ - Continued.\,</tabconta>,<line>,\ \,</line>"></charsubset>
</att>
</e-i-c>

<e-i-c gi="ipbpl0tblfoot" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<presp nominal="8pt" priority="force">
	<textbrk startln="0" endln="1">
	<tabatts widthtype="specific" specwidth="7.1in" frame="none" framestyle="blank">
	<stdcellatts colsep="2pt" rowsep="2pt" colsepon="0" rowsepon="0" leftmar="2pt" rightmar="2pt" topmar="1pt" botmar="1pt">	</tabatts>

	<tgroupatts cols="1">	</tgroupatts>

	<colatts colname="foot" colwidth="7.1in">	</colatts>

	<rowatts>
	<stdcellatts rowsep="2pt" rowsepon="1" valign="bottom">	</rowatts>

	<cellatts>	</cellatts>

	<usetext source="shown.footer">
	<subchars>
	<font style="sanserif" size="8pt">
	<cellatts>
	<stdcellatts leftmar="0.5in" halign="left" valign="bottom">	</cellatts>
	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
