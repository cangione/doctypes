<charlist inherit="1">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="volnum" context="idinfo" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<suppress sup="1">
	<usetext source="\VOLUME NO. \,#CONTENT">
	<subchars>
	<font style="sanserif" size="14pt">
	<quadding quad="left" lastquad="lleft">
	<presp minimum="12pt" nominal="12pt" maximum="12pt">
	<textbrk startln="1">	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="revnum" context="idinfo" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
