<charsubset>
<savetext textid="secur.str" conrule="\(U) \,0.25em">
<usetext source="secur.str" placemnt="before">
<subchars>
<highlt scoring="0">
<textbrk startln="0" endln="0"></subchars>
</usetext>
<savetext textid="secur.str" conrule="\\" placemnt="after"></charsubset>
</att>
<att>
<specval attname="security" attval="s">
<charsubset>
<savetext textid="secur.str" conrule="\(S) \,0.25em">
<usetext source="secur.str" placemnt="before">
<subchars>
<highlt scoring="0">
<textbrk startln="0" endln="0"></subchars>
</usetext>
<savetext textid="secur.str" conrule="\\" placemnt="after"></charsubset>
</att>
