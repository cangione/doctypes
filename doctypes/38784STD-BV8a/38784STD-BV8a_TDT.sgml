	<ele>
		<tag>bindByCoords</tag>
		<long>Bind By Coordinates</long>
		<desc>Identifies coordinates on a graphic that may be used for referencing. Please note that there is currently no FOSI support for this element.</desc>
		<source>None</source>
		<contmdl>(xref*)</contmdl>
		<usedin>graphic</usedin>
		<ents>cgmatts</ents>
		<specatts>
			<attrtbl>
				<attr>coords</attr>
				<type>CDATA</type>
				<default>#REQUIRED</default>
				<attrdesc>A list of the coordinates identifing the region on the graphic.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>title</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Label / Screentip of hotspot</attrdesc>

				<attr>descript</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Description of graphical hotspot </attrdesc>

				<attr>visibility</attr>
				<type>(visible | hidden)</type>
				<default>visible</default>
				<attrdesc>The 'visibility' attribute indicates if an object is visible or not. A non-visible object behaves like a non-interactive object (i.e., it cannot be clicked or highlighted).</attrdesc>

				<attr>interactivity</attr>
				<type>(interactive | none)</type>
				<default>none</default>
				<attrdesc>The 'interactivity' attribute indicates if an object may receive mouse events. When the 'interactivity' of an object is set to off, events for this object are disabled.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
