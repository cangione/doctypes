<!ELEMENT prcitem2  - -  (prcitem, prclist3?)                          >
<!ATTLIST prcitem2
          id        ID                                #IMPLIED         >
<!ELEMENT prcitem3  - -  (prcitem, prclist4?)                          >
<!ATTLIST prcitem3
          id        ID                                #IMPLIED         >
<!ELEMENT prcitem4  - -  (prcitem, prclist5?)                          >
<!ATTLIST prcitem4
          id        ID                                #IMPLIED         >
<!ELEMENT prcitem5  - -  (prcitem, prclist6?)                          >
<!ATTLIST prcitem5
          id        ID                                #IMPLIED         >
<!ELEMENT prcitem6  - -  (prcitem, prclist7?)                          >
<!ATTLIST prcitem6
          id        ID                                #IMPLIED         >
<!ELEMENT prcitem7  - -  (prcitem)                                     >
<!ATTLIST prcitem7
          id        ID                                #IMPLIED         >

<!ELEMENT prcitem   - -  (title?, (%w.c;), (%text;), graphic*)         >

<!-- =============================================================== -->
<!--                STANDARD LISTS                                   -->
<!-- =============================================================== -->

<!ELEMENT list1     - - (l1item+)                                      >
<!ATTLIST list1
