<usetext source="\.\" placemnt="after">
<subchars>
<highlt scoring="0">
<textbrk startln="0" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="applicref" attloc="ratddesc" attval="#ANY">
<fillval attname="applicref" attloc="ratddesc" fillcat="savetext"
fillchar="conrule">
