</charsubset>
</att>

<att logic="and">
<specval attname="orient" attval="land1">
<charsubset>
	<textbrk startpg="next" pageid="frontpgland" newpgmdl="local">
	<tabatts widthtype="relative" relwidth="98" consep="0">	</tabatts>
</charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<specval attname="continued" attval="0">
<charsubset>
