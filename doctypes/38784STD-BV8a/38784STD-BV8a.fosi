	<indent leftind="@" rightind="*+1.5in" firstln="*">
	<quadding quad="center">
	<highlt scoring="1">
	<textbrk startln="1">
	<algroup refpoint="top"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="def" context="applichd" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<indent leftind="1.75in" rightind=".25in" firstln="*">
	<quadding quad="left">
	<highlt scoring="1">
	<postsp minimum="11pt" nominal="11pt" maximum="11pt">
	<textbrk endln="1">
	<algroup refpoint="top"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="term" context="applic" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<suppress sup="1">
	<savetext textid="term.st" conrule="#CONTENT" append="0">
	<savetext textid="def.st" conrule=""></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="def" context="applic" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<suppress sup="1" children="1">
	<savetext textid="def.st" conrule="#CONTENT"></charlist>

<att logic="and">
<specval attname="flagnote" attloc="applic" attval="1">
<charsubset>
	<usetext source="0.2in, <applic-boxing.ps>, term.st, </applic-boxing.ps>">
	<subchars>
	<indent leftind="0in" rightind="*+0.5in" firstln="0in">
	<textbrk startln="1" endln="1">
	<algroup refpoint="top">	</subchars>
	</usetext>

	<usetext source="def.st">
	<subchars>
	<indent leftind="0.6in" rightind="0in" firstln="0.6in">
	<textbrk startln="1" endln="1">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="flagnote" attloc="applic" attval="0">
<charsubset>
	<usetext source="0.2in,term.st">
	<subchars>
	<indent leftind="0in" rightind="*+0.5in" firstln="0in">
	<textbrk startln="1" endln="0">
	<algroup refpoint="top">	</subchars>
	</usetext>

	<usetext source="def.st">
	<subchars>
	<indent leftind="0.6in" rightind="0in" firstln="0.6in">
	<textbrk startln="0" endln="1">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="applic" occur="first" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<presp minimum="12pt" nominal="12pt" maximum="12pt" priority="force">
	<postsp minimum="6pt" nominal="6pt" maximum="12pt">
	<keeps keep="1" scope="col">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="id" attval="#ANY">
<specval attname="flagnote" attval="1">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="<applic-boxing.ps>,term.st,</applic-boxing.ps>,0.5em" placemnt="after"></charsubset>
</att>

<att logic="and">
<specval attname="id" attval="#ANY">
<specval attname="flagnote" attval="0">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="term.st,0.5em" placemnt="after"></charsubset>
</att>
</e-i-c>

<e-i-c gi="applic" occur="middle" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<presp minimum="6pt" nominal="6pt" maximum="6pt" condit="discard" priority="force">
	<postsp minimum="6pt" nominal="6pt" maximum="12pt">
	<keeps keep="1" scope="col">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="id" attval="#ANY">
<specval attname="flagnote" attval="1">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="<applic-boxing.ps>,term.st,</applic-boxing.ps>,0.5em" placemnt="after"></charsubset>
</att>

<att logic="and">
<specval attname="id" attval="#ANY">
<specval attname="flagnote" attval="0">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="term.st,0.5em" placemnt="after"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="applic" occur="last" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<presp minimum="6pt" nominal="6pt" maximum="6pt" priority="force">
	<postsp minimum="12pt" nominal="12pt" maximum="12pt" priority="force">
	<keeps keep="1" scope="col">
	<textbrk startln="1" endln="1">
	<usetext source="\ \" placemnt="after">	</usetext>
</charlist>

<att logic="and">
<specval attname="id" attval="#ANY">
<specval attname="flagnote" attval="1">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="<applic-boxing.ps>,term.st,</applic-boxing.ps>,0.5em" placemnt="after"></charsubset>
</att>

<att logic="and">
<specval attname="id" attval="#ANY">
<specval attname="flagnote" attval="0">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="term.st,0.5em" placemnt="after"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="applic-boxing.ps" occur="all" scope="usetext" elemtype="pseudo">
<charlist inherit="0">
	<font famname="helvetica" size="9pt" weight="bold" offset="0.05pt">
	<highlt fontclr="white">
	<boxing toffset="8.0pt" boffset="0.4pt" loffset="0.5pt" roffset="0.5pt" trel="first" brel="last" siderel="content" inclr="iblack" inpct="100" radius="2"></charlist>
</e-i-c>

<e-i-c gi="acronymlist" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<postsp nominal="11pt"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="internatlstd" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="wcn"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
	<usetext source="\NOTE\" placemnt="before">
	<subchars charsubsetref="wcntitle">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="id" attval="#ANY">
<charsubset>
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="<para.ps>,#CONTENT,</para.ps>"></charsubset>
</att>

<att logic="and">
<specval attname="xrefid" attval="#ANY">
<charsubset>
	<usetext source="#XREFSAVE(xrefid,xrefstr)">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#ANY">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
	<suppress sup="1"></charsubset>
</att>
</e-i-c>

<e-i-c gi="ratddesc" context="* front" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="clearstrings">
	<reset resetlist="step1ct">
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="ratdtitlestring">
	<savetext textid="graphic.str" conrule=""></charlist>

<att logic="and">
<specval attname="sssn" attval="#ANY">
<charsubset>
	<savetext textid="sssn.st" conrule="\ (\,#CONTENT(sssn),\)\">
	<savetext textid="sssn.footer.st" conrule="#CONTENT(sssn)"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#ANY">
<charsubset>
	<savetext textid="labelstr" conrule="#CONTENT(label)"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<charsubset>
	<reset resetlist="sp1ct">
	<enumerat increm="1" enumid="para0ct">
	<savetext textid="labelstr" conrule="prefix.st,para0ct">
	<savetext textid="label" conrule="labelstr" saverule="1"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Deleted)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Reserved)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="na">
<specval attname="status" attval="notapp">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Not Applicable)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<specval attname="deltype" attval="#NE#\real\">
<charsubset charsubsetref="delchlvl"></charsubset>
</att>

<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
<charsubset charsubsetref="delstatus"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#NE#0">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<specval attname="deltype" attval="#NE#\real\">
<charsubset>
	<savetext textid="tocmatter" conrule="<toclinec>,1.5em,labelstr,@6.5em,               deltypestr,tocfill,<tocnumx>, pgnumber,                </tocnumx>,</toclinec>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="tocmattertmp" conrule="<toclined>,3em,labelstr,@6em,                            deltypestr,tocfill,<tocnumx>,pgnumber,                            </tocnumx>,</toclined>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="fcp" attval="#EQ#1">
<charsubset>
	<savetext textid="graphic.str" conrule="<fcp.ps>,</fcp.ps>,0.25em" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="esds" attval="#EQ#1">
<charsubset>
	<savetext textid="graphic.str" conrule="<esds.ps>,</esds.ps>,0.25em" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="hci" attval="#EQ#1">
<charsubset>
	<savetext textid="graphic.str" conrule="<hci.ps>,</hci.ps>,0.25em" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="hcp" attval="#EQ#1">
<charsubset>
	<savetext textid="graphic.str" conrule="<hcp.ps>,</hcp.ps>,0.25em" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="oci" attval="#EQ#1">
<charsubset>
	<savetext textid="graphic.str" conrule="<oci.ps>,</oci.ps>,0.25em" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="ocp" attval="#EQ#1">
<charsubset>
	<savetext textid="graphic.str" conrule="<ocp.ps>,</ocp.ps>,0.25em" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="nsp" attval="#EQ#1">
<charsubset>
	<savetext textid="graphic.str" conrule="<nsp.ps>,</nsp.ps>,0.25em" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="applicref" attval="#ANY">
<charsubset>
	<savetext textid="applicref.str" conrule="#XREFSAVE(applicref,xrefstr)"></charsubset>
</att>

<att logic="and">
<specval attname="security" attval="u">
<specval attname="fgi" attval="#ANY">
<charsubset>
	<savetext textid="secur.str" conrule="\(\,#CONTENT(fgi),\-U) \,0.25em"></charsubset>
</att>

<att logic="and">
<specval attname="security" attval="u">
<specval attname="fgi" attval="#NONE">
<charsubset>
	<savetext textid="secur.str" conrule="\(U) \,0.25em"></charsubset>
</att>

<att logic="and">
<specval attname="security" attval="s">
<specval attname="fgi" attval="#NONE">
<charsubset>
	<savetext textid="secur.str" conrule="\(S) \,0.25em"></charsubset>
</att>

<att logic="and">
<specval attname="security" attval="s">
<specval attname="fgi" attval="#ANY">
<charsubset>
	<savetext textid="secur.str" conrule="\(\,#CONTENT(fgi),\-S) \,0.25em"></charsubset>
</att>

<att logic="and">
<specval attname="security" attval="c">
<specval attname="fgi" attval="#NONE">
<charsubset>
	<savetext textid="secur.str" conrule="\(C) \,0.25em"></charsubset>
</att>

<att logic="and">
<specval attname="security" attval="c">
<specval attname="fgi" attval="#ANY">
<charsubset>
	<savetext textid="secur.str" conrule="\(\,#CONTENT(fgi),\-C) \,0.25em"></charsubset>
</att>
</e-i-c>

<e-i-c gi="TITLE" context="ratddesc" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="para0.title.csub">
	<hyphen hyph="0">
	<quadding quad="left" lastquad="relative">
	<keeps keep="1" scope="col" next="1">
	<savetext textid="ratdtitlestring" conrule="<uc>,#CONTENT,</uc>">
	<usetext source="LABELSTR,1em">
	<subchars>
	<highlt scoring="0">
	<textbrk startln="1">	</subchars>
	</usetext>

	<usetext source="secur.str,graphic.str,applicref.str">
	<subchars>
	<highlt scoring="0">	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="inschlvl" attloc="para0" attval="#NE#0">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="body" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<textbrk startpg="recto" pageid="bodypg" newpgmdl="global">
	<reset resetlist="chapenum sectenum">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<savetext textid="dot.st" conrule="">
	<savetext textid="inbody.st" conrule="\yes\"></charlist>

<att logic="and">
<specval attname="numcols" attval="#EQ#\1\">
<charsubset>
	<span span="1"></charsubset>
</att>

<att logic="and">
<specval attname="numcols" attval="#EQ#\2\">
<charsubset>
	<span span="2"></charsubset>
</att>
</e-i-c>

<e-i-c gi="body" context="volume" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<textbrk startpg="recto" pageid="bodypg" newpgmdl="global">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<savetext textid="dot.st" conrule="">
	<savetext textid="inbody.st" conrule="\yes\"></charlist>

<att logic="and">
<specval attname="numcols" attval="#EQ#\1\">
<charsubset>
	<span span="1"></charsubset>
</att>

<att logic="and">
<specval attname="numcols" attval="#EQ#\2\">
<charsubset>
	<span span="2"></charsubset>
</att>

<att logic="and">
<specval attname="resetnbrs" attloc="volume" attval="#EQ#\1\">
<charsubset>
	<reset resetlist="chapenum sectenum"></charsubset>
</att>

<att logic="and">
<specval attname="resetnbrs" attloc="volume" attval="#EQ#\0\">
<charsubset></charsubset>
</att>
</e-i-c>

<e-i-c gi="volume" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<enumerat increm="1" enumid="volenum">
	<savetext textid="tmidnostr" conrule="\\">
	<savetext textid="voltocmatter" conrule="\\">
	<savetext textid="volloimatter" conrule="\\">
	<savetext textid="vollotmatter" conrule="\\"></charlist>

<att logic="and">
<specval attname="volpages" attval="#EQ#1">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="volstring" conrule="#CONTENT(label),\-\">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinea>,1.5em,\Volume \,#CONTENT(label),spfill,</toclinea>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="lotmatter" conrule="<lotlinec>,\Volume \,#CONTENT(label),spfill,</lotlinec>" append="1">
	<savetext textid="lotmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="lofmatter" conrule="<loflinec>,\Volume \,#CONTENT(label),spfill,</loflinec>" append="1">
	<savetext textid="lofmatter" conrule="<toclinechappre>,</toclinechappre>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="volpages" attval="#EQ#1">
<specval attname="label" attval="#NONE">
<charsubset>
	<savetext textid="volstring" conrule="volenum,\-\">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinea>,1.5em,\Volume \,volenum,spfill,</toclinea>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="lotmatter" conrule="<lotlinec>,\Volume \,volenum,spfill,</lotlinec>" append="1">
	<savetext textid="lotmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="lofmatter" conrule="<loflinec>,\Volume \,volenum,spfill,</loflinec>" append="1">
	<savetext textid="lofmatter" conrule="<toclinechappre>,</toclinechappre>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="volpages" attval="#EQ#0">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="volstring" conrule="\\">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinea>,1.5em,\Volume \,#CONTENT(label),spfill,</toclinea>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="lotmatter" conrule="<lotlinec>,\Volume \,#CONTENT(label),spfill,</lotlinec>" append="1">
	<savetext textid="lotmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="lofmatter" conrule="<loflinec>,\Volume \,#CONTENT(label),spfill,</loflinec>" append="1">
	<savetext textid="lofmatter" conrule="<toclinechappre>,</toclinechappre>" append="1"></charsubset>
</att>

<att logic="and">
<specval attname="volpages" attval="#EQ#0">
<specval attname="label" attval="#NONE">
<charsubset>
	<savetext textid="volstring" conrule="\\">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<savetext textid="tocmatter" conrule="<toclinea>,1.5em,\Volume \,volenum,spfill,</toclinea>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
