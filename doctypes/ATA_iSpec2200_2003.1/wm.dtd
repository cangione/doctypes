<!-- ============================================================ -->
<!--                      EXTended Wire LIST                      -->
<!-- ============================================================ -->
<!ELEMENT extwlist  - -  (chgdesc*, title, extwrow+)                >
<!ATTLIST extwlist
          oldkey         NAME                         #IMPLIED
          %revatt;                                                  >

<!ELEMENT extwrow   - -  ((effect, chgdesc*, (actwire | nactwire
                          | sparepin), modcode?) | %deleted;)       >
<!ATTLIST extwrow
          chappref       CDATA                        #IMPLIED
          %revatt;                                                  >

<!ELEMENT actwire   - -  (wire, from, to)                           >
<!ELEMENT nactwire  - -  (wire, from?, to?)                         >
<!ELEMENT sparepin  - -  (from)                                     >
<!ELEMENT from      - -  (((%ein;, connect?) | wirecode), termnbr, 
                          shunt?, termpnr?, termcode?)              >
<!ATTLIST from 
          wexdir    CDATA                             #IMPLIED      >
<!ELEMENT to        - -  (((%ein;, connect?) | wirecode), termnbr, 
                          shunt?, termpnr?, termcode?)              >
<!ATTLIST to
          wexdir    CDATA                             #IMPLIED      >
<!ELEMENT wire      - -  (wirecode, length+, wiretype+, pnr?,
                          hdiagnbr, fam?, wirerte?, bundpnr?,
                          bunddesc?, feedthru*, sensep?)            >

<!ELEMENT wirecode  - -  ((wirenbr | wnbrmfr), wireawg?, wireclr?, 
