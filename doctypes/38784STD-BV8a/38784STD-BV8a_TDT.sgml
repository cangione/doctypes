	<ele>
		<tag>mrrespns</tag>
		<long>&notuse;</long>
		<desc>This element is part of the electronic review process. Further information on this element will be provided as the documentation matures. The element is used only in the review process and will not be used during document composition.</desc>
		<source>None.</source>
		<contmdl>(mrpara | mrlist)*</contmdl>
		<usedin>modreq</usedin>
		<specatts>
			<attrtbl>
				<attr>disposn</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Attribute is used to specify information about the modification request. This attribute is not supported by the FOSI at this time. The element is under review.</attrdesc>

				<attr>status</attr>
				<type>NMTOKEN</type>
				<default>#IMPLIED</default>
				<attrdesc>Attribute is used to specify information about the modification request. This attribute is not supported by the FOSI at this time. The element is under review.</attrdesc>
