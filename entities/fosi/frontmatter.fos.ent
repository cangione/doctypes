<e-i-c gi="leptext.fmt"><?Pub Dtl>
<charlist charsubsetref="own-line">
<usetext source="\Put the pages which make the change into the manual. Discard the pages you have replaced and/or removed in accordance with your applicable Security Regulations\">
</usetext>
<usetext source="!<note><line>On a page you have put in, the text which has been changed, and
the new text which has been added, is shown by a vertical line. The vertical
line is put in:</line><line>- the left margin for a left page</line><line>- the right margin for a right page</line><line>A change to an illustration is shown by corner marks or a small hand; a finger on the hand points to the changed area.</line></note>!">
</usetext>
<usetext source="\The date we supplied the first issue of the pages,and the dates we supplied the change pages, are:\">
<subchars charsubsetref="own-line prespace.7 postspace.7"></subchars>
</usetext>
</charlist>
</e-i-c>
<e-i-c gi="lep">
<charlist charsubsetref="own-line">
<textbrk startpg="recto" pageid="lep.page" newpgmdl="local" startln="1" endln="1">
<usetext source="lephead.txt" placemnt="before">
<subchars charsubsetref="own-line quad.centre font.12 bold postspace.4"></subchars>
</usetext>
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="<leptext.fmt>,</leptext.fmt>" placemnt="before"></usetext>
<usetext source="<own-line.fmt>,leptab1.app,</own-line.fmt>" placemnt="before">
</usetext>
<usetext source="\The total number of pages for this publication is \,pagecount.txt,\ as shown in the list below.\">
<subchars charsubsetref="own-line prespace.7 postspace.7"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="lepcontents"><?Pub Lcl _id="f1">
