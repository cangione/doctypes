conrule="<toclinec>,<toctitle.fmt>,label.txt,@4em,\DELETED\,tocfill,</toctitle.fmt>,<tocnumx>,page.chap.txt,\-\,folio.txt[BO],</tocnumx>,</toclinec>"
append="1">
