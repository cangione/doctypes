<usetext source="<fig-title.fmt>,foldtitle.ftr,</fig-title.fmt>"
placemnt="after">
<subchars>
<font inherit="0" weight="bold">
<quadding quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt" condit="discard"
priority="high">
<postsp minimum="12pt" nominal="12pt" maximum="12pt" priority="high">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<usetext source="contentcbar.txt,\ \">
<subchars>
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<!--end- blankapron=yes-->
<e-i-c gi="foldouts5x8" occur="all"><?Pub Lcl _id="f1322"><?Pub Dtl>
<charlist inherit="0" charsubsetref="reset-folios">
<textbrk startpg="recto">
<savetext textid="firstfoflag" conrule="\1\" placemnt="before">
<savetext textid="fosectflag" conrule="\1\" placemnt="before">
<savetext textid="fosectflag" conrule="\0\" placemnt="after"></charlist>
&division-settings;&set-deltypstr;
<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
<savetext textid="deltypestr" conrule="contentcbar.txt,\DELETED\">
<savetext textid="titleholdst" conrule="contentcbar.txt,\DELETED\">
</charsubset>
</att>
<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
