	  <!--=============================================-->
	<!-- inform element								  		  						   -->
	<!--=============================================-->
	<xs:element name="whatIf" type="whatIfType">
		    <xs:annotation>
			      <xs:documentation>get access to several scenarios related to the information the flight crew is reading</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="whatIfType">
		    <xs:sequence maxOccurs="unbounded">
			      <xs:element name="ifCondition" type="ifConditionType">
				        <xs:annotation>
					          <xs:documentation>if condition in a What-If</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <xs:complexType name="ifConditionType">
		    <xs:sequence>
			      <xs:element ref="caseCond"/>
			      <xs:group ref="crossRefGroup"/>
		    </xs:sequence>
	  </xs:complexType>
</xs:schema>