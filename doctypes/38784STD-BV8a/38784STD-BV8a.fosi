<specval attname="verstatpg" attval="unver">
<charsubset>
	<savetext textid="vsmatter" conrule="\<tabmat><tgroup cols=&quot;4&quot;><thead><row><entry></entry></row></thead><tbody>\,#EXPORTNL" placemnt="before">
	<usetext source="vsmatter,\</tbody></tgroup></tabmat>\,#EXPORTNL" placemnt="after" userule="6" useparam="vsmatter.dat">
