<e-i-c gi="xfigure" context="* pl" occur="all"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="clearstrings">
<quadding quad="center" lastquad="lcenter">
<postsp minimum="6pt" nominal="12pt" maximum="12pt" condit="discard"
priority="high">
<textbrk startln="1" endln="1">
<reset resetlist="subfig.total.ctr">
<enumerat increm="0" enumid="subfig.old.ctr" setvalue="1">
<savetext textid="figpg" conrule="folio.txt[BO]">
<savetext textid="subfig.ist" conrule="">
<savetext textid="subfig.flag" conrule="\no\" placemnt="before">
<savetext textid="legend.flag" conrule="\no\" placemnt="before">
<savetext textid="legend" conrule="\0\" placemnt="before">
<savetext textid="subfigno.ist" conrule="">
<savetext textid="prefix.tdv" conrule="\Figure\">
<savetext textid="prefix.tdv" conrule="\\" placemnt="after"></charlist>
<att logic="and">
<specval attname="pgwide" attval="#EQ#1">
<charsubset>
<span span="1"></charsubset>
</att>
<att logic="and">
<charsubset>
<savetext textid="fignum" conrule="label.txt"></charsubset>
</att>
<att logic="and"><?Pub Lcl
_comment=' att logic="and"&gt;
<specval attname="print-only" attloc="system-var" attval="#ANY"&gt;
<specval attname="delchlvl" attval="#NONE"&gt;
<specval attname="legend" attloc="foldout" attval="#EQ#0"&gt;
<charsubset&gt;
<usetext
source="\Figure \,fignum,\.\,1em,foldtitle,\ &ndash; Continued.\"&gt;<?Pub Dtl&gt;
<subchars&gt;
<font weight="bold"&gt;
<quadding quad="center" lastquad="lcenter"&gt;
<presp minimum="1pi" nominal="1pi" maximum="1pi"&gt;
<postsp minimum="2pi" nominal="2pi" maximum="2pi"&gt;
<textbrk startln="1" endln="0"&gt;
<float flidref="bot-col.flt" width="col" scope="figtable"
pagetype="forward"&gt;</subchars&gt;
</usetext&gt;
</charsubset&gt;
</att '>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="xrefstr" conrule="\Figure \,label.txt"></charsubset>
</att>
<att logic="and">
<specval attname="id" attval="#ANY">
