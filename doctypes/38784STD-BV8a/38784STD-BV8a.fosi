<e-i-c gi="graphic" context="figure" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<keeps keep="1" scope="col" prev="0">
	<vjinfo keepspr="kforce">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="orient" attloc="figure" attval="PORT">
<fillval attname="boardno" fillcat="putgraph" fillchar="graphname">
<fillval attname="reprodep" fillcat="putgraph" fillchar="depth">
<fillval attname="reprowid" fillcat="putgraph" fillchar="width">
<charsubset>
	<putgraph rotation="0">	</putgraph>
</charsubset>
</att>

<att logic="and">
<specval attname="orient" attloc="figure" attval="#NONE">
<fillval attname="boardno" fillcat="putgraph" fillchar="graphname">
<fillval attname="reprodep" fillcat="putgraph" fillchar="depth">
<fillval attname="reprowid" fillcat="putgraph" fillchar="width">
<charsubset>
	<putgraph rotation="0">	</putgraph>
</charsubset>
</att>

<att logic="and">
<specval attname="orient" attloc="figure" attval="LAND">
<fillval attname="boardno" fillcat="putgraph" fillchar="graphname">
<fillval attname="reprodep" fillcat="putgraph" fillchar="depth">
<fillval attname="reprowid" fillcat="putgraph" fillchar="width">
<charsubset>
