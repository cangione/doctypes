<e-i-c gi="tfnid" occur="first"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="0">
<suppress sup="1"></charlist>
<att logic="or">
<specval attname="tfntype" attval="alpha">
<specval attname="tfntype" attval="num">
<charsubset>
<savetext textid="tfnid.st" conrule="label.txt">
<savetext textid="tfnidstr"
conrule="<superscript>,tfnid.st,</superscript>" append="1">
<usetext source="<superscript>,tfnid.st,\, \,</superscript>"></usetext>
</charsubset>
</att>
<att logic="and">
<specval attname="tfntype" attval="sym">
<specval attname="tfnsymbol" attval="#NONE">
<charsubset>
<savetext textid="tfnid.st" conrule="symbol.tdv">
<savetext textid="tfnidstr"
conrule="<superscript>,tfnid.st,</superscript>" append="1">
<usetext source="<superscript>,tfnid.st,\, \,</superscript>"></usetext>
<usetext source="set-next-symbol.tdv"></usetext>
</charsubset>
</att>
<att logic="and">
<specval attname="tfnsymbol" attval="#ANY">
<specval attname="tfntype" attval="sym">
<charsubset>
<savetext textid="tfnid.st" conrule="#CONTENT(tfnsymbol)">
<savetext textid="tfnidstr"
conrule="<superscript>,tfnid.st,</superscript>" append="1">
<usetext source="<superscript>,tfnid.st,\, \,</superscript>"></usetext>
</charsubset>
</att>
<att>
