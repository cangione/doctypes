          lang        CDATA                                 #REQUIRED
          cusname     CDATA                                 #IMPLIED
          docnbr      CDATA                                 #IMPLIED
          manufact    CDATA                                 #REQUIRED
          oidate      NUMBER                                #REQUIRED
          revdate     NUMBER                                #REQUIRED
          chg         (N | R | U | D | I)                   #REQUIRED
          msgrev      NUMBER                                #REQUIRED 
          efflen      NUMBER                                #IMPLIED
          efftype     CDATA                                 #IMPLIED  >

<!ELEMENT increv - - (candmsi | msi | ssi | zonanl | task | sheet)+   >

