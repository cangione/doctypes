<e-i-c gi="ipbsertable"><?Pub Lcl _id="f549"><?Pub Dtl>
<charlist>
<postsp minimum="18pt" nominal="18pt" maximum="18pt" condit="keep"
priority="high">
<textbrk startln="1" endln="1">
<span span="1">
<savetext textid="ipbsertable-body.txt" conrule="\\" placemnt="before">
<savetext textid="tabtitle" conrule="\Serialization\" placemnt="before">
</charlist>&security-mark;
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="ipbsertable-structure.txt"
conrule='!<colspec colname="col1" colwidth="1.75in">
<colspec colname="col2" colwidth="1.25in">
<colspec colname="col3">!' placemnt="before">
<savetext textid="ipbsertable-header.txt"
conrule='!<thead>
<row valign="bottom">
<entry rowsep="1" colsep="0">Nomenclature</entry>
<entry rowsep="1" colsep="0">Model No.</entry>
<entry rowsep="1" colsep="0">Serial No.</entry>
</row>
</thead>!' placemnt="before">
<usetext
source='!<table>
<title>!,tabtitle,!</title>
<tgroup cols="3">!,ipbsertable-structure.txt,ipbsertable-header.txt,!<tbody>!,ipbsertable-body.txt,!</tbody>
</tgroup>
</table>!' placemnt="after"></usetext>
</charsubset>
</att>
<att>
<specval attname="UseTitleForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\False\">
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,label.txt"></charsubset>
</att>
<att>
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\False\">
<specval attname="UseTitleForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Serialization\"></charsubset>
</att>
<att>
<specval attname="UseTitleForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Serialization \,label.txt">
</charsubset>
</att>
<att logic="or">
