<!--Alert-->
<e-i-c gi="warning caution note" context="* step * sub-steps * opproc">
<charlist inherit="0">
<reset resetlist="row.app pparatxt reftxt tabletxt"></charlist>
</e-i-c>
<e-i-c gi="warning caution note" context="* indicationgrp * opproc">
<charlist inherit="0">
<reset resetlist="row.app pparatxt reftxt tabletxt"></charlist>
</e-i-c>
<e-i-c gi="warning" context="* opproc">
<charlist inherit="0" charsubsetref="paragraph space">
<savetext textid="nobrk.txt" conrule="!!" placemnt="before" append="0">
</charlist>
<att>
<specval attname="warning-type" attloc="warning" attval="not-hazmat">
<charsubset>
<savetext textid="table.app"
conrule='!<row rowsep="0">!,row.app,!</row>!' placemnt="after"
append="1">
<reset resetlist="row.app pparatxt reftxt tabletxt"></charsubset>
</att>
<att>
<specval attname="warning-type" attloc="warning" attval="hazmat">
<charsubset>
<savetext textid="tabletxt"
conrule="<ppara-ctr>,<bold>,#CONTENT,</bold>,</ppara-ctr>" append="1">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3">!,tabletxt,!</entry>!' append="1">
<savetext textid="table.app"
conrule='!<row rowsep="0">!,row.app,!</row>!' placemnt="after"
append="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="para" context="warning * indicationgrp * opproc" occur="only">
<charlist inherit="0">
<suppress sup="1">
<savetext textid="cautiontxt" conrule="<dblline>,\WARNING\,</dblline>">
<savetext textid="tabletxt"
conrule="<pnote>,cautiontxt,</pnote>,<ppara2b>,#CONTENT,</ppara2b>"
append="1">
<savetext textid="col3.app" conrule="tabletxt" append="1">
<reset resetlist="pparatxt reftxt tabletxt"></charlist>
</e-i-c>
<e-i-c gi="para" context="warning * indicationgrp * opproc"
occur="first">
<charlist inherit="1">
<suppress sup="1">
<savetext textid="cautiontxt" conrule="<dblline>,\WARNING\,</dblline>">
<savetext textid="tabletxt"
conrule="<pnote>,cautiontxt,</pnote>,<ppara2b>,#CONTENT,</ppara2b>"
append="1"></charlist>
</e-i-c>
<e-i-c gi="para" context="warning * indicationgrp * opproc"
occur="notfirst">
<charlist inherit="1">
<suppress sup="1">
<savetext textid="tabletxt" conrule="<ppara2b>,#CONTENT,</ppara2b>"
append="1"></charlist>
</e-i-c>
<e-i-c gi="para" context="warning * indicationgrp * opproc" occur="last">
<charlist inherit="1">
<suppress sup="1">
<savetext textid="tabletxt" conrule="<ppara2b>,#CONTENT,</ppara2b>"
append="1">
<savetext textid="col3.app" conrule="<ppara2b>,tabletxt,</ppara2b>"
