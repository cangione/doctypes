<!--Alerts-->
<e-i-c gi="warning" context="* trblproc-a">
<charlist inherit="0" charsubsetref="paragraph space">
<savetext textid="nobrk.txt" conrule="!!" placemnt="before" append="0">
<savetext textid="wcntxt" conrule="<dblline>,\WARNING\,</dblline>">
<savetext textid="wcntxt" conrule="<pnote>,wcntxt,</pnote>"></charlist>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\true\">
<specval attname="warning-type" attloc="warning" attval="not-hazmat">
<charsubset><?Pub Dtl>
<savetext textid="table.app"
conrule='!<row rowsep="0"><entry colname="col1">!,tabletxt,!</entry><entry></entry><entry></entry></row>!'
placemnt="after" append="1">
<reset resetlist="row.app pparatxt reftxt tabletxt"></charsubset>
</att>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\true\">
<specval attname="warning-type" attloc="warning" attval="hazmat">
<charsubset><?Pub Dtl>
<savetext textid="row.app"
conrule="<ppara-noindent>,<bold>,#CONTENT,</bold>,</ppara-noindent>"
append="1"></charsubset>
</att>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\false\">
<specval attname="warning-type" attloc="warning" attval="hazmat">
<charsubset><?Pub Dtl>
<savetext textid="row.app"
conrule="<ppara-noindent>,<bold>,#CONTENT,</bold>,</ppara-noindent>"
append="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="caution" context="* trblproc-a">
<charlist inherit="0">
<savetext textid="nobrk.txt" conrule="!!" placemnt="before" append="0">
<savetext textid="wcntxt" conrule="<buline>,\CAUTION\,</buline>">
</charlist>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\true\">
<charsubset><?Pub Dtl>
<savetext textid="table.app"
conrule='!<row rowsep="0"><entry colname="col1">!,tabletxt,!</entry><entry></entry><entry></entry></row>!'
placemnt="after" append="1">
<reset resetlist="row.app pparatxt reftxt tabletxt"></charsubset>
</att>
</e-i-c>
<e-i-c gi="note" context="* trblproc-a">
<charlist inherit="0">
<savetext textid="nobrk.txt" conrule="!!" placemnt="before" append="0">
<savetext textid="wcntxt" conrule="<pnote>,\NOTE\,</pnote>"
placemnt="before"></charlist>
<att>
<specval attname="Proccon" attloc="#FOSI" attval="#EQ#\true\">
<charsubset><?Pub Dtl>
<savetext textid="table.app"
conrule='!<row rowsep="0"><entry colname="col1">!,tabletxt,!</entry><entry></entry><entry></entry></row>!'
placemnt="after" append="1">
<reset resetlist="row.app pparatxt reftxt tabletxt"></charsubset>
</att>
</e-i-c>
<!--TROUBLESHOOTING PROCEDURE-B-->
<e-i-c gi="trblproc-b"><?Pub Dtl>
<charlist envname="tableenv">
<presp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<postsp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<textbrk startln="1" endln="1">
<span span="1">
<usetext
source='!<table rowsep="0"><tgroup cols="3"><colspec colname="col1" align="left"/><colspec colname="col2"
align="left"/><colspec colname="col3"
align="left"/><spanspec spanname="span1to3" namest="col1" nameend="col3"/><thead><row rowsep="1"><entry align="center"><bold>MALFUNCTION</bold></entry><entry align="center"><bold>PROBABLE CAUSE</bold></entry><entry align="center"><bold>CORRECTIVE ACTION</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
<reset resetlist="table.app tableconttxt tabletxt">
<reset resetlist="tfnnumct tfnalphact">
<reset resetlist="qaptxt hcitxt hcptxt esdstxt paract step1ct">
&ic.characteristics.clear.savetext;</charlist>&ic.characteristics.att;
&table.number.set;&change.marks.att;</e-i-c>
<e-i-c gi="title" context="trblproc-b"><?Pub Dtl>
<charlist charsubsetref="table.title">
<span span="1">
<usetext
source="qaptxt,caitxt,csitxt,csptxt,esdstxt,hcitxt,hcptxt,ocitxt,ocptxt,odstxt"
placemnt="before">
<subchars>
<font weight="bold"></subchars>
</usetext>
</charlist>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext
source="tablenumtxt,<bold>,qaptxt,caitxt,csitxt,csptxt,esdstxt,hcitxt,hcptxt,ocitxt,ocptxt,odstxt,</bold>,#CONTENT,\ (Cont)\">
<subchars charsubsetref="table.title.cont">
<float scope="trblproc-b"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="table" context="trblproc-b"><?Pub Dtl>
<charlist envname="tableenv"></charlist>
</e-i-c>
<e-i-c gi="symptomgrp" occur="all"><?Pub Dtl>
<charlist charsubsetref="calist1">
<enumerat increm="1" enumid="step1ct">
<savetext textid="step1cttxt" conrule="step1ct,\.\,@1.7pi">
<savetext textid="step1num" conrule="step1ct">
<savetext textid="table.app"
conrule='!<row>!,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">
<reset resetlist="row.app col1.app col2.app col3.app tabletxt reftxt">
<reset resetlist="outline.lev1.ct"></charlist>
</e-i-c>
<e-i-c gi="symptom" context="trblproc-b" occur="all"><?Pub Dtl>
<charlist>
<suppress sup="1">
<savetext textid="col1.app" conrule="#CONTENT">
<savetext textid="reftxt" conrule="\\"></charlist>
</e-i-c>
<e-i-c gi="malfuncgroup" occur="first"><?Pub Dtl>
<charlist>
<savetext textid="reftxt" conrule="\\"></charlist>
</e-i-c>
<e-i-c gi="malfuncgroup" occur="notfirst"><?Pub Dtl>
<charlist>
<savetext textid="table.app"
conrule='!<row>!,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="before" append="1">
<reset resetlist="row.app col1.app col2.app col3.app tabletxt reftxt">
<savetext textid="reftxt" conrule="\\"></charlist>
</e-i-c>
<e-i-c gi="reference" context="* malfuncgroup" occur="all"><?Pub Dtl>
<charlist inherit="0">
<suppress sup="1">
<savetext textid="reftxt" conrule="\ (\,#CONTENT,\)\" placemnt="after">
</charlist>
</e-i-c>
<e-i-c gi="action" context="* malfuncgroup" occur="all"><?Pub Dtl>
<charlist inherit="0">
<suppress sup="1">
<savetext textid="col3.app" conrule="#CONTENT,reftxt" append="1">
<savetext textid="reftxt" conrule="\\"></charlist>
</e-i-c>
<e-i-c gi="malfunction" context="malfuncgroup" occur="all"><?Pub Dtl>
<charlist charsubsetref="paragraph">
<suppress sup="1">
<savetext textid="col2.app" conrule="#CONTENT" append="1">
<savetext textid="reftxt" conrule="\\"></charlist>
</e-i-c>
<e-i-c gi="no"><?Pub Dtl>
<charlist>
<suppress sup="1"></charlist>
<att>
<fillval attname="otherprocedure" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="xrefstr-otherprocedure">
<savetext textid="row.app"
conrule='!<entry colname="col2" valign="bottom">!,\paragraph \,xrefstr-otherprocedure,\, step \,xrefstr,!</entry>!'
append="1"></charsubset>
</att>
<att>
<specval attname="otherprocedure" attval="#NONE">
<fillval attname="idref" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="xrefstr">
<savetext textid="row.app"
conrule='!<entry colname="col2" valign="bottom">!,xrefstr,!</entry>!'
append="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="yes"><?Pub Dtl>
<charlist>
<suppress sup="1"></charlist>
<att>
<fillval attname="idref" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="xrefstr"></charsubset>
</att>
<att>
<fillval attname="otherprocedure" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="xrefstr-otherprocedure">
<savetext textid="row.app"
conrule='!<entry colname="col3" valign="bottom">!,\paragraph \,xrefstr-otherprocedure,\, step \,xrefstr,!</entry>!'
append="1"></charsubset>
</att>
<att>
<specval attname="otherprocedure" attval="#NONE">
<fillval attname="idref" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="xrefstr">
<savetext textid="row.app"
conrule='!<entry colname="col3" valign="bottom">!,xrefstr,!</entry>!'
append="1"></charsubset>
</att>
</e-i-c>
<!--Final Action-->
<e-i-c gi="malfunction" context="finalaction"><?Pub Dtl>
<charlist charsubsetref="calist1">
<enumerat increm="1" enumid="step1ct">
<savetext textid="step1cttxt" conrule="step1ct,\.\,@1.7pi">
<savetext textid="step1num" conrule="step1ct"></charlist>
</e-i-c>
<e-i-c gi="para" context="malfunction * finalaction"><?Pub Dtl>
<charlist>
<suppress sup="1">
<savetext textid="row.app"
conrule="<ppara>,step1cttxt,<bold>,qaptxt,caitxt,csitxt,csptxt,esdstxt,hcitxt,hcptxt,ocitxt,ocptxt,odstxt,</bold>,#CONTENT,reftxt,<bold>,\ (T/S COMPLETED)\,</bold>,</ppara>"
append="1">
