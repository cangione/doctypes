<savetext textid="aillist.app"
conrule="<ailistro>,<stitle>,aiwp-title.txt,</stitle>,<wpno>,aiwp-wpno.txt,</wpno>,<swpno>,aiwp-swpno.txt,</swpno>,</ailistro>"
append="1"></charsubset>
</att>
<att>
<specval attname="UseTitleForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attloc="wp" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="scontent.txt,#CONTENT,econtent.txt"
xrefidtag="wp"></charsubset>
</att>
<att>
