placemnt="before">
<savetext textid="comp-header.txt"
conrule='!<thead><row valign="bottom"><entry rowsep="1" align="center">!,\Item\,!</entry><entry rowsep="1" align="center">!,\Packaged/Unpackaged\,!</entry><entry rowsep="1" align="center">!,\Drop Distance\,!</entry><entry rowsep="1" align="center">!,\Required Action\,!</entry></row></thead>!'
placemnt="before">
