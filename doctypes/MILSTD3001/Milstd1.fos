<!--Historical Record of Applicable Technical Directives-->
<e-i-c gi="ratd" context="hratd"><?Pub Dtl>
<charlist envname="tableenv">
<presp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<postsp minimum="10pt" nominal="12pt" maximum="16pt" priority="high">
<textbrk startln="1" endln="1">
<span span="1">
