<e-i-c gi="fwdintro" context="front * docwuc" occur="all"><?Pub Lcl
_id="f1325"><?Pub Dtl>
<charlist inherit="1"
charsubsetref="clearstrings reset-folios foliostyle-ar">
<font style="serif">
<savetext textid="code.txt" conrule="\\" placemnt="before"></charlist>
&division-settings;&att-set-label;
<att logic="and">
<specval attname="mantype" attloc="docwuc" attval="standard">
<charsubset>
<textbrk startpg="recto" pageid="frontpg-5x8" newpgmdl="global">
<span span="1">
<savetext textid="dot.st" conrule="\.\">
<usetext source="\INTRODUCTION\">
<subchars>
<font inherit="1" style="sanserif" size="14pt" weight="bold">
<quadding quad="center">
<postsp minimum="14pt" nominal="14pt" maximum="14pt" priority="high">
<textbrk startln="1" endln="1">
<span span="1"></subchars>
</usetext>
</charsubset>
</att>
