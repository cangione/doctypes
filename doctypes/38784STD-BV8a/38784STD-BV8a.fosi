<e-i-c gi="partno" context="lrpentry" occur="notfirst" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<suppress sup="1"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="title" context="lrpentry" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<suppress sup="1">
	<usetext source="lrp.str">
	<subchars>
	<indent leftind="4pt" firstln="0pt">
	<cellatts colname="tmidno">
	<stdcellatts leftmar="2pt" rightmar="2pt" topmar="2pt" botmar="1pt" halign="left">	</cellatts>
	</subchars>
	</usetext>

	<usetext source="#CONTENT">
	<subchars>
	<indent leftind="8pt" firstln="0pt">
	<cellatts colname="title">
	<stdcellatts leftmar="2pt" rightmar="2pt" topmar="2pt" botmar="1pt" halign="left">	</cellatts>
	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="glosslist" context="glossary" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font inherit="0" style="sanserif" size="8pt"></charlist>

<att logic="and">
<specval attname="numcols" attloc="rear" attval="#EQ#1">
<charsubset>
	<span span="1">
	<tabatts widthtype="colrelative" relwidth="100" frame="none">
	<stdcellatts colsep="0" rowsep="0" colsepon="0" leftmar="5pt" rightmar="2pt" topmar="1pt" botmar="1pt">	</tabatts>

	<tgroupatts cols="2">	</tgroupatts>

	<colatts colname="term" colwidth="1*">	</colatts>

	<colatts colname="def" colwidth="3*">	</colatts>

	<colatts spanname="letter" namest="term" nameend="def">	</colatts>

	<usetext source="<body.ps>">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="numcols" attloc="rear" attval="#EQ#2">
<charsubset>
	<span span="2">
	<tabatts widthtype="colrelative" relwidth="50" frame="none">
	<stdcellatts colsep="0" rowsep="0" colsepon="0" leftmar="5pt" rightmar="2pt" topmar="1pt" botmar="1pt">	</tabatts>

	<tgroupatts cols="2">	</tgroupatts>

	<colatts colname="term" colwidth="1*">	</colatts>

	<colatts colname="def" colwidth="3*">	</colatts>

	<colatts spanname="letter" namest="term" nameend="def">	</colatts>

	<usetext source="<body.ps>">	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="glossrow" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<rowatts>	</rowatts>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="def" context="* glosslist" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<cellatts colname="def">
	<stdcellatts halign="left">	</cellatts>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="letter" context="* glosslist" occur="first" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<keeps keep="1" next="1">
	<rowatts>	</rowatts>

	<cellatts spanname="letter">
	<stdcellatts topmar="0pt" botmar="5pt" halign="center">	</cellatts>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="letter" context="* glosslist" occur="notfirst" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<keeps keep="1" next="1">
	<rowatts>	</rowatts>

	<cellatts spanname="letter">
	<stdcellatts topmar="10pt" botmar="5pt" halign="center">	</cellatts>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="term" context="* glosslist" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<rowatts>	</rowatts>

	<cellatts colname="term">
	<stdcellatts halign="left">	</cellatts>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="ddsheet.table" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<tabatts widthtype="specific" specwidth="7.25in" frame="none" framestyle="blank">
	<stdcellatts>	</tabatts>

	<tgroupatts cols="2">	</tgroupatts>

	<colatts colname="nomen" colwidth="4.0in">	</colatts>

	<colatts colname="number" colwidth="3.0in">	</colatts>

	<colatts spanname="spanall" namest="nomen" nameend="number">	</colatts>
</charlist>
</e-i-c>

<e-i-c gi="ddsheet.tablebody" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<subsetatts subsettype="body">	</subsetatts>

	<rowatts>
	<stdcellatts>	</rowatts>
</charlist>
</e-i-c>

<e-i-c gi="ddnomen.ps" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<usetext source="ddnomen.str">
	<subchars>
	<indent leftind="4pt" firstln="0pt">
	<cellatts colname="nomen">
	<stdcellatts leftmar="4pt" rightmar="4pt" topmar="12pt" botmar="0pt" halign="left">	</cellatts>
	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="ddnumber.ps" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<usetext source="ddsheet.str">
	<subchars>
	<indent leftind="4pt" firstln="0pt">
	<cellatts colname="number">
	<stdcellatts leftmar="2pt" rightmar="2pt" topmar="12pt" botmar="0pt" halign="right">	</cellatts>
	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="ruling.ps" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<usetext source="\ \">
	<subchars>
	<presp nominal="-10pt">
	<cellatts colname="spanall">
	<stdcellatts rowsepon="0" leftmar="2pt" rightmar="2pt" topmar="5pt" botmar="5pt" halign="center">	</cellatts>

	<ruling thick="0.75pt" lentype="rel" rellen="col" voffset="1pt" ruleclr="black" rulepct="100" type="single">	</ruling>
	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="ddwarning.ps" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<usetext source="\THE INSTRUCTIONS CONTAINED IN PRECEDING SECTIONS OF THIS TECHNICAL MANUAL APPLY EXCEPT FOR THE DIFFERENCES LISTED IN THIS DATA SHEET\">
	<subchars>
	<cellatts colname="spanall">
	<stdcellatts rowsepon="0" leftmar="2pt" rightmar="2pt" topmar="5pt" botmar="5pt" halign="center">	</cellatts>
	</subchars>
	</usetext>
</charlist>
</e-i-c>
</newtabdesc>

<ftndesc>
<e-i-c gi="FTNREF" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<enumerat increm="1" enumid="ftnct"></charlist>

<att logic="and">
<specval attname="mark" attval="num">
<charsubset>
	<savetext textid="ftnct.str" conrule="ftnct[AR]">
	<usetext source="ftnct.str">
	<subchars>
	<font style="sanserif" size="7pt" offset="4pt">
	<textbrk startln="0" endln="0">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="mark" attval="alpha">
<charsubset>
	<savetext textid="ftnct.str" conrule="ftnct[AU]">
	<usetext source="ftnct.str">
	<subchars>
	<font style="sanserif" size="7pt" offset="4pt">
	<textbrk startln="0" endln="0">	</subchars>
	</usetext>
</charsubset>
</att>
</e-i-c>

<ftnatts>
<charlist inherit="0">
	<font style="serif" size="9pt">
	<leading lead="10pt">
	<quadding quad="justify">
	<presp minimum="2pt" nominal="3pt" maximum="3.5pt">
	<usetext source="ftnct.str">
	<subchars>
	<font style="sanserif" size="6pt" offset="4pt">
	<textbrk startln="0" endln="0">	</subchars>
	</usetext>

	<usetext source="#XREFSAVE(xrefid,xrefstr)">
	<subchars>
	<font style="serif" size="7pt" offset="0.33em">
	<textbrk endln="1">	</subchars>
	</usetext>
</charlist>
</ftnatts>
</ftndesc>
</outspec>

