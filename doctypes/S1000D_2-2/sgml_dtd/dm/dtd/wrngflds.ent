<!--**********************************************************************
    * Define Element dsc.elecequip (Equipment Data/Field Descriptions)   *
    * containing:-                                                       *
    *  dsc.rfd         - Mandatory Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.pnr         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.altpnr      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.mfc         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.instloc     - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.accdopl     - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.assy        - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.nhassy      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.sbc         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.sibplugid   - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.trl         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.clc         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.econtact    - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.statedes    - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.rpc         - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.nomenc      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.equdescref  - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.fdescref    - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    *  dsc.illref      - Optional  Single   contains Definition stored   *
    *                                                in entity %DSCDECL;.*
    ********************************************************************** -->

<!ELEMENT dsc.elecequip - - (dsc.rfd, dsc.pnr?, dsc.altpnr?, 
                             dsc.mfc?, dsc.instloc?, dsc.accdopl?, 
                             dsc.assy?, dsc.nhassy?, dsc.sbc?,
                             dsc.sibplugid?, dsc.trl?, dsc.clc?, 
                             dsc.econtact?, dsc.statedes?, dsc.rpc?, 
                             dsc.nomenc?, dsc.equdescref?, dsc.fdescref?, 
                             dsc.illref?)>
<!-- Elements <dsc.econtact>, <dsc.statedes> and <dsc.nomenc> added -->
<!-- Element <dsc.equdescref> repositioned -->


