<e-i-c gi="subpara7" context="* front * docwc"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="para clearstrings">
<reset resetlist="subp8.ctr">
<enumerat increm="1" enumid="subp7.ctr">
<savetext textid="label.txt"
conrule="para0.ctr,\.\,subp1.ctr,\.\,subp2.ctr,\.\,subp3.ctr,\.\,subp4.ctr,\.\,subp5.ctr,\.\,subp6.ctr,\.\,subp7.ctr">
