source='!<table rowsep="0" colsep="0"><tgroup cols="9"><colspec colname="col1" align="left" colwidth="3pi"/><colspec colname="col2"
align="left" colwidth="8pi"/><colspec colname="col3" align="left"/><colspec colname="col4" align="center" colwidth="2.6pi"/><colspec colname="col5" align="center" colwidth="3pi"/><colspec colname="col6" align="center" colwidth="3pi"/><colspec colname="col7" align="center" colwidth="4pi"/><colspec colname="col8" align="center" colwidth="5pi"/><colspec colname="col9" align="center" colwidth="3pi"/><spanspec spanname="span1to9" namest="col1" nameend="col9"/><thead><row rowsep="1"><entry colsep="1" align="center"><bold>Index No.</bold></entry><entry align="center" colsep="1"><bold>Part Number</bold></entry><entry align="left" colsep="1"><bold>&emsp;&emsp;&emsp;Description1&ensp;2&ensp;3&ensp;4&ensp;5&ensp;6&ensp;7</bold></entry><entry align="center" colsep="1"><bold>Mat</bold></entry><entry align="center" colsep="1"><bold>Stock Size</bold></entry><entry align="center" colsep="1"><bold>Units per Assy</bold></entry><entry align="center" colsep="1"><bold>Usable On Code</bold></entry><entry align="center" colsep="1"><bold>SM&amp;R Code</bold></entry><entry align="center" colsep="1"><bold>WUC</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after">
<subchars>
<font style="sanserif" size="8">
<leading lead="9pt"></subchars>
</usetext>
<savetext textid="number" conrule="tablenum">
<reset resetlist="table.app">
<reset resetlist="indexnum indexahead">
<reset
resetlist="row.app indexnotxt gaplpartnotxt nomentxt nhanotetxt cagetxt refdestxt specdwgtxt extreftxt tolerancetxt sizetxt drilltrimtxt descnotetxt loxtxt esdstxt qecatxt hcitxt magtxt col1.app col2.app col3.app col4.app col5.app col6.app col7.app col8.app col9.app col3structdatatxt">
&ic.characteristics.ipd.clear.savetext;</charlist>
