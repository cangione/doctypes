<e-i-c gi="figure"><?Pub Dtl>
<charlist>
<font inherit="0">
<indent inherit="0">
<quadding inherit="0" quad="center">
<presp minimum="16pt" nominal="18pt" maximum="22pt" priority="med">
<postsp minimum="16pt" nominal="18pt" maximum="22pt" priority="high">
<textbrk startln="1" endln="1">
<reset resetlist="sheetct"></charlist>
<att>
<specval attname="deltype" attval="#NONE">
<charsubset><?Pub Dtl>
<usetext source="one-graphic-figtitle" placemnt="after">
<subchars>
<leading inherit="0" lead="12pt">
<indent inherit="0">
<quadding inherit="0" quad="center">
<presp minimum="6pt" nominal="8pt" maximum="12pt" condit="keep"
priority="med">
<postsp minimum="11pt" nominal="12pt" maximum="12pt" priority="high">
<keeps prev="1">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="label" attloc="figure" attval="#NONE">
<charsubset><?Pub Dtl>
<enumerat increm="1" enumid="figct">
<savetext textid="fignum" conrule="figct">
<savetext textid="fignumstr" conrule="\Figure \,fignum">
<savetext textid="figtitle" conrule="\Figure \, figct">
<savetext textid="number" conrule="figtitle"></charsubset>
</att>
<att>
<specval attname="label" attloc="figure" attval="#ne#\nonum\">
<specval attname="label" attloc="figure" attval="#ANY">
<fillval attname="label" attloc="figure" fillcat="savetext"
fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="fignum">
<savetext textid="figtitle" conrule="\Figure \,fignum,\.\,8pt">
<savetext textid="number" conrule="figtitle"></charsubset>
</att>
<att>
<specval attname="label" attloc="figure" attval="nonum">
<charsubset><?Pub Dtl>
<savetext textid="fignum" conrule="\\">
<savetext textid="number" conrule="figtitle">
<savetext textid="figtitle" conrule="figuretitle"></charsubset>
</att>
<att>
<fillval attname="id" attloc="figure" fillcat="savetext"
fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="fignum"></charsubset>
</att>
