	  <xs:include schemaLocation="../attrs/commonAttrs.xsd"/>
	  <!--=====================================================-->
	<!--  WarningProc element definition -->
	<!--=====================================================-->
	<xs:element name="warningProc" type="wcnProcType">
		    <xs:annotation>
			      <xs:documentation>An operating procedural content that may result in personal injury or loss of life if not followed..</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=====================================================-->
	<!--  CautionProc element definition -->
	<!--=====================================================-->
	<xs:element name="cautionProc" type="wcnProcType">
		    <xs:annotation>
			      <xs:documentation>An operating procedural content that may result in damage to equipment if not followed.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=====================================================-->
	<!--  NoteProc element definition -->
	<!--=====================================================-->
	<xs:element name="noteProc" type="wcnProcType">
		    <xs:annotation>
			      <xs:documentation>An operating procedural content considered essential to emphasise. Information contained in notes may also be safety related.</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=====================================================-->
	<xs:complexType name="wcnProcType">
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <!--=====================================================-->
	<!--  WCNProc group  -->
	<!--=====================================================-->
	<xs:group name="wcnProcGroup">
		    <xs:annotation>
			      <xs:documentation>A grouping of elements that provide advisory information of special significance or emphasis.</xs:documentation>
		    </xs:annotation>
		    <xs:choice>
			      <xs:element ref="warningProc"/>
			      <xs:element ref="cautionProc"/>
			      <xs:element ref="noteProc"/>
		    </xs:choice>
	  </xs:group>
</xs:schema>