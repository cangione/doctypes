conrule="<ixpt>,alphaidxlvl1.txt,</ixpt>,<ixsub1>,alphaidxlvl2.txt,</ixsub1>,<ixsub2>,alphaidxlvl3.txt,</ixsub2>,<ixpgstr>,wpct.txt[BO],\/\,foliostr[BO],</ixpgstr>,<ixpgkey>,manualpgstr,</ixpgkey>"
append="1">
<savetext textid="strAlphaLvl3.Pg" conrule="foliostr[BO]">
<savetext textid="a-volX.txt"
conrule="<aisystementry>,<name>,alphaidxlvl1.txt,</name>,<aiwpvolentry>,<title>,alphaidxlvl2.txt,</title>,<tmidno>,dashstr,</tmidno>,<reference>,wpct.txt[BO],</reference>,<aiwpsubentry>,<title>,alphaidxlvl3.txt,</title>,<reference>,wpct.txt[BO],\/\,foliostr[BO],</reference>,</aiwpsubentry>,</aiwpvolentry>,</aisystementry>,\&#RE;\"
append="1">
