<charlist inherit="1">
	<font inherit="0">
	<indent inherit="0" leftind="40pt1em" rightind="40pt" firstln="0pt">
	<quadding inherit="0" quad="left">
	<keeps keep="1" widowct="3" orphanct="3">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="TOCNUMX" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font inherit="0" offset="3pt">
	<leading lead="0.01pt" force="1">
	<indent leftind="3.0in" rightind="0in" firstln="3.0in">
	<quadding inherit="0" quad="right">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="TOCLINED" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font inherit="1">
	<indent inherit="1" leftind="14em" rightind="15pt" firstln="0">
	<quadding inherit="0" quad="left">
	<postsp nominal="0">
	<textbrk startpg="off" startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="TOCNUM" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font inherit="0">
	<quadding inherit="0" quad="right"></charlist>
</e-i-c>

<e-i-c gi="TOCNUMREAR" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font inherit="0" offset="3pt">
	<leading lead="0.01pt" force="1">
	<indent leftind="2.25in" rightind="0in" firstln="2.25in">
	<quadding inherit="0" quad="right">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="TOCLINEREAR" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<font inherit="0">
	<indent inherit="0" leftind="72pt" rightind="60pt" firstln="0pt">
	<quadding inherit="0" quad="left" lastquad="lleft">
	<highlt allcap="1">
	<keeps keep="1" scope="col">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="figno" context="* illuslist" occur="all" scope="usetext" elemtype="gi">
