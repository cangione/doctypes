<!--Sequence List-->
<e-i-c gi="seqlist" context="* note * testproc"><?Pub Dtl>
<charlist charsubsetref="outline.lev1"></charlist>
</e-i-c>
<e-i-c gi="title" context="seqlist * testproc"><?Pub Dtl>
<charlist charsubsetref="standalone space underscore">
<suppress sup="1">
<savetext textid="tabletxt"
conrule="<ppara>,<bold>,#CONTENT,</bold>,</ppara>" append="1">
</charlist>
</e-i-c>
<e-i-c gi="item" context="seqlist * testproc"><?Pub Dtl>
<charlist inherit="1">
<enumerat increm="1" enumid="outline.lev1.ct"></charlist>
</e-i-c>
<e-i-c gi="para" context="* seqlist * note * testproc" occur="all">
<charlist inherit="1">
<suppress sup="1"></charlist>
<att>
<specval attname="label" attloc="item" attval="#ANY">
<charsubset charsubsetref="outline.text outline.lev1.item.indent"><?Pub Dtl>
<savetext textid="labeltxt">
<savetext textid="tabletxt"
conrule="<ppara>,<bold>,labeltxt,\. \,#CONTENT,</bold>,</ppara>"
append="1"></charsubset>
</att>
<att>
<specval attname="label" attloc="item" attval="#NONE">
<charsubset>
<savetext textid="tabletxt"
conrule="<ppara2b>,outline.lev1.ct,\. \,#CONTENT,</ppara2b>" append="1">
</charsubset>
</att>
</e-i-c>
<!--Step-->
<e-i-c gi="step" context="* testproc" occur="all"><?Pub Dtl>
<charlist charsubsetref="calist1">
