<savetext textid="deltypestr" conrule="contentcbar.txt,\(Deleted)\">
<usetext source="label.txt,\ \,deltypestr">
<subchars>
<font inherit="0">
<postsp minimum="11pt" nominal="11pt" maximum="11pt">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<savetext textid="tocmatter"
conrule="<toclinec>,<toctitle.fmt>,1.5em,label.txt,@6.5em,deltypestr,</toctitle.fmt>,</toclinec>"
append="1"></charsubset>
</att>
<att>
<specval attname="name" attval="foldout">
<fillval attname="label" fillcat="savetext" fillchar="conrule">
<charsubset>
<savetext textid="label.txt">
<savetext textid="deltypestr" conrule="contentcbar.txt,\(Deleted)\">
