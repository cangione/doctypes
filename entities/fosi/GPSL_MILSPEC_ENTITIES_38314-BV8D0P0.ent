'>
<!ENTITY sssn-proc '<!-- GPSL:RK Entity "sssn-proc" -->
<att>
<specval attname="SSSN" attval="#ANY">
<charsubset>
<savetext textid="sssn.st" conrule="\ \,0.125em,\ (\,#CONTENT(sssn),\)\">
</charsubset>
</att>
'>
<!ENTITY wcn-id-idref '<!-- GPSL:RK Entity "wcn-id-idref" -->
<att>
<specval attname="id" attval="#ANY">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="xrefstr" conrule="<wcnwrapper.psu>,<para.ps>,scontent.txt,#CONTENT,econtent.txt,</para.ps>,</wcnwrapper.psu>">
</charsubset>
</att>
<att>
<specval attname="xrefid" attval="#ANY">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<usetext source="#XREF(xrefid,xrefstr)">
</usetext>
</charsubset>
</att>
<att>
<specval attname="id" attval="#ANY">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="<para.ps>,contentcbar.txt,</para.ps>">
</charsubset>
</att>
<att>
<specval attname="xrefid" attval="#ANY">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<usetext source="contentcbar.txt">
</usetext>
</charsubset>
</att>
'>
