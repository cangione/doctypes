<e-i-c gi="ftnote"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<enumerat increm="1" enumid="ftnote.ctr">
<savetext textid="label.txt" conrule="ftnote.ctr"></charlist>
&att-set-label;&att-content-cbar;
<att>
<specval attname="editor-only" attloc="system-var" attval="#ANY">
<charsubset>
<font size="10pt"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="ftn.txt" conrule="scontent.txt,#CONTENT,econtent.txt">
<savetext textid="ftnct.txt"
conrule="scontent.txt,label.txt,econtent.txt">
<usetext source="ftnct.txt">
<subchars>
<font inherit="1" style="sanserif" size="7pt" offset="+4pt">
<highlt inherit="0">
<keeps prev="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<savetext textid="ftnct.txt"
conrule="scontent.txt,label.txt,econtent.txt">
<savetext textid="ftn.txt" conrule="scontent.txt,\Deleted\,econtent.txt">
<usetext source="scontent.txt,\ \,econtent.txt">
<subchars>
<font inherit="1" style="sanserif" size="7pt" offset="+4pt">
<highlt inherit="0">
<keeps prev="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<specval attname="id" attloc="ftnote" attval="#ANY">
<charsubset>
<savetext textid="xref-formatted.txt"
conrule="scontent.txt,<footnote.fmt>,label.txt,</footnote.fmt>,econtent.txt"
xrefidtag="ftnote"></charsubset>
</att>
</e-i-c>
<ftnatts><?Pub Dtl>
<charlist>
<font style="serif" size="9pt">
<leading lead="10pt">
<quadding quad="justify">
<presp minimum="3pt" nominal="3pt" maximum="3pt">
<suppress sup="1">
<usetext
source="scontent.txt,label.txt,0.5em,<ftn.psu>,ftn.txt,</ftn.psu>,econtent.txt"
placemnt="before">
