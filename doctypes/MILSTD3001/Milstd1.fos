</att>
<att><?Pub Dtl>
<specval attname="security" attloc="manual" attval="u">
<specval attname="numberoftmidnos" attloc="manual" attval="1">
<charsubset><?Pub Dtl>
<textbrk startpg="next" pageid="niewppgset"></charsubset>
</att>
<att><?Pub Dtl>
<specval attname="security" attloc="manual" attval="#NE#\u\">
<specval attname="numberoftmidnos" attloc="manual" attval="2">
<charsubset><?Pub Dtl>
<textbrk startpg="next" pageid="securniewppgset2"></charsubset>
</att>
<att><?Pub Dtl>
<specval attname="security" attloc="manual" attval="u">
<specval attname="numberoftmidnos" attloc="manual" attval="2">
<charsubset><?Pub Dtl>
<textbrk startpg="next" pageid="niewppgset2"></charsubset>
</att>
<att>
