<!ENTITY PrimeCdInfo.Screen "<att>
  <specval attname='screen-only' attloc='system-var' attval='#ANY'>
  <charsubset>
    <usetext source='\CLASSIFICATION \'><subchars charsubsetref='title.inline.STYLE'></subchars></usetext>
    <usetext source='classified.screen.text'><subchars charsubsetref='brk.inline.STYLE'></subchars></usetext>
    <usetext source='\CARD \'><subchars charsubsetref='title.inline.STYLE'></subchars></usetext>
    <usetext source='card.number.screen.text'><subchars charsubsetref='brk.inline.STYLE allcaps'></subchars></usetext>
    <usetext source='\PUB NO. \'><subchars charsubsetref='title.inline.STYLE'></subchars></usetext>
    <usetext source='service.tm.id.number.text'><subchars charsubsetref='brk.inline.STYLE allcaps'></subchars></usetext>
    <usetext source='\DATE \'><subchars charsubsetref='title.inline.STYLE'></subchars></usetext>
    <usetext source='pub.date.text'><subchars charsubsetref='brk.inline.STYLE allcaps'></subchars></usetext>
    <usetext source='\CHANGE NO. \'><subchars charsubsetref='title.inline.STYLE'></subchars></usetext>
    <usetext source='change.number.text'><subchars charsubsetref='brk.inline.STYLE'></subchars></usetext>
