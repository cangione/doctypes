<!ENTITY % mnucbasld PUBLIC "-//USA-DOD//DTD 9977K-AV6D0P0//EN" >

<!ENTITY % bodyele "suppinfo, munitldproc+" >

<!-- %mnucbasld;
-->

<!ENTITY % mnucbasld PUBLIC "-//USA-DOD//DTD 9977K-AV6D0P0//EN" >
%mnucbasld;




<!ENTITY note5 "With local commander approval, the following
fuzes may remain installed. " >


<!-- ELEMENT and ATTRIBUTE LIST DECLARATIONS -->

<!ELEMENT docnnmunld - - (front, body, rear?) +(pgbrk | brk |
				subjinfo | line | modreq | location) >

<!ELEMENT fuzerem - o (%text1;) >
<!ATTLIST fuzerem %sub1att; >

<!ELEMENT munitldproc - - (%titles, general, rackload, munitunloadproc)
					+(figure | table | foldout) >
<!ATTLIST munitldproc %chapatt; >

<!ELEMENT munitunloadproc - o (%parazero, safing, preunload, unload+, (fuzerem | sensorrem)) >
<!ATTLIST munitunloadproc %sectatt; >

<!ELEMENT sensorrem - o (%text1;) >
<!ATTLIST sensorrem %sub1att; >

<!ELEMENT suppinfo - - (%titles, gensafreq, emergproc, airdesc, genproc, 
					airprep, fctfuncchk, strayvoltchk, 
					section*) +(figure | table | foldout) >
<!ATTLIST suppinfo %chapatt; >

