	<xs:annotation>
		    <xs:documentation>Version Number: 2017.1</xs:documentation>
		    <xs:documentation>Revision Date: 2017-10-31</xs:documentation>
		    <xs:documentation>Revision Comments: Spec 2300 revision 2017.1</xs:documentation>
	  </xs:annotation>
	  <xs:include schemaLocation="../common/basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/links.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/dmIdent.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/dmIssue.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/receiver.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/dmAttrs.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/pmRef.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/pmIssue.xsd"/>
	  <xs:include schemaLocation="../common/dataManagement/statusEntryCode.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/extensibleInterface.xsd"/>
	  <!--=============================================-->
	<!-- DataSet StatusList Element Declaration -->
	<!--=============================================-->
	<xs:element name="dssl">
		    <xs:annotation>
			      <xs:documentation>Data Set Status List</xs:documentation>
		    </xs:annotation>
		    <xs:complexType>
			      <xs:sequence>
				        <xs:element name="dsslIdent" type="dsslIdentElemType">
					          <xs:annotation>
						            <xs:documentation>Data set Status List identification</xs:documentation>
					          </xs:annotation>
				        </xs:element>
				        <xs:element name="issueInfo" type="issueInfoElemType">
					          <xs:annotation>
						            <xs:documentation>Date of the last exchange package delivery (i.e. issueDate of the last exchangePackageStatusList)</xs:documentation>
					          </xs:annotation>
				        </xs:element>
				        <xs:element ref="receiverIdent" minOccurs="0"/>
				        <xs:element name="dsslContent" type="dsslContentElemType">
					          <xs:annotation>
						            <xs:documentation>list of data module and publication module entries, with related dmEntryType or pmEntryType and issueInfo, plus list of objects (graphic, multimedia)</xs:documentation>
					          </xs:annotation>
				        </xs:element>
			      </xs:sequence>
			      <xs:attribute name="id" type="idType" use="optional">
				        <xs:annotation>
					          <xs:documentation>Optional id for data management</xs:documentation>
				        </xs:annotation>
			      </xs:attribute>
		    </xs:complexType>
	  </xs:element>
	  <!--=============================================-->
	<!-- dsslIdentend Content model												 -->
	<!--=============================================-->
	<xs:complexType name="dsslIdentElemType">
		    <xs:sequence>
			      <xs:element ref="identExtension" minOccurs="0"/>
			      <xs:element name="dsslCode" type="dsslCodeElemType">
				        <xs:annotation>
					          <xs:documentation>data set status list code</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
	  </xs:complexType>
	  <xs:complexType name="dsslCodeElemType">
		    <xs:attribute name="modelIdentCode" type="modelIdentCodeAttType" use="required">
			      <xs:annotation>
				        <xs:documentation>the model identifier using NSPA Model Identification Code list</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="senderIdent" type="senderIdentAttType" use="required">
			      <xs:annotation>
				        <xs:documentation>originator (sender) identification</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
	  <xs:simpleType name="senderIdentAttType">
		    <xs:restriction base="xs:string">
			      <xs:pattern value="[A-Z0-9]{5}"/>
		    </xs:restriction>
	  </xs:simpleType>
	  <!--=============================================-->
	<!-- dsslContentElemType Content model												 -->
	<!--=============================================-->
	<xs:complexType name="dsslContentElemType">
		    <xs:sequence>
			      <xs:element name="pmStatusEntry" type="pmStatusEntryElemType" maxOccurs="unbounded">
				        <xs:annotation>
					          <xs:documentation>the publication module status entry gives the information items concerning a publication module</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="dmStatusEntry" type="dmStatusEntryElemType" maxOccurs="unbounded">
				        <xs:annotation>
					          <xs:documentation>the data module status entry gives the information items concerning a data module</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="object" type="objectType" minOccurs="0" maxOccurs="unbounded">
				        <xs:annotation>
					          <xs:documentation>Identifies a external objects (graphics, multimedia) .</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- dmStatusEntry Content model												 -->
	<!--=============================================-->
	<xs:complexType name="dmStatusEntryElemType">
		    <xs:sequence>
			      <xs:element ref="dmRef">
				        <xs:annotation>
					          <xs:documentation>reference to related data module</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="dmStatusIssueInfo" type="dmIssueInfoElemType">
				        <xs:annotation>
					          <xs:documentation>issue info of related dm status fragment.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="dmContentIssueInfo" type="dmIssueInfoElemType">
				        <xs:annotation>
					          <xs:documentation>issue info of related dm content fragment.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attributeGroup ref="dmStatusEntryCodeAttGrp"/>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- pmStatusEntry Content model												 -->
	<!--=============================================-->
	<xs:complexType name="pmStatusEntryElemType">
		    <xs:sequence>
			      <xs:element ref="pmRef">
				        <xs:annotation>
					          <xs:documentation>reference to related publication module</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="pmStatusIssueInfo" type="pmIssueInfoElemType">
				        <xs:annotation>
					          <xs:documentation>issue info of related pm status fragment.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="pmContentIssueInfo" type="pmIssueInfoElemType">
				        <xs:annotation>
					          <xs:documentation>issue info of related pm content fragment.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attributeGroup ref="pmStatusEntryCodeAttGrp"/>
	  </xs:complexType>
	  <!--=============================================-->
	<!-- object Content model												 -->
	<!--=============================================-->
	<xs:complexType name="objectType">
		    <xs:attribute name="objectType" use="required">
			      <xs:annotation>
				        <xs:documentation>a graphic or a multimediaObject</xs:documentation>
			      </xs:annotation>
			      <xs:simpleType>
				        <xs:restriction base="xs:string">
					          <xs:enumeration value="graphic"/>
					          <xs:enumeration value="multimedia"/>
				        </xs:restriction>
			      </xs:simpleType>
		    </xs:attribute>
		    <xs:attribute name="infoIdent" type="xs:string" use="required">
			      <xs:annotation>
				        <xs:documentation>ICN of related deleted object"</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attributeGroup ref="icnExtensionAttGrp"/>
	  </xs:complexType>
</xs:schema>