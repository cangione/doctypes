	<ele>
		<tag>figure</tag>
		<long>Figure</long>
		<desc>Identifies an illustration.</desc>
		<source>4.2.8</source>
		<contmdl>(title, (((subfig | subfigfo), (subfig | subfigfo)+) | ((graphic, legend?) | tabdisplay)+))   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>ipbplgrp and globally included in appendix, chapter, ddchapter, foreword, intro, ipbfwordchap, preface, and safesum.</usedin>
		<ents>fig, exclus, and figatts</ents>
		<specatts>
			<attrtbl>
				<attr>pgwide</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Defines whether the figure will fill the entire width of the page.</attrdesc>

				<attr>orient</attr>
				<type>(port | land | land2)</type>
				<default>port</default>
				<attrdesc>Defines the orientation of the figure. The land2 attribute also rotates the figure title.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>This allows you to identify each element and later reference it by its id value.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to assign an applicable reference</attrdesc>

				<attr>legend</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>This attribute is set to 1 when a legend is tagged as part of the figure.</attrdesc>

				<attr>nxtpg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates whether the legend should appear on the same page as the graphic or on the next page.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>foldout</tag>
		<long>Foldout</long>
		<desc>Identifies a foldout</desc>
		<source>4.2.4.1</source>
		<contmdl>(title, (((subfig | subfigfo), (subfig | subfigfo)+) | ((graphic, legend?) | tabdisplay)+))   -(figure | table | foldout | objmedia)</contmdl>
		<usedin>foldsect and globally included in appendix, chapter, and ddchapter.</usedin>
		<ents>fig, exclus, yesorno, and figatts</ents>
		<specatts>
			<attrtbl>
				<attr>pgstyle</attr>
				<type>(11x17 | 11x20.5 | 11x24 | 11x27.5 | 11x31 | 11x34.5 | 11x38 | 11x41.5 | 11x45)</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines the pagesize for the foldout</attrdesc>

				<attr>blankapron</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Toggle to indicate whether the foldout includes a blank apron. A value of '1' indicates that the foldout will have a blank apron, a value of '0' indicates that the foldout will not have a blank apron.</attrdesc>

				<attr>pgwide</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Defines whether the figure will fill the entire width of the page.</attrdesc>

				<attr>orient</attr>
				<type>(port | land | land2)</type>
				<default>port</default>
				<attrdesc>Defines the orientation of the figure. The land2 attribute also rotates the figure title.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>This allows you to identify each element and later reference it by its id value.</attrdesc>

				<attr>applicref</attr>
				<type>IDREFS</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to assign an applicable reference</attrdesc>

				<attr>legend</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>This attribute is set to 1 when a legend is tagged as part of the figure.</attrdesc>

				<attr>nxtpg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Indicates whether the legend should appear on the same page as the graphic or on the next page.</attrdesc>

				<attr>verdate</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Identifies the date the element was verified.</attrdesc>

				<attr>verrem</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for the author to make remarks about the verification of the element.</attrdesc>

				<attr>verstatus</attr>
				<type>(unver | ver | notapplicable)</type>
				<default>unver</default>
				<attrdesc>Identifies verification status of the element.</attrdesc>

				<attr>label</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows you to label this item manually. The fosi will automatically do this for you, so its use is not necessary unless a label out of the ordinary is desired.</attrdesc>

				<attr>sssn</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>System, Subsystem, or Subject Number can be assiged to this element.</attrdesc>

				<attr>indexid</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides an index ID for this element. Not currently supported by the FOSI - this attribute is under review.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>foldsect</tag>
		<long>Foldout Section</long>
		<desc>Identifies the area where foldouts are placed when they are included at the end of the manual. This element is not marked as a chapter or section, but is merely a placeholder for the foldouts.</desc>
		<source>4.2.4.1d</source>
		<contmdl>(foldout+) -(note)</contmdl>
		<usedin>rear</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>foreword</tag>
		<long>Foreword</long>
		<desc>Identifies the foreword of the manual. This element is identical to the preface and introduction elements, with the exception of the FOSI-generated title for that portion of the manual.</desc>
		<source>4.5.9</source>
		<contmdl>(para0, (para0 | applicdef | symsect | abbrsect | internatlstd | lrp | tctolist | ratddesc | tmimprep)*)   +(figure | table)</contmdl>
		<usedin>front and auxfront</usedin>
		<ents>fpi and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>front</tag>
		<long>Front</long>
		<desc>Identifies the front matter of the manual.</desc>
		<source>4.5</source>
		<contmdl>(warnpage?, idinfo, chginssht?, (lep | vollep), verstat?, tpdr?, chgrec?, (contents | volcontents), (illuslist| volilluslist)?, (tablelist | voltablelist)?, (foreword | preface | intro), safesum?)   +(ftnote)</contmdl>
		<usedin>doc and volume</usedin>
		<ents>frnt and yesorno</ents>
		<specatts>
			<attrtbl>
				<attr>t2page</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>A toggle that allows the author to turn the second title page on if necessary.</attrdesc>

				<attr>numcols</attr>
				<type>(1 | 2)</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows the author to define the page format as one or two columns for this section of the manual.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>ftnote</tag>
		<long>Footnote</long>
		<desc>Identifies footnotes to paragraphs and tables. The footnote appears on the same page that the corresponding footnote reference (<![ CDATA [<ftnref>]]>) occurs. Only the footnote whose id matches the xrefid specified in the footnote reference will appear. Footnotes to text will be displayed at the bottom of the page where the footnote is referenced.</desc>
		<source>4.3.1n & 4.2.2</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+ | randlist | deflist | seqlist)+  -(ftnote | ftnref | figure | table | foldout | objmedia)</contmdl>
		<usedin>Globally included in appendix, auxfront, body, and front.</usedin>
		<ents>text, list, exclus, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>id</attr>
				<type>ID</type>
				<default>#REQUIRED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>ftnref</tag>
		<long>Footnote Reference</long>
		<desc>Identifies a reference to a footnote. This element will cause the footnote number/letter/symbol to appear at the point in the text where used, and will cause the footnote number/letter/symbol and the footnote text to appear at the bottom of the page.</desc>
		<source>4.3.1n</source>
		<contmdl>EMPTY</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>xrefid</attr>
				<type>IDREF</type>
				<default>#REQUIRED</default>
				<attrdesc>Defines the ID of the element that you are referencing. The value of this attribute should match the value of an ID attribute elsewhere in the manual.</attrdesc>

				<attr>mark</attr>
				<type>(num | sym | alpha)</type>
				<default>num</default>
				<attrdesc>Indicates the type of symbol or mark used to indicate a footnote.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>glossary</tag>
		<long>Glossary</long>
		<desc>Identifies the glossary of the manual.</desc>
		<source>4.2.9.7</source>
		<contmdl>((letter?, glosslist)+) -(note)</contmdl>
		<usedin>rear</usedin>
