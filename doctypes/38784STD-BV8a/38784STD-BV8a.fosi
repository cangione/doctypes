<e-i-c gi="RANDLIST" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<presp nominal="12pt">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
