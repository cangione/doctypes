<!ATTLIST list5
          cont      %yesorno;                         "0"              >
<!ELEMENT list6     - - (l6item+)                                      >
<!ATTLIST list6
          cont      %yesorno;                         "0"              >
<!ELEMENT list7     - - (l7item+)                                      >
<!ATTLIST list7
