<e-i-c gi="ratddesc" context="* front"><?Pub Lcl _id="f1"
_comment="usetext
source='<font-8pt.fmt&gt;,!<table frame=&#34;all&#34;&gt;<tgroup cols=&#34;9&#34;&gt;<?PubTbl tgroup ctmarg=&#34;2pt&#34; cbmarg=&#34;0.5pt&#34;&gt;!,ipbpl0tbl-structure.txt,ipbpl0tbl-header.txt,!<tbody&gt;!,ipbpl0tbl-body.txt,!</tbody&gt;</tgroup&gt;</table&gt;!,</font-8pt.fmt&gt;'
placemnt=&#34;after&#34;&gt;</usetext"><?Pub Dtl>
