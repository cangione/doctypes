<e-i-c gi="ipbnumgrp" context="ipbnumindx" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<span span="3">
	<tabatts widthtype="colrelative" relwidth="33" frame="all">
	<stdcellatts colsep="0" rowsep="0pt" leftmar="5pt" rightmar="2pt" topmar="2pt">	</tabatts>

	<tgroupatts cols="2">	</tgroupatts>

	<colatts colname="col1" colwidth="1*">	</colatts>

	<colatts colname="col2" colwidth="1*">	</colatts>

	<usetext source="<header.ps>,  <partnohead>,\\,</partnohead>,<fignohead>,\FIGURE &\,</fignohead>,  <partnohead>,\PART NUMBER\,</partnohead>,<fignohead>,\INDEX NO.\,</fignohead>,  </header.ps>,<body.ps>">	</usetext>
</charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="header.ps" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<subsetatts subsettype="head">	</subsetatts>

	<rowatts>
	<stdcellatts topmar="2pt">	</rowatts>
</charlist>
</e-i-c>

<e-i-c gi="body.ps" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<subsetatts subsettype="body">	</subsetatts>

	<rowatts>
	<stdcellatts topmar="2pt">	</rowatts>
</charlist>
</e-i-c>

<e-i-c gi="ipbgroup10" context="ipbnumgrp * ipbnumindx" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<rowatts>	</rowatts>

	<cellatts colname="col1">
	<stdcellatts colsep="1pt" colsepon="1" topmar="4pt" halign="center">	</cellatts>

	<usetext source="\ \" placemnt="after">
	<subchars>
	<cellatts colname="col2">
	<stdcellatts colsep="1pt" colsepon="1" topmar="4pt" halign="center">	</cellatts>
	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="partnohead" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font style="sanserif" size="8pt">
	<cellatts colname="col1">
	<stdcellatts colsep="1pt" colsepon="1" topmar="4pt" halign="center" valign="bottom">	</cellatts>
</charlist>
</e-i-c>

<e-i-c gi="fignohead" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font style="sanserif" size="8pt">
	<cellatts colname="col2">
	<stdcellatts colsep="1pt" colsepon="1" topmar="4pt" halign="center" valign="bottom">	</cellatts>
</charlist>
</e-i-c>

