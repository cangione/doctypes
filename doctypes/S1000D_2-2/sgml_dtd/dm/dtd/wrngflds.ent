<!--**********************************************************************
    * Define Element dsc.stdparts (Standard Parts Data/Field             *
    *                              Descriptions)                         *
    * containing:-                                                       *
    *  dsc.connector     - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.mass, dsc.orientation,*
    *                                          dsc.assy, dsc.rack,       *
    *                                          dsc.ccount, dsc.contact,  *
    *                                          dsc.cdia, dsc.fin,        *
    *                                          dsc.tplus, dsc.tminus,    *
    *                                          dsc.sterm, dsc.coax,      *
    *                                          dsc.triax, dsc.module,    *
    *                                          dsc.block, dsc.shunt,     *
    *                                          dsc.econtact,             *
    *                                          dsc.statedes, dsc.accpnr, *
    *                                          dsc.fdescref, dsc.illref. *
    *  dsc.vpart         - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.csize, dsc.mat,       *
    *                                          dsc.mass, dsc.colour,     *
    *                                          dsc.protect, dsc.cdia,    *
    *                                          dsc.mint, dsc.maxt,       *
    *                                          dsc.fdescref, dsc.illref. *
    *  dsc.accessory     - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.mass, dsc.orientation,*
    *                                          dsc.assy, dsc.fdescref,   *
    *                                          dsc.illref.               *
    *  dsc.solder-sleeve - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.length, dsc.mat,      *
    *                                          dsc.mass, dsc.mind,       *
    *                                          dsc.maxd, dsc.fdescref,   *
    *                                          dsc.illref.               *
    *  dsc.shrink-sleeve - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.size, dsc.mass,       *
    *                                          dsc.colour, dsc.mind,     *
    *                                          dsc.maxd, dsc.mint,       *
    *                                          dsc.maxt, dsc.minh,       *
    *                                          dsc.maxh, dsc.fdescref,   *
    *                                          dsc.illref.               *
    *  dsc.ident-sleeve  - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.length, dsc.mat,      *
    *                                          dsc.mass, dsc.fdescref,   *
    *                                          dsc.illref.               *
    *  dsc.conduit       - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.size, dsc.mass,       *
    *                                          dsc.colour, dsc.wallthk,  *
    *                                          dsc.mint, dsc.maxt,       *
    *                                          dsc.fdescref, dsc.illref. *
    *  dsc.wire-mat      - Optional  Single   contains dsc.pnr,          *
    *                                          dsc.altpnr, dsc.mfc,      *
    *                                          dsc.wiretype,             *
    *                                          dsc.wiregauge, dsc.core,  *
    *                                          dsc.size, dsc.mass,       *
    *                                          dsc.colour,               *
    *                                          dsc.outjackcol,           *
    *                                          dsc.outdia, dsc.res,      *
    *                                          dsc.voltage, dsc.amperage,*
    *                                          dsc.mint, dsc.maxt,       *
    *                                          dsc.screencount, dsc.coax,*
    *                                          dsc.triax, dsc.impedance, *
    *                                          dsc.freq, dsc.attenuation,*
