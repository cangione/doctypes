<!-- DOCTYPE em   [ -->
<!-- The following set of declarations may be referred to
     using the public entity as follows:
<!DOCTYPE em PUBLIC
    "-//ATA-TEXT//DTD EM-VER12-LEVEL2//EN" [ ]>              -->

<!-- ======================================================= -->
<!--          NOTATIONS                                      -->
<!-- ======================================================= -->

<!NOTATION cgm PUBLIC
    "-//USA-DOD//NOTATION Computer Graphics Metafile//EN"      >

<!NOTATION ccitt4 PUBLIC
    "-//USA-DOD//NOTATION CCITT Group4 Facsimile//EN"          >

<!NOTATION gcf PUBLIC
 "-//ATA-TEXT//NOTATION Graphic Companion File//EN"            >

<!NOTATION pdf PUBLIC
 "-//Adobe Inc.//NOTATION Portable Document Format//EN"        >

<!NOTATION png PUBLIC
 "-//W3C//NOTATION Portable Network Graphics//EN"              >

<!NOTATION jpeg PUBLIC
 "+//ISBN 0-7923-9432-1::Graphic Notation//NOTATION Joint
  Photographic Experts Group Raster//EN"                       >

<!NOTATION vrml PUBLIC
 "-//ATA-TEXT//NOTATION Virtual Reality Modeling Language//EN" >

<!NOTATION mpeg PUBLIC
 "-//ATA-TEXT//NOTATION Motion Pictures Expert Group//EN"      >

<!NOTATION mp3 PUBLIC
 "-//ATA-TEXT//NOTATION Motion Pictures Expert Group, Audio
  Layer 3//EN"                                                 >

<!-- ======================================================= -->
<!--                      ENTITIES                           -->
<!-- ======================================================= -->
<!--                                                         -->
<!ENTITY  % g.r  "(refblock* | (grphcref*, refext*, refint*))" >
<!ENTITY  % w.c      "(warning*, caution*)"                    >
<!ENTITY  % text     "(para | tabdat | table | unlist |
                       numlist | note)+"                       >
<!ENTITY  % deleted  "(deleted, chgdesc*)"                     >
<!ENTITY  % yesorno  "NUMBER"                                  >
<!ENTITY  % revatt
            "chg       (N | D | R | U)            #REQUIRED
             key        ID                        #REQUIRED
             revdate    NUMBER                    #REQUIRED"   >

<!ENTITY   % ISOtech      PUBLIC
"ISO 8879-1986//ENTITIES   General Technical//EN"              >
<!ENTITY   % ISOpub      PUBLIC
"ISO 8879-1986//ENTITIES Publishing//EN"                       >
<!ENTITY   % ISOnum      PUBLIC
"ISO 8879-1986//ENTITIES   Numeric and Special Graphic//EN"    >
<!ENTITY   % ISOgrk1     PUBLIC
"ISO 8879-1986//ENTITIES   Greek Letters//EN"                  >
<!ENTITY   % ISOgrk2     PUBLIC
"ISO 8879-1986//ENTITIES Monotoniko Greek//EN"                 >
<!ENTITY   % ISOgrk3     PUBLIC
"ISO 8879-1986//ENTITIES Greek Symbols//EN"                    >
<!ENTITY   % ISOgrk4     PUBLIC
"ISO 8879-1986//ENTITIES Alternative Greek Symbols//EN"        >
<!ENTITY   % ISOlat1     PUBLIC
"ISO 8879-1986//ENTITIES Added Latin 1//EN"                    >
<!ENTITY   % ISObox      PUBLIC
"ISO 8879-1986//ENTITIES Box and Line Drawing//EN"             >
<!ENTITY   % ISOamso     PUBLIC
"ISO 8879-1986//ENTITIES Added Math Symbols: Ordinary//EN"     >
<!ENTITY   % ISOamsc     PUBLIC
"ISO 8879-1986//ENTITIES Added Math Symbols: Delimiters//EN"   >

%ISOtech; %ISOpub; %ISOnum; %ISOgrk1; %ISOgrk2; %ISOgrk3;
%ISOgrk4; %ISOlat1; %ISObox; %ISOamso; %ISOamsc;
<!--                                                         -->
<!-- ======================================================= -->
<!--                   EM TOP LEVEL STRUCTURE                -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT em       - -  ((title, legalntc?, mfmatr, chapter*)
                        | increv | tr+) +(revst | revend
                        | cocst | cocend | hotlink)            >
<!ATTLIST em
          spl       CDATA                         #REQUIRED
          model     CDATA                         #REQUIRED
          oidate    NUMBER                        #REQUIRED
          tsn       CDATA                         #REQUIRED
          cus       CDATA                         #IMPLIED
          cusname   CDATA                         #IMPLIED
          docnbr    CDATA                         #IMPLIED
          lang      CDATA                         #REQUIRED
          revdate   NUMBER                        #REQUIRED
          chg       (N | R | U)                   "N"
          efflen    NUMBER                        #IMPLIED
          efftype   CDATA                         #IMPLIED     >
<!--                                                         -->
<!ELEMENT increv    - -  (transltr?, legalntc?, (chapter
                         | section | subject | pgblk | task
                         | subtask | trlist | conindex | sblist
                         | intro | howtouse | hazmtlst)+)      >
<!--                                                         -->
<!ELEMENT tr        - -  (legalntc?, trfmatr, trlist?,
                         (chapter | section+ | subject+
                         | pgblk+ | task+ | sheet+ | graphic+
                         | intro | sblist | legalntc | hazmtlst
                         | subtask+))                          >
<!--                                                         -->
<!ELEMENT trfmatr   - -  (title, trreason, (%text;)?)          >
<!ATTLIST trfmatr
          trnbr     CDATA                         #REQUIRED
          issdate   NUMBER                        #REQUIRED
          trdel     CDATA                         #IMPLIED
          trrepl    CDATA                         #IMPLIED     >

<!ELEMENT trreason  - -  %text;                                >

<!-- ======================================================= -->
<!--       Legal Notice Information                          -->
<!-- ======================================================= -->

<!ELEMENT legalntc  - - (exprtcl | cpyrght | proptary | geninfo)+>
<!ATTLIST legalntc
          %revatt;                                             >

<!ELEMENT proptary  - - (fullstmt, partstmt?)                  >
<!ELEMENT fullstmt  - - (title?, cpyrght?, para+)              >
<!ELEMENT partstmt  - - (title?, para+)                        >
<!ELEMENT exprtcl   - - (para | unlist | numlist | note)+      >
<!ELEMENT cpyrght   - - (year*, holder*, geninfo)              >
<!ELEMENT year      - - (#PCDATA)                              >
<!ELEMENT holder    - - (#PCDATA)                              >
<!ELEMENT geninfo   - - (para | unlist | numlist | note)+      >

<!-- ======================================================= -->
<!--             ENGINE MANUAL FRONT MATTER                  -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT mfmatr    - - (transltr?, trlist?, conindex?,
                         sblist*, intro?, howtouse?, hazmtlst?)>
<!ELEMENT transltr  - - (chgdesc*, title, (%text;))+           >
<!ATTLIST transltr
          oldkey    NAME                          #IMPLIED
          %revatt;                                             >

<!ELEMENT trlist    - - (trdata+ | isempty)                    >
<!ATTLIST trlist
          oldkey    NAME                          #IMPLIED
          %revatt;                                             >

<!ELEMENT trdata    - - (effect?, trnbr, trstatus, trloc+)     >

<!ELEMENT conindex  - - (chgdesc*, title, (prclist1 | table)+)+>
<!ATTLIST conindex
          oldkey    NAME                          #IMPLIED
          %revatt;                                             >

<!ELEMENT sblist    - - (effect?, chgdesc*, title, %text;,
                        (sbdata+ | isempty))                   >
<!ATTLIST sblist
          %revatt;                                             >

<!ELEMENT sbdata    - - (sbnbr, sbdesc?, issdate?, ics)        >

<!ELEMENT intro     - - (chgdesc*, title, prclist1)+           >
<!ATTLIST intro
          oldkey    NAME                          #IMPLIED
          %revatt;                                             >

<!ELEMENT howtouse  - - (chgdesc*, title, prclist1)+           >
<!ATTLIST howtouse
          oldkey    NAME                          #IMPLIED
          %revatt;                                             >

<!ELEMENT sbnbr     - - (#PCDATA)                              >
<!ELEMENT issdate   - - (#PCDATA)                              >
<!ELEMENT ics       - - (#PCDATA)                              >
<!ELEMENT trnbr     - - (#PCDATA)                              >
<!ELEMENT trstatus  - - (#PCDATA)                              >
<!ELEMENT trloc     - - (#PCDATA)                              >
<!ELEMENT sbdesc    - - (#PCDATA)                              >

<!ELEMENT hazmtlst  - - (title, pretopic*, hazmt+)             >
<!ATTLIST hazmtlst
          %revatt;                                             >
<!ELEMENT pretopic  - - (title, (%text; | list1)) +(effect)    >
<!ELEMENT hazmt     - - (title, warning)                       >
<!ATTLIST hazmt
          id        ID                            #REQUIRED    >
<!--                                                         -->
<!-- ======================================================= -->
<!--                      CHAPTER                            -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT chapter   - -  (effect?, ((chgdesc*, title?,
                         section+) | %deleted;))               >
<!ATTLIST chapter
          chapnbr   NUMBER                        #REQUIRED
          %revatt;                                             >
<!--                                                         -->
<!-- ======================================================= -->
<!--                      SECTION                            -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT section   - -  (effect?, ((chgdesc*,title?,
                         subject+) | %deleted;))               >
<!ATTLIST section
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          %revatt;                                             >
<!--                                                         -->
<!-- ======================================================= -->
<!--                       SUBJECT                           -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT subject   - -  (effect?, ((chgdesc*, title?,
                         pgblk+) | %deleted;))                 >
<!ATTLIST subject
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          %revatt;                                             >
<!--                                                         -->
<!-- ======================================================= -->
<!--                      PAGEBLOCK                          -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT pgblk     - -  (effect?, ((chgdesc*, title, pbfmatr?,
                         regulatory*, ((task+ | prclist1)?),
                         graphic*) | %deleted;))             >
<!ATTLIST pgblk
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          pgblknbr  NUMBER                        #REQUIRED
          breaknbr  CDATA                         "NA"
          confnbr   CDATA                         "NA"
          confgtxt  CDATA                         " "
          %revatt;                                             >
<!--                                                         -->
<!ELEMENT pbfmatr   - -  (title?, %g.r;, (list1 | %text;)*)
                                                  +(effect)    >
<!--                                                         -->
<!-- ======================================================= -->
<!--                        TASK                             -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT task      - -  (effect?, ((chgdesc*, title, %g.r;,
                         regulatory*, (%w.c;), note*, tfmatr?,
                         (taskproc | subtask | graphic)*)
                         | %deleted;))                         >
<!ATTLIST task
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          pgblknbr  NUMBER                        #REQUIRED
          breaknbr  CDATA                         "NA"
          confnbr   CDATA                         "NA"
          confgtxt  CDATA                         " "
          func      CDATA                         " "
          seq       CDATA                         #REQUIRED
          confltr   CDATA                         " "
          varnbr    CDATA                         "0"
          alunqi    CDATA                         " "
          %revatt;                                             >
<!--                                                         -->
<!ELEMENT tfmatr    - -  (tprereq+)                            >
<!--                                                         -->
<!-- ======================================================= -->
<!-- Added attribute "alt" to enable two numbering schemes   -->
<!-- to be used as visual cues to alternative elements below -->
<!-- the task or subtask level.  Example: steps 1, 2, 3 and  -->
<!-- steps 1A, 2A, 3A.                                       -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT tprereq  - -  (title, ((%w.c;) | (%text;))*, list1?)
                                                     +(effect) >
<!ATTLIST tprereq
          alt      %yesorno;                      #IMPLIED     >
<!--                                                         -->
<!-- ======================================================= -->
<!-- Changed the structure of taskproc to harmonize          -->
<!-- location of notes.  The prior structure was:            -->
<!-- taskproc     - -  (title, (%g.r;), (%w.c;), note*,      -->
<!--                          ((subtask, graphic*)+ |        -->
<!--                          list1 | (para | tabdat |       -->
<!--                         table | unlist | numlist))+)    -->
<!--                                              +(effect)  -->
<!--                                                         -->
<!-- Added attribute "alt" to enable two numbering schemes   -->
<!-- to be used as visual cues to alternative elements below -->
<!-- the task or subtask level.  Example: steps 1, 2, 3 and  -->
<!-- steps 1A, 2A, 3A.                                       -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT taskproc - -  (title, (%g.r;), (%w.c;), ((subtask,
                         graphic*)+ | list1 | %text; )+)
                                                  +(effect)    >
<!ATTLIST taskproc
          alt      %yesorno;                      #IMPLIED     >
<!--                                                         -->
<!-- ======================================================= -->
<!--                      SUBTASK                            -->
<!-- ======================================================= -->
<!-- Changed "varnbr" from NUMBER to CDATA to accommodate    -->
<!-- non-numeric legacy data of some manufacturers.          -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT subtask   - -  (effect?, ((chgdesc*, title, %g.r;,
                         regulatory*, (%w.c;), note*, (list1
                         | list2 | list3 | list4 | list5
                         | table* | tabdat*)) | %deleted;))
                         +(effect) >
<!ATTLIST subtask
          chapnbr   NUMBER                        #REQUIRED
          sectnbr   NUMBER                        #REQUIRED
          subjnbr   NUMBER                        #REQUIRED
          pgblknbr  NUMBER                        #REQUIRED
          func      CDATA                         " "
          seq       CDATA                         #REQUIRED
          confltr   CDATA                         " "
          varnbr    CDATA                         "0"
          alunqi    CDATA                         " "
          %revatt;                                             >
<!--                                                         -->
<!-- ======================================================= -->
<!--             PROCEDURE LIST STRUCTURE      (NON-TASKED)  -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT prclist1  - -  (prcitem1+)              +(effect)    >
<!ELEMENT prclist2  - -  (prcitem2+)                           >
<!ELEMENT prclist3  - -  (prcitem3+)                           >
<!ELEMENT prclist4  - -  (prcitem4+)                           >
<!ELEMENT prclist5  - -  (prcitem5+)                           >
<!ELEMENT prclist6  - -  (prcitem6+)                           >
<!ELEMENT prclist7  - -  (prcitem7+)                           >
<!--                                                         -->
<!ELEMENT prcitem1  - -  (prcitem, prclist2?)                  >
<!ATTLIST prcitem1
          id       ID                             #IMPLIED
          alt      %yesorno;                      #IMPLIED     >
<!ELEMENT prcitem2  - -  (prcitem, prclist3?)                  >
<!ATTLIST prcitem2
          id       ID                             #IMPLIED
          alt      %yesorno;                      #IMPLIED     >
<!ELEMENT prcitem3  - -  (prcitem, prclist4?)                  >
<!ATTLIST prcitem3
          id       ID                             #IMPLIED
          alt      %yesorno;                      #IMPLIED     >
<!ELEMENT prcitem4  - -  (prcitem, prclist5?)                  >
<!ATTLIST prcitem4
          id       ID                             #IMPLIED
          alt      %yesorno;                      #IMPLIED     >
<!ELEMENT prcitem5  - -  (prcitem, prclist6?)                  >
<!ATTLIST prcitem5
          id       ID                             #IMPLIED
          alt      %yesorno;                      #IMPLIED     >
<!ELEMENT prcitem6  - -  (prcitem, prclist7?)                  >
<!ATTLIST prcitem6
          id       ID                             #IMPLIED
          alt      %yesorno;                      #IMPLIED     >
<!ELEMENT prcitem7  - -  (prcitem)                             >
<!ATTLIST prcitem7
          id       ID                             #IMPLIED
          alt      %yesorno;                      #IMPLIED     >

<!ELEMENT prcitem   - -  (title?, regulatory*, (%w.c;)?,
                         (%text;), graphic*)                   >
<!--                                                         -->
<!-- ======================================================= -->
<!--                STANDARD LISTS                           -->
<!-- ======================================================= -->
<!-- The "cont" attribute existed in version 2.2, but this   -->
<!-- comment is added for explanation.  The "cont" attribute -->
<!-- was added to lists (listN) and list items (LNitem) to   -->
<!-- control step numbers, so that step numbers could        -->
<!-- continue across subtasks, instead of starting with "1"  -->
<!-- each time a subtask occurred in a list.  The numbering  -->
<!-- continues from the previous list or list item if the    -->
<!-- value of "cont" is "1".  The numbering restarts at the  -->
<!-- appropriate initial value ("1" or "A"), if the value of -->
<!-- "cont" is "0".                                          -->
<!-- ======================================================= -->
<!-- Added attribute "alt" to enable two numbering schemes   -->
<!-- to be used as visual cues to alternative elements below -->
<!-- the task or subtask level.  Example: steps 1, 2, 3 and  -->
<!-- steps 1A, 2A, 3A.                                       -->
<!-- ======================================================= -->
<!--                                                         -->
<!ELEMENT list1     - -  (l1item+)                             >
<!ATTLIST list1
          cont      %yesorno;                     "0"          >
<!ELEMENT list2     - -  (l2item+)                             >
<!ATTLIST list2
          cont      %yesorno;                     "0"          >
<!ELEMENT list3     - -  (l3item+)                             >
<!ATTLIST list3
          cont      %yesorno;                     "0"          >
<!ELEMENT list4     - -  (l4item+)                             >
<!ATTLIST list4
          cont      %yesorno;                     "0"          >
<!ELEMENT list5     - -  (l5item+)                             >
<!ATTLIST list5
          cont      %yesorno;                     "0"          >
<!ELEMENT list6     - -  (l6item+)                             >
<!ATTLIST list6
          cont      %yesorno;                     "0"          >
<!ELEMENT list7     - -  (l7item+)                             >
<!ATTLIST list7
          cont      %yesorno;                     "0"          >

<!ELEMENT l1item    - - (((%w.c;), regulatory*, (%text;
                        | entry*)), (list2, note*)?)           >
<!ATTLIST l1item
          id        ID                             #IMPLIED
          cont      %yesorno;                      "0"
          alt       %yesorno;                      #IMPLIED    >
<!ELEMENT l2item    - - (((%w.c;), regulatory*, (%text;
                        | entry*)), (list3, note*)?)           >
<!ATTLIST l2item
          id        ID                             #IMPLIED
          cont      %yesorno;                      "0"
          alt       %yesorno;                      #IMPLIED    >
<!ELEMENT l3item    - - (((%w.c;), regulatory*, (%text;
                        | entry*)),(list4, note*)?)            >
<!ATTLIST l3item
          id        ID                             #IMPLIED
          cont      %yesorno;                      "0"
          alt       %yesorno;                      #IMPLIED    >
<!ELEMENT l4item    - - (((%w.c;), regulatory*, (%text;
