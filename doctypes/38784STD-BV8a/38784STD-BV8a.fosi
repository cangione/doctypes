<e-i-c gi="tmidno" context="idinfo" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<suppress sup="1"></charlist>

<att logic="and">
<specval attname="docstat.str" attloc="#FOSI" attval="#EQ#\prelim\">
<charsubset>
	<savetext textid="tmidnostr" conrule="<tmidno.ps>,\P\,#CONTENT,</tmidno.ps>" append="1">
	<savetext textid="vstattonum.st" conrule="\P\,#CONTENT"></charsubset>
</att>

<att logic="and">
<specval attname="service" attloc="doc" attval="#NE#\af\">
<specval attname="docstat.str" attloc="#FOSI" attval="#EQ#\draft\">
<charsubset>
	<savetext textid="tmidnostr" conrule="<tmidno.ps>,\DRAFT \,#CONTENT,</tmidno.ps>" append="1">
	<savetext textid="vstattonum.st" conrule="\DRAFT \,#CONTENT"></charsubset>
</att>

<att logic="and">
<specval attname="service" attloc="doc" attval="#EQ#\af\">
<specval attname="docstat.str" attloc="#FOSI" attval="#EQ#\draft\">
<charsubset>
	<savetext textid="tmidnostr" conrule="<tmidno.ps>,\P\,#CONTENT,</tmidno.ps>" append="1">
	<savetext textid="vstattonum.st" conrule="\P \,#CONTENT"></charsubset>
</att>

<att logic="and">
<specval attname="docstat.str" attloc="#FOSI" attval="#NE#\prelim\">
<specval attname="docstat.str" attloc="#FOSI" attval="#NE#\draft\">
<charsubset>
	<savetext textid="tmidnostr" conrule="<tmidno.ps>,#CONTENT,</tmidno.ps>" append="1">
	<savetext textid="vstattonum.st" conrule="#CONTENT"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

