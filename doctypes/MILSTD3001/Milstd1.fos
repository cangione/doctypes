<!--INTRODUCTION TITLED PARAGRAPHS-->
<e-i-c gi="intro"><?Pub Dtl>&ca.list.number.set;&change.marks.att;
</e-i-c>
<e-i-c gi="intro" context="schemwp"><?Pub Dtl>&ca.list.number.set;
<att><?Pub Dtl>
<specval attname="label" attval="schematicdiagrams">
<charsubset>
<usetext source="\Figure Title\,33pi,\Figure Number\" placemnt="after">
<subchars>
<font inherit="1" size="9pt" weight="bold">
<leading lead="11pt">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<ruling thick="1pt" lentype="spec" speclen="42pi" placemnt="after">
<leading lead="1pt">
<presp minimum="4pt" nominal="4pt" maximum="4pt" condit="keep"
priority="high">
<textbrk startln="1" endln="1"></ruling>
<usetext source="schematicdiagrams.app" placemnt="after" userule="2"
useparam="maxunmerge=0"></usetext>
</charsubset>
</att>&change.marks.att;</e-i-c>
<e-i-c gi="intro" context="wdiawp"><?Pub Dtl>
<charlist charsubsetref="division calisttop">
<reset resetlist="paract step1ct">
<enumerat increm="1" enumid="taskct">
<enumerat increm="1" enumid="paract">
<savetext textid="taskparanum" conrule="taskct,\-\,paract">
<savetext textid="number" conrule="taskparanum,\. \"></charlist>
<att>
<testgroup logic="or">
<specval attname="label" attval="wiringdiagrams">
<specval attname="label" attval="WIRINGDIAGRAMS"></testgroup>
<charsubset><?Pub Dtl>
<usetext source="\Figure Title\,33pi,\Figure Number\" placemnt="after">
<subchars>
<font inherit="1" size="9pt" weight="bold">
<leading lead="11pt">
<textbrk startln="1" endln="1"></subchars>
</usetext>
<ruling thick="1pt" lentype="spec" speclen="42pi" placemnt="after">
<leading lead="1pt">
<presp minimum="4pt" nominal="4pt" maximum="4pt" condit="keep"
priority="high">
<textbrk startln="1" endln="1"></ruling>
<usetext source="wiringdiagrams.app" placemnt="after" userule="2"
useparam="maxunmerge=0"></usetext>
</charsubset>
</att>
<att>
<testgroup sense="false" logic="or">
<specval attname="label" attval="wiringdiagrams">
<specval attname="label" attval="WIRINGDIAGRAMS"></testgroup>
<fillval attname="label" fillcat="savetext" fillchar="conrule">
<charsubset><?Pub Dtl>
<savetext textid="taskparanum"></charsubset>
</att>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="taskparanum"></charsubset>
</att>&change.marks.att;</e-i-c>
