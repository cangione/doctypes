<e-i-c gi="table" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="clearstrings">
	<quadding quad="center">
	<presp nominal="12pt" condit="discard">
	<postsp minimum="6pt" nominal="12pt" maximum="12pt" condit="discard">
	<textbrk startln="1" endln="1">
	<savetext textid="t0pgnum" conrule="pgnumber[BO]" placemnt="before">
	<savetext textid="dlctcont" conrule="">
	<savetext textid="applicref.str" conrule=""></charlist>

<att logic="and">
<fillval attname="fontsize" fillcat="font" fillchar="size">
<charsubset>
	<font></charsubset>
</att>

<att logic="and">
<specval attname="pgwide" attval="#EQ#1">
<specval attname="status" attval="#NONE">
<specval attname="orient" attval="port">
<charsubset>
	<tabatts widthtype="relative" consep="0">	</tabatts>
</charsubset>
</att>

<att logic="and">
<specval attname="pgwide" attval="#EQ#0">
<specval attname="status" attval="#NONE">
<specval attname="orient" attval="port">
<charsubset>
	<tabatts widthtype="colrelative" relwidth="100" consep="0">	</tabatts>
</charsubset>
</att>

<att logic="and">
<specval attname="orient" attval="land1">
<charsubset>
	<textbrk startpg="next" pageid="bodypgland" newpgmdl="local">
	<tabatts widthtype="relative" relwidth="98" consep="0">	</tabatts>
</charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<specval attname="continued" attval="0">
<charsubset>
	<savetext textid="xreftype" conrule="\Table\">
	<savetext textid="xrefstr" conrule="#CONTENT(label)">
	<savetext textid="labelstr" conrule="#CONTENT(label)"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<specval attname="inbody.st" attloc="#FOSI" attval="#EQ#\no\">
<specval attname="continued" attval="0">
<charsubset>
	<enumerat increm="1" enumid="tabct">
	<savetext textid="labelstr" conrule="tabct">
	<savetext textid="xreftype" conrule="\Table\">
	<savetext textid="xrefstr" conrule="tabct">
	<savetext textid="label" conrule="labelstr" saverule="1"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
