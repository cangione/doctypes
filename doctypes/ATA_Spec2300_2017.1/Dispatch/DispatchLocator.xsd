	  <xs:include schemaLocation="../common/basicDataTypes/figure.xsd"/>
	  <xs:redefine schemaLocation="../common/dataManagement/dmodule.xsd">
		    <xs:complexType name="contentElemType">
			      <xs:complexContent>
				        <xs:extension base="contentElemType">
					          <xs:sequence>
						            <xs:element ref="dispatchLocator"/>
					          </xs:sequence>
				        </xs:extension>
			      </xs:complexContent>
		    </xs:complexType>
	  </xs:redefine>
	  <xs:include schemaLocation="../common/basicDataTypes/extensibleInterface.xsd"/>
	  <!--=============================================-->
	<!-- dmodule Element Declaration-->
	<!--=============================================-->
	<xs:element name="dmodule" type="dmoduleElemType"/>
	  <!--=============================================-->
	<!-- dispatchLocator Element Declaration (DM  root) -->
	<!--=============================================-->
	<xs:element name="dispatchLocator" type="dispatchLocatorType">
		    <xs:annotation>
			      <xs:documentation>Generally, system diagrams to describe the locations in which dispatch/CDL items are located for references and navigation purposes</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <!--=============================================-->
	<!-- dispatchLocator Type Definition -->
	<!--=============================================-->
	<xs:complexType name="dispatchLocatorType">
		    <xs:sequence>
			      <xs:element name="title" type="nameType">
				        <xs:annotation>
					          <xs:documentation/>
				        </xs:annotation>
			      </xs:element>
			      <xs:element ref="figure">
				        <xs:annotation>
					          <xs:documentation>Interactive graphic including links to location where Dispatch/CDL items are described.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
		    <xs:attribute name="layer" type="layerType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Layer of information</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
</xs:schema>