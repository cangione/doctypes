<e-i-c gi="volcontents" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<leading lead="12pt">
	<indent inherit="0">
	<textbrk startpg="recto" pageid="tocpg" newpgmdl="global">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<savetext textid="foliostr" conrule="">
	<savetext textid="volfoliostr" conrule="">
	<usetext source="voltocmatter" placemnt="after">
	<subchars>
	<span span="2">	</subchars>
	</usetext>

	<usetext source="bookmarks" userule="-3">
	<subchars>	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="resetpg" attloc="#FOSI" attval="#EQ#\no\">
<charsubset>
	<reset resetlist="pageenum">
	<enumerat increm="0" enumid="pageenum" setvalue="1">
	<savetext textid="resetpg" conrule="\yes\"></charsubset>
</att>
</e-i-c>

<e-i-c gi="VOLILLUSLIST" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<textbrk startpg="next" pageid="frontpg" newpgmdl="global" startln="1" endln="1">
	<span span="2">
	<savetext textid="voltocmatter" conrule="<toclinea>,1.5em,\LIST OF ILLUSTRATIONS\,tocfill,<tocnumchap>,pgnumber,</tocnumchap>,</toclinea>" append="1">
	<savetext textid="voltocmatter" conrule="<TOCLINECHAPPRE></TOCLINECHAPPRE>" append="1">
	<savetext textid="tocmatter" conrule="<toclinea>,1.5em,\LIST OF ILLUSTRATIONS\,tocfill,<tocnumchap>,pgnumber,</tocnumchap>,</toclinea>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<usetext source="\LIST OF ILLUSTRATIONS\" placemnt="before">
	<subchars charsubsetref="allcap14.csub">	</subchars>
	</usetext>

	<usetext source="\Number\,spfill,\Title\,spfill,\Page\,2pi,                           \Number\,spfill,\Title\,spfill,\Page\" placemnt="before">
	<subchars>
	<font style="serif">
	<quadding quad="justify">
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="autobuild" attval="#EQ#\1\">
<charsubset>
	<usetext source="vollofmatter">	</usetext>

	<usetext source="bookmarks" userule="-3">
	<subchars>	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="autobuild" attval="#NONE">
<charsubset>
	<usetext source="xvollofmatter">	</usetext>

	<usetext source="bookmarks" userule="-3">
	<subchars>	</subchars>
	</usetext>
</charsubset>
</att>
</e-i-c>

<e-i-c gi="VOLTABLELIST" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<span span="2">
	<savetext textid="voltocmatter" conrule="<toclinea>,1.5em,\LIST OF TABLES\,                          tocfill,<tocnumchap>,pgnumber,</tocnumchap>,</toclinea>" append="1">
	<savetext textid="voltocmatter" conrule="<TOCLINECHAPPRE></TOCLINECHAPPRE>" append="1">
	<savetext textid="tocmatter" conrule="<toclinea>,1.5em,\LIST OF TABLES\,                          tocfill,<tocnumchap>,pgnumber,</tocnumchap>,</toclinea>" append="1">
	<savetext textid="tocmatter" conrule="<toclinechappre>,</toclinechappre>" append="1">
	<usetext source="\LIST OF TABLES\" placemnt="before">
	<subchars charsubsetref="allcap14.csub">	</subchars>
	</usetext>

	<usetext source="\Number\,spfill,\Title\,spfill,\Page\,2pi,                        \Number\,spfill,\Title\,spfill,\Page\ " placemnt="before">
	<subchars>
	<font style="serif">
	<quadding quad="justify">
	<presp nominal="12pt">
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>
</charlist>

<att logic="and">
<specval attname="autobuild" attval="#EQ#\1\">
<charsubset>
	<usetext source="vollotmatter">	</usetext>

	<usetext source="bookmarks" userule="-3">
	<subchars>	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="autobuild" attval="#NONE">
<charsubset>
	<usetext source="xvollotmatter">	</usetext>

	<usetext source="bookmarks" userule="-3">
	<subchars>	</subchars>
	</usetext>
</charsubset>
</att>
</e-i-c>

