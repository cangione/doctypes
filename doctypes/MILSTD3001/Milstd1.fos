<!--CONTROL AND INDICATOR GRAPHIC and TABLE-->
<e-i-c gi="ctrlind"><?Pub Dtl>
<charlist>
<presp minimum="1pi" nominal="1.3pi" maximum="1.6pi" condit="keep"
priority="high">
<postsp minimum="8pt" nominal="1pi" maximum="1.4pi" condit="keep"
priority="low">
<textbrk startln="1" endln="1"></charlist>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset>
<savetext conrule="\Table \,tablenum" placemnt="after"></charsubset>
</att>
</e-i-c>
<e-i-c gi="ctrlindtab"><?Pub Dtl>
<charlist charsubsetref="paragraph space">
<usetext
source='!<table rowsep="0"><tgroup cols="3"><colspec colname="col1" align="center" colwidth="6pi"/><colspec colname="col2"
align="left" colwidth="15pi"/><colspec colname="col3" align="left"/><spanspec
spanname="span1to3" namest="col1" nameend="col3"/><thead><row rowsep="1"><entry><bold>ITEM</bold></entry><entry
align="center"><bold>CONTROL/INDICATOR</bold></entry><entry align="center"><bold>FUNCTION</bold></entry></row></thead><tbody>!,table.app,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
<reset resetlist="table.app"></charlist>&table.number.set;
&change.marks.att;</e-i-c>
<e-i-c gi="title" context="ctrlindtab"><?Pub Dtl>
<charlist charsubsetref="table.title">
<postsp minimum=".5em" nominal=".5em" maximum=".5em" priority="none">
</charlist>
<att>
<specval attname="screen-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="\ITEM\,@4pi,\CONTROL/INDICATORS\,@20pi,\FUNCTION\"
placemnt="after">
<subchars>
<font weight="bold">
<quadding quad="left">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="tablenumtxt, #CONTENT,\ (Cont)\">
<subchars charsubsetref="table.title.cont">
<float scope="ctrlindtab"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="ctrlindentry" context="ctrlindtab"><?Pub Dtl>
<charlist inherit="1" charsubsetref="paragraph space">
<indent inherit="0" leftind="@+4pi" rightind="@" firstln="*">
<savetext textid="table.app"
conrule='!<row>!,!<entry colname="col1">!,col1.app,!</entry>!,!<entry colname="col2">!,col2.app,!</entry>!,!<entry colname="col3">!,col3.app,!</entry>!,!</row>!'
placemnt="after" append="1">
<reset resetlist="row.app col1.app col2.app col3.app"></charlist>
<att>
<specval attname="screen-only" attloc="system-var" attval="#ANY">
<charsubset>
<indent leftind="0pt" rightind="0pt" firstln="*">
<textbrk startln="1" endln="1"></charsubset>
</att>
</e-i-c>
<e-i-c gi="indexno" context="* ctrlindentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col1.app" conrule="#CONTENT" append="1"></charlist>
<att>
<specval attname="screen-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="@4pi" placemnt="after"></usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="nomen" context="* ctrlindentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col2.app" conrule="#CONTENT" append="1"></charlist>
<att>
<specval attname="screen-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="@20pi" placemnt="after"></usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="function" context="* ctrlindentry"><?Pub Dtl>
<charlist inherit="1">
<suppress sup="1">
<savetext textid="col3.app" conrule="#CONTENT" append="1"></charlist>
</e-i-c>
<e-i-c gi="noteslist" context="ctrlindtab"><?Pub Dtl>
<charlist inherit="1">
<reset resetlist="row.app outline.lev1.ct notestxt"></charlist>
<att>
<specval attname="screen-only" attloc="system-var" attval="#ANY">
<charsubset>
<usetext source="\NOTES\">
<subchars>
<font weight="bold">
<quadding quad="center">
<presp nominal="10pt" condit="keep" priority="force">
<postsp nominal="10pt" condit="keep" priority="force">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="notesentry" context="noteslist * ctrlindtab" occur="first"><?Pub Dtl>
<charlist>
<suppress sup="1">
<enumerat increm="1" enumid="outline.lev1.ct">
<savetext textid="tableftnotenum" conrule="outline.lev1.ct">
<savetext textid="notestxt"
conrule="<pnote>,\NOTES\,</pnote>,<ppara>,outline.lev1.ct,\. \,#CONTENT,</ppara>">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3" align="left">!,notestxt,!</entry>!'>
<savetext textid="table.app"
conrule='!<row rowsep="0">!,row.app,!</row>!' placemnt="after"
append="1"></charlist>
<att>
<specval attname="screen-only" attloc="system-var" attval="#ANY">
<charsubset>
<textbrk startln="1" endln="1">
<usetext source="outline.lev1.ct,\. \"></usetext>
</charsubset>
</att>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tableftnotenum"></charsubset>
</att>
</e-i-c>
<e-i-c gi="notesentry" context="noteslist * ctrlindtab" occur="notfirst"><?Pub Dtl>
<charlist>
<suppress sup="1">
<enumerat increm="1" enumid="outline.lev1.ct">
<savetext textid="tableftnotenum" conrule="outline.lev1.ct">
<savetext textid="notestxt"
conrule="<ppara>,outline.lev1.ct,\. \,#CONTENT,</ppara>">
<savetext textid="row.app"
conrule='!<entry spanname="span1to3" align="left">!,notestxt,!</entry>!'>
<savetext textid="table.app"
conrule='!<row rowsep="0">!,row.app,!</row>!' placemnt="after"
append="1"></charlist>
<att>
<specval attname="screen-only" attloc="system-var" attval="#ANY">
<charsubset>
<textbrk startln="1" endln="1">
<usetext source="outline.lev1.ct,\. \"></usetext>
</charsubset>
</att>
<att>
<fillval attname="id" fillcat="savetext" fillchar="textid">
<charsubset><?Pub Dtl>
<savetext conrule="tableftnotenum"></charsubset>
</att>
