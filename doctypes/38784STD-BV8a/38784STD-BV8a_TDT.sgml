	<ele>
		<tag>illuslist</tag>
		<long>List of Illustrations</long>
		<desc>Identifies the list of illustrations in the manual. This information is automatically compiled by the FOSI. If this element is not used, no list of illustrations will appear in the manual.</desc>
		<source>4.5.7</source>
		<contmdl>(illlistrow | (figno, title, pageno))* -(note)</contmdl>
		<usedin>front and auxfront</usedin>
		<specatts>
			<attrtbl>
				<attr>autobuild</attr>
				<type>CDATA</type>
				<default>#CONREF</default>
				<attrdesc>This attribute should be set equal to 1 when the list of illustrations is autogenerated.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
		<tag>index</tag>
		<long>Index</long>
		<desc>Identifies the index.</desc>
		<source>4.2.9.8</source>
		<contmdl>(indexrow | (letter?, (prentry, secentry*)))+ -(note)</contmdl>
		<usedin>rear</usedin>
		<ents>secur and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>autobuild</attr>
				<type>CDATA</type>
				<default>#CONREF</default>
				<attrdesc>This attribute should be set equal to 1 when the index is autogenerated.</attrdesc>

				<attr>type</attr>
				<type>(parano | pageno | both)</type>
				<default>parano</default>
				<attrdesc>Allows the author to determine whether page numbers, or paragraph numbers, or both page and paragraph numbers, figure, or table numbers are used.</attrdesc>

				<attr>id</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Allows the author to generate a unique ID for use when referencing this entry.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place for inline FMS portion marking.</attrdesc>

				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the element was inserted at the change level indicated.</attrdesc>

				<attr>delchlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during change package process to indicate the element was deleted at the change level indicated</attrdesc>

				<attr>status</attr>
				<type>(empty | deleted | reserved | notapp)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used during the change package process to indicate the current status of the element.</attrdesc>

				<attr>revchg</attr>
				<type>NUMBER</type>
				<default>0</default>
				<attrdesc>Toggle between a revision or a change.  Attribute is set to "1" to indicate a revision.</attrdesc>
			</attrtbl>
		</specatts>
	</ele>
	<ele>
