<e-i-c gi="ratd" occur="all"><?Pub Lcl _id="f1055"><?Pub Dtl>
<charlist inherit="0">
<postsp minimum="12pt" nominal="12pt" maximum="12pt" condit="discard"
priority="high">
<textbrk startln="1" endln="1">
<span span="1">
<savetext textid="xrefstr"
conrule="\Record of Applicable Technical Directives\"></charlist>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<postsp minimum="12pt" nominal="24pt" maximum="24pt" priority="force">
<textbrk endln="1">
<usetext
source='!<tabmat frame="none">
<title>!,\Record of Applicable Technical Directives.\,!</title>
<tgroup cols="5">
<colspec colname="col1" colwidth="0.75*">
<colspec colname="col2" colwidth="1.125*">
<colspec colname="col3" colwidth="2.5*">
<colspec colname="col4" colwidth="1.125*">
<colspec colname="col5" colwidth="1.375*">
<thead>
<row rowsep="0">
<entry colsep="0" align="center">!,\Type&sol;No.\,!</entry>
<entry rowsep="0" colsep="0" align="center">!,\Date\,!</entry>
<entry rowsep="0" colsep="0" align="center">!,\Title and ECP No.\,!</entry>
<entry rowsep="0" colsep="0" align="center">!,\Date Inc.\,!</entry>
<entry rowsep="0" colsep="0" align="center">!,\Remarks\,!</entry>
</row>
</thead>
<tbody>!,ratdtbl-body.txt,!</tbody>
</tgroup>
</tabmat>!' placemnt="after">
<subchars>
<span span="1"></subchars>
</usetext>
<savetext textid="ratdtbl-body.txt" placemnt="after"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<usetext source="\Record of Applicable Technical Directives - DELETED.\">
<subchars>
<font weight="bold">
<leading lead="12pt">
<quadding inherit="0" quad="center" lastquad="lcenter">
<presp minimum="12pt" nominal="12pt" maximum="12pt">
<postsp minimum="10pt" nominal="10pt" maximum="10pt" condit="keep"
priority="force">
<keeps scope="col" orphanct="2" next="1">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>&deleted-children;&security-mark;&mark.changed;</e-i-c>
<e-i-c gi="ratdentry"><?Pub Lcl _id="f1056"><?Pub Dtl>
<charlist></charlist>
<att>
<specval attname="editor-only" attloc="system-var" attval="#ANY">
<charsubset>
<textbrk startln="1" endln="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="ratdtbl-body.txt"
conrule='!<row rowsep="0">
