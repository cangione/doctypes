<e-i-c gi="subpara7" context="* docwc"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1" charsubsetref="para clearstrings">
<reset resetlist="step1.ctr">
<reset resetlist="subp8.ctr">
<enumerat increm="1" enumid="subp7.ctr">
<savetext textid="label.txt"
conrule="sect.ctr,\.\,para0.ctr,\.\,subp1.ctr,\.\,subp2.ctr,\.\,subp3.ctr,\.\,subp4.ctr,\.\,subp5.ctr,\.\,subp6.ctr,\.\,subp7.ctr">
<savetext textid="title-appear" conrule="\no\"></charlist>
&att-set-label;&att-stringdecl-reset;&att-save-symbols;&security-mark;
&set-deltypstr;&sssn-proc;
<att>
<specval attname="editor-only" attloc="system-var" attval="#ANY">
<charsubset>
<textbrk startln="1" endln="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<usetext source="label.txt,0.5em,deltypestr" placemnt="before">
<subchars>
<leading lead="10pt">
<indent leftind="3.25pi" rightind="2pi" firstln="2pi">
<presp nominal="8pt" priority="force">
<textbrk startln="1" endln="1"></subchars>
</usetext>
</charsubset>
</att>
