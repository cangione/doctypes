conrule="<ipbnumgrprow>,<partno>,contentcbar.txt,</partno>,<ipbfigindex>,contentcbar.txt,</ipbfigindex>,</ipbnumgrprow>"
placemnt="after" append="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attloc="ipbplgrp" attval="#ANY">
<specval attname="name" attval="ipbdesc">
<charsubset>
<savetext textid="refdes.txt"
