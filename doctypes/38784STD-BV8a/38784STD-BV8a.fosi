<specval attname="cols" attloc="ipbrfdsindx" attval="#EQ#3">
<charsubset>
	<tabatts widthtype="specific" specwidth="7in" frame="all">
	<stdcellatts colsep="1" rowsep="0" leftmar="5pt" rightmar="2pt" topmar="2pt" celconflict="append">	</tabatts>

	<tgroupatts cols="7">	</tgroupatts>

	<colatts colname="col.rfd1" colwidth="1.25in">	</colatts>

	<colatts colname="col.rfd2" colwidth="1in">	</colatts>

	<colatts colname="col.rfd3" colwidth="1in">	</colatts>

	<colatts colname="mid.rfd" colwidth="0.5in">	</colatts>

	<colatts colname="col.rfd4" colwidth="1.25in">	</colatts>

	<colatts colname="col.rfd5" colwidth="1in">	</colatts>

	<colatts colname="col.rfd6" colwidth="1in">	</colatts>

	<usetext source="<header.ps>,<refhd>,\REFERENCE\, </refhd>,        <sssnhd>,\S/S/SN\, </sssnhd>, <fighd>,\FIGURE &\, </fighd>,        <mid.rfd>, <ref2.ps>,\REFERENCE\, </ref2.ps>,        <sssn2.ps>,\S/S/SN\, </sssn2.ps>, <fig2.ps>,\FIGURE &\, </fig2.ps>,        <refhd>,\DESIGNATION\, </refhd>, <sssnhd>,\\, </sssnhd>,                 <fighd>,\INDEX NO.\, </fighd>,<mid.rfd>,                  <ref2.ps>,\DESIGNATION\, </ref2.ps>, <sssn2.ps>,\\, </sssn2.ps>,                  <fig2.ps>,\INDEX NO.\, </fig2.ps>, </header.ps>,<body.ps>">	</usetext>
