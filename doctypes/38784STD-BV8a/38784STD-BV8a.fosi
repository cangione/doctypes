</charsubset>
</att>

<att logic="and">
<specval attname="type" attloc="ipbrfdsindx" attval="#EQ#\sssn\">
<specval attname="cols" attloc="ipbrfdsindx" attval="#EQ#3">
<charsubset>
	<span span="3">
	<tabatts widthtype="colrelative" relwidth="33" frame="all">
	<stdcellatts colsep="1" rowsep="0" colsepon="1" leftmar="5pt" rightmar="2pt" topmar="2pt">	</tabatts>

	<tgroupatts cols="2">	</tgroupatts>

	<colatts colname="col1" colwidth="1*">	</colatts>

