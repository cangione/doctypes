</att>
<att>
<specval attname="security" attloc="manual" attval="u">
<specval attname="numberoftmidnos" attloc="manual" attval="3">
<charsubset><?Pub Dtl>
<textbrk startpg="next" pageid="niewppgset3"></charsubset>
</att>
<att>
<specval attname="security" attloc="manual" attval="#NE#\u\">
