          numtype   (NNP | AUP | NNB | ALB | NNS | ALS
                    | DBR | RUP | RLP | RUR | RLR | NNR
                    | AUR | ALR)                      "NNP"           >
<!--                                                                -->
<!ELEMENT numlitem  - -  (para+)                                      >
<!ATTLIST numlitem
          label     CDATA                             #IMPLIED        >
<!--                                                                -->
<!-- ============================================================== -->
<!--                        PARAGRAPH                               -->
<!-- ============================================================== -->
<!ELEMENT para      - -  (#PCDATA  | txtgrphc | grphcref | refint
                         | refext | pnr | sub | super | refmedia
                         | grsymbol)+                                 >
<!--                                                                -->
<!ELEMENT txtgrphc  - -  (txtline+)                                   >
<!ELEMENT txtline   - -  (#PCDATA)                                    >
<!ELEMENT sub       - -  (#PCDATA)                                    >
<!ELEMENT super     - -  (#PCDATA)                                    >
<!--                                                                -->
<!-- ============================================================== -->
<!--                  STANDARD LISTS                                -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT list1     - - (l1item+)                                     >
<!ELEMENT list2     - - (l2item+)                                     >
<!ELEMENT list3     - - (l3item+)                                     >
<!ELEMENT list4     - - (l4item+)                                     >
<!ELEMENT list5     - - (l5item+)                                     >
<!ELEMENT list6     - - (l6item+)                                     >
<!ELEMENT list7     - - (l7item+)                                     >
<!--                                                                -->
<!ELEMENT l1item    - - ((%w.c;), (%text;), (list2, note*)?)          >
<!ATTLIST l1item
          id        ID                             #IMPLIED           >
<!ELEMENT l2item    - - ((%w.c;), (%text;), (list3, note*)?)          >
<!ATTLIST l2item
          id        ID                             #IMPLIED           >
<!ELEMENT l3item    - - ((%w.c;), (%text;), (list4, note*)?)          >
<!ATTLIST l3item
          id        ID                             #IMPLIED           >
<!ELEMENT l4item    - - ((%w.c;), (%text;), (list5, note*)?)          >
<!ATTLIST l4item
          id        ID                             #IMPLIED           >
<!ELEMENT l5item    - - ((%w.c;), (%text;), (list6, note*)?)          >
<!ATTLIST l5item
          id        ID                             #IMPLIED           >
<!ELEMENT l6item    - - ((%w.c;), (%text;), (list7, note*)?)          >
<!ATTLIST l6item
          id        ID                             #IMPLIED           >
<!ELEMENT l7item    - - ((%w.c;), (%text;))                           >
<!ATTLIST l7item
          id        ID                             #IMPLIED           >
<!--                                                                -->
<!-- ============================================================== -->
<!--                  HOT LINK                                      -->
<!--  Retrieval engine's cross reference mechanism                  -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT hotlink   - O EMPTY                                         >
<!--                                                                -->
<!ATTLIST hotlink
          targetid      CDATA                         #IMPLIED
          targetrefid   CDATA                         #IMPLIED        >
<!-- ============================================================== -->
<!--                     TITLE                                      -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT title     - -  (#PCDATA | sub | super)+                     >
<!--                                                                -->
<!-- ============================================================== -->
<!--                  MARK REVISED ELEMENTS                         -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT revst     - O   EMPTY                                       >
<!ELEMENT revend    - O   EMPTY                                       >
<!ELEMENT cocst     - O   EMPTY                                       >
<!ELEMENT cocend    - O   EMPTY                                       >
<!--                                                                -->
<!-- ============================================================== -->
<!--                MARK DELETED OR ISEMPTY ELEMENTS                -->
<!--  Element for marking a deleted anchor                          -->
<!--  Element for showing an empty element                          -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT deleted   - O   EMPTY                                       >
<!ELEMENT isempty   - O   EMPTY                                       >
<!--                                                                -->
<!-- ============================================================== -->
<!--                     EFFECTIVITY                                -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT effect    - -  ((sbeff | coceff)*)                          >
<!ATTLIST effect
          effrg     CDATA                             #IMPLIED
          efftext   CDATA                             #IMPLIED        >
<!--                                                                -->
<!ELEMENT sbeff     - O   EMPTY                                       >
<!ATTLIST sbeff
          effrg     CDATA                             #IMPLIED
          efftext   CDATA                             #IMPLIED
          sbnbr     CDATA                             #REQUIRED
          sbtype    CDATA                             #REQUIRED
          sbcond    CDATA                             #IMPLIED
          sbrev     CDATA                             #IMPLIED        >
<!--                                                                -->
<!ELEMENT coceff    - O   EMPTY                                       >
<!ATTLIST coceff
          effrg     CDATA                             #IMPLIED
          efftext   CDATA                             #IMPLIED
          cocnbr    CDATA                             #REQUIRED
          coccond   CDATA                             #IMPLIED
          cocrev    CDATA                             #IMPLIED        >

<!-- ============================================================== -->
<!--                 TABLE (CELLULAR, CALS BASED)                   -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT table     - -   ((title?, tgroup, ftnote*) | graphic+)
                                                      -(table)        >
<!ATTLIST table
          tabstyle  NMTOKEN                           #IMPLIED
          frame     (top | bottom | topbot
                    | all | sides | none)             #IMPLIED
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED
          orient    (port | land)                     #IMPLIED
          pgwide    %yesorno;                         #IMPLIED
          id        ID                                #IMPLIED        >

<!ELEMENT tgroup    - O  (colspec*, spanspec*, thead?, tfoot?, tbody) >
<!ATTLIST tgroup
          cols      NUMBER                            #REQUIRED
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED
          align     (left | right | center
                    | justify | char)                 "left"
          charoff   NUTOKEN                           "50"
          char      CDATA                             ""              >

<!ELEMENT colspec   - O   EMPTY                                       >
<!ATTLIST colspec
          colnum    NUMBER                            #IMPLIED
          colname   NMTOKEN                           #IMPLIED
          align     (left | right | center
                    | justify | char)                 #IMPLIED
          charoff   NUTOKEN                           #IMPLIED
          char      CDATA                             #IMPLIED
          colwidth  CDATA                             #IMPLIED
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED        >

<!ELEMENT spanspec  - O   EMPTY                                       >
<!ATTLIST spanspec
          namest    NMTOKEN                           #REQUIRED
          nameend   NMTOKEN                           #REQUIRED
          spanname  NMTOKEN                           #IMPLIED
          align     (left | right | center
                    | justify | char)                 "center"
          charoff   NUTOKEN                           #IMPLIED
          char      CDATA                             #IMPLIED
          rowsep    %yesorno;                         #IMPLIED
          colsep    %yesorno;                         #IMPLIED        >

<!ELEMENT thead     - O  (colspec*, row+)                             >
<!ATTLIST thead
          valign    (top | middle | bottom)           "bottom"        >

<!ELEMENT tfoot     - O  (colspec*, row+)                             >
<!ATTLIST tfoot
          valign    (top | middle | bottom)           "top"           >

<!ELEMENT tbody     - O  (row+)                                       >
<!ATTLIST tbody
          valign    (top | middle | bottom)           "top"           >

<!ELEMENT row       - O  (entry+)                                     >
<!ATTLIST row
          rowsep    %yesorno;                         #IMPLIED        >

<!ELEMENT entry     - O  (%text; | %w.c;)*                            >
<!ATTLIST entry
          colname   NMTOKEN                           #IMPLIED
          namest    NMTOKEN                           #IMPLIED
          nameend   NMTOKEN                           #IMPLIED
          spanname  NMTOKEN                           #IMPLIED
          morerows  NUMBER                            "0"
          colsep    %yesorno;                         #IMPLIED
          rowsep    %yesorno;                         #IMPLIED
          rotate    %yesorno;                         "0"
          valign    (top | bottom | middle)           "top"
          align     (left | right | center
                     | justify | char)                #IMPLIED
          charoff   NUTOKEN                           #IMPLIED
          char      CDATA                             #IMPLIED        >
<!--                                                                -->
<!ELEMENT ftnote    - - (%text;)                                      >
<!ATTLIST ftnote
          ftnoteid  ID                                #REQUIRED       >
<!--                                                                -->
<!-- ============================================================== -->
<!--                    WARNING, CAUTION, NOTE                      -->
<!-- ============================================================== -->
<!--                                                                -->
<!ELEMENT warning   - - (effect?, (%text;))           -(note)         >
<!ELEMENT note      - - (effect?, (%text;))           -(note)         >
<!ELEMENT caution   - - (effect?, (%text;))           -(note)         >
<!--                                                                -->
<!-- ============================================================== -->
<!--     REGULATORY                                                 -->
<!-- ============================================================== -->
<!ELEMENT regulatory  - - (effect?, regulation+)                      >
<!ELEMENT regulation  - - (effect?, grsymbol?, #PCDATA)               >
<!ATTLIST regulation
          regtype   CDATA                             #REQUIRED
          regsource CDATA                             #IMPLIED
          regvalue  CDATA                             #IMPLIED        >
