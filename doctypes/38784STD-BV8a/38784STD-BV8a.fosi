<e-i-c gi="RANDLIST" context="para step" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<indent inherit="1" leftind="@2em" firstln="*">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#GE#1">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>
</e-i-c>

<e-i-c gi="RANDLIST" context="item seqlist" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<indent inherit="1" leftind="@2em" firstln="*">
	<textbrk startln="1" endln="1"></charlist>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<charsubset charsubsetref="delchlvl">
