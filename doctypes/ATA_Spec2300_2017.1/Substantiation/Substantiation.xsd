	<xs:annotation>
		    <xs:documentation>Version Number: 2017.1</xs:documentation>
		    <xs:documentation>Revision Date: 2017-10-31</xs:documentation>
		    <xs:documentation>Revision Comments: Spec 2300 revision 2017.1</xs:documentation>
	  </xs:annotation>
	  <xs:redefine schemaLocation="../common/dataManagement/dmodule.xsd">
		    <xs:complexType name="contentElemType">
			      <xs:complexContent>
				        <xs:extension base="contentElemType">
					          <xs:sequence>
						            <xs:element ref="substantiation"/>
					          </xs:sequence>
				        </xs:extension>
			      </xs:complexContent>
		    </xs:complexType>
	  </xs:redefine>
	  <xs:include schemaLocation="../common/basicDataTypes/text.xsd"/>
	  <xs:include schemaLocation="../common/systems/commonDescriptionTypes.xsd"/>
	  <xs:include schemaLocation="../common/basicDataTypes/extensibleInterface.xsd"/>
	  <!--=============================================-->
	<!-- dmodule Element Declaration (DM  root) -->
	<!--=============================================-->
	<xs:element name="dmodule" type="dmoduleElemType"/>
	  <!--=============================================-->
	<!-- substantiation Element Declaration-->
	<!--=============================================-->
	<xs:element name="substantiation" type="substantiationType">
		    <xs:annotation>
			      <xs:documentation>background, technical analysis, justification and history information on a given MMEL Item</xs:documentation>
		    </xs:annotation>
	  </xs:element>
	  <xs:complexType name="substantiationType">
		    <xs:sequence>
			      <xs:element name="title" type="nameType">
				        <xs:annotation>
					          <xs:documentation>General title/info for the DM</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="systemBackGround" type="descriptionType">
				        <xs:annotation>
					          <xs:documentation>General information, system description, test results, etc.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="consequenceOfFailure" type="descriptionType">
				        <xs:annotation>
					          <xs:documentation>Describes how the operation of the airplane is affected by the failure. The consequence of flying in the MEL configuration</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="consequenceOfNextCriticalFailure" type="descriptionType">
				        <xs:annotation>
					          <xs:documentation>Describes how the operation of the airplane is affected by the next most critical failure of an associated or interrelated system to the first failure after dispatch.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="historyAndRationale" type="descriptionType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>A cumulative history of changes made to the Dispatch Item and why.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="procedurePurpose" type="descriptionType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Rationale for the M and O procedures included in the Dispatch Item.</xs:documentation>
				        </xs:annotation>
			      </xs:element>
			      <xs:element name="timeOfDispatchRationale" type="descriptionType" minOccurs="0">
				        <xs:annotation>
					          <xs:documentation>Rationale for time of dispatch (e.g., repair interval, dispatch relief).</xs:documentation>
				        </xs:annotation>
			      </xs:element>
		    </xs:sequence>
		    <xs:attribute name="id" type="idType" use="optional">
			      <xs:annotation>
				        <xs:documentation>Optional id for data management</xs:documentation>
			      </xs:annotation>
		    </xs:attribute>
	  </xs:complexType>
</xs:schema>