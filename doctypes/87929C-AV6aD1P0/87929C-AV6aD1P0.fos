pagetype="forward"></subchars>
</usetext>
<usetext
source="<NI-pn-col1.fmt>,\PART\,<linebreak.fmt>,</linebreak.fmt>,\NUMBER\,</NI-pn-col1.fmt>,<NI-figidx-col1.fmt>,\FIGURE\,<linebreak.fmt>,</linebreak.fmt>,\&\,<linebreak.fmt>,</linebreak.fmt>,\INDEX\,</NI-figidx-col1.fmt>,<NI-pn-col2.fmt>,\PART\,<linebreak.fmt>,</linebreak.fmt>,\NUMBER\,</NI-pn-col2.fmt>,<NI-figidx-col2.fmt>,\FIGURE\,<linebreak.fmt>,</linebreak.fmt>,\&\,<linebreak.fmt>,</linebreak.fmt>,\INDEX\,</NI-figidx-col2.fmt>,<NI-pn-col3.fmt>,\PART\,<linebreak.fmt>,</linebreak.fmt>,\NUMBER\,</NI-pn-col3.fmt>,<NI-figidx-col3.fmt>,\FIGURE\,<linebreak.fmt>,</linebreak.fmt>,\&\,<linebreak.fmt>,</linebreak.fmt>,\INDEX\,</NI-figidx-col3.fmt>">
<subchars>
<font style="sanserif" size="8pt">
<leading lead="10pt">
<presp minimum="2.5pi" nominal="2.5pi" maximum="2.5pi" condit="discard"
priority="high">
