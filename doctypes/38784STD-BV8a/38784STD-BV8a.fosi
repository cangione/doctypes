<e-i-c gi="volLEP" occur="first" scope="usetext" elemtype="gi">
<charlist envname="lepenv" inherit="0"></charlist>

<att logic="and">
<specval attname="t2page" attloc="front" attval="#EQ#0">
<charsubset>
	<textbrk startpg="next">
	<span span="3">
	<savetext textid="foliostr" conrule="\\">
	<savetext textid="volfoliostr" conrule="\\">
	<usetext source="\Dates of issue for original and changed pages are:\">
	<subchars>
	<font style="sanserif">
	<presp nominal="12pt" condit="discard">
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>

	<usetext source="chghiststr">
	<subchars>
	<span span="2">	</subchars>
	</usetext>

	<usetext source="\TOTAL NUMBER OF PAGES IN THIS PUBLICATION IS \,                        lep.str[BO], \ CONSISTING OF THE FOLLOWING:\">
	<subchars>
	<font style="sanserif">
	<quadding quad="center">
	<presp nominal="12pt" condit="keep">
	<postsp nominal="12pt" condit="discard">
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>

	<usetext source="\Page\,spfill,\*Change\,1pi,                        \Page\,spfill,\*Change\,1pi,                        \Page\,spfill,\*Change\,1pi">
	<subchars>
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>

	<usetext source="6pt,\No.\,spfill,\No.\,6pt,1pi,                        6pt,\No.\,spfill,\No.\,6pt,1pi,                        6pt,\No.\,spfill,\No.\,6pt,1pi">
	<subchars>
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="t2page" attloc="front" attval="#EQ#1">
<charsubset>
	<textbrk startpg="recto" pageid="leppg" newpgmdl="global">
	<span span="3">
	<savetext textid="foliostr" conrule="\\">
	<savetext textid="volfoliostr" conrule="\\">
