<!--Entity Filename: 38784STD-BV5_SERTABLE_EICS.ent -->
<e-i-c gi="ipbsertable"><?Pub Dtl>
<charlist>
<postsp minimum="18pt" nominal="18pt" maximum="18pt" condit="keep"
priority="high">
<textbrk startln="1" endln="1">
<span span="1">
<savetext textid="ipbsertable-body.txt" conrule="\\" placemnt="before">
<savetext textid="tabtitle" conrule="\Serialization\" placemnt="before">
</charlist>&security-mark;
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="ipbsertable-structure.txt"
conrule='!<colspec colname="col1" colwidth="1.75in"><colspec colname="col2" colwidth="1.25in"><colspec colname="col3">!'
placemnt="before">
<savetext textid="ipbsertable-header.txt"
conrule='!<thead><row valign="bottom"><entry rowsep="1" colsep="0">Nomenclature</entry><entry rowsep="1" colsep="0">Model No.</entry><entry rowsep="1" colsep="0">Serial No.</entry></row></thead>!'
placemnt="before">
<usetext
source='!<table><title>!,tabtitle,!</title><tgroup cols="3">!,ipbsertable-structure.txt,ipbsertable-header.txt,!<tbody>!,ipbsertable-body.txt,!</tbody></tgroup></table>!'
placemnt="after"></usetext>
</charsubset>
</att>
<att>
<specval attname="UseTitleForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\False\">
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,label.txt"></charsubset>
</att>
<att>
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\False\">
<specval attname="UseTitleForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Serialization\"></charsubset>
</att>
<att>
<specval attname="UseTitleForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="UseLabelForCrossReference.ext" attloc="#FOSI"
attval="#EQ#\True\">
<specval attname="id" attval="#ANY">
<charsubset>
<savetext textid="xrefstr" conrule="\Serialization \,label.txt">
</charsubset>
</att>
<att logic="or">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<savetext textid="lotmatter"
conrule="<toclinec>,<toctitle.fmt>,label.txt,@4em,\DELETED\,tocfill,</toctitle.fmt>,<tocnumx>,folio.txt[BO],</tocnumx>,</toclinec>"
append="1">
<usetext source="!<table><title>!,\Deleted\,!</title></table>!">
</usetext>
</charsubset>
</att>
<att>
<fillval attname="col1width" attloc="ipbsertable" fillcat="savetext"
fillchar="conrule">
<charsubset>
<savetext textid="col1width.txt"></charsubset>
</att>
<att>
<fillval attname="col2width" attloc="ipbsertable" fillcat="savetext"
fillchar="conrule">
<charsubset>
<savetext textid="col2width.txt"></charsubset>
</att>&deleted-children;&mark.changed;</e-i-c>
<e-i-c gi="ipbserrow"><?Pub Dtl>
<charlist></charlist>
<att>
<specval attname="editor-only" attloc="system-var" attval="#ANY">
<charsubset>
<textbrk startln="1" endln="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="ipbsertable-body.txt"
conrule="!<row>!,ipbsertable-nomen.txt,ipbsertable-modelno.txt,ipbsertable-serno.txt,!</row>!"
placemnt="after" append="1"></charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
<suppress sup="1">
<savetext textid="ipbsertable-body.txt"
conrule='!<row><?PubTbl row rht="0pt"><entry rowsep="0" colsep="0">!,contentcbar.txt,!</entry><entry rowsep="0" colsep="0"></entry><entry rowsep="0" colsep="0"></entry></row>!'
placemnt="after" append="1"></charsubset>
</att>
<att logic="or">
<specval attname="delchlvl" attval="#ANY">
<specval attname="delchlvl" attval="#NONE">
<charsubset>
<savetext textid="ibpsertable-nomen.txt" conrule="\\">
<savetext textid="ipbsertable-modelno.txt" conrule="\\">
<savetext textid="ipbsertable-serno.txt" conrule="\\"></charsubset>
