<e-i-c gi="TITLE" context="subpara6 * body" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="subpara6.title.csub">
	<keeps keep="1" scope="col" next="1">
	<savetext textid="title-appear" conrule="\yes\">
	<usetext source="LABELSTR,1em">
	<subchars>
	<highlt scoring="0">
	<textbrk startln="1">	</subchars>
	</usetext>

	<usetext source="secur.str,graphic.str,applicref.str">
	<subchars>
	<highlt scoring="0">	</subchars>
	</usetext>

	<usetext source="1.5em" placemnt="after">
	<subchars>
	<highlt scoring="0">
	<keeps scope="line" prev="1">	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="PARA" context="subpara6" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="clearstrings">
	<postsp nominal="11pt">
	<textbrk endln="1"></charlist>

<att logic="and">
<specval attname="title-appear" attloc="#FOSI" attval="#EQ#\yes\">
<charsubset></charsubset>
</att>

<att logic="and">
<specval attname="title-appear" attloc="#FOSI" attval="#EQ#\no\">
<charsubset>
	<usetext source="LABELSTR,1em">
	<subchars>
	<font style="sanserif">
	<textbrk startln="1">	</subchars>
	</usetext>

	<usetext source="secur.str,graphic.str,applicref.str">
	<subchars>
	<highlt scoring="0">	</subchars>
	</usetext>
</charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#ANY">
<charsubset charsubsetref="inschlvl"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#ANY">
<charsubset>
	<suppress sup="1"></charsubset>
</att>
</e-i-c>

<e-i-c gi="SUBPARA7" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1" charsubsetref="para clearstrings">
	<reset resetlist="sp8ct step1ct">
	<savetext textid="sp70pgnum" conrule="pgnumber[BO]" placemnt="before">
	<savetext textid="title-appear" conrule="\no\">
	<savetext textid="xreftype" conrule="\\">
	<savetext textid="xrefstr" conrule="subpara7titlestring">
	<savetext textid="graphic.str" conrule="">
	<savetext textid="secur.str" conrule=""></charlist>

<att logic="and">
<specval attname="sssn" attval="#ANY">
<charsubset>
	<savetext textid="sssn.st" conrule="\ (\,#CONTENT(sssn),\)\">
	<savetext textid="sssn.footer.st" conrule="#CONTENT(sssn)"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#ANY">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
	<savetext textid="labelstr" conrule="#CONTENT(label)"></charsubset>
</att>

<att logic="and">
<specval attname="label" attval="#NONE">
<charsubset>
	<enumerat increm="1" enumid="sp7ct">
	<savetext textid="labelstr" conrule="prefix.st, para0ct,\.\,sp1ct,\.\,sp2ct,\.\,sp3ct,\.\sp4ct,\.\sp5ct,\.\sp6ct,\.\sp7ct">
	<savetext textid="label" conrule="labelstr" saverule="1"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="delete">
<specval attname="status" attval="deleted">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Deleted)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="reserve">
<specval attname="status" attval="reserved">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Reserved)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="na">
<specval attname="status" attval="notapp">
<charsubset>
	<savetext textid="deltypestr" conrule="\(Not Applicable)\"></charsubset>
</att>

<att logic="or">
<specval attname="deltype" attval="real">
<specval attname="status" attval="empty">
<charsubset>
	<suppress sup="1"></charsubset>
</att>

<att logic="and">
<specval attname="delchlvl" attval="#GE#1">
<specval attname="deltype" attval="#NE#\real\">
<charsubset charsubsetref="delchlvl"></charsubset>
</att>

<att logic="and">
<specval attname="status" attval="#ANY">
<specval attname="status" attval="#NE#\empty\">
<charsubset charsubsetref="delstatus"></charsubset>
</att>

<att logic="and">
<specval attname="inschlvl" attval="#NE#0">
<charsubset charsubsetref="inschlvl"></charsubset>
