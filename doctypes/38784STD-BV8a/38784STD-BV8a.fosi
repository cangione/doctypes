	<subchars>
	<font style="sanserif">
	<presp nominal="12pt" condit="discard">
	<textbrk startln="1" endln="1">
	<span span="1">	</subchars>
	</usetext>

	<usetext source="chghiststr">
	<subchars>
	<span span="2">	</subchars>
	</usetext>

	<usetext source="\TOTAL NUMBER OF PAGES IN THIS PUBLICATION IS \,                        lep.str[BO], \ CONSISTING OF THE FOLLOWING:\">
	<subchars>
	<font style="sanserif">
	<quadding quad="center">
	<presp nominal="12pt" condit="keep">
