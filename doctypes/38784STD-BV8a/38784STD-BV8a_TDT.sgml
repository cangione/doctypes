	<ele>
		<tag>prindex</tag>
		<long>Primary Index</long>
		<desc>Identifies a primary alphabetical index topic in the manual.</desc>
		<source>4.2.9.8</source>
		<contmdl>((#PCDATA | change | tabmat | ftnref | xref | verbatim | emphasis | applicabil | extapplicabil | graphic | extref | dataiden | hcp | hci | esds | nsp | oci | ocp | fcp | acronym | prindex | secindex | nameloc | clink | ilink | object)+) -(prindex)</contmdl>
		<usedin>abbrtitle, activity, address, applicabil, appltitle, authnot, change, chgdate, chgnum, chgpara, chgtxt, clink, cogact, contractno, copyright, dataiden, date, dateinc, def, destr, discl, distrib, doctype, ecpno, effdatenot, emphasis, entry, expcont, extapplicabil, figno, ftnote, hazmat, ilink, insertpg, internatlstd, ipbcage, ipbfigindex, ipbfigureno, ipbpartnosym, ipbrefdes, ipbsmrcode, ipbsssn, ipbunits, ipbuseoncode, item, label, lepchg, leppage, letter, line, maintlvl, mfr, modelno, moveddata, mritem, mrpara, nmlist, nomen, nsn, oadr, pageno, para, param, partno, phrase, pretmidno, prindex, pubdate, remarks, removepg, revnum, secindex, seqno, serno, sigblock, subject, subtitle, supersed, suppl, symtitle, tabno, tctono, term, tfnid, title, tmidno, topic, tpdrlocation, tpdrno, typedes, typeno, underline, vollepchg, volleppage, volnot, and volnum</usedin>
		<ents>text, yesorno, secur, and chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>pridnbr</attr>
				<type>ID</type>
				<default>#IMPLIED</default>
				<attrdesc>Defines a unique identification number that allows an association between items tagged as primary index topics and those tagged as secondary index topics.</attrdesc>

				<attr>display</attr>
				<type>NUMBER</type>
				<default>1</default>
				<attrdesc>Determines whether the contents of this element should appear in the text where tagged or just be referenced in the Index. '1' means display in text and index. '0' means display only in index.</attrdesc>

				<attr>security</attr>
				<type>(u | c | s | n)</type>
				<default>n</default>
				<attrdesc>Identifies security level of the element.</attrdesc>

				<attr>caveat</attr>
				<type>CDATA</type>
				<default>#IMPLIED</default>
				<attrdesc>Provides a place to set the caveat for the document. This attribute should be ignored unless on the doc element.</attrdesc>

				<attr>fgi</attr>
