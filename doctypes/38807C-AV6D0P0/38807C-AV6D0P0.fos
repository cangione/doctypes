<e-i-c gi="sertable"><?Pub Dtl>
<charlist>
<postsp nominal="18pt" condit="keep" priority="high">
<textbrk startln="1" endln="1">
<savetext textid="label.txt" conrule="chap.txt,\-\,tbl.ctr">
<savetext textid="tabtitle" conrule="\Serialization\" placemnt="before">
</charlist>
<att logic="and">
<specval attname="deltype" attval="#NE#\real\">
<specval attname="status" attval="#NE#\empty\">
<charsubset>
<savetext textid="xrefstr" conrule="\Table \,label.txt"></charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="pgwide" attloc="sertable" attval="1">
<charsubset>
<savetext textid="lotmatter"
conrule="<toclinec>,<toctitle.fmt>,label.txt,@3em,tabtitle,tocfill,</toctitle.fmt>,<tocnumx>,folio.txt[BO],</tocnumx>,</toclinec>"
append="1">
<savetext textid="sertable-structure.txt"
conrule='!<colspec colname="col1" colwidth="2*"><colspec colname="col2" colwidth="1.25in"><colspec colname="col3" colwidth="1.25in"><spanspec namest="col1" nameend="col3" spanname="SPAN1">!'
placemnt="before">
<savetext textid="sertable-header.txt"
conrule='!<thead><row valign="bottom"><entry rowsep="1" colsep="0">Nomenclature</entry><entry rowsep="1" colsep="0">Model No.</entry><entry rowsep="1" colsep="0">Serial No.</entry></row></thead>!'
placemnt="before">
<usetext
source='!<table><title>!,tabtitle,!</title><tgroup cols="3">!,sertable-structure.txt,sertable-header.txt,!<tbody>!,sertable-body.txt,!</tbody></tgroup></table>!'
placemnt="after">
<subchars>
<savetext textid="sertable-body.txt" conrule="\\" placemnt="after">
</subchars>
</usetext>
</charsubset>
</att>
<att logic="and">
<specval attname="delchlvl" attval="#NONE">
<specval attname="pgwide" attloc="sertable" attval="#NE#\1\">
<charsubset>
<savetext textid="lotmatter"
conrule="<toclinec>,<toctitle.fmt>,label.txt,@3em,tabtitle,tocfill,</toctitle.fmt>,<tocnumx>,folio.txt[BO],</tocnumx>,</toclinec>"
append="1">
<savetext textid="sertable-structure.txt"
conrule='!<colspec colname="col1" colwidth="1.5in"><colspec colname="col2" colwidth="1in"><colspec colname="col3" colwidth="1in">!'
placemnt="before">
<savetext textid="sertable-header.txt"
conrule='!<thead><row valign="bottom"><entry rowsep="1" colsep="0">Nomenclature</entry><entry rowsep="1" colsep="0">Model No.</entry><entry rowsep="1" colsep="0">Serial No.</entry></row></thead>!'
placemnt="before">
<usetext
source='!<table pgwide="0"><title>!,tabtitle,!</title><tgroup cols="3">!,sertable-structure.txt,sertable-header.txt,!<tbody>!,sertable-body.txt,!</tbody></tgroup></table>!'
placemnt="after">
<subchars>
<savetext textid="sertable-body.txt" conrule="\\" placemnt="after">
</subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="delchlvl" attval="#ANY">
<charsubset>
