	<ele>
		<tag>symrow</tag>
		<long>Symbol Row</long>
		<desc>Identifies a term and def for the Symbol Section. Element added for the insertion/deletion of these elements together.</desc>
		<source>4.5.9 & 4.3.4</source>
		<contmdl>(term, def)</contmdl>
		<usedin>symsect</usedin>
		<ents>chgatt</ents>
		<specatts>
			<attrtbl>
				<attr>deltype</attr>
				<type>(delete | real | reserve | NA)</type>
				<default>#IMPLIED</default>
				<attrdesc>Used to generate change packages - Delete Type</attrdesc>

				<attr>inschlvl</attr>
				<type>nmtoken</type>
				<default>#IMPLIED</default>
