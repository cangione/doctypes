<e-i-c gi="abbrtitle"><?Pub Lcl _id="f1"><?Pub Dtl>
<charlist inherit="1">
<presp minimum="10pt" nominal="10pt" maximum="10pt">
<keeps scope="col" keep="1" next="7"></charlist>
<att>
<specval attname="security" attval="u">
<charsubset>
<savetext textid="secur.str" conrule="\(U) \,0.25em">
<usetext source="secur.str" placemnt="before">
<subchars>
<highlt scoring="0">
<textbrk startln="0" endln="0"></subchars>
</usetext>
<savetext textid="secur.str" conrule="\\" placemnt="after"></charsubset>
</att>
<att>
<specval attname="security" attval="s">
<charsubset>
<savetext textid="secur.str" conrule="\(S) \,0.25em">
<usetext source="secur.str" placemnt="before">
<subchars>
<highlt scoring="0">
<textbrk startln="0" endln="0"></subchars>
</usetext>
<savetext textid="secur.str" conrule="\\" placemnt="after"></charsubset>
</att>
<att>
<specval attname="security" attval="c">
<charsubset>
<savetext textid="secur.str" conrule="\(C) \,0.25em">
<usetext source="secur.str" placemnt="before">
<subchars>
<highlt scoring="0">
<textbrk startln="0" endln="0"></subchars>
</usetext>
<savetext textid="secur.str" conrule="\\" placemnt="after"></charsubset>
</att>
<att logic="or">
<specval attname="security" attval="#NONE">
<specval attname="security" attval="n">
<charsubset>
<font weight="bold">
<hyphen hyph="0">
<quadding quad="center" lastquad="lcenter">
<postsp minimum="12pt" nominal="12pt" maximum="12pt" priority="med">
<textbrk startln="1" endln="1"></charsubset>
</att>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<specval attname="front-numcols.txt" attloc="#FOSI" attval="#EQ#\one\">
<charsubset>
<savetext textid="abbrtitle.txt"
conrule="scontent.txt,#CONTENT,econtent.txt">
<usetext
source="<figtab-title.fmt>,abbrtitle.txt,\ &ndash; Continued\,</figtab-title.fmt>">
<subchars>
<font weight="bold">
<hyphen hyph="0">
<quadding quad="center" lastquad="lcenter">
<textbrk startln="1" endln="1">
<float flidref="top-page.flt" width="col" scope="abbrsect"
pagetype="forward"></subchars>
</usetext>
</charsubset>
</att>
<att>
<specval attname="print-only" attloc="system-var" attval="#ANY">
<specval attname="front-numcols.txt" attloc="#FOSI" attval="#EQ#\two\">
<charsubset>
<savetext textid="abbrtitle.txt"
conrule="scontent.txt,#CONTENT,econtent.txt">
<usetext
source="<figtab-title.fmt>,abbrtitle.txt,\ &ndash; Continued\,</figtab-title.fmt>">
