	<usetext source="\ \" placemnt="before">
	<subchars>
	<font size="10pt">
	<leading lead="12pt">
	<textbrk startln="1" endln="1">	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="TOCLINEA" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="1">
	<font inherit="0">
	<indent inherit="0" leftind="72pt" rightind="40pt" firstln="0pt">
	<quadding inherit="0" quad="left" lastquad="lleft">
	<highlt allcap="1">
	<keeps keep="1" scope="col">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="TOCNUMCHAP" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<font inherit="0" offset="1pt">
	<leading lead="0.01pt" force="1">
	<indent leftind="3.0in" rightind="0in" firstln="3.0in">
	<quadding inherit="0" quad="right">
	<textbrk startln="1" endln="1"></charlist>
</e-i-c>

<e-i-c gi="TOCLINESECPRE" occur="all" scope="usetext" elemtype="gi">
<charlist inherit="0">
	<usetext source="\ \" placemnt="before">
	<subchars>
	<font size="5pt">
	<leading lead="7pt">
	<textbrk startln="1" endln="1">	</subchars>
	</usetext>
</charlist>
</e-i-c>

<e-i-c gi="TOCLINESEC" occur="all" scope="usetext" elemtype="gi">
