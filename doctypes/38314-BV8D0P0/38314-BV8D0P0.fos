conrule='!<entry align="left" spanname="tonum">!,\TO Number:\,0.5em,vstattonum.st,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatter2.tdv"
conrule='!<entry align="left">!,\Date:\,0.5em,vstatdate.st,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatter3.tdv"
conrule='!<entry align="left">!,\TO Management Agency:\,0.5em,toma.txt,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatterhd.tdv"
conrule='!<row rowsep="1">!,vsmatter1.tdv,vsmatter2.tdv,vsmatter3.tdv,!</row>!'
placemnt="before" append="0">
<savetext textid="vsmatter1.tdv"
conrule='!<entry align="left" spanname="chngnum">!,\Change Number/Date:\,0.5em,vstatchg.st,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatterhd.tdv"
conrule='!<row rowsep="1">!,vsmatter1.tdv,!</row>!' append="1">
<savetext textid="vsmatter1.tdv"
conrule='!<entry align="center">!,\Function / Para / Figure etc.\,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatter2.tdv"
conrule='!<entry align="center">!,\Verification Status\,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatter3.tdv"
conrule='!<entry align="center">!,\Date Verified\,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatter4.tdv"
conrule='!<entry align="center">!,\Remarks\,!</entry>!'
placemnt="before" append="0">
<savetext textid="vsmatterhd.tdv"
conrule='!<row rowsep="1">!,vsmatter1.tdv,vsmatter2.tdv,vsmatter3.tdv,vsmatter4.tdv,!</row>!'
placemnt="before" append="1">
<savetext textid="vsmatterhead.tdv"
conrule='!<colspec colname="fpf" colwidth="1.5*"><colspec colname="vstat" colwidth="1.0*"><colspec colname="datever" colwidth="1.5*"><colspec colname="rem" colwidth="3*"><spanspec spanname="tonum" namest="fpf" nameend="vstat"><spanspec spanname="chngnum" namest="fpf" nameend="rem">!'
placemnt="before" append="1">
<savetext textid="vsmatter.tiv"
conrule='!<row rowsep="0"><?PubTbl row rht="0pt"><entry colname="fpf"></entry><entry colname="vstat"></entry><entry colname="datever"></entry><entry colname="rem"></entry></row>!'
placemnt="before">
<savetext textid="vsmatterbody.tdv"
conrule="!<tbody>!,vsmatter.tiv,!</tbody>!" placemnt="after">
<savetext textid="vstable.tiv"
conrule='!<table frame="all"><tgroup cols="4">!,vsmatterhead.tdv,vsmatterbody.tdv,!</tgroup></table>!'
placemnt="after"></charsubset>
