<!ELEMENT wireawg   - -  (#PCDATA)                                  >
<!ELEMENT wireclr   - -  (#PCDATA)                                  >
<!ELEMENT bundnbr   - -  (#PCDATA)                                  >
<!ELEMENT diagref   - -  (refint | refext)                          >
<!ELEMENT connect   - -  (#PCDATA)                                  >
<!ELEMENT termnbr   - -  (#PCDATA)                                  >
