<charlist inherit="1"></charlist>
</e-i-c>
<!--ptc: used for new footer formatting-->
<e-i-c gi="sssn.psu"><?Pub Dtl>
<charlist inherit="1">
<font style="sanserif" size="18pt" weight="bold"></charlist>
</e-i-c>
<!--ptc: changed from -5 to -1-->
<e-i-c gi="footer.psu"><?Pub Dtl>
<charlist>
<postsp minimum="-1pt" nominal="-1pt" maximum="-1pt" condit="discard"
priority="high">
<textbrk startln="1" endln="1"></charlist>
</e-i-c>
<e-i-c gi="tabmat" context="* footer.psu"><?Pub Dtl>
<charlist inherit="1">
<font style="sanserif"></charlist>
</e-i-c>
<e-i-c gi="folio-font.psu"><?Pub Dtl>
<charlist inherit="1">
<font style="sanserif" size="10pt" weight="bold"></charlist>
</e-i-c>
<e-i-c gi="change-font.psu"><?Pub Dtl>
<charlist inherit="1">
<font style="sanserif" size="10pt" weight="bold"></charlist>
</e-i-c>
<e-i-c gi="deletion-font.psu"><?Pub Dtl>
<charlist inherit="1">
<font style="sanserif"></charlist>
</e-i-c>
<e-i-c gi="lep-hd-brk.fmt"><?Pub Dtl>
<charlist>
<keeps scope="col" next="1" prev="1">
<textbrk startln="1" endln="1"></charlist>
</e-i-c>
<e-i-c gi="ftn.psu"><?Pub Dtl>
<charlist>
<font style="serif" size="9pt">
<leading lead="10pt">
<quadding quad="justify">
<presp minimum="3pt" nominal="3pt" maximum="3pt"></charlist>
</e-i-c>
<!--Emergency Border Support Below-->
<e-i-c gi="emergency-border-recto.psu">
<charlist></charlist>
<att>
<specval attname="main::needs_emergency_borders"
attloc="system-func" attval="1">
<charsubset>
<usetext source="\ \">
<subchars>
<indent leftind="-1.5pi" rightind="-1.5pi" firstln="*">
<textbrk startln="1" endln="1">
<boxing boffset="11.25in" trel="top" brel="bottom" thick="0.5in"
tthick="0.5in" bthick="0.5in" rthick="0.5in" ttype="tslash"
btype="bslash" ltype="lblank" rtype="rslash"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="emergency-border-verso.psu">
<charlist></charlist>
<att>
<specval attname="main::needs_emergency_borders"
attloc="system-func" attval="1">
<charsubset>
<usetext source="\ \">
<subchars>
<indent rightind="-1.5pi" firstln="*">
<textbrk startln="1" endln="1">
<boxing boffset="11.25in" trel="top" brel="bottom" tthick="0.5in"
bthick="0.5in" lthick="0.5in" ttype="tslash" btype="bslash"
ltype="lslash" rtype="rblank"></subchars>
</usetext>
</charsubset>
</att>
</e-i-c>
<e-i-c gi="emergency-border-top.psu"><?Pub Dtl>
